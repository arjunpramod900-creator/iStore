<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details — iStore Admin</title>
    <meta name="description" content="Admin order detail view — manage individual order status, logistics, returns and payment.">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin-order-details.css?v=2.2">
    <link rel="stylesheet" href="/css/components/admin-sidebar.css?v=2.2">
    <link rel="stylesheet" href="/css/admin-dashboard.css?v=2.2">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* ── Return status indicator badge ── */
        .aod-return-status-wrap {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px;
            border-radius: var(--aod-radius-sm);
            margin-bottom: 8px;
        }
        .aod-return-status-wrap--approved {
            background: rgba(5, 150, 105, 0.08);
            border: 1px solid rgba(5, 150, 105, 0.20);
        }
        .aod-return-status-wrap--rejected {
            background: rgba(186, 26, 26, 0.06);
            border: 1px solid rgba(186, 26, 26, 0.15);
        }
        .aod-return-status-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--aod-sub);
        }
        .aod-return-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 14px;
            border-radius: var(--aod-radius-pill);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }
        .aod-return-status-badge--approved {
            background: rgba(5, 150, 105, 0.12);
            color: #059669;
        }
        .aod-return-status-badge--rejected {
            background: rgba(186, 26, 26, 0.10);
            color: #BA1A1A;
        }
        /* ── Disabled state for locked buttons ── */
        .aod-update-btn:disabled,
        .aod-btn-approve:disabled,
        .aod-btn-reject:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
        }
        /* ── Locked status select ── */
        .aod-status-select:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            background-color: #f4f4f5;
        }
        /* ── Return pending warning on status update card ── */
        .aod-return-pending-notice {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            background: rgba(245, 158, 11, 0.08);
            border: 1px solid rgba(245, 158, 11, 0.25);
            border-radius: var(--aod-radius-sm);
            font-size: 12px;
            font-weight: 500;
            color: #92400E;
        }
        .aod-return-pending-notice i {
            flex-shrink: 0;
            width: 14px;
            height: 14px;
            color: #D97706;
        }

        /* ── Per-item return actions (inside products table) ── */
        .aod-item-return-actions {
            display: flex;
            flex-direction: column;
            gap: 6px;
            justify-content: center;
        }
        .aod-btn-approve--sm,
        .aod-btn-reject--sm {
            padding: 6px 12px;
            font-size: 11px;
            border-radius: var(--aod-radius-sm, 8px);
            border: none;
            cursor: pointer;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }
        .aod-btn-approve--sm {
            background: rgba(5, 150, 105, 0.12);
            color: #059669;
        }
        .aod-btn-approve--sm:hover {
            background: rgba(5, 150, 105, 0.2);
        }
        .aod-btn-reject--sm {
            background: rgba(186, 26, 26, 0.10);
            color: #BA1A1A;
        }
        .aod-btn-reject--sm:hover {
            background: rgba(186, 26, 26, 0.18);
        }
        .aod-btn-approve--sm:disabled,
        .aod-btn-reject--sm:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        /* ── Active item badge ── */
        .aod-active-badge{
            display:inline-flex;
            align-items:center;
            justify-content:center;
            padding:5px 14px;
            border-radius:999px;
            background:rgba(37,99,235,.1);
            color:#2563EB;
            font-size:11px;
            font-weight:800;
            letter-spacing:.5px;
            text-transform:uppercase;
        }
    </style>
</head>

<body>

    <%
        const orderId     = order.orderId;
        const orderDate   = new Date(order.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
        const orderStatus = order.orderStatus;
        const payStatus   = order.paymentStatus;
        const items       = order.items || [];

        /* Item totals are shown post-offer only (pre-coupon, pre-tax).
           Coupon and tax are displayed at the order level in the Pricing Summary. */

        const activeItems = items.filter(i =>
            i.itemStatus !== ORDER_STATUS.CANCELLED &&
            i.itemStatus !== ORDER_STATUS.RETURNED  &&
            i.itemReturnStatus !== "Approved"
        );
        const subtotal       = order.pricingSnapshot?.originalSubtotal || order.subtotal || 0;
        const offerDiscount  = order.pricingSnapshot?.originalOfferDiscount || order.offerDiscount || 0;
        const couponDiscount = order.pricingSnapshot?.originalCouponDiscount || order.couponDiscount || 0;
        const taxAmount      = order.pricingSnapshot?.originalTaxAmount || order.taxAmount || 0;
        const deliveryCharge = order.pricingSnapshot?.originalDeliveryCharge || order.deliveryCharge || 0;
        const finalAmount    = order.pricingSnapshot?.originalFinalAmount || order.finalAmount || 0;

        const pricing = {
            mrp:      subtotal + offerDiscount,
            offer:    offerDiscount,
            hasOffer: offerDiscount > 0,
            subtotal: subtotal,
            coupon:   couponDiscount,
            hasCoupon: couponDiscount > 0,
            tax:      taxAmount,
            shipping: deliveryCharge,
            total:    finalAmount,
            refund:   order.refundAmount || 0
        };

        /* ── Revised Order Summary ── */
        const hasActiveItems = items.some(i =>
            i.itemStatus !== ORDER_STATUS.CANCELLED &&
            i.itemStatus !== ORDER_STATUS.RETURNED  &&
            i.itemReturnStatus !== "Approved"
        );
        const originalFinalAmount = order.pricingSnapshot?.originalFinalAmount || finalAmount;
        const isRevised = (order.finalAmount < originalFinalAmount) && hasActiveItems;

        const revisedMRP        = (order.subtotal || 0) + (order.offerDiscount || 0);
        const revisedOffer      = order.offerDiscount || 0;
        const revisedSubtotal   = order.subtotal || 0;
        const revisedCoupon     = order.couponDiscount || 0;
        const revisedCouponRevoked = order.pricingSnapshot && revisedCoupon === 0 && couponDiscount > 0;
        const revisedTax        = order.taxAmount || 0;
        const revisedDelivery   = order.deliveryCharge || 0;
        const revisedTotal      = order.finalAmount || 0;

        const timeline = [
            {
                title: "Order Placed",
                desc:  "Order successfully created",
                time:  new Date(order.createdAt).toLocaleString(),
                done:  true
            },
            {
                title: order.orderStatus,
                desc:  `Current Status: ${order.orderStatus}`,
                time:  "Current Stage",
                done:  ["Delivered","Cancelled","Returned"].includes(order.orderStatus)
            }
        ];

        /* ── FIX 2: ret.exists only when status is actively "Requested" ── */
        const ret = {
            exists:   order.returnStatus === RETURN_STATUS.REQUESTED,
            approved: order.returnStatus === RETURN_STATUS.APPROVED,
            rejected: order.returnStatus === RETURN_STATUS.REJECTED,
            reason:   order.returnReason,
            status:   order.returnStatus || "None"
        };

        /* ── FIX 4: lock status update if return is pending ── */
        const isLocked = ["Delivered","Cancelled","Returned"].includes(order.orderStatus);
        const isReturnPending = order.returnStatus === RETURN_STATUS.REQUESTED;
        const isPaymentLocked =
    order.paymentMethod === "RAZORPAY" &&
    order.paymentStatus !== "Paid";

        /* Combine both locks for the select/button */
        const statusUpdateLocked =
    isLocked ||
    isReturnPending ||
    isPaymentLocked;

        function fmt(n) { return "₹" + Number(n).toLocaleString("en-IN"); }

        const hasTracking = !!order.trackingNumber;
    %>



    <%- include('../partials/admin/sidebar', { page: 'orders' }) %>

    <main class="dashboard-main">

        <!-- ── BREADCRUMB + HEADER ── -->
        <div class="aod-header-row" id="aodHeaderRow">
            <div class="aod-header-left">
                <nav class="aod-breadcrumb" aria-label="Breadcrumb">
                    <a href="/admin/dashboard" class="aod-bc-crumb">Dashboard</a>
                    <span class="aod-bc-sep">/</span>
                    <a href="/admin/orders" class="aod-bc-crumb">Orders</a>
                    <span class="aod-bc-sep">/</span>
                    <span class="aod-bc-crumb active">Order Details</span>
                </nav>
                <h1 class="aod-page-title">Order Details</h1>
            </div>
            <a href="/admin/orders" class="aod-back-btn">
                <i data-lucide="plus" size="10" style="transform:rotate(45deg)"></i>
                Back to Orders
            </a>
        </div>

        <!-- ── 4-CARD SUMMARY ROW ── -->
        <div class="aod-summary-cards" id="aodSummaryCards">
            <div class="aod-summary-card">
                <span class="aod-sc-label">Order ID</span>
                <span class="aod-sc-value"><%= orderId %></span>
            </div>
            <div class="aod-summary-card">
                <span class="aod-sc-label">Order Date</span>
                <span class="aod-sc-value dark"><%= orderDate %></span>
            </div>
            <div class="aod-summary-card">
                <span class="aod-sc-label">Order Status</span>
                <div class="aod-sc-status">
                    <span class="aod-status-dot aod-status-dot--order"></span>
                    <span class="aod-sc-status-text aod-sc-status-text--order"><%= orderStatus %></span>
                </div>
            </div>
            <div class="aod-summary-card">
                <span class="aod-sc-label">Payment Status</span>
                <div class="aod-sc-status">
                    <span class="aod-status-dot aod-status-dot--payment"></span>
                    <span class="aod-sc-status-text aod-sc-status-text--payment"><%= payStatus %></span>
                </div>
            </div>
        </div>

        <!-- ── TWO-COLUMN BODY ── -->
        <div class="aod-body" id="aodBody">

            <!-- ════════ LEFT COLUMN ════════ -->
            <div class="aod-left" id="aodLeft">

                <!-- Ordered Products -->
                <div class="aod-card" id="aodProductsCard">
                    <div class="aod-card-header">
                        <h2 class="aod-card-title">Ordered Products</h2>
                    </div>
                    <div style="overflow-x: auto; width: 100%; -webkit-overflow-scrolling: touch;">
                        <table class="aod-products-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Variant</th>
                                <th class="center">Qty</th>
                                <th class="right">Unit Price</th>
                                <th class="right">Total</th>
                                <th class="center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% items.forEach((item, idx) => {
                                const img      = item.productImage || "/images/product-placeholder.png";
                                const itemTotal = item.price * item.quantity;
                            %>
                            <tr>
                                <td style="vertical-align: top;">
                                    <div class="aod-prod-cell">
                                        <div class="aod-prod-thumb">
                                            <img src="<%= img %>" alt="<%= item.productName %>" loading="lazy">
                                        </div>
                                        <div class="aod-prod-info">
                                            <span class="aod-prod-name"><%= item.productName %></span>
                                            <span class="aod-prod-sku" style="margin-bottom: 6px;">Item #<%= idx + 1 %></span>
                                            
                                            <!-- ITEM DISCOUNT BREAKDOWN (offer only; coupon & tax shown in Pricing Summary) -->
                                            <div style="font-size: 11px; color: #6B7280; line-height: 1.5;">
                                                <% if (item.originalPrice && item.originalPrice > item.price) { %>
                                                    <span style="display: block;">MRP: <span style="text-decoration: line-through;"><%= fmt(item.originalPrice * item.quantity) %></span></span>
                                                <% } %>
                                                <% if (item.offerDiscount > 0) { %>
                                                    <span style="display: block;">Offer: −<%= fmt(item.offerDiscount * item.quantity) %></span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td style="vertical-align: top; padding-top: 16px;">
                                    <div class="aod-variant-cell">
                                        <% if (item.variantName) { %>
                                            <span class="aod-variant-specs"><%= item.variantName %></span>
                                        <% } %>
                                    </div>
                                </td>
                                <td class="center" style="vertical-align: top; padding-top: 16px;"><span class="aod-qty"><%= item.quantity %></span></td>
                                <td class="right" style="vertical-align: top; padding-top: 16px;"><span class="aod-price"><%= fmt(item.price) %></span></td>
                                <td class="right" style="vertical-align: top; padding-top: 16px;">
                                    <% if (item.offerDiscount > 0) { %>
                                        <span style="text-decoration: line-through; color: #9CA3AF; font-size: 11px; display: block; margin-bottom: 2px;">
                                            <%= fmt((item.originalPrice || item.price) * item.quantity) %>
                                        </span>
                                    <% } %>
                                    <span class="aod-total" style="font-weight: 700;"><%= fmt(itemTotal) %></span>
                                </td>
<td class="center" style="vertical-align: top; padding-top: 16px;">

    <% if (item.itemStatus === ORDER_STATUS.CANCELLED) { %>

        <span class="aod-return-status-badge aod-return-status-badge--rejected">
            <i data-lucide="x" size="10"></i>
            Cancelled
        </span>

    <% } else if (item.itemReturnStatus === RETURN_STATUS.REQUESTED) { %>

        <div class="aod-item-return-actions">

            <button
                class="aod-btn-approve aod-btn-approve--sm"
                data-item-id="<%= item._id %>"
                onclick="handleItemReturn('<%= item._id %>', 'approve', this)"
            >
                Approve
            </button>

            <button
                class="aod-btn-reject aod-btn-reject--sm"
                data-item-id="<%= item._id %>"
                onclick="handleItemReturn('<%= item._id %>', 'reject', this)"
            >
                Reject
            </button>

        </div>

    <% } else if (item.itemStatus === ORDER_STATUS.RETURNED) { %>

        <span class="aod-return-status-badge aod-return-status-badge--approved">
            <i data-lucide="check" size="10"></i>
            Returned
        </span>

    <% } else if (item.itemReturnStatus === RETURN_STATUS.REJECTED) { %>

        <span class="aod-return-status-badge aod-return-status-badge--rejected">
            <i data-lucide="x" size="10"></i>
            Return Rejected
        </span>

    <% } else { 
        /* Item is Active - Allow individual status update */
        const itemStatus = item.itemStatus || "Pending";
        const isItemUpdateLocked = [ORDER_STATUS.DELIVERED, ORDER_STATUS.CANCELLED, ORDER_STATUS.RETURNED].includes(itemStatus) || isPaymentLocked || isReturnPending;
    %>

        <div style="display: flex; flex-direction: column; gap: 6px; align-items: flex-end;">
            <select 
                id="itemStatusSelect_<%= item._id %>" 
                class="aod-status-select" 
                style="padding: 4px 24px 4px 8px; font-size: 11px; height: 28px;"
                <%= isItemUpdateLocked ? "disabled" : "" %>>
                <option value="Pending"          <%= itemStatus === ORDER_STATUS.PENDING          ? "selected" : "" %>>Pending</option>
                <option value="Processing"       <%= itemStatus === ORDER_STATUS.PROCESSING       ? "selected" : "" %>>Processing</option>
                <option value="Shipped"          <%= itemStatus === ORDER_STATUS.SHIPPED          ? "selected" : "" %>>Shipped</option>
                <option value="Out for Delivery" <%= itemStatus === ORDER_STATUS.OUT_FOR_DELIVERY ? "selected" : "" %>>Out for Delivery</option>
                <option value="Delivered"        <%= itemStatus === ORDER_STATUS.DELIVERED        ? "selected" : "" %>>Delivered</option>
                <option value="Cancelled"        <%= itemStatus === ORDER_STATUS.CANCELLED        ? "selected" : "" %>>Cancelled</option>
            </select>
            <button 
                type="button"
                class="aod-update-btn" 
                style="padding: 4px 12px; font-size: 10px; min-height: 24px;"
                onclick="updateItemStatus('<%= item._id %>', this)"
                <%= isItemUpdateLocked ? "disabled" : "" %>>
                Update
            </button>
        </div>

    <% } %>

</td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    </div>
                </div>

                <!-- Revised Order Summary (replaces Logistics — only when order was mutated) -->
                <% if (isRevised) { %>
                <div class="aod-card" id="aodRevisedSummaryCard" style="overflow: hidden; padding: 0;">

                    <!-- Header strip -->
                    <div style="background: linear-gradient(135deg, #603763 0%, #701A75 100%); padding: 16px 20px; display: flex; align-items: center; gap: 10px;">
                        <div style="width: 32px; height: 32px; background: rgba(255,255,255,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i data-lucide="file-diff" size="16" style="color: #fff;"></i>
                        </div>
                        <div>
                            <div style="font-size: 13px; font-weight: 700; color: #fff; letter-spacing: 0.02em;">Revised Order Summary</div>
                            <div style="font-size: 11px; color: rgba(255,255,255,0.7); margin-top: 1px;">Reflects current order after changes</div>
                        </div>
                        <div style="margin-left: auto; background: rgba(255,255,255,0.2); color: #fff; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px; letter-spacing: 0.05em;">UPDATED</div>
                    </div>

                    <!-- Row section -->
                    <div style="padding: 16px 20px; display: flex; flex-direction: column; gap: 0;">

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid #F9FAFB;">
                            <span style="font-size: 13px; color: #6B7280;">MRP Total</span>
                            <span style="font-size: 13px; font-weight: 500; color: #2C1421;"><%= fmt(revisedMRP) %></span>
                        </div>

                        <% if (revisedOffer > 0) { %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid #F9FAFB;">
                            <span style="font-size: 13px; color: #6B7280;">Offer Discount</span>
                            <span style="font-size: 13px; font-weight: 600; color: #EF4444;">−<%= fmt(revisedOffer) %></span>
                        </div>
                        <% } %>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #D0C3CC;">
                            <span style="font-size: 13px; font-weight: 700; color: #2C1421;">Subtotal</span>
                            <span style="font-size: 13px; font-weight: 700; color: #2C1421;"><%= fmt(revisedSubtotal) %></span>
                        </div>

                        <% if (revisedCouponRevoked) { %>
                        <div style="padding: 10px 0; border-bottom: 1px solid #F9FAFB;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div style="display: flex; align-items: center; gap: 6px;">
                                    <span style="font-size: 13px; color: #6B7280;">Coupon</span>
                                    <span style="background: #FEE2E2; color: #DC2626; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; letter-spacing: 0.05em;">REVOKED</span>
                                </div>
                                <span style="font-size: 13px; font-weight: 600; color: #DC2626;">Not Applicable</span>
                            </div>
                            <div style="font-size: 11px; color: #9CA3AF; margin-top: 4px; text-align: right;">Order value no longer meets minimum purchase requirement</div>
                        </div>
                        <% } else if (revisedCoupon > 0) { %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid #F9FAFB;">
                            <span style="font-size: 13px; color: #6B7280;">Coupon</span>
                            <span style="font-size: 13px; font-weight: 600; color: #059669;">−<%= fmt(revisedCoupon) %></span>
                        </div>
                        <% } %>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid #F9FAFB;">
                            <span style="font-size: 13px; color: #6B7280;">Tax (GST)</span>
                            <span style="font-size: 13px; font-weight: 500; color: #2C1421;"><%= fmt(revisedTax) %></span>
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 9px 0;">
                            <span style="font-size: 13px; color: #6B7280;">Shipping</span>
                            <span style="font-size: 13px; font-weight: 700; color: #F59E0B;"><%= revisedDelivery === 0 ? 'FREE' : fmt(revisedDelivery) %></span>
                        </div>

                    </div>

                    <!-- Total bar -->
                    <div style="background: linear-gradient(135deg, #FFF0F8 0%, #FFE0F4 100%); border-top: 1px solid #EBB5EA; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 14px; font-weight: 700; color: #603763;">Revised Total</span>
                        <span style="font-size: 18px; font-weight: 800; color: #701A75; letter-spacing: -0.03em;"><%= fmt(revisedTotal) %></span>
                    </div>

                </div>
                <% } %>

                <!-- Order Timeline -->
                <div class="aod-card aod-timeline-card" id="aodTimelineCard">
                    <h2 class="aod-card-title">Order Timeline</h2>
                    <div class="aod-timeline">
                        <% timeline.forEach((step, idx) => { %>
                        <div class="aod-step">
                            <div class="aod-step-icon <%= step.done ? 'aod-step-icon--done' : 'aod-step-icon--active' %>">
                                <% if (step.done) { %>
                                    <i data-lucide="check" size="10"></i>
                                <% } else { %>
                                    <i data-lucide="clock" size="10"></i>
                                <% } %>
                            </div>
                            <div class="aod-step-body">
                                <span class="aod-step-title"><%= step.title %></span>
                                <span class="aod-step-desc"><%= step.desc %></span>
                            </div>
                            <span class="aod-step-time"><%= step.time %></span>
                        </div>
                        <% }) %>
                    </div>
                </div>



                <!-- ── Return Section ──
                     Shows approve/reject only when status === "Requested".
                     Shows a read-only indicator when Approved or Rejected.
                     Hidden entirely when returnStatus === RETURN_STATUS.NONE.
                ── -->

                <!-- FIX 2 + FIX 3: Active return request — show action buttons -->
                <% if (ret.exists) { %>
                <div class="aod-card" id="aodReturnCard">
                    <div class="aod-return-card">
                        <div class="aod-return-heading">
                            <span class="aod-return-heading-icon"><i data-lucide="alert-circle" size="18"></i></span>
                            <h2 class="aod-return-title">Return Request</h2>
                        </div>
                        <div class="aod-return-body">
                            <div class="aod-return-banner">
                                <span class="aod-return-banner-label">Return Requested</span>
                                <span class="aod-return-yes">YES</span>
                            </div>
                            <div class="aod-return-grid">
                                <div class="aod-return-field">
                                    <span class="aod-return-field-label">Reason</span>
                                    <span class="aod-return-field-value"><%= ret.reason || '—' %></span>
                                </div>
                                <div class="aod-return-field">
                                    <span class="aod-return-field-label">Refund Method</span>
                                    <span class="aod-return-field-value"><%= order.paymentMethod || '—' %></span>
                                </div>
                            </div>
                            <div class="aod-return-actions">
                                <button class="aod-btn-approve" id="btnApproveReturn" onclick="handleReturn('approve')">
                                    Approve Return
                                </button>
                                <button class="aod-btn-reject" id="btnRejectReturn" onclick="handleReturn('reject')">
                                    Reject Return
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- FIX 3: Already handled return — show read-only status indicator -->
                <% if (ret.approved || ret.rejected) { %>
                <div class="aod-card" id="aodReturnCard">
                    <div class="aod-return-card">
                        <div class="aod-return-heading">
                            <span class="aod-return-heading-icon">
                                <% if (ret.approved) { %>
                                    <i data-lucide="check-circle" size="18" style="color:#059669"></i>
                                <% } else { %>
                                    <i data-lucide="x-circle" size="18" style="color:#BA1A1A"></i>
                                <% } %>
                            </span>
                            <h2 class="aod-return-title">Return Request</h2>
                        </div>
                        <div class="aod-return-body">

                            <!-- Status badge -->
                            <div class="aod-return-status-wrap aod-return-status-wrap--<%= ret.approved ? 'approved' : 'rejected' %>">
                                <span class="aod-return-status-label">
                                    Return request has been <%= ret.approved ? 'approved' : 'rejected' %>.
                                </span>
                                <span class="aod-return-status-badge aod-return-status-badge--<%= ret.approved ? 'approved' : 'rejected' %>">
                                    <% if (ret.approved) { %>
                                        <i data-lucide="check" size="10"></i> Approved
                                    <% } else { %>
                                        <i data-lucide="x" size="10"></i> Rejected
                                    <% } %>
                                </span>
                            </div>

                            <div class="aod-return-grid">
                                <div class="aod-return-field">
                                    <span class="aod-return-field-label">Reason</span>
                                    <span class="aod-return-field-value"><%= ret.reason || '—' %></span>
                                </div>
                                <div class="aod-return-field">
                                    <span class="aod-return-field-label">Refund Method</span>
                                    <span class="aod-return-field-value"><%= order.paymentMethod || '—' %></span>
                                </div>
                                <% if (ret.approved && order.refundAmount) { %>
                                <div class="aod-return-field">
                                    <span class="aod-return-field-label">Refund Amount</span>
                                    <span class="aod-return-field-value" style="color:#059669"><%= fmt(order.refundAmount) %></span>
                                </div>
                                <% } %>
                            </div>

                        </div>
                    </div>
                </div>
                <% } %>

            </div>
            <!-- /aod-left -->

            <!-- ════════ RIGHT COLUMN ════════ -->
            <div class="aod-right" id="aodRight">

                <!-- Pricing Summary -->
                <div class="aod-card" id="aodPricingCard">
                    <div class="aod-pricing-card">
                        <h2 class="aod-pricing-title">Pricing Summary</h2>
                        <div class="aod-pricing-rows">
                            <!-- MRP Total -->
                            <div class="aod-pricing-row">
                                <span class="aod-pricing-label">MRP Total</span>
                                <span class="aod-pricing-value"><%= fmt(pricing.mrp) %></span>
                            </div>

                            <!-- Offer Discount -->
                            <% if (pricing.hasOffer) { %>
                            <div class="aod-pricing-row">
                                <span class="aod-pricing-label">Offer Discount</span>
                                <span class="aod-pricing-value discount">−<%= fmt(pricing.offer) %></span>
                            </div>
                            <% } %>

                            <!-- Subtotal -->
                            <div class="aod-pricing-row" style="padding-top: 10px; border-top: 1px dashed #E5E7EB; margin-top: 6px; margin-bottom: 6px;">
                                <span class="aod-pricing-label" style="font-weight: 600; color: #374151;">Subtotal</span>
                                <span class="aod-pricing-value" style="font-weight: 600; color: #374151;"><%= fmt(pricing.subtotal) %></span>
                            </div>

                            <!-- Coupon -->
                            <% if (pricing.hasCoupon) { %>
                            <div class="aod-pricing-row">
                                <span class="aod-pricing-label" style="display:flex; align-items:center; gap: 6px;">
                                    Coupon
                                    <% if (order.couponCode) { %>
                                        <span style="background: rgba(5,150,105,0.1); color: #059669; padding: 2px 6px; border-radius: 4px; font-size: 11px; font-weight: 700; text-transform: uppercase;"><%= order.couponCode %></span>
                                    <% } %>
                                </span>
                                <span class="aod-pricing-value" style="color: #059669; font-weight: 600;">−<%= fmt(pricing.coupon) %></span>
                            </div>
                            <% } %>

                            <!-- Tax -->
                            <div class="aod-pricing-row">
                                <span class="aod-pricing-label">Tax (GST)</span>
                                <span class="aod-pricing-value"><%= fmt(pricing.tax) %></span>
                            </div>

                            <!-- Shipping -->
                            <div class="aod-pricing-row">
                                <span class="aod-pricing-label">Shipping</span>
                                <% if (pricing.shipping === 0) { %>
                                    <span class="aod-pricing-value free">FREE</span>
                                <% } else { %>
                                    <span class="aod-pricing-value"><%= fmt(pricing.shipping) %></span>
                                <% } %>
                            </div>
                        </div>
                        <div class="aod-pricing-total">
                            <span class="aod-pricing-total-label">Order Total</span>
                            <span class="aod-pricing-total-value"><%= fmt(pricing.total) %></span>
                        </div>
                    </div>
                </div>

                <%
                    // Collect all items that were cancelled or returned
                    const refundableItems = items.filter(i =>
                        i.itemStatus === ORDER_STATUS.CANCELLED ||
                        i.itemStatus === ORDER_STATUS.RETURNED  ||
                        i.itemReturnStatus === RETURN_STATUS.APPROVED
                    );

                    // Total refund across all items (from order-level accumulator)
                    const totalRefund = order.refundAmount || 0;

                    // Show the Refund Summary card if any items were cancelled/returned
                    const showRefundCard = refundableItems.length > 0;
                    
                    // Determine if this is a legacy full-order refund where individual item refunds aren't tracked
                    const isLegacyRefund = (order.paymentStatus === PAYMENT_STATUS.REFUNDED || (order.isRefundProcessed && order.refundAmount > 0)) && 
                                           items.every(i => !i.isRefundProcessed);
                %>
                <% if (showRefundCard) { %>
                <!-- Refund Summary — per-item breakdown -->
                <div class="aod-card" id="aodRefundCard">
                    <div class="aod-pricing-card" style="background-color: #F9FAFB; border-color: #F3F4F6;">
                        <h2 class="aod-pricing-title" style="color: #4B5563;">Refund Summary</h2>

                        <!-- Header row -->
                        <div style="display:grid; grid-template-columns: 1fr auto auto; gap: 8px; padding: 6px 0 10px; border-bottom: 1px dashed #E5E7EB; margin-bottom: 10px;">
                            <span style="font-size: 11px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.5px;">Item</span>
                            <span style="font-size: 11px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.5px; text-align:right;">Type</span>
                            <span style="font-size: 11px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.5px; text-align:right; min-width:90px;">Refund</span>
                        </div>

                        <!-- Per-item rows -->
                        <% refundableItems.forEach(item => {
                            const isCancelled = item.itemStatus === ORDER_STATUS.CANCELLED;
                            const isReturned  = item.itemStatus === ORDER_STATUS.RETURNED || item.itemReturnStatus === RETURN_STATUS.APPROVED;
                            const itemRefund  = item.refundAmount || 0;
                            const hadRefund   = item.isRefundProcessed && itemRefund > 0;
                        %>
                        <div style="display:grid; grid-template-columns: 1fr auto auto; gap: 8px; align-items: center; padding: 8px 0; border-bottom: 1px solid #F3F4F6;">
                            <!-- Product name + variant -->
                            <div>
                                <div style="font-size: 13px; font-weight: 600; color: #374151;"><%= item.productName || "Item" %></div>
                                <% if (item.variantName || item.variantValue) { %>
                                <div style="font-size: 11px; color: #9CA3AF; margin-top: 2px;"><%= [item.variantName, item.variantValue].filter(Boolean).join(" · ") %></div>
                                <% } %>
                            </div>

                            <!-- Status badge -->
                            <div>
                                <% if (isCancelled) { %>
                                <span style="font-size: 10px; font-weight: 700; background: rgba(239,68,68,0.08); color: #DC2626; padding: 3px 8px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.5px; white-space:nowrap;">Cancelled</span>
                                <% } else { %>
                                <span style="font-size: 10px; font-weight: 700; background: rgba(234,179,8,0.08); color: #B45309; padding: 3px 8px; border-radius: 6px; text-transform: uppercase; letter-spacing: 0.5px; white-space:nowrap;">Returned</span>
                                <% } %>
                            </div>

                            <!-- Refund amount or "No refund" -->
                            <div style="text-align:right; min-width:90px;">
                                <% if (hadRefund) { %>
                                <span style="font-size: 13px; font-weight: 700; color: #059669;"><%= fmt(itemRefund) %></span>
                                <div style="font-size: 10px; color: #059669; margin-top: 2px;">Credited to wallet</div>
                                <% } else if (isLegacyRefund) { %>
                                <span style="font-size: 13px; font-weight: 700; color: #059669;">Refunded</span>
                                <div style="font-size: 10px; color: #059669; margin-top: 2px;">Included in total</div>
                                <% } else { %>
                                <span style="font-size: 12px; font-weight: 600; color: #9CA3AF;">No refund</span>
                                <div style="font-size: 10px; color: #9CA3AF; margin-top: 2px;">Order wasn't paid</div>
                                <% } %>
                            </div>
                        </div>
                        <% }); %>

                        <!-- Total row -->
                        <div style="display:flex; justify-content:space-between; align-items:center; padding-top: 14px; margin-top: 4px;">
                            <span style="font-size: 15px; font-weight: 700; color: #111827;">Total Refunded</span>
                            <div style="text-align:right;">
                                <span style="font-size: 17px; font-weight: 800; color: #111827;"><%= fmt(totalRefund) %></span>
                                <% if (totalRefund > 0) { %>
                                <div style="font-size: 12px; color: #059669; font-weight: 500; margin-top: 3px; font-style: italic;">
                                    <i data-lucide="check-circle" size="12" style="display:inline; vertical-align:text-bottom; margin-right:2px;"></i>Credited to user wallet
                                </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% } %>

                <!-- Customer Details -->
                <div class="aod-card" id="aodCustomerCard">
                    <div class="aod-customer-card">
                        <h2 class="aod-customer-title">Customer Details</h2>
                        <div class="aod-customer-profile">
                            <div class="aod-cust-avatar">
                                <%= order.userId?.fullName
                                    ? order.userId.fullName.split(" ").map(w => w[0]).join("").slice(0,2).toUpperCase()
                                    : "U" %>
                            </div>
                            <div class="aod-cust-info">
                                <span class="aod-cust-name"><%= order.userId?.fullName || "Unknown User" %></span>
                                <span class="aod-cust-email"><%= order.userId?.email || "" %></span>
                            </div>
                        </div>
                        <div class="aod-cust-section">
                            <span class="aod-cust-section-label">Shipping Address</span>
                            <p class="aod-address-lines">
                                <%= [
                                    order.shippingAddress?.addressLine1,
                                    order.shippingAddress?.city,
                                    order.shippingAddress?.state,
                                    order.shippingAddress?.country,
                                    order.shippingAddress?.pincode
                                ].filter(Boolean).join(", ") %>
                            </p>
                        </div>
                        <div class="aod-cust-section">
                            <span class="aod-cust-section-label">Payment Details</span>
                            <div class="aod-payment-row">
                                <span class="aod-payment-row-label">Method</span>
                                <span class="aod-payment-row-value"><%= order.paymentMethod || '—' %></span>
                            </div>
                            <div class="aod-payment-row" style="margin-top:4px">
                                <span class="aod-payment-row-label">Txn ID</span>
                                <span class="aod-payment-row-value"><%= order.paymentId || '—' %></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Update Order Status -->
                <div class="aod-card" id="aodUpdateCard">
                    <div class="aod-update-card">
                        <h2 class="aod-update-title">Update Order Status</h2>

                        <!-- FIX 4: warn admin if return is pending -->
                        <% if (isReturnPending) { %>
                        <div class="aod-return-pending-notice">
                            <i data-lucide="alert-triangle"></i>
                            <span>A return request is pending. Resolve it before updating the order status.</span>
                        </div>
                        <% } %>
                        <% if (isPaymentLocked) { %>
<div class="aod-return-pending-notice">
    <i data-lucide="alert-triangle"></i>
    <span>
        Payment has not been completed. Order status cannot be updated until payment succeeds.
    </span>
</div>
<% } %>

                        <select
                            id="orderStatusSelect"
                            class="aod-status-select"
                            <%= statusUpdateLocked ? "disabled" : "" %>>
                            <option value="Pending"          <%= orderStatus === ORDER_STATUS.PENDING          ? "selected" : "" %>>Pending</option>
                            <option value="Processing"       <%= orderStatus === ORDER_STATUS.PROCESSING       ? "selected" : "" %>>Processing</option>
                            <option value="Shipped"          <%= orderStatus === ORDER_STATUS.SHIPPED          ? "selected" : "" %>>Shipped</option>
                            <option value="Out for Delivery" <%= orderStatus === ORDER_STATUS.OUT_FOR_DELIVERY ? "selected" : "" %>>Out for Delivery</option>
                            <option value="Delivered"        <%= orderStatus === ORDER_STATUS.DELIVERED        ? "selected" : "" %>>Delivered</option>
                            <option value="Cancelled"        <%= orderStatus === ORDER_STATUS.CANCELLED        ? "selected" : "" %>>Cancelled</option>
                            <option value="Returned"         <%= orderStatus === ORDER_STATUS.RETURNED         ? "selected" : "" %>>Returned</option>
                        </select>

                        <button
                            type="button"
                            class="aod-update-btn"
                            id="btnUpdateStatus"
                            onclick="updateStatus()"
                            <%= statusUpdateLocked ? "disabled" : "" %>>
                            Update Status
                        </button>
                    </div>
                </div>

            </div>
            <!-- /aod-right -->

        </div>
        <!-- /aod-body -->

        <!-- Admin Footer -->
        <footer class="aod-footer">
            <div class="aod-footer-left">
                <a href="/admin/dashboard" class="aod-footer-logo">iStore Admin</a>
                <span>©&nbsp;<%= new Date().getFullYear() %> iStore Admin. All rights reserved.</span>
            </div>
            <div class="aod-footer-right">
                <a href="#" class="aod-footer-link">Support</a>
                <a href="#" class="aod-footer-link">Privacy Policy</a>
                <a href="#" class="aod-footer-link">Terms of Service</a>
            </div>
        </footer>

    </main>

    <script>
        lucide.createIcons();

        /* ── GSAP entrance ── */
        gsap.from('.aod-header-row',   { y: -12, opacity: 0, duration: 0.45, ease: 'power2.out', delay: 0.08 });
        gsap.from('.aod-summary-card', { y: 16,  opacity: 0, duration: 0.40, stagger: 0.07, ease: 'power2.out', delay: 0.16 });
        gsap.from('#aodProductsCard',  { y: 24,  opacity: 0, duration: 0.45, ease: 'power2.out', delay: 0.30 });
        gsap.from('#aodTimelineCard',  { y: 24,  opacity: 0, duration: 0.45, ease: 'power2.out', delay: 0.38 });
        gsap.from('#aodLogisticsCard', { y: 24,  opacity: 0, duration: 0.45, ease: 'power2.out', delay: 0.44 });
        gsap.from('#aodReturnCard',    { y: 24,  opacity: 0, duration: 0.45, ease: 'power2.out', delay: 0.50 });
        gsap.from('.aod-right > *',    { y: 18,  opacity: 0, duration: 0.40, stagger: 0.10, ease: 'power2.out', delay: 0.28 });
        gsap.from('.aod-step',         { x: -12, opacity: 0, duration: 0.35, stagger: 0.10, ease: 'power2.out', delay: 0.50 });

        /* ── FIX 6: Copy tracking number ── */
        function copyTracking() {
            const num = document.getElementById('trackingNum')?.textContent?.trim();
            if (!num || num === '—') return;
            navigator.clipboard.writeText(num).then(() => {
                Swal.fire({ toast: true, position: 'top', showConfirmButton: false, timer: 2000, icon: 'success', title: 'Tracking number copied!' });
            });
        }

        /* ── Update order status ── */
        function updateStatus() {
            const sel = document.getElementById('orderStatusSelect');
            const btn = document.getElementById('btnUpdateStatus');
            if (!sel || !btn) return;
            if (sel.disabled || btn.disabled) return;

            const status = sel?.value;
            if (!status) return;

            Swal.fire({
                title: `Update status to "${status}"?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#7A4E7C',
                cancelButtonColor:  '#6B7280',
                confirmButtonText:  'Yes, Update',
                cancelButtonText:   'Cancel',
            }).then(result => {
                if (!result.isConfirmed) return;

                /* Loading state */
                btn.disabled    = true;
                btn.textContent = 'Updating…';

                fetch("/admin/orders/<%= order._id %>/status", {
                    method:  "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body:    JSON.stringify({ status })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ icon: "success", title: "Status Updated", text: data.message, confirmButtonColor: "#7A4E7C" })
                            .then(() => location.reload());
                    } else {
                        btn.disabled    = false;
                        btn.textContent = 'Update Status';
                        Swal.fire({ icon: "error", title: "Update Failed", text: data.message });
                    }
                })
                .catch(() => {
                    btn.disabled    = false;
                    btn.textContent = 'Update Status';
                    Swal.fire({ icon: "error", title: "Network Error", text: "Could not reach the server." });
                });
            });
        }

        /* ── Individual Item Status Update ── */
        function updateItemStatus(itemId, btn) {
            const select = document.getElementById('itemStatusSelect_' + itemId);
            if (!select) return;
            const status = select.value;

            Swal.fire({
                title: 'Update Item Status?',
                text: `Are you sure you want to change this item to ${status}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#7A4E7C',
                cancelButtonColor: '#6B7280',
                confirmButtonText: 'Yes, update'
            }).then((result) => {
                if (!result.isConfirmed) return;

                const origText = btn.textContent;
                btn.disabled = true;
                btn.textContent = 'Updating...';

                fetch(`/admin/orders/<%= order._id %>/item/${itemId}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            icon: "success",
                            title: "Status Updated",
                            text: data.message,
                            confirmButtonColor: '#7A4E7C'
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        btn.disabled = false;
                        btn.textContent = origText;
                        Swal.fire({ icon: "error", title: "Update Failed", text: data.message });
                    }
                })
                .catch(() => {
                    btn.disabled = false;
                    btn.textContent = origText;
                    Swal.fire({ icon: "error", title: "Network Error", text: "Could not reach the server." });
                });
            });
        }

        /* ── FIX 2 + FIX 5: Return actions with loading state + instant hide ── */
        function handleReturn(action) {
            const isApprove = action === 'approve';

            Swal.fire({
                title: isApprove ? 'Approve this return?' : 'Reject this return?',
                text:  isApprove
                    ? 'The customer will be refunded to their wallet.'
                    : 'The return request will be rejected.',
                icon:  isApprove ? 'question' : 'warning',
                showCancelButton:   true,
                confirmButtonColor: isApprove ? '#7A4E7C' : '#BA1A1A',
                cancelButtonColor:  '#6B7280',
                confirmButtonText:  isApprove ? 'Yes, Approve' : 'Yes, Reject',
                cancelButtonText:   'Cancel',
            }).then(result => {
                if (!result.isConfirmed) return;

                /* Disable both buttons immediately */
                const approveBtn = document.getElementById('btnApproveReturn');
                const rejectBtn  = document.getElementById('btnRejectReturn');
                if (approveBtn) { approveBtn.disabled = true; approveBtn.textContent = isApprove ? 'Approving…' : 'Approve Return'; }
                if (rejectBtn)  { rejectBtn.disabled  = true; rejectBtn.textContent  = !isApprove ? 'Rejecting…' : 'Reject Return'; }

                fetch("/admin/orders/<%= order._id %>/return", {
                    method:  "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body:    JSON.stringify({ action })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        /* Animate card out immediately */
                        const card = document.getElementById('aodReturnCard');
                        if (card) {
                            gsap.to(card, {
                                opacity: 0, y: -12, height: 0,
                                marginBottom: 0, padding: 0,
                                duration: 0.4, ease: 'power2.in',
                                onComplete: () => card.remove()
                            });
                        }
                        Swal.fire({ icon: 'success', title: data.message, confirmButtonColor: '#7A4E7C' })
                            .then(() => location.reload());
                    } else {
                        /* Re-enable on failure */
                        if (approveBtn) { approveBtn.disabled = false; approveBtn.textContent = 'Approve Return'; }
                        if (rejectBtn)  { rejectBtn.disabled  = false; rejectBtn.textContent  = 'Reject Return'; }
                        Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
                    }
                })
                .catch(() => {
                    if (approveBtn) { approveBtn.disabled = false; approveBtn.textContent = 'Approve Return'; }
                    if (rejectBtn)  { rejectBtn.disabled  = false; rejectBtn.textContent  = 'Reject Return'; }
                    Swal.fire({ icon: 'error', title: 'Network Error', text: 'Could not reach the server.' });
                });
            });
        }

        /* ── Per-item return approve/reject ── */
        function handleItemReturn(itemId, action, btnEl) {
            const isApprove = action === 'approve';

            Swal.fire({
                title: isApprove ? 'Approve this item return?' : 'Reject this item return?',
                text:  isApprove
                    ? 'Stock will be restored and the customer refunded to their wallet.'
                    : 'The return request for this item will be rejected.',
                icon:  isApprove ? 'question' : 'warning',
                showCancelButton:   true,
                confirmButtonColor: isApprove ? '#7A4E7C' : '#BA1A1A',
                cancelButtonColor:  '#6B7280',
                confirmButtonText:  isApprove ? 'Yes, Approve' : 'Yes, Reject',
                cancelButtonText:   'Cancel',
            }).then(result => {
                if (!result.isConfirmed) return;

                const row = btnEl.closest('tr');
                const buttons = row.querySelectorAll('.aod-btn-approve--sm, .aod-btn-reject--sm');
                buttons.forEach(b => b.disabled = true);
                btnEl.textContent = isApprove ? 'Approving…' : 'Rejecting…';

                fetch(`/admin/orders/<%= order._id %>/item/${itemId}/return`, {
                    method:  "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body:    JSON.stringify({ action })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ icon: 'success', title: data.message, confirmButtonColor: '#7A4E7C' })
                            .then(() => location.reload());
                    } else {
                        buttons.forEach(b => b.disabled = false);
                        btnEl.textContent = isApprove ? 'Approve' : 'Reject';
                        Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
                    }
                })
                .catch(() => {
                    buttons.forEach(b => b.disabled = false);
                    btnEl.textContent = isApprove ? 'Approve' : 'Reject';
                    Swal.fire({ icon: 'error', title: 'Network Error', text: 'Could not reach the server.' });
                });
            });
        }
    </script>

</body>
</html>
