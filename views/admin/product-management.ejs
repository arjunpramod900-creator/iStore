<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Management - Admin | iStore</title>
  <link rel="stylesheet" href="/css/components/admin-sidebar.css?v=1.1">
  <link rel="stylesheet" href="/css/admin-dashboard.css?v=1.1">
  <link rel="stylesheet" href="/css/admin-products.css?v=1.1">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
</head>
<body>

  <%- include('../partials/admin/sidebar') %>

  <main class="dashboard-main">

    <!-- PAGE HEADER -->
    <header class="page-header">
      <div class="header-left">
        <nav class="breadcrumb">
          <a href="/admin/dashboard">DASHBOARD</a>
          <i data-lucide="chevron-right" size="12"></i>
          <span class="current">PRODUCTS</span>
        </nav>
        <h1 class="page-title">Product Management</h1>
        <p class="page-subtitle">Manage all store products efficiently.</p>
      </div>
    </header>

    <!-- STATS -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-header">
          <span class="stat-label">TOTAL PRODUCTS</span>
          <i data-lucide="package" size="20"></i>
        </div>
        <span class="stat-value"><%= stats.total %></span>
        <div class="stat-sub"><i data-lucide="trending-up" size="14"></i> Inventory products</div>
      </div>
      <div class="stat-card">
        <div class="stat-header">
          <span class="stat-label">ACTIVE PRODUCTS</span>
          <div class="status-dot-small dot-pink"></div>
        </div>
        <span class="stat-value"><%= stats.active %></span>
        <div class="stat-sub">Currently visible in store</div>
      </div>
      <div class="stat-card">
        <div class="stat-header">
          <span class="stat-label">INACTIVE PRODUCTS</span>
          <div class="status-dot-small dot-gray"></div>
        </div>
        <span class="stat-value"><%= stats.inactive %></span>
        <div class="stat-sub">Hidden from storefront</div>
      </div>
    </section>

    <!-- ACTION BAR -->
    <form method="GET" action="/admin/products">
      <section class="action-bar">
        <div class="filters-left">
          <div class="search-wrapper">
            <i data-lucide="search" size="16" class="search-icon-inline"></i>
            <input type="text" name="search" class="search-input-field"
              placeholder="Search products..." value="<%= search %>">
          </div>
          <select name="category" class="filter-select">
            <option value="">All Categories</option>
            <% categories.forEach(categoryItem => { %>
              <option value="<%= categoryItem._id %>"
                <%= categoryItem._id.toString() === category ? "selected" : "" %>>
                <%= categoryItem.name %>
              </option>
            <% }) %>
          </select>
          <select name="status" class="filter-select">
            <option value="all"      <%= status === "all"      ? "selected" : "" %>>All Status</option>
            <option value="active"   <%= status === "active"   ? "selected" : "" %>>Active</option>
            <option value="inactive" <%= status === "inactive" ? "selected" : "" %>>Inactive</option>
            <option value="trash"    <%= status === "trash"    ? "selected" : "" %>>Trash</option>
          </select>
          <button type="submit" class="btn-add">
            <i data-lucide="filter"></i> Apply
          </button>
        </div>
        <button type="button" id="openAddModalBtn" class="btn-add">
          <i data-lucide="plus"></i> Add Product
        </button>
      </section>
    </form>

    <!-- TABLE -->
    <div class="table-card">
      <div class="table-header-row">
        <h2 class="table-title">All Products</h2>
        <a href="#" class="btn-export">Export CSV</a>
      </div>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>PRODUCT</th>
              <th>CATEGORY</th>
              <th>VARIANTS</th>
              <th>PRICE</th>
              <th style="text-align:right;">STOCK</th>
              <th>STATUS</th>
              <th style="text-align:right;">ACTIONS</th>
            </tr>
          </thead>
          <tbody>
            <% if (products.length > 0) { %>
              <% products.forEach(product => { %>
                <tr>
                  <td>
                    <div class="product-info-cell">
                      <img src="<%= product.thumbnail || '/images/default-product.png' %>"
                        class="product-thumb" alt="<%= product.name %>">
                      <div class="product-details">
                        <span class="product-name"><%= product.name %></span>
                        <span class="product-sku">SKU: <%= product.defaultSKU %></span>
                        <% if (product.productOffer) { %>
                          <div class="offer-badge offer-product"><%= product.productOffer.discountValue %>% OFF (Product Offer)</div>
                        <% } else if (product.categoryOffer) { %>
                          <div class="offer-badge offer-category"><%= product.categoryOffer.discountValue %>% OFF (Category Offer)</div>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <td><%= product.categoryId?.name || "N/A" %></td>
                  <td><%= product.variantCount %> Variants</td>
                  <td class="price-text">₹<%= product.defaultPrice.toLocaleString() %></td>
                  <td style="text-align:right;"><%= product.totalStock %></td>
                  <td>
                    <div class="status-badge">
                      <div class="status-dot-small <%= product.isActive ? 'dot-pink' : 'dot-gray' %>"></div>
                      <%= product.isActive ? "Active" : "Inactive" %>
                    </div>
                  </td>
                  <td>
                    <div class="action-btns">
                      <% if (!product.isDeleted) { %>
                        <a href="/admin/products/<%= product._id %>" class="btn-icon-action">
                          <i data-lucide="eye"></i>
                        </a>
                        <button type="button" class="btn-icon-action edit-btn" data-id="<%= product._id %>">
                          <i data-lucide="edit-2"></i>
                        </button>
                        <button type="button" class="btn-icon-action delete-btn" data-id="<%= product._id %>">
                          <i data-lucide="trash-2"></i>
                        </button>
                      <% } else { %>
                        <button type="button" class="btn-icon-action restore-btn" data-id="<%= product._id %>">
                          <i data-lucide="rotate-ccw"></i>
                        </button>
                        <button type="button" class="btn-icon-action permanent-delete-btn" data-id="<%= product._id %>">
                          <i data-lucide="x-circle"></i>
                        </button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="7" class="empty-table">No products found</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- PAGINATION -->
      <div class="pagination-container">
        <span class="pagination-info">
          Showing <%= ((currentPage - 1) * limit) + 1 %> to
          <%= Math.min(currentPage * limit, totalProducts) %> of <%= totalProducts %> entries
        </span>
        <div class="pagination-controls">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage-1 %>&search=<%= search %>&category=<%= category %>&status=<%= status %>" class="page-nav">
              <i data-lucide="chevron-left"></i>
            </a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&status=<%= status %>"
              class="page-num <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage+1 %>&search=<%= search %>&category=<%= category %>&status=<%= status %>" class="page-nav">
              <i data-lucide="chevron-right"></i>
            </a>
          <% } %>
        </div>
      </div>
    </div>

    <footer class="page-footer">
      <span class="footer-text">© 2026 iStore Admin</span>
    </footer>
  </main>


  <!-- =========================================
       ADD PRODUCT MODAL
  ========================================= -->
  <div class="modal-overlay" id="addProductModal" style="display:none;">
    <div class="modal-box">

      <div class="modal-header">
        <h2>Add New Product</h2>
        <button type="button" class="modal-close-btn" id="closeAddModalBtn">
          <i data-lucide="x"></i>
        </button>
      </div>

      <div class="modal-body">
        <div class="error-alert" id="addProductError" style="display:none;"></div>

        <form id="addProductForm" class="bento-form-grid" enctype="multipart/form-data" data-no-loader="true" novalidate>

          <div class="column">

            <!-- Basic Details -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="package" size="20"></i>
                <h2>Product Basic Details</h2>
              </div>

              <div class="form-group">
                <label class="form-label">Product Name</label>
                <input type="text" name="name" id="add-name" class="form-input"
                  placeholder="e.g., iPhone 17 Pro Max">
                <span class="field-error" id="add-name-error"></span>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Category</label>
                  <select name="categoryId" id="add-category" class="form-select">
                    <option value="">Select Category</option>
                    <% categories.forEach(category => { %>
                      <option value="<%= category._id %>"><%= category.name %></option>
                    <% }) %>
                  </select>
                  <span class="field-error" id="add-category-error"></span>
                </div>
                <div class="form-group">
                  <label class="form-label">Product Status</label>
                  <select name="isActive" class="form-select">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" id="add-description" class="form-textarea"
                  placeholder="Write premium product description..."></textarea>
                <span class="field-error" id="add-description-error"></span>
              </div>
            </section>

            <!-- Images -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="image" size="18"></i>
                <h2>Product Images</h2>
              </div>

              <div class="image-grid">
                <label class="upload-slot" id="add-thumbnail-slot">
                  <input type="file" name="thumbnail" id="addThumbnailInput" accept="image/*" hidden>
                  <i data-lucide="plus-circle" size="24"></i>
                  <span>Upload Image</span>
                </label>
                <div class="image-preview" id="addThumbnailPreview" style="display:none;">
                  <img src="" id="addPreviewImage" alt="Preview">
                  <button type="button" class="remove-img-btn" id="addRemoveImageBtn">
                    <i data-lucide="x" size="14"></i>
                  </button>
                </div>
              </div>
              <span class="field-error" id="add-thumbnail-error"></span>
              <p class="image-note">Recommended size: 2000×2000px</p>

              <div class="variant-images-wrapper">
                <label class="form-label">Variant Gallery Images</label>
                <input type="file" name="variantImages" id="addVariantImages"
                  accept="image/*" multiple>
                <span class="field-error" id="add-variant-images-error"></span>
                <p class="image-note">Upload minimum 3 images</p>
                <div class="variant-preview-grid" id="addVariantPreviewGrid"></div>
              </div>
            </section>

          </div>

          <div class="column">

            <!-- Pricing & Stock -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="banknote" size="20"></i>
                <h2>Pricing & Stock</h2>
              </div>

              <div class="form-group">
                <label class="form-label">Price</label>
                <div class="price-input-wrapper">
                  <span class="price-symbol">₹</span>
                  <input type="number" name="price" id="add-price" class="form-input" placeholder="129900">
                </div>
                <span class="field-error" id="add-price-error"></span>
              </div>

              <div class="form-group">
                <label class="form-label">Compare Price <span style="font-weight:400;text-transform:none;letter-spacing:0;">(Optional)</span></label>
                <div class="price-input-wrapper">
                  <span class="price-symbol">₹</span>
                  <input type="number" name="comparePrice" id="add-compare-price" class="form-input" placeholder="139900">
                </div>
                <span class="field-error" id="add-compare-price-error"></span>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Stock</label>
                  <input type="number" name="stock" id="add-stock" class="form-input" placeholder="100">
                  <span class="field-error" id="add-stock-error"></span>
                </div>
                <div class="form-group">
                  <label class="form-label">SKU</label>
                  <input type="text" name="SKU" id="add-sku" class="form-input sku-input" placeholder="APL-IP17-512">
                  <span class="field-error" id="add-sku-error"></span>
                </div>
              </div>
            </section>

            <!-- Technical Specs -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="cpu" size="18"></i>
                <h2>Technical Specs</h2>
              </div>

              <div class="form-group">
                <label class="form-label">Storage</label>
                <input type="text" name="storage" id="add-storage" class="form-input" placeholder="256GB">
                <span class="field-error" id="add-storage-error"></span>
              </div>

              <div class="form-group">
                <label class="form-label">RAM</label>
                <input type="text" name="RAM" id="add-ram" class="form-input" placeholder="8GB">
                <span class="field-error" id="add-ram-error"></span>
              </div>

              <div class="form-group">
                <label class="form-label">Color</label>
                <input type="text" name="color" id="add-color" class="form-input" placeholder="Titanium">
                <span class="field-error" id="add-color-error"></span>
              </div>
            </section>

            <!-- Visibility -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="eye" size="18"></i>
                <h2>Visibility</h2>
              </div>
              <div class="status-row">
                <span class="form-label">Featured Product</span>
                <label class="switch"><input type="checkbox" name="isFeatured" value="true"><span class="slider"></span></label>
              </div>
              <div class="status-row">
                <span class="form-label">Best Seller</span>
                <label class="switch"><input type="checkbox" name="isBestSeller" value="true"><span class="slider"></span></label>
              </div>
              <div class="status-row">
                <span class="form-label">Deal Product</span>
                <label class="switch"><input type="checkbox" name="isDeal" value="true"><span class="slider"></span></label>
              </div>
            </section>

          </div>

          <div class="footer-actions" style="grid-column:1/-1;">
            <span class="draft-note">iStore Premium Inventory System</span>
            <button type="button" class="btn-cancel" id="cancelAddModalBtn">Cancel</button>
            <button type="submit" class="btn-save" id="addProductSubmitBtn">Save Product</button>
          </div>

        </form>
      </div>
    </div>
  </div>


  <!-- =========================================
       EDIT PRODUCT MODAL
  ========================================= -->
  <div class="modal-overlay" id="editProductModal" style="display:none;">
    <div class="modal-box">

      <div class="modal-header">
        <h2>Edit Product</h2>
        <button type="button" class="modal-close-btn" id="closeEditModalBtn">
          <i data-lucide="x"></i>
        </button>
      </div>

      <div class="modal-body">
        <div class="error-alert" id="editProductError" style="display:none;"></div>

        <form id="editProductForm" class="bento-form-grid" enctype="multipart/form-data" data-no-loader="true" novalidate>

          <input type="hidden" name="productId" id="editProductId">
          <input type="hidden" name="variantId" id="editVariantId">

          <div class="column">

            <!-- Basic Details -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="package" size="20"></i>
                <h2>Product Basic Details</h2>
              </div>

              <div class="form-group">
                <label class="form-label">Product Name</label>
                <input type="text" name="name" id="editName" class="form-input">
                <span class="field-error" id="edit-name-error"></span>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Category</label>
                  <select name="categoryId" id="editCategoryId" class="form-select">
                    <% categories.forEach(category => { %>
                      <option value="<%= category._id %>"><%= category.name %></option>
                    <% }) %>
                  </select>
                  <span class="field-error" id="edit-category-error"></span>
                </div>
                <div class="form-group">
                  <label class="form-label">Product Status</label>
                  <select name="isActive" id="editIsActive" class="form-select">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" id="editDescription" class="form-textarea"></textarea>
                <span class="field-error" id="edit-description-error"></span>
              </div>
            </section>

            <!-- Images -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="image" size="18"></i>
                <h2>Product Images</h2>
              </div>
              <div class="image-grid">
                <label class="upload-slot">
                  <input type="file" name="thumbnail" id="editThumbnailInput" accept="image/*" hidden>
                  <i data-lucide="plus-circle" size="24"></i>
                  <span>Replace Image</span>
                </label>
                <div class="image-preview" id="editThumbnailPreview">
                  <img src="" id="editPreviewImage" alt="Preview">
                  <button type="button" class="remove-img-btn" id="editRemoveImageBtn">
                    <i data-lucide="x" size="14"></i>
                  </button>
                </div>
              </div>
              <p class="image-note">Upload a new image only if needed.</p>
            </section>

          </div>

          <div class="column">

            <!-- Pricing & Stock -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="banknote" size="20"></i>
                <h2>Pricing & Stock</h2>
              </div>

              <div class="form-group">
                <label class="form-label">Price</label>
                <div class="price-input-wrapper">
                  <span class="price-symbol">₹</span>
                  <input type="number" name="price" id="editPrice" class="form-input">
                </div>
                <span class="field-error" id="edit-price-error"></span>
              </div>

              <div class="form-group">
                <label class="form-label">Compare Price <span style="font-weight:400;text-transform:none;letter-spacing:0;">(Optional)</span></label>
                <div class="price-input-wrapper">
                  <span class="price-symbol">₹</span>
                  <input type="number" name="comparePrice" id="editComparePrice" class="form-input">
                </div>
                <span class="field-error" id="edit-compare-price-error"></span>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Stock</label>
                  <input type="number" name="stock" id="editStock" class="form-input">
                  <span class="field-error" id="edit-stock-error"></span>
                </div>
                <div class="form-group">
                  <label class="form-label">SKU</label>
                  <input type="text" name="SKU" id="editSKU" class="form-input sku-input">
                  <span class="field-error" id="edit-sku-error"></span>
                </div>
              </div>
            </section>

            <!-- Technical Specs -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="cpu" size="18"></i>
                <h2>Technical Specs</h2>
              </div>

              <div class="form-group">
                <label class="form-label">Storage</label>
                <input type="text" name="storage" id="editStorage" class="form-input">
                <span class="field-error" id="edit-storage-error"></span>
              </div>

              <div class="form-group">
                <label class="form-label">RAM</label>
                <input type="text" name="RAM" id="editRAM" class="form-input">
                <span class="field-error" id="edit-ram-error"></span>
              </div>

              <div class="form-group">
                <label class="form-label">Color</label>
                <input type="text" name="color" id="editColor" class="form-input">
                <span class="field-error" id="edit-color-error"></span>
              </div>
            </section>

            <!-- Visibility -->
            <section class="section-card">
              <div class="section-header">
                <i data-lucide="eye" size="18"></i>
                <h2>Visibility</h2>
              </div>
              <div class="status-row">
                <span class="form-label">Featured Product</span>
                <label class="switch"><input type="checkbox" name="isFeatured" id="editIsFeatured" value="true"><span class="slider"></span></label>
              </div>
              <div class="status-row">
                <span class="form-label">Best Seller</span>
                <label class="switch"><input type="checkbox" name="isBestSeller" id="editIsBestSeller" value="true"><span class="slider"></span></label>
              </div>
              <div class="status-row">
                <span class="form-label">Deal Product</span>
                <label class="switch"><input type="checkbox" name="isDeal" id="editIsDeal" value="true"><span class="slider"></span></label>
              </div>
            </section>

          </div>

          <div class="footer-actions" style="grid-column:1/-1;">
            <span class="draft-note">iStore Premium Inventory System</span>
            <button type="button" class="btn-cancel" id="cancelEditModalBtn">Cancel</button>
            <button type="submit" class="btn-save" id="editProductSubmitBtn">Update Product</button>
          </div>

        </form>
      </div>
    </div>
  </div>


  <!-- ============================================================
       CROP MODAL (shared for product add/edit)
  ============================================================ -->
  <div class="crop-overlay" id="cropOverlay">
    <div class="crop-dialog">
      <div class="crop-dialog-header">
        <h3>Crop Image</h3>
        <button type="button" class="modal-close-btn" id="cropCloseBtn">
          <i data-lucide="x" size="16"></i>
        </button>
      </div>
      <div class="crop-dialog-body">
        <div class="crop-image-wrap">
          <img id="cropTargetImg" src="" alt="Crop preview">
        </div>
      </div>
      <div class="crop-dialog-footer">
        <button type="button" class="modal-btn-cancel" id="cropCancelBtn">Cancel</button>
        <button type="button" class="modal-btn-save" id="cropApplyBtn">Apply Crop</button>
      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();

    /* ================================================
       MODAL OPEN / CLOSE
    ================================================ */

    const addModal  = document.getElementById("addProductModal");
    const editModal = document.getElementById("editProductModal");

    function openModal(modal)  { modal.style.display = "flex"; document.body.style.overflow = "hidden"; }
    function closeModal(modal) { modal.style.display = "none"; document.body.style.overflow = "";       }

    document.getElementById("openAddModalBtn").addEventListener("click", () => {
      document.getElementById("addProductForm").reset();
      document.getElementById("addThumbnailPreview").style.display = "none";
      document.getElementById("addVariantPreviewGrid").innerHTML   = "";
      document.getElementById("addProductError").style.display     = "none";
      clearAllErrors("add");
      openModal(addModal);
      lucide.createIcons();
    });

    document.getElementById("closeAddModalBtn").addEventListener("click",  () => closeModal(addModal));
    document.getElementById("cancelAddModalBtn").addEventListener("click", () => closeModal(addModal));
    document.getElementById("closeEditModalBtn").addEventListener("click",  () => closeModal(editModal));
    document.getElementById("cancelEditModalBtn").addEventListener("click", () => closeModal(editModal));

    addModal.addEventListener("click",  e => { if (e.target === addModal)  closeModal(addModal);  });
    editModal.addEventListener("click", e => { if (e.target === editModal) closeModal(editModal); });

    /* ================================================
       INLINE VALIDATION HELPERS
    ================================================ */

    function setError(inputEl, errorId, msg) {
      if (!inputEl) return;
      inputEl.classList.add("input-error");
      inputEl.classList.remove("input-success");
      const s = document.getElementById(errorId);
      if (s) { s.textContent = msg; s.classList.add("visible"); }
    }

    function setSuccess(inputEl, errorId) {
      if (!inputEl) return;
      inputEl.classList.remove("input-error");
      inputEl.classList.add("input-success");
      const s = document.getElementById(errorId);
      if (s) { s.textContent = ""; s.classList.remove("visible"); }
    }

    function clearField(inputEl, errorId) {
      if (!inputEl) return;
      inputEl.classList.remove("input-error", "input-success");
      const s = document.getElementById(errorId);
      if (s) { s.textContent = ""; s.classList.remove("visible"); }
    }

    /* ---- field validators (prefix = "add" | "edit") ---- */

    function validateName(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-name" : "editName");
      const val = el.value.trim();
      const err = prefix + "-name-error";
if (!val) {
  setError(el, err, "Product name is required");
  return false;
}

if (!/^[A-Za-z]/.test(val)) {
  setError(el, err, "Must start with a letter");
  return false;
}

if (val.length < 3) {
  setError(el, err, "Name must be at least 3 characters");
  return false;
}

if (val.length > 30) {
  setError(el, err, "Name cannot exceed 100 characters");
  return false;
}
      setSuccess(el, err); return true;
    }

    function validateCategory(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-category" : "editCategoryId");
      const err = prefix + "-category-error";
      if (!el.value) { setError(el, err, "Please select a category"); return false; }
      setSuccess(el, err); return true;
    }

    function validateDescription(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-description" : "editDescription");
      const val = el.value.trim();
      const err = prefix + "-description-error";
      if (!val)            { setError(el, err, "Description is required");                      return false; }
      if (!/^[A-Za-z]/.test(val)) {

  setError(el, err, "Must start with a letter");

  return false;

}
      if (val.length < 10) { setError(el, err, "Description must be at least 10 characters");  return false; }
      if (val.length > 1000) { setError(el, err, "Description is too long");  return false; }
      setSuccess(el, err); return true;
    }

    function validatePrice(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-price" : "editPrice");
      const err = prefix + "-price-error";
      if (!el.value)                               { setError(el, err, "Price is required");                return false; }
      if (isNaN(parseFloat(el.value)) || +el.value <= 0) { setError(el, err, "Enter a valid price");       return false; }
      if (+el.value > 10000000)                    { setError(el, err, "Price seems too high");             return false; }
      setSuccess(el, err); return true;
    }

    function validateComparePrice(prefix) {
      const priceEl   = document.getElementById(prefix === "add" ? "add-price"         : "editPrice");
      const compareEl = document.getElementById(prefix === "add" ? "add-compare-price" : "editComparePrice");
      const err       = prefix + "-compare-price-error";
      if (!compareEl.value) { setSuccess(compareEl, err); return true; } /* optional */
      const p = parseFloat(priceEl.value);
      const c = parseFloat(compareEl.value);
      if (isNaN(c) || c <= 0) { setError(compareEl, err, "Enter a valid compare price"); return false; }
      if (c <= p)              { setError(compareEl, err, "Compare price must be higher than the selling price"); return false; }
      setSuccess(compareEl, err); return true;
    }

    function validateStock(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-stock" : "editStock");
      const err = prefix + "-stock-error";
      if (el.value === "" || el.value === null) { setError(el, err, "Stock is required");           return false; }
      const n = parseInt(el.value);
      if (isNaN(n) || n < 0)  { setError(el, err, "Stock cannot be negative");                     return false; }
      if (n > 100000)          { setError(el, err, "Stock value seems too high");                   return false; }
      setSuccess(el, err); return true;
    }

    function validateSKU(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-sku" : "editSKU");
      const val = el.value.trim();
      const err = prefix + "-sku-error";
      if (!val)            { setError(el, err, "SKU is required");                                           return false; }
      if (val.length < 3)  { setError(el, err, "SKU must be at least 3 characters");                        return false; }
      if (!/^[A-Za-z]/.test(val)) {

  setError(el, err, "Must start with a letter");

  return false;

}
      if (val.length > 40) { setError(el, err, "SKU cannot exceed 40 characters");                          return false; }
      if (!/^[A-Za-z0-9\-_]+$/.test(val)) { setError(el, err, "SKU can only contain letters, numbers, - and _"); return false; }
      setSuccess(el, err); return true;
    }

    function validateStorage(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-storage" : "editStorage");
      const val = el.value.trim();
      const err = prefix + "-storage-error";
      if (!val)                         { setError(el, err, "Storage is required");       return false; }
      if (!/^\d+(GB|TB)$/i.test(val))   { setError(el, err, "e.g. 256GB or 1TB");        return false; }
      setSuccess(el, err); return true;
    }

    function validateRAM(prefix) {
      const el  = document.getElementById(prefix === "add" ? "add-ram" : "editRAM");
      const val = el.value.trim();
      const err = prefix + "-ram-error";
      if (!val)                       { setError(el, err, "RAM is required");        return false; }
      if (!/^\d+GB$/i.test(val))      { setError(el, err, "e.g. 8GB or 16GB");      return false; }
      setSuccess(el, err); return true;
    }

function validateColor(prefix) {
  const el  = document.getElementById(prefix === "add" ? "add-color" : "editColor");
  const val = el.value.trim();
  const err = prefix + "-color-error";

  if (!val) {
    setError(el, err, "Color is required");
    return false;
  }

  if (val.length < 2) {
    setError(el, err, "Enter a valid color name");
    return false;
  }

  if (val.length > 30) {
    setError(el, err, "Color name is too long");
    return false;
  }

  // Allow only letters and spaces
  if (!/^[A-Za-z ]+$/.test(val)) {
    setError(el, err, "Only letters and spaces are allowed");
    return false;
  }

  setSuccess(el, err);
  return true;
}

    function validateThumbnail(prefix, fileInput) {
      const err  = prefix + "-thumbnail-error";
      const slot = document.getElementById(prefix === "add" ? "add-thumbnail-slot" : null);
      const s    = document.getElementById(err);

      if (!fileInput.files || !fileInput.files[0]) {
        /* Edit mode: thumbnail already exists, so skip */
        if (prefix === "edit") { if (s) { s.textContent = ""; s.classList.remove("visible"); } return true; }
        if (slot) slot.classList.add("input-error");
        if (s)    { s.textContent = "Please upload a product thumbnail"; s.classList.add("visible"); }
        return false;
      }
      const file    = fileInput.files[0];
      const allowed = ["image/jpeg","image/png","image/jpg","image/webp"];
      if (!allowed.includes(file.type)) {
        if (s) { s.textContent = "Only JPG, PNG or WEBP allowed"; s.classList.add("visible"); }
        return false;
      }
      if (file.size > 5 * 1024 * 1024) {
        if (s) { s.textContent = "Image must be under 5MB"; s.classList.add("visible"); }
        return false;
      }
      if (slot) slot.classList.remove("input-error");
      if (s)    { s.textContent = ""; s.classList.remove("visible"); }
      return true;
    }

    function validateVariantImages(fileInput) {
      const s = document.getElementById("add-variant-images-error");
      if (!fileInput.files || fileInput.files.length < 3) {
        if (s) { s.textContent = "Please upload at least 3 variant images"; s.classList.add("visible"); }
        return false;
      }
      if (s) { s.textContent = ""; s.classList.remove("visible"); }
      return true;
    }

    /* ---- clear all errors when modal opens ---- */

    function clearAllErrors(prefix) {
      const suffixes = [
        "name","category","description","price","compare-price",
        "stock","sku","storage","ram","color","thumbnail"
      ];
      suffixes.forEach(s => {
        const errSpan = document.getElementById(`${prefix}-${s}-error`);
        if (errSpan) { errSpan.textContent = ""; errSpan.classList.remove("visible"); }
      });
      /* clear input states */
      document.querySelectorAll(`#${prefix === "add" ? "addProductForm" : "editProductForm"} .input-error, 
                                  #${prefix === "add" ? "addProductForm" : "editProductForm"} .input-success`)
        .forEach(el => el.classList.remove("input-error","input-success"));
    }

    /* ---- real-time: validate on blur, clear error while fixing ---- */

    function attachBlur(inputId, validator) {
      const el = document.getElementById(inputId);
      if (!el) return;
      el.addEventListener("blur", validator);
      el.addEventListener("input", function () {
        if (this.classList.contains("input-error")) validator();
      });
    }

    /* ADD form */
    attachBlur("add-name",          () => validateName("add"));
    attachBlur("add-category",      () => validateCategory("add"));
    attachBlur("add-description",   () => validateDescription("add"));
    attachBlur("add-price",         () => { validatePrice("add"); validateComparePrice("add"); });
    attachBlur("add-compare-price", () => validateComparePrice("add"));
    attachBlur("add-stock",         () => validateStock("add"));
    attachBlur("add-sku",           () => validateSKU("add"));
    attachBlur("add-storage",       () => validateStorage("add"));
    attachBlur("add-ram",           () => validateRAM("add"));
    attachBlur("add-color",         () => validateColor("add"));

    /* EDIT form */
    attachBlur("editName",         () => validateName("edit"));
    attachBlur("editCategoryId",   () => validateCategory("edit"));
    attachBlur("editDescription",  () => validateDescription("edit"));
    attachBlur("editPrice",        () => { validatePrice("edit"); validateComparePrice("edit"); });
    attachBlur("editComparePrice", () => validateComparePrice("edit"));
    attachBlur("editStock",        () => validateStock("edit"));
    attachBlur("editSKU",          () => validateSKU("edit"));
    attachBlur("editStorage",      () => validateStorage("edit"));
    attachBlur("editRAM",          () => validateRAM("edit"));
    attachBlur("editColor",        () => validateColor("edit"));

    /* ================================================
       CROPPER GLOBALS
    ================================================ */
    const ALLOWED_IMG_TYPES = ["image/jpeg", "image/jpg", "image/png", "image/webp"];
    const MAX_IMG_SIZE = 5 * 1024 * 1024;

    const cropOverlay   = document.getElementById("cropOverlay");
    const cropTargetImg = document.getElementById("cropTargetImg");
    const cropApplyBtn  = document.getElementById("cropApplyBtn");
    const cropCancelBtn = document.getElementById("cropCancelBtn");
    const cropCloseBtn  = document.getElementById("cropCloseBtn");

    let activeCropper  = null;
    let cropCallback   = null;

    function openCropDialog(imageSrc, callback, aspectRatio = 4/5) {
      cropCallback = callback;
      cropTargetImg.src = imageSrc;
      cropOverlay.classList.add("open");

      cropTargetImg.onload = function () {
        if (activeCropper) activeCropper.destroy();
        activeCropper = new Cropper(cropTargetImg, {
          aspectRatio: aspectRatio,
          viewMode: 1,
          dragMode: "move",
          autoCropArea: 0.85,
          cropBoxResizable: true,
          cropBoxMovable: true,
          background: false,
          responsive: true,
          guides: false,
          center: true,
          highlight: false,
        });
      };
    }

    function closeCropDialog() {
      cropOverlay.classList.remove("open");
      if (activeCropper) { activeCropper.destroy(); activeCropper = null; }
      cropCallback = null;
    }

    cropApplyBtn.addEventListener("click", () => {
      if (!activeCropper || !cropCallback) return;
      const canvas = activeCropper.getCroppedCanvas({
        width: 1200,
        height: 1200,
        imageSmoothingEnabled: true,
        imageSmoothingQuality: "high",
      });
      const dataUrl = canvas.toDataURL("image/jpeg", 0.92);
      canvas.toBlob(blob => {
        cropCallback(dataUrl, blob);
      }, "image/jpeg", 0.92);
    });

    cropCancelBtn.addEventListener("click", closeCropDialog);
    cropCloseBtn.addEventListener("click", closeCropDialog);

    function validateImage(file, errId, slotId) {
      const s = document.getElementById(errId);
      const slot = document.getElementById(slotId);
      if (!file) return false;
      if (!ALLOWED_IMG_TYPES.includes(file.type)) {
        if (s) { s.textContent = "Only JPG, PNG or WebP allowed"; s.classList.add("visible"); }
        if (slot) slot.classList.add("input-error");
        return false;
      }
      if (file.size > MAX_IMG_SIZE) {
        if (s) { s.textContent = "File exceeds 5MB limit"; s.classList.add("visible"); }
        if (slot) slot.classList.add("input-error");
        return false;
      }
      if (s) { s.textContent = ""; s.classList.remove("visible"); }
      if (slot) slot.classList.remove("input-error");
      return true;
    }

    /* ================================================
       ADD PRODUCT — IMAGE PREVIEWS
    ================================================ */

    const addThumbnailInput   = document.getElementById("addThumbnailInput");
    const addThumbnailPreview = document.getElementById("addThumbnailPreview");
    const addPreviewImage     = document.getElementById("addPreviewImage");
    let addThumbnailBlob      = null;

    addThumbnailInput.addEventListener("change", function () {
      const file = this.files[0];
      if (!file || !validateImage(file, "add-thumbnail-error", "add-thumbnail-slot")) {
        this.value = ""; return;
      }
      const reader = new FileReader();
      reader.onload = e => {
        openCropDialog(e.target.result, (dataUrl, blob) => {
          addPreviewImage.src = dataUrl;
          addThumbnailPreview.style.display = "block";
          addThumbnailBlob = blob;
          closeCropDialog();
        }, 1); /* 1:1 for product thumbnail */
      };
      reader.readAsDataURL(file);
    });

    document.getElementById("addRemoveImageBtn").addEventListener("click", () => {
      addThumbnailInput.value = "";
      addPreviewImage.src     = "";
      addThumbnailPreview.style.display = "none";
      addThumbnailBlob = null;
    });

    const addVariantImages      = document.getElementById("addVariantImages");
    const addVariantPreviewGrid = document.getElementById("addVariantPreviewGrid");
    let addVariantBlobs         = [];
    let pendingVariantFiles     = [];

    addVariantImages.addEventListener("change", function () {
      pendingVariantFiles = Array.from(this.files);
      if (!pendingVariantFiles.length) return;
      
      const s = document.getElementById("add-variant-images-error");
      const slot = document.getElementById("add-variant-images-slot"); // Might not exist, but safe
      
      if (pendingVariantFiles.length > 10) {
        if (s) { s.textContent = "Maximum of 10 variant images allowed"; s.classList.add("visible"); }
        this.value = ""; return;
      }
      
      let valid = true;

      for (let f of pendingVariantFiles) {
        if (!ALLOWED_IMG_TYPES.includes(f.type) || f.size > MAX_IMG_SIZE) {
          if (s) { s.textContent = "Invalid type or size > 5MB"; s.classList.add("visible"); }
          valid = false; break;
        }
      }

      if (!valid) { this.value = ""; return; }
      if (s) { s.textContent = ""; s.classList.remove("visible"); }
      
      addVariantBlobs = [];
      addVariantPreviewGrid.innerHTML = "";
      processNextVariantImage();
    });

    function processNextVariantImage() {
      if (!pendingVariantFiles.length) {
        /* done cropping all */
        const s = document.getElementById("add-variant-images-error");
        if (s && addVariantBlobs.length >= 3) { s.textContent = ""; s.classList.remove("visible"); }
        return;
      }
      const file = pendingVariantFiles[0];
      const reader = new FileReader();
      reader.onload = e => {
        openCropDialog(e.target.result, (dataUrl, blob) => {
          addVariantPreviewGrid.innerHTML += `<div class="variant-preview-item"><img src="${dataUrl}" alt="Variant"></div>`;
          addVariantBlobs.push(blob);
          closeCropDialog();
          pendingVariantFiles.shift();
          processNextVariantImage();
        }, 4/5); /* 4:5 for variant images */
      };
      reader.readAsDataURL(file);
    }

    /* ================================================
       ADD PRODUCT — SUBMIT
    ================================================ */

    document.getElementById("addProductForm").addEventListener("submit", async (e) => {
      e.preventDefault();

      /* Run all validators */
      const nameOk         = validateName("add");
      const categoryOk     = validateCategory("add");
      const descriptionOk  = validateDescription("add");
      const priceOk        = validatePrice("add");
      const comparePriceOk = validateComparePrice("add");
      const stockOk        = validateStock("add");
      const skuOk          = validateSKU("add");
      const storageOk      = validateStorage("add");
      const ramOk          = validateRAM("add");
      const colorOk        = validateColor("add");
      
      const thumbErr = document.getElementById("add-thumbnail-error");
      const thumbSlot = document.getElementById("add-thumbnail-slot");
      let thumbnailOk = true;
      if (!addThumbnailBlob) {
        if (thumbErr) { thumbErr.textContent = "Product thumbnail is required"; thumbErr.classList.add("visible"); }
        if (thumbSlot) thumbSlot.classList.add("input-error");
        thumbnailOk = false;
      }

      const varErr = document.getElementById("add-variant-images-error");
      let variantImgOk = true;
      if (addVariantBlobs.length < 3) {
        if (varErr) { varErr.textContent = "Please upload at least 3 variant images"; varErr.classList.add("visible"); }
        variantImgOk = false;
      } else if (addVariantBlobs.length > 10) {
        if (varErr) { varErr.textContent = "Maximum of 10 variant images allowed"; varErr.classList.add("visible"); }
        variantImgOk = false;
      }

      if (!nameOk || !categoryOk || !descriptionOk || !priceOk || !comparePriceOk ||
          !stockOk || !skuOk || !storageOk || !ramOk || !colorOk || !thumbnailOk || !variantImgOk) {
        const firstError = document.querySelector("#addProductForm .input-error, #addProductForm .upload-slot.input-error, #addProductForm .field-error.visible");
        if (firstError) firstError.scrollIntoView({ behavior: "smooth", block: "center" });
        return;
      }

      const errorBox  = document.getElementById("addProductError");
      const submitBtn = document.getElementById("addProductSubmitBtn");
      errorBox.style.display = "none";
      submitBtn.disabled     = true;
      submitBtn.textContent  = "Saving...";

      try {
        const formData = new FormData(e.target);
        
        // Remove raw files and inject cropped blobs
        formData.delete("thumbnail");
        formData.delete("variantImages");
        
        formData.append("thumbnail", addThumbnailBlob, "thumbnail.jpg");
        addVariantBlobs.forEach((blob, index) => {
          formData.append("variantImages", blob, `variant-${index}.jpg`);
        });

        const response = await fetch("/admin/products/add", {
          method: "POST",
          body: formData,
        });
        const data = await response.json();
        if (!data.success) {
          errorBox.textContent = data.message || "Failed to add product";
          errorBox.style.display = "block";
          submitBtn.disabled = false;
          submitBtn.textContent = "Save Product";
          return;
        }
        closeModal(addModal);
        await Swal.fire({ toast: true, position: "top", icon: "success",
          title: "Product added successfully", showConfirmButton: false, timer: 2000, timerProgressBar: true });
        window.location.reload();
      } catch {
        errorBox.textContent   = "Something went wrong. Please try again.";
        errorBox.style.display = "block";
        submitBtn.disabled    = false;
        submitBtn.textContent = "Save Product";
      }
    });

    /* ================================================
       EDIT PRODUCT — OPEN + POPULATE
    ================================================ */

    document.addEventListener("click", async (e) => {
      const btn = e.target.closest(".edit-btn");
      if (!btn) return;

      const productId = btn.dataset.id;
      try {
        const response = await fetch(`/admin/products/${productId}/json`);
        const data     = await response.json();
        if (!data.success) { Swal.fire({ icon: "error", title: "Failed to load product" }); return; }

        const product = data.product;
        const variant = data.variant || {};

        document.getElementById("editProductId").value    = product._id;
        document.getElementById("editVariantId").value    = variant._id || "";
        document.getElementById("editName").value         = product.name || "";
        document.getElementById("editCategoryId").value   = product.categoryId?._id || product.categoryId || "";
        document.getElementById("editIsActive").value     = String(product.isActive);
        document.getElementById("editDescription").value  = product.description || "";
        document.getElementById("editPreviewImage").src   = product.thumbnail || "/images/default-product.png";
        document.getElementById("editThumbnailInput").value = "";
        editThumbnailBlob = null;
        document.getElementById("editPrice").value        = variant.price || "";
        document.getElementById("editComparePrice").value = variant.comparePrice || "";
        document.getElementById("editStock").value        = variant.stock || "";
        document.getElementById("editSKU").value          = variant.SKU || "";
        document.getElementById("editStorage").value      = variant.storage || "";
        document.getElementById("editRAM").value          = variant.RAM || "";
        document.getElementById("editColor").value        = variant.color || "";
        document.getElementById("editIsFeatured").checked  = !!product.isFeatured;
        document.getElementById("editIsBestSeller").checked = !!product.isBestSeller;
        document.getElementById("editIsDeal").checked      = !!product.isDeal;

        document.getElementById("editProductError").style.display = "none";
        clearAllErrors("edit");
        openModal(editModal);
        lucide.createIcons();
      } catch {
        Swal.fire({ icon: "error", title: "Failed to load product" });
      }
    });

    let editThumbnailBlob = null;
    document.getElementById("editThumbnailInput").addEventListener("change", function () {
      const file = this.files[0];
      if (!file || !validateImage(file, null, null)) {
        this.value = ""; return;
      }
      const reader = new FileReader();
      reader.onload = e => {
        openCropDialog(e.target.result, (dataUrl, blob) => {
          document.getElementById("editPreviewImage").src = dataUrl;
          editThumbnailBlob = blob;
          closeCropDialog();
        }, 1);
      };
      reader.readAsDataURL(file);
    });

    /* ================================================
       EDIT PRODUCT — SUBMIT
    ================================================ */

    document.getElementById("editProductForm").addEventListener("submit", async (e) => {
      e.preventDefault();

      const nameOk         = validateName("edit");
      const categoryOk     = validateCategory("edit");
      const descriptionOk  = validateDescription("edit");
      const priceOk        = validatePrice("edit");
      const comparePriceOk = validateComparePrice("edit");
      const stockOk        = validateStock("edit");
      const skuOk          = validateSKU("edit");
      const storageOk      = validateStorage("edit");
      const ramOk          = validateRAM("edit");
      const colorOk        = validateColor("edit");
      // thumbnail is optional on edit
      const thumbnailOk    = true; 

      if (!nameOk || !categoryOk || !descriptionOk || !priceOk || !comparePriceOk ||
          !stockOk || !skuOk || !storageOk || !ramOk || !colorOk) {
        const firstError = document.querySelector("#editProductForm .input-error, #editProductForm .field-error.visible");
        if (firstError) firstError.scrollIntoView({ behavior: "smooth", block: "center" });
        return;
      }

      const productId = document.getElementById("editProductId").value;
      const errorBox  = document.getElementById("editProductError");
      const submitBtn = document.getElementById("editProductSubmitBtn");
      errorBox.style.display = "none";
      submitBtn.disabled     = true;
      submitBtn.textContent  = "Updating...";

      try {
        const formData = new FormData(e.target);
        
        if (editThumbnailBlob) {
          formData.delete("thumbnail");
          formData.append("thumbnail", editThumbnailBlob, "thumbnail-edit.jpg");
        }

        const response = await fetch(`/admin/products/edit/${productId}`, {
          method: "POST",
          body: formData,
        });
        const data = await response.json();
        if (!data.success) {
          errorBox.textContent   = data.message || "Failed to update product";
          errorBox.style.display = "block";
          submitBtn.disabled = false;
          submitBtn.textContent = "Update Product";
          return;
        }
        closeModal(editModal);
        await Swal.fire({ toast: true, position: "top", icon: "success",
          title: "Product updated successfully", showConfirmButton: false, timer: 2000, timerProgressBar: true });
        window.location.reload();
      } catch {
        errorBox.textContent   = "Something went wrong. Please try again.";
        errorBox.style.display = "block";
        submitBtn.disabled    = false;
        submitBtn.textContent = "Update Product";
      }
    });

    /* ================================================
       DELETE / RESTORE / PERMANENT DELETE
    ================================================ */

    document.addEventListener("click", async (e) => {
      const btn = e.target.closest(".delete-btn");
      if (!btn) return;
      const result = await Swal.fire({
        title: "Delete Product?", text: "This product will be hidden from the store.",
        icon: "warning", showCancelButton: true,
        confirmButtonColor: "#603763", cancelButtonColor: "#E5E7EB", confirmButtonText: "Delete"
      });
      if (!result.isConfirmed) return;
      const originalHTML = btn.innerHTML;
      try {
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader-circle" class="spin"></i>';
        if (typeof lucide !== 'undefined') lucide.createIcons();
        const res  = await fetch(`/admin/delete-product/${btn.dataset.id}`, { method: "PATCH" });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ icon: "success", title: "Deleted Successfully", timer: 1200, showConfirmButton: false });
          window.location.reload();
        } else throw new Error();
      } catch { 
        btn.disabled = false; 
        btn.innerHTML = originalHTML;
        if (typeof lucide !== 'undefined') lucide.createIcons();
        Swal.fire({ icon: "error", title: "Failed to delete product" }); 
      }
    });

    document.addEventListener("click", async (e) => {
      const btn = e.target.closest(".restore-btn");
      if (!btn) return;
      const originalHTML = btn.innerHTML;
      try {
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader-circle" class="spin"></i>';
        if (typeof lucide !== 'undefined') lucide.createIcons();
        const res  = await fetch(`/admin/restore-product/${btn.dataset.id}`, { method: "PATCH" });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ icon: "success", title: "Product restored", timer: 1200, showConfirmButton: false });
          window.location.reload();
        }
      } catch { 
        btn.disabled = false; 
        btn.innerHTML = originalHTML;
        if (typeof lucide !== 'undefined') lucide.createIcons();
        Swal.fire({ icon: "error", title: "Restore failed" }); 
      }
    });

    document.addEventListener("click", async (e) => {
      const btn = e.target.closest(".permanent-delete-btn");
      if (!btn) return;
      const result = await Swal.fire({
        title: "Delete Permanently?", text: "This action cannot be undone.",
        icon: "warning", showCancelButton: true,
        confirmButtonColor: "#BA1A1A", confirmButtonText: "Delete Forever"
      });
      if (!result.isConfirmed) return;
      const originalHTML = btn.innerHTML;
      try {
        btn.disabled = true;
        btn.innerHTML = '<i data-lucide="loader-circle" class="spin"></i>';
        if (typeof lucide !== 'undefined') lucide.createIcons();
        const res  = await fetch(`/admin/permanent-delete-product/${btn.dataset.id}`, { method: "DELETE" });
        const data = await res.json();
        if (data.success) {
          await Swal.fire({ icon: "success", title: "Product permanently deleted", timer: 1200, showConfirmButton: false });
          window.location.reload();
        }
      } catch { 
        btn.disabled = false; 
        btn.innerHTML = originalHTML;
        if (typeof lucide !== 'undefined') lucide.createIcons();
        Swal.fire({ icon: "error", title: "Delete failed" }); 
      }
    });

  </script>

</body>
