<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Forgot Password - Admin | iStore</title>

<link rel="stylesheet" href="/css/admin-forgot-password.css">

<link rel="stylesheet"
href="/css/sweetalert-theme.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<script src="https://unpkg.com/lucide@latest"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

<div class="admin-forgot-container">

<!-- LEFT PANEL -->

<aside class="branding-panel">

<div class="decor-shape shape-1"></div>
<div class="decor-shape shape-2"></div>

<div class="branding-content">

<div class="admin-logo-box">

<i data-lucide="rotate-ccw" size="40"></i>

</div>

<h1 class="branding-title">
iStore Admin
</h1>

<p class="branding-subtitle">
Password Recovery Portal
</p>

<div class="progress-indicator">

<div class="progress-bar active"></div>
<div class="progress-bar inactive"></div>
<div class="progress-bar inactive"></div>

</div>

</div>

<div class="branding-footer">

<span>
SYSTEM SECURITY PROTOCOL V4.2
</span>

<span>
TIER 1 AUTHENTICATION
</span>

</div>

</aside>

<!-- RIGHT PANEL -->

<main class="recovery-panel">

<div class="recovery-wrapper">

<div class="recovery-card">

<div class="recovery-header">

<h2>Forgot Password</h2>

<p>
Enter your admin email to receive OTP
</p>

</div>

<form
id="adminForgotForm"
class="recovery-form">

<div class="form-group">

<label class="form-label">

Admin Email Address

</label>

<div class="input-wrapper">

<i data-lucide="mail"></i>

<input
type="email"
name="email"
id="email"
class="admin-input"
placeholder="Enter your registered email"
required>

</div>

</div>

<button
type="submit"
class="submit-btn">

<span>
Send OTP
</span>

<i data-lucide="arrow-right" size="16"></i>

</button>

<a
href="/admin/login"
class="back-to-login">

<i data-lucide="chevron-left" size="16"></i>

<span>
Back to Login
</span>

</a>

</form>

<div class="card-footer">

<p class="copyright">

© 2026 iStore Admin.

All rights reserved.

</p>

</div>

</div>

</div>

</main>

</div>

<script>

/* Icons */

lucide.createIcons()



/* ============================
   SEND OTP REQUEST
============================ */

const form =
document.getElementById("adminForgotForm")

form.addEventListener(

"submit",

async (e) => {

e.preventDefault()

const email =
document.getElementById("email").value.trim()

try {

/* Loading */

Swal.fire({

title: "Sending OTP...",

allowOutsideClick: false,

didOpen: () => {

Swal.showLoading()

}

})

const response =
await axios.post(

"/admin/send-otp",

{ email }

)

if (response.data.success) {

Swal.fire({

icon: "success",

title: "OTP Sent",

text: "Check admin email",

timer: 1500,

showConfirmButton: false

})

setTimeout(() => {

window.location.href =
"/admin/verify-otp"

}, 1500)

}

}

catch (error) {

Swal.fire({

icon: "error",

title: "Failed",

text:

error.response?.data?.message
|| "Email not found"

})

}

}

)



/* Animations */

gsap.from(".branding-content > *", {

y: 30,
opacity: 0,
duration: 0.8,
stagger: 0.2,
ease: "power2.out"

})

gsap.from(".recovery-card", {

x: 50,
opacity: 0,
duration: 1,
ease: "power3.out",
delay: 0.3

})

</script>

</body>
</html>