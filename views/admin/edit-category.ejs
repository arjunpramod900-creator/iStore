<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Category - Admin | iStore</title>

   <link rel="stylesheet" href="/css/components/admin-sidebar.css">
<link rel="stylesheet" href="/css/admin-dashboard.css">
<link rel="stylesheet" href="/css/admin-edit-category.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <script src="https://unpkg.com/lucide@latest"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

 <!-- Sidebar Navbar -->
   <%- include('../partials/admin/sidebar') %>

<main class="main-content">

   <!-- Breadcrumbs & Header -->
<header class="page-header">

    <div class="header-left">

        <nav class="breadcrumb">

            <a href="/admin/dashboard">
            DASHBOARD
            </a>

            <i data-lucide="chevron-right" size="12"></i>

            <a href="/admin/categories">
            CATEGORIES
            </a>

            <i data-lucide="chevron-right" size="12"></i>

            <span class="current">
            EDIT CATEGORY
            </span>

        </nav>

        <h1 class="page-title">
        Edit Category
        </h1>

    </div>

</header>

    <form
    action="/admin/edit-category/<%= category._id %>"
    method="POST"
    enctype="multipart/form-data"
    id="editCategoryForm">

        <div class="content-grid">

            <!-- LEFT COLUMN -->
            <div class="left-column">

                <section class="card">

                    <div class="card-header">

                        <h2 class="card-title">
                        Category Details
                        </h2>

                        <i
                        data-lucide="folder"
                        class="card-icon"
                        size="20">
                        </i>

                    </div>

                    <!-- CATEGORY NAME -->

                    <div class="form-group">

                        <label class="form-label">
                        CATEGORY NAME
                        </label>

                        <input
                        type="text"
                        class="form-input"
                        name="name"
                        maxlength="40"
                        value="<%= category.name %>"
                        required>

                    </div>

                    <!-- SLUG -->

                    <div class="form-group">

                        <label class="form-label">
                        CATEGORY SLUG
                        </label>

                        <input
                        type="text"
                        class="form-input"
                        value="<%= category.slug %>"
                        readonly>

                    </div>

                    <!-- DESCRIPTION -->

                    <div class="form-group">

                        <label class="form-label">
                        DESCRIPTION
                        </label>

                        <textarea
                        class="form-textarea"
                        name="description"
                        maxlength="200"
                        placeholder="Describe this category..."><%= category.description || "" %></textarea>

                    </div>

                </section>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="right-column">

                <!-- IMAGE CARD -->

                <section class="card visual-card">

                    <div class="card-header">

                        <h2 class="card-title">
                        Category Image
                        </h2>

                    </div>

                    <div class="image-container">

                        <img
                        src="<%= category.image %>"
                        alt="<%= category.name %>"
                        class="image-preview"
                        id="previewImage">

                        <div class="image-overlay">

                            <button
                            type="button"
                            class="btn-upload-round"
                            id="uploadBtn">

                                <i
                                data-lucide="camera"
                                size="20">
                                </i>

                            </button>

                        </div>

                    </div>

                    <input
                    type="file"
                    name="image"
                    id="imageInput"
                    hidden
                    accept="image/*">

                    <div class="visual-actions">

                        <button
                        type="button"
                        class="btn-primary-action"
                        id="replaceBtn">

                            <i
                            data-lucide="edit-2"
                            size="16">
                            </i>

                            Replace Image

                        </button>

                        <div class="btn-secondary-group">

                            <button
                            type="button"
                            class="btn-secondary-action"
                            id="removeBtn">

                                Remove

                            </button>

                        </div>

                    </div>

                </section>

                <!-- STATUS -->

                <section class="card">

                    <div class="status-row">

                        <div class="status-label-group">

                            <span class="status-name">
                            VISIBILITY
                            </span>

                            <div class="status-indicator">

                                <div class="dot"></div>

                                <span>
                                <%= category.isActive ? "Active" : "Inactive" %>
                                </span>

                            </div>

                        </div>

                       <div
                        class="toggle-switch <%= category.isActive ? 'active' : '' %>"
                        id="statusToggle">

                            <div class="toggle-handle"></div>

                        </div>

                    </div>

                    <input
                    type="hidden"
                    name="isActive"
                    id="isActiveInput"
                    value="<%= category.isActive %>">

                </section>

            </div>

        </div>

        <!-- ACTIONS -->

        <div class="end-actions">

            <a
            href="/admin/categories"
            class="btn-link">

            Cancel

            </a>

            <button
            type="submit"
            class="btn-update">

            Update Category

            </button>

        </div>

    </form>

</main>

<script>

lucide.createIcons()

/* =========================
   TOGGLE
========================= */

/* STATUS TOGGLE*/

const toggle =
document.getElementById("statusToggle")

const handle =
toggle.querySelector(".toggle-handle")

const statusInput =
document.getElementById("isActiveInput")

let isActive =
statusInput.value === "true"



/* INITIAL UI */

if (isActive) {

toggle.style.background =
"#603763"

handle.style.right = "2px"
handle.style.left = "auto"

}

else {

toggle.style.background =
"#D1D5DB"

handle.style.left = "2px"
handle.style.right = "auto"

}



/* TOGGLE CLICK */

toggle.addEventListener("click", () => {

isActive = !isActive

statusInput.value = isActive

if (isActive) {

toggle.style.background =
"#603763"

handle.style.right = "2px"
handle.style.left = "auto"

}

else {

toggle.style.background =
"#D1D5DB"

handle.style.left = "2px"
handle.style.right = "auto"

}

})



/* =========================
   IMAGE PREVIEW
========================= */

const imageInput =
document.getElementById("imageInput")

const previewImage =
document.getElementById("previewImage")

document
.getElementById("replaceBtn")
.addEventListener("click", () => {

imageInput.click()

})

document
.getElementById("uploadBtn")
.addEventListener("click", () => {

imageInput.click()

})

imageInput.addEventListener("change", function () {

const file = this.files[0]

if (!file) return

const reader =
new FileReader()

reader.onload = function (e) {

previewImage.src =
e.target.result

}

reader.readAsDataURL(file)

})



/* =========================
   REMOVE IMAGE
========================= */

document
.getElementById("removeBtn")
.addEventListener("click", () => {

previewImage.src = ""

imageInput.value = ""

})



/* =========================
   FORM VALIDATION
========================= */

const form =
document.getElementById(
"editCategoryForm"
)

form.addEventListener(

"submit",

function (e) {

const name =
document.querySelector(
'input[name="name"]'
)

const trimmedName =
name.value.trim()

if (

trimmedName.length < 3 ||

trimmedName.length > 40

) {

e.preventDefault()

Swal.fire({

icon: "error",

title: "Validation Error",

text:
"Category name must be between 3 and 40 characters"

})

return

}

}

)

</script>

</body>
</html>