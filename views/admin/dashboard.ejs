<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Admin | iStore</title>
  <link rel="stylesheet" href="/css/components/admin-sidebar.css?v=1.2">
  <link rel="stylesheet" href="/css/admin-dashboard.css?v=1.2">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/sweetalert-theme.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

  <%- include('../partials/admin/sidebar') %>

  <%
    const d              = dashboardData || {};
    const chartLabels    = d.chartLabels    || [];
    const chartData      = d.chartData      || [];
    const grossChartData = d.grossChartData || [];
    const netChartData   = d.netChartData   || [];
    const chartTitle     = d.chartTitle     || "Revenue Trends";
    const rangeLabel     = d.rangeLabel     || "";

    /* status badge helper */
    function statusClass(s) {
      const m = {
        delivered:        "badge-delivered",
        processing:       "badge-processing",
        pending:          "badge-pending",
        cancelled:        "badge-cancelled",
        returned:         "badge-returned",
        shipped:          "badge-shipped",
        "out for delivery": "badge-shipped",
      };
      return m[(s||"").toLowerCase()] || "badge-pending";
    }
  %>

  <main class="dashboard-main">

    <!-- ── HEADER ── -->
    <header class="dashboard-header">
      <div class="header-title">
        <span class="subtitle">OVERVIEW</span>
        <h1>Dashboard</h1>
        <p class="range-label"><%= rangeLabel %></p>
      </div>
    </header>

    <!-- ── KPI GRID ── -->
    <section class="kpi-grid">

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon revenue"><i data-lucide="banknote" size="20"></i></div>
          <span class="kpi-chip kpi-chip-purple">Revenue</span>
        </div>
        <div class="kpi-info">
          <span class="kpi-label">TOTAL REVENUE</span>
          <span class="kpi-value">₹<%= (d.totalRevenue || 0).toLocaleString("en-IN") %></span>
          <span class="kpi-sub">Delivered orders</span>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon orders"><i data-lucide="shopping-bag" size="20"></i></div>
          <span class="kpi-chip kpi-chip-blue">Orders</span>
        </div>
        <div class="kpi-info">
          <span class="kpi-label">TOTAL ORDERS</span>
          <span class="kpi-value"><%= (d.totalOrders || 0).toLocaleString("en-IN") %></span>
          <span class="kpi-sub">All statuses in range</span>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon customers"><i data-lucide="users" size="20"></i></div>
          <span class="kpi-chip kpi-chip-green">Customers</span>
        </div>
        <div class="kpi-info">
          <span class="kpi-label">TOTAL CUSTOMERS</span>
          <span class="kpi-value"><%= (d.totalCustomers || 0).toLocaleString("en-IN") %></span>
          <span class="kpi-sub">Active users</span>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon products"><i data-lucide="package" size="20"></i></div>
          <span class="kpi-chip kpi-chip-gray">Products</span>
        </div>
        <div class="kpi-info">
          <span class="kpi-label">TOTAL PRODUCTS</span>
          <span class="kpi-value"><%= (d.totalProducts || 0).toLocaleString("en-IN") %></span>
          <span class="kpi-sub">In inventory</span>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon returns"><i data-lucide="corner-down-left" size="20"></i></div>
          <span class="kpi-chip kpi-chip-red">Returns</span>
        </div>
        <div class="kpi-info">
          <span class="kpi-label">TOTAL RETURNS</span>
          <span class="kpi-value"><%= (d.totalReturns || 0).toLocaleString("en-IN") %></span>
          <span class="kpi-sub"><%= d.returnRate || 0 %>% return rate</span>
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon pending"><i data-lucide="clock" size="20"></i></div>
          <span class="kpi-chip kpi-chip-orange">Pending</span>
        </div>
        <div class="kpi-info">
          <span class="kpi-label">PENDING ORDERS</span>
          <span class="kpi-value"><%= (d.totalPending || 0).toLocaleString("en-IN") %></span>
          <span class="kpi-sub">Awaiting processing</span>
        </div>
      </div>

    </section>

    <!-- ── CHART ── -->
    <section class="chart-section">
      <div class="chart-header">
        <div class="chart-title">
          <h2><%= chartTitle %></h2>
          <p class="chart-subtitle"><%= rangeLabel %></p>
        </div>

        <!-- Filter tabs moved here from the page header -->
        <nav class="chart-filter-tabs">
          <a href="/admin/dashboard?filter=daily"
            class="chart-filter-tab <%= filter === 'daily'   ? 'active' : '' %>">Today</a>
          <a href="/admin/dashboard?filter=weekly"
            class="chart-filter-tab <%= filter === 'weekly'  ? 'active' : '' %>">Last 7 Days</a>
          <a href="/admin/dashboard?filter=monthly"
            class="chart-filter-tab <%= filter === 'monthly' ? 'active' : '' %>">This Month</a>
          <a href="/admin/dashboard?filter=yearly"
            class="chart-filter-tab <%= filter === 'yearly'  ? 'active' : '' %>">This Year</a>
        </nav>

        <div class="chart-legend">
          <div class="legend-item">
            <div class="legend-dot current" style="background:#603763;"></div>
            <span>Gross Revenue (₹)</span>
          </div>
          <div class="legend-item" style="margin-left:16px;">
            <div class="legend-dot" style="background:#059669;"></div>
            <span>Net Revenue (₹)</span>
          </div>
        </div>
      </div>

      <% if (grossChartData.length === 0 || grossChartData.every(v => v === 0)) { %>
        <div class="chart-empty">
          <i data-lucide="bar-chart-2" size="40"></i>
          <p>No revenue data for this period</p>
        </div>
      <% } else { %>
        <div class="chart-container">
          <canvas id="revenueChart"></canvas>
        </div>
      <% } %>
    </section>

    <!-- ── MAIN CONTENT GRID ── -->
    <div class="content-grid">

      <!-- LEFT COLUMN -->
      <div class="main-column">

        <!-- Recent Orders -->
        <div class="dashboard-card">
          <div class="card-header-inner">
            <h3>Recent Orders</h3>
            <a href="/admin/orders" class="card-link">View All →</a>
          </div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>ORDER ID</th>
                  <th>CUSTOMER</th>
                  <th>AMOUNT</th>
                  <th>STATUS</th>
                  <th>DATE</th>
                </tr>
              </thead>
              <tbody>
                <% if (d.recentOrders?.length > 0) { %>
                  <% d.recentOrders.forEach(order => { %>
                    <tr>
                      <td class="td-order-id"><%= order.orderId %></td>
                      <td>
                        <div class="td-customer">
                          <div class="customer-avatar">
                            <i data-lucide="user" size="16" style="margin:6px;color:#603763;"></i>
                          </div>
                          <span class="customer-name"><%= order.userId?.fullName || "Customer" %></span>
                        </div>
                      </td>
                      <td class="td-amount">₹<%= order.displayAmount.toLocaleString("en-IN") %></td>
                      <td>
                        <span class="order-badge <%= statusClass(order.orderStatus) %>">
                          <%= order.orderStatus %>
                        </span>
                      </td>
                      <td class="td-date"><%= new Date(order.createdAt).toLocaleDateString("en-IN") %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="5" class="empty-cell">No orders in this period</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Top Products -->
        <div class="dashboard-card">
          <div class="card-header-inner">
            <h3>Top Products</h3>
            <a href="/admin/products" class="card-link">View All →</a>
          </div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>PRODUCT NAME</th>
                  <th>UNITS SOLD</th>
                  <th>REVENUE</th>
                </tr>
              </thead>
              <tbody>
                <% if (d.topProducts?.length > 0) { %>
                  <% d.topProducts.forEach(product => { %>
                    <tr>
                      <td>
                        <div class="td-customer">
                          <div class="product-icon">
                            <i data-lucide="package" size="16" color="#603763"></i>
                          </div>
                          <span class="td-product-name"><%= product.productName %></span>
                        </div>
                      </td>
                      <td class="td-units"><%= product.unitsSold %></td>
                      <td class="td-amount">₹<%= product.revenue.toLocaleString("en-IN") %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="3" class="empty-cell">No sales data in this period</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN -->
      <aside class="side-column">

        <!-- Stock Alerts -->
        <div class="dashboard-card alert-card">
          <div class="alert-header">
            <div class="alert-title">
              <i data-lucide="alert-triangle" color="#7B1E5A" size="18"></i>
              Stock Alerts
            </div>
            <span class="urgent-badge"><%= d.stockAlerts?.length || 0 %> Urgent</span>
          </div>
          <div class="alert-list">
            <% if (d.stockAlerts?.length > 0) { %>
              <% d.stockAlerts.forEach(item => { %>
                <div class="alert-item">
                  <div class="alert-item-info">
                    <div class="alert-item-icon">
                      <i data-lucide="package" size="14" color="#A1A1AA"></i>
                    </div>
                    <div class="alert-item-text">
                      <span class="alert-item-name"><%= item.productId?.name || "Product" %></span>
                      <span class="alert-item-stock
                        <%= item.stock <= 5 ? 'stock-critical' : 'stock-low' %>">
                        <%= item.stock %> units left
                      </span>
                    </div>
                  </div>
                  <a href="/admin/products" class="alert-item-action" title="Restock">
                    <i data-lucide="plus-circle" size="16"></i>
                  </a>
                </div>
              <% }) %>
            <% } else { %>
              <div class="alert-empty">
                <i data-lucide="check-circle" size="20" color="#10b981"></i>
                <span>All products well-stocked</span>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Top Categories -->
        <div class="dashboard-card categories-card">
          <div class="card-header-inner">
            <h3>Top Categories</h3>
            <a href="/admin/categories" class="card-link">Manage →</a>
          </div>
          <div class="category-list">
            <% if (d.topCategories?.length > 0) { %>
              <% d.topCategories.forEach((cat, idx) => { %>
                <div class="category-item">
                  <div class="category-info">
                    <span class="category-name"><%= cat._id %></span>
                    <span class="category-stats">
                      ₹<%= cat.revenue.toLocaleString("en-IN") %> &bull; <%= cat.percentage %>%
                    </span>
                  </div>
                  <div class="category-bar-container">
                    <div class="category-bar-fill c-purple-<%= (idx % 3) + 1 %>"
                      style="width:<%= cat.percentage %>%;"></div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="empty-cell" style="padding:16px;">No category data in this period</div>
            <% } %>
          </div>
          <a href="/admin/sales-report" class="btn-report">DETAILED REPORT</a>
        </div>

        <!-- Quick Stats -->
        <div class="dashboard-card quick-stats-card">
          <div class="card-header-inner">
            <h3>Order Summary</h3>
          </div>
          <div class="quick-stats-list">
            <div class="quick-stat-item">
              <span class="quick-stat-label">Pending</span>
              <span class="quick-stat-value qs-pending"><%= d.totalPending || 0 %></span>
            </div>
            <div class="quick-stat-item">
              <span class="quick-stat-label">Cancelled</span>
              <span class="quick-stat-value qs-cancelled"><%= d.totalCancelled || 0 %></span>
            </div>
            <div class="quick-stat-item">
              <span class="quick-stat-label">Returned</span>
              <span class="quick-stat-value qs-returned"><%= d.totalReturns || 0 %></span>
            </div>
            <div class="quick-stat-item">
              <span class="quick-stat-label">Return Rate</span>
              <span class="quick-stat-value qs-rate"><%= d.returnRate || 0 %>%</span>
            </div>
          </div>
        </div>

      </aside>
    </div>

    <footer class="dashboard-footer">
      <p>© 2026 iStore Admin &mdash; All data reflects the selected period: <strong><%= rangeLabel %></strong></p>
    </footer>

  </main>

  <script>
    lucide.createIcons();

    /* ── Chart ── */
    const chartLabels    = <%- JSON.stringify(chartLabels) %>;
    const grossRevenue   = <%- JSON.stringify(grossChartData) %>;
    const netRevenue     = <%- JSON.stringify(netChartData) %>;
    const filterType     = "<%= filter %>";

    const ctx = document.getElementById("revenueChart");

    if (ctx && grossRevenue.length > 0) {

      const c2d = ctx.getContext("2d");

      const grossGradient = c2d.createLinearGradient(0, 0, 0, 320);
      grossGradient.addColorStop(0, "rgba(96,55,99,0.20)");
      grossGradient.addColorStop(1, "rgba(96,55,99,0)");

      const netGradient = c2d.createLinearGradient(0, 0, 0, 320);
      netGradient.addColorStop(0, "rgba(5,150,105,0.15)");
      netGradient.addColorStop(1, "rgba(5,150,105,0)");

      const useBar = filterType === "daily";

      new Chart(ctx, {
        type: useBar ? "bar" : "line",
        data: {
          labels: chartLabels,
          datasets: [
            {
              label:                "Gross Revenue (₹)",
              data:                 grossRevenue,
              borderColor:          "#603763",
              borderWidth:          useBar ? 0 : 2.5,
              backgroundColor:      useBar ? "rgba(96,55,99,0.55)" : grossGradient,
              fill:                 !useBar,
              tension:              0.4,
              borderRadius:         useBar ? 8 : 0,
              pointBackgroundColor: "#FFFFFF",
              pointBorderColor:     "#603763",
              pointBorderWidth:     2,
              pointRadius:          useBar ? 0 : 4,
              pointHoverRadius:     useBar ? 0 : 7,
            },
            {
              label:                "Net Revenue (₹)",
              data:                 netRevenue,
              borderColor:          "#059669",
              borderWidth:          useBar ? 0 : 2.5,
              backgroundColor:      useBar ? "rgba(5,150,105,0.40)" : netGradient,
              fill:                 !useBar,
              tension:              0.4,
              borderRadius:         useBar ? 8 : 0,
              pointBackgroundColor: "#FFFFFF",
              pointBorderColor:     "#059669",
              pointBorderWidth:     2,
              pointRadius:          useBar ? 0 : 4,
              pointHoverRadius:     useBar ? 0 : 7,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          layout: { padding: { top: 8, right: 8 } },
          plugins: {
            legend: { display: false },
            tooltip: {
              mode: "index",
              intersect: false,
              backgroundColor: "#2C1421",
              titleColor: "#fff",
              bodyColor:  "#fff",
              padding: 12,
              cornerRadius: 10,
              callbacks: {
                label: ctx => " ₹" + new Intl.NumberFormat("en-IN").format(ctx.parsed.y),
              },
            },
          },
          scales: {
            x: {
              grid: { display: false, drawBorder: false },
              ticks: {
                color: "#4D444C",
                font: { family: "Inter", size: 11, weight: "600" },
                maxTicksLimit: filterType === "daily" ? 12 : undefined,
              },
            },
            y: {
              beginAtZero: true,
              grid: { color: "rgba(208,195,204,0.18)", drawBorder: false },
              ticks: {
                color: "#4D444C",
                font: { family: "Inter", size: 11 },
                callback: v => "₹" + new Intl.NumberFormat("en-IN").format(v),
              },
            },
          },
          interaction: { mode: "nearest", axis: "x", intersect: false },
        },
      });
    }

    /* ── Safari back button fix ── */
    window.addEventListener("pageshow", e => {
      if (e.persisted) window.location.reload();
    });

    /* ── Admin session polling every 30s ── */
    setInterval(async () => {
      try {
        const res  = await fetch("/admin/check-session");
        const data = await res.json();
        if (!data.active) window.location.href = "/admin/login";
      } catch {}
    }, 30000);
  </script>

</body>
</html>
