<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Overview - Admin | iStore</title>
    <link rel="stylesheet" href="/css/components/admin-sidebar.css">
    <link rel="stylesheet" href="/css/admin-dashboard.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

     <!-- Sidebar Navbar -->
   <%- include('../partials/admin/sidebar') %>
   <% const data = dashboardData || {};%>
    <%
    const chartLabels =
    data.revenueChart?.map(
    item => item._id
    ) || [];

    const chartRevenue =
    data.revenueChart?.map(
    item => item.revenue
    ) || [];
    %>

    <main class="dashboard-main">
        
        <!-- Header -->
        <header class="dashboard-header">
            <div class="header-title">
                <span class="subtitle">OVERVIEW</span>
                <h1>Dashboard Overview</h1>
            </div>
            <div class="header-actions">
                <div class="date-filter">

                    <a
                        href="/admin/dashboard?filter=daily"
                        class="<%= filter === 'daily' ? 'active-filter' : '' %>"
                    >
                        Daily
                    </a>

                    <a
                        href="/admin/dashboard?filter=monthly"
                        class="<%= filter === 'monthly' ? 'active-filter' : '' %>"
                    >
                        Monthly
                    </a>

                    <a
                        href="/admin/dashboard?filter=yearly"
                        class="<%= filter === 'yearly' ? 'active-filter' : '' %>"
                    >
                        Yearly
                    </a>

                </div>
            </div>
        </header>

        <!-- KPI Grid -->
        <section class="kpi-grid">
            <!-- Revenue -->
            <div class="kpi-card">
                <div class="kpi-top">
                    <div class="kpi-icon revenue">
                        <i data-lucide="banknote" size="20"></i>
                    </div>
                    <div class="kpi-trend positive">
                        <i data-lucide="trending-up" size="12"></i>
                        <span>+12%</span>
                    </div>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">TOTAL REVENUE</span>
                    <span class="kpi-value">
                    ₹<%= (data.totalRevenue || 0).toLocaleString("en-IN") %>
                    </span>
                </div>
            </div>

            <!-- Orders -->
            <div class="kpi-card">
                <div class="kpi-top">
                    <div class="kpi-icon orders">
                        <i data-lucide="shopping-bag" size="20"></i>
                    </div>
                    <div class="kpi-trend positive">
                        <i data-lucide="trending-up" size="12"></i>
                        <span>+8%</span>
                    </div>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">TOTAL ORDERS</span>
                    <span class="kpi-value">
                    <%= (data.totalOrders || 0).toLocaleString("en-IN") %>
                    </span>
                </div>
            </div>

            <!-- Customers -->
            <div class="kpi-card">
                <div class="kpi-top">
                    <div class="kpi-icon customers">
                        <i data-lucide="users" size="20"></i>
                    </div>
                    <div class="kpi-trend positive">
                        <i data-lucide="trending-up" size="12"></i>
                        <span>+18%</span>
                    </div>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">TOTAL CUSTOMERS</span>
                    <span class="kpi-value">
                    <%= (data.totalCustomers || 0).toLocaleString("en-IN") %>
                    </span>
                </div>
            </div>

            <!-- Products -->
            <div class="kpi-card">
                <div class="kpi-top">
                    <div class="kpi-icon products">
                        <i data-lucide="package" size="20"></i>
                    </div>
                    <div class="kpi-trend neutral">
                        <span>Stable</span>
                    </div>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">TOTAL PRODUCTS</span>
                    <span class="kpi-value">
                    <%= (data.totalProducts || 0).toLocaleString("en-IN") %>
                    </span>
                </div>
            </div>

            <!-- Returns -->
            <div class="kpi-card">
                <div class="kpi-top">
                    <div class="kpi-icon returns">
                        <i data-lucide="corner-down-left" size="20"></i>
                    </div>
                    <div class="kpi-trend negative">
                        <i data-lucide="trending-up" size="12"></i>
                        <span>+2%</span>
                    </div>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">TOTAL RETURNS</span>
                    <span class="kpi-value">0</span>
                </div>
            </div>
        </section>

        <!-- Chart Section -->
        <section class="chart-section">
            <div class="chart-header">
                <div class="chart-title">
                    <h2>

                    Revenue Trends

                    <small>

                    (

                    <%= filter || "weekly" %>

                    )

                    </small>

                    </h2>
                    <p>Daily sales performance tracking</p>
                </div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <div class="legend-dot current"></div>
                        <span>Current Period</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot previous"></div>
                        <span>Previous Period</span>
                    </div>
                </div>
            </div>
            
            <div class="chart-container">
                <!-- SVG Chart Mockup -->
                <div
                style="
                height:300px;
                width:100%;
                "
                >
                    <canvas
                    id="revenueChart"
                    ></canvas>
                </div>


            </div>
        </section>

        <!-- Main Content Grid -->
        <div class="content-grid">
            
            <!-- Left Column: Tables -->
            <div class="main-column">
                
                <!-- Recent Orders -->
                <div class="dashboard-card">
                    <div class="card-header-inner">
                        <h3>Recent Orders</h3>
                            <a
                            href="/admin/orders"
                            class="card-link"
                            >
                            View All
                            </a>
                    </div>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>ORDER ID</th>
                                    <th>CUSTOMER</th>
                                    <th>AMOUNT</th>
                                    <th>STATUS</th>
                                    <th>DATE</th>
                                </tr>
                            </thead>
                                <tbody>

                                <% if (data.recentOrders?.length > 0) { %>

                                    <% data.recentOrders.forEach(order => { %>

                                        <tr>

                                            <td class="td-order-id">

                                                <%= order.orderId %>

                                            </td>

                                            <td class="td-customer">

                                                <div
                                                    class="customer-avatar"
                                                    style="background:#A7F3D0;"
                                                >
                                                    <i
                                                        data-lucide="user"
                                                        size="20"
                                                        style="
                                                            margin:6px;
                                                            color:#065F46;
                                                        "
                                                    ></i>
                                                </div>

                                                <span class="customer-name">

                                                    <%= order.userId?.fullName || "Customer" %>

                                                </span>

                                            </td>

                                            <td class="td-amount">

                                                ₹<%= order.finalAmount.toLocaleString("en-IN") %>

                                            </td>

                                            <td>

                                                <div
                                                    class="
                                                    status-badge
                                                    <%= order.orderStatus?.toLowerCase() %>
                                                    "
                                                >

                                                    <div class="status-dot"></div>

                                                    <%= order.orderStatus %>

                                                </div>

                                            </td>

                                            <td class="td-date">

                                                <%= new Date(order.createdAt)
                                                .toLocaleDateString("en-IN") %>

                                            </td>

                                        </tr>

                                    <% }) %>

                                <% } else { %>

                                <tr>

                                <td colspan="5">

                                No orders found

                                </td>

                                </tr>

                                <% } %>

                                </tbody>
                        </table>
                    </div>
                </div>

                <!-- Top Products -->
                <div class="dashboard-card">
                    <div class="card-header-inner">
                        <h3>Top Products</h3>
                    </div>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>PRODUCT NAME</th>
                                    <th>UNITS SOLD</th>
                                    <th>SALES</th>
                                    <th>STOCK</th>
                                </tr>
                            </thead>
                                <tbody>

                                <% if (data.topProducts?.length > 0) { %>

                                    <% data.topProducts.forEach(product => { %>

                                        <tr>

                                            <td>

                                                <div class="td-customer">

                                                    <div class="product-icon">

                                                        <i
                                                        data-lucide="package"
                                                        color="#603763"
                                                        ></i>

                                                    </div>

                                                    <span class="td-product-name">

                                                        <%= product.productName %>

                                                    </span>

                                                </div>

                                            </td>

                                            <td class="td-units">

                                                <%= product.unitsSold %>

                                            </td>

                                            <td class="td-amount">

                                                ₹<%= product.revenue.toLocaleString("en-IN") %>

                                            </td>

                                            <td>

                                                <div
                                                class="stock-bar-container"
                                                >

                                                    <div
                                                    class="stock-bar-fill good"
                                                    style="width:100%;"
                                                    ></div>

                                                </div>

                                            </td>

                                        </tr>

                                    <% }) %>

                                <% } else { %>

                                <tr>

                                    <td colspan="4">

                                        No sales data available

                                    </td>

                                </tr>

                                <% } %>

                                </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <!-- Right Column: Alerts & Categories -->
            <aside class="side-column">
                
                <!-- Stock Alerts -->
                <div class="dashboard-card alert-card">
                    <div class="alert-header">
                        <div class="alert-title">
                            <i data-lucide="alert-triangle" color="#7B1E5A" size="20"></i>
                            Stock Alerts
                        </div>
                        <span class="urgent-badge">

                        <%= data.stockAlerts?.length || 0 %>

                        Urgent

                        </span>
                    </div>
                    
                    <div class="alert-list">

                    <% if (data.stockAlerts?.length > 0) { %>

                        <% data.stockAlerts.forEach(item => { %>

                            <div class="alert-item">

                                <div class="alert-item-info">

                                    <div class="alert-item-icon">

                                        <i
                                        data-lucide="package"
                                        size="16"
                                        color="#A1A1AA"
                                        ></i>

                                    </div>

                                    <div class="alert-item-text">

                                        <span class="alert-item-name">

                                            <%= item.productId?.name || "Product" %>

                                        </span>

                                        <span class="alert-item-stock">

                                            <%= item.stock %> items left

                                        </span>

                                    </div>

                                </div>

                                <button class="alert-item-action">

                                    <i
                                    data-lucide="shopping-cart"
                                    size="16"
                                    ></i>

                                </button>

                            </div>

                        <% }) %>

                    <% } else { %>

                        <div class="alert-item">

                            <div class="alert-item-text">

                                No low stock alerts

                            </div>

                        </div>

                    <% } %>

                    </div>
                </div>

                <!-- Top Categories -->
                <div class="dashboard-card categories-card">
                    <div class="categories-header">
                        <h3>Top Categories</h3>
                    </div>
                    
                        <div class="category-list">

                        <% if (data.topCategories?.length > 0) { %>

                            <% data.topCategories.forEach(category => { %>

                                <div class="category-item">

                                    <div class="category-info">

                                        <span class="category-name">

                                            <%= category._id %>

                                        </span>

                                        <span class="category-stats">

                                            ₹<%= category.revenue.toLocaleString("en-IN") %>

                                            •

                                            <%= category.percentage %>%

                                        </span>

                                    </div>

                                    <div class="category-bar-container">

                                        <div
                                            class="category-bar-fill c-purple-1"
                                            style="
                                                width:
                                                <%= category.percentage %>%;
                                            "
                                        ></div>

                                    </div>

                                </div>

                            <% }) %>

                        <% } else { %>

                            <div class="category-item">

                                No category data available

                            </div>

                        <% } %>

                        </div>

                        <a
                        href="/admin/sales-report"
                        class="btn-report"
                        >
                        DETAILED REPORT
                        </a>
                </div>

            </aside>

        </div>

        <footer class="dashboard-footer">
            <p>© 2026 iStore Admin. Crafted for Excellence.</p>
        </footer>

    </main>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

const chartLabels =
<%- JSON.stringify(chartLabels) %>;

const chartRevenue =
<%- JSON.stringify(chartRevenue) %>;

const ctx =
document
.getElementById(
"revenueChart"
);

if (
ctx &&
chartRevenue.length > 0
){

new Chart(ctx, {

type: "line",

data: {

labels: chartLabels,

datasets: [

{

label: "Revenue",

data: chartRevenue,

borderColor: "#603763",

backgroundColor:
"rgba(96,55,99,0.1)",

fill: true,

tension: 0.4,

borderWidth: 3,

},

],

},

options: {

responsive: true,

plugins: {

legend: {

display: false,

},

},

},

});

}
else {

console.log(
"No revenue data available"
);

}

        

/* Prevent Back Button Cache (Safari Fix) */

window.addEventListener(
"pageshow",
function (event) {

if (event.persisted) {

window.location.reload()

}

}
)



/* Check Admin Session Every 5 Seconds */

setInterval(async () => {

try {

const response =
await fetch(
"/admin/check-session"
)

const data =
await response.json()

if (!data.active) {

window.location.href =
"/admin/login"

}

}

catch (error) {

console.log(
"Admin session check failed"
)

}

}, 5000)


    </script>
</body>
</html>
