/* =========================================
   PREMIUM MULTI IMAGE MANAGER
========================================= */

let selectedFiles = [];
let existingImages = [];

const imageInput =
document.getElementById("variantImageInput");

const previewGrid =
document.getElementById("variantPreviewGrid");

const previewImage =
document.getElementById("previewImage");

/* =========================================
   RENDER IMAGES
========================================= */

function renderImages() {

   previewGrid.innerHTML = "";

const allImages = [

    ...existingImages.map(img => ({
        type: "existing",
        url: img
    })),

    ...selectedFiles.map(file => ({
        type: "file",
        file,
        url: URL.createObjectURL(file)
    }))

];

/* =========================
   NO IMAGE
========================= */

if(!allImages.length) {

    previewImage.src =
    "<%= product.thumbnail %>";

    return;

}

/* =========================
   SET MAIN IMAGE
========================= */

previewImage.src =
allImages[0].url;

/* =========================
   RENDER THUMBNAILS
========================= */

allImages.forEach((imageData) => {

    const previewItem =
    document.createElement("div");

    previewItem.className =
    "preview-image-item";

    previewItem.innerHTML = `

        <img src="${imageData.url}">

        <button
            type="button"
            class="remove-image-btn"
        >
            ×
        </button>

    `;

    /* =========================
       CHANGE MAIN IMAGE
    ========================= */

    previewItem
    .querySelector("img")
    .addEventListener(
        "click",
        () => {

            previewImage.src =
            imageData.url;

        }
    );

    /* =========================
       DELETE IMAGE
    ========================= */

    previewItem
    .querySelector(
        ".remove-image-btn"
    )
    .addEventListener(
        "click",
        () => {

            if(imageData.type === "file") {

                selectedFiles =
                selectedFiles.filter(
                    f => f !== imageData.file
                );

            }

            else {

                existingImages =
                existingImages.filter(
                    img => img !== imageData.url
                );

            }

            renderImages();

        }
    );

    previewGrid.appendChild(
        previewItem
    );

});

}

