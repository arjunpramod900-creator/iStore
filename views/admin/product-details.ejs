<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Product Details - Admin | iStore
    </title>

    <!-- CSS -->
    <link
        rel="stylesheet"
        href="/css/admin-product-details.css"
    >

    <link
        rel="stylesheet"
        href="/css/admin-header.css"
    >

    <link
        rel="stylesheet"
        href="/css/admin-dashboard.css"
    >

    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
    >

    <!-- Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- cropper.js -->
    <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css"/>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

    <%- include('../partials/admin/header') %>

    <main class="main-canvas">

        <!-- =========================================
             HEADER
        ========================================== -->

        <header class="header-section">

            <nav class="breadcrumbs">

                <a href="/admin/dashboard">
                    DASHBOARD
                </a>

                <span class="separator">/</span>

                <a href="/admin/products">
                    PRODUCTS
                </a>

                <span class="separator">/</span>

                <span class="active">
                    PRODUCT DETAILS
                </span>

            </nav>

            <div class="title-actions-row">

                <div class="page-title-group">

                    <h1>
                        Product Details
                    </h1>

                    <p>
                        View product insights
                    </p>

                </div>

                <div class="action-buttons">

                   <button
    class="btn-detail btn-add-variant"
    id="openVariantModalBtn"
>

    <i
        data-lucide="plus-circle"
        size="18"
    ></i>

    Add Variant

</button>

                    <button
                        class="btn-detail btn-edit"
                        onclick="window.location.href='/admin/products/edit/<%= product._id %>'"
                    >

                        <i
                            data-lucide="edit-3"
                            size="18"
                        ></i>

                        Edit Product

                    </button>

                    <button
                        class="btn-detail btn-delete"
                        id="deleteProductBtn"
                    >

                        <i
                            data-lucide="trash-2"
                            size="18"
                        ></i>

                        Delete

                    </button>

                </div>

            </div>

        </header>

        <!-- =========================================
             ANALYTICS GRID
        ========================================== -->

        <section class="analytics-grid">

            <div class="analytic-card">

                <div class="analytic-icon-wrapper">

                    <i
                        data-lucide="package"
                        size="20"
                    ></i>

                </div>

               <div class="analytic-info">

    <span class="analytic-label">
        Total Stock
    </span>

    <span class="analytic-value">
        <%= totalStock %>
    </span>

    <span class="analytic-subtext">
        Units
    </span>

</div>

            </div>

            <div class="analytic-card">

                <div class="analytic-icon-wrapper">

                    <i
                        data-lucide="shopping-bag"
                        size="20"
                    ></i>

                </div>

               <div class="analytic-info">

    <span class="analytic-label">
        Total Sales
    </span>

    <span class="analytic-value">
        <%= typeof totalSales !== 'undefined' ? totalSales : 0 %>
    </span>

    <span class="analytic-subtext">
        Orders
    </span>

</div>
            </div>

            <div class="analytic-card">

                <div class="analytic-icon-wrapper">

                    <i
                        data-lucide="refresh-cw"
                        size="20"
                    ></i>

                </div>

                <div class="analytic-info">

    <span class="analytic-label">
        Total Returns
    </span>

    <span class="analytic-value">
        <%= typeof totalReturns !== 'undefined' ? totalReturns : 0 %>
    </span>

    <span class="analytic-subtext">
        Returned
    </span>

</div>
            </div>

            <div class="analytic-card">

                <div class="analytic-icon-wrapper">

                    <i
                        data-lucide="banknote"
                        size="20"
                    ></i>

                </div>

               <div class="analytic-info">

    <span class="analytic-label">
        Revenue
    </span>

    <span class="analytic-value">

        ₹<%= typeof totalRevenue !== 'undefined'
            ? totalRevenue.toLocaleString()
            : '18,245,600'
        %>

    </span>

    <span class="analytic-subtext">
        Total Revenue
    </span>

</div>

            </div>

        </section>

        <!-- =========================================
             PRODUCT SHOWCASE
        ========================================== -->

        <section class="product-showcase-grid">

            <!-- LEFT -->
            <div class="product-gallery">

                <div class="main-image-container">

                    <img
                        id="mainProductImage"
                        src="<%= variants[0]?.images?.[0] || product.thumbnail %>"
                        alt="<%= product.name %>"
                    >

                </div>

                <div class="thumbnail-list">

                    <% 
                      const galleryImages = variants[0]?.images?.length
    ? variants[0].images
    : [product.thumbnail]
                    %>

                    <% galleryImages.forEach((image, index) => { %>

                        <div
                            class="thumbnail-item <%= index === 0 ? 'active' : '' %>"
                        >

                            <img
                                src="<%= image %>"
                                alt="Thumbnail"
                            >

                        </div>

                    <% }) %>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="product-info-panel">

                <div class="info-header">

                    <div class="product-title-group">

                        <span class="badge-status">
                            Premium Series
                        </span>

                        <h2>
                            <%= product.name %>
                        </h2>

                    </div>

                    <div class="
                        status-active-badge
                        <%= product.isActive ? 'active' : 'blocked' %>
                    ">

                        <div class="status-dot-blur"></div>

                        <span class="status-active-text">

                           <%= product.isActive ? 'Active' : 'Inactive' %>

                        </span>

                    </div>

                </div>

                <div class="info-details-grid">

                    <div class="detail-item">

                        <span class="detail-label">
                            Category
                        </span>

                        <span class="detail-value">

                            <%= product.categoryId?.name || "N/A" %>

                        </span>

                    </div>

                    <div class="detail-item">

                        <span class="detail-label">
                            Variants
                        </span>

                        <span class="detail-value">

                            <%= totalVariants %> Configs Available

                        </span>

                    </div>

                    <div class="detail-item">

                        <span class="detail-label">
                            Base Price
                        </span>

                        <span class="detail-value price">

                            ₹<%= basePrice.toLocaleString() %>

                        </span>

                    </div>

                </div>

                <div class="description-section">

                    <span class="detail-label">
                        Description
                    </span>

                    <p class="description-text">

                        <%= product.description %>

                    </p>

                </div>

                <!-- =========================================
                     TECHNICAL HIGHLIGHTS
                ========================================== -->

                <div class="technical-highlights">

                    <span class="detail-label">
                        Technical Highlights
                    </span>

                   <div class="highlight-tags">

                    <span class="tag">
                        Premium Build
                    </span>

                    <span class="tag">
                        Official Apple Product
                    </span>

                    <span class="tag">
                        High Performance
                    </span>

                    </div>

                </div>
                <!-- =========================================
                    VARIANT SPECIFICATIONS
                ========================================= -->

                <div class="technical-highlights">

                    <span class="detail-label">
                        Variant Specifications
                    </span>

                    <div
                        id="variantSpecsContainer"
                        class="highlight-tags">

                        <span class="tag" id="specColor">
                            Black
                        </span>

                        <span class="tag" id="specStorage">
                            256GB
                        </span>

                        <span class="tag" id="specRAM">
                            8GB RAM
                        </span>

                        <span class="tag" id="specSKU">
                            IP17-BLK-256
                        </span>

                        <span class="tag" id="specStock">
                            5 Units
                        </span>

                    </div>

                </div>

            </div>

        </section>

        <!-- =========================================
             VARIANTS
        ========================================== -->

        <section class="variants-section">

            <h3 class="section-title">
                Variant Management
            </h3>

            <!-- SEARCH -->

           <div class="variant-toolbar">

    <div class="variant-toolbar-left">

        <div class="search-wrapper">

            <i
                data-lucide="search"
                size="16"
            ></i>

            <input
                type="text"
                id="variantSearch"
                class="variant-search"
                placeholder="Search variants..."
            >

        </div>

    </div>

    <div class="variant-toolbar-right">

        <select
            id="stockFilter"
            class="variant-filter"
        >

            <option value="all">
                All Stock
            </option>

            <option value="instock">
                In Stock
            </option>

            <option value="low">
                Low Stock
            </option>

            <option value="critical">
                Critical
            </option>
            <option value="trash">
                Trash
            </option>

        </select>

        <div class="variant-count-badge">

            <%= totalVariants %> Variants

        </div>

    </div>

</div>

            <div class="table-card">

                <table class="variants-table">

                    <thead>

                        <tr>

                            <th>Preview</th>
                            <th>Variant Name</th>
                            <th>Storage</th>
                            <th>RAM</th>
                            <th>Color</th>
                            <th>Price</th>
                            <th>Stock</th>

                            <th style="text-align:right;">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        <% if(variants.length > 0) { %>

                            <% variants.forEach(variant => { %>

                               <tr
    class="variant-row"

    data-deleted="<%= variant.isDeleted %>"
    data-sku="<%= variant.SKU %>"
    data-storage="<%= variant.storage %>"
    data-ram="<%= variant.RAM %>"
    data-color="<%= variant.color %>"
    data-price="<%= variant.price %>"
    data-stock="<%= variant.stock %>"
    data-images='<%- JSON.stringify(variant.images) %>'
>
                                    <td>

                                        <div class="variant-preview">

                                            <img
                                                src="<%= variant.images?.[0] || product.thumbnail %>"
                                                alt=""
                                            >

                                        </div>

                                    </td>

                                    <td class="font-bold">
                                        <%= variant.SKU %>
                                    </td>

                                    <td>
                                        <%= variant.storage %>
                                    </td>

                                    <td>
                                        <%= variant.RAM %>
                                    </td>

                                    <td>
                                        <%= variant.color %>
                                    </td>

                                    <td class="font-bold">

                                        ₹<%= variant.price.toLocaleString() %>

                                    </td>

                                    <td>

                                        <% if(variant.stock <= 10) { %>

                                            <span class="stock-badge critical">

                                                <%= variant.stock %> units

                                            </span>

                                        <% } else if(variant.stock <= 50) { %>

                                            <span class="stock-badge low">

                                                <%= variant.stock %> units

                                            </span>

                                        <% } else { %>

                                            <span class="stock-badge">

                                                <%= variant.stock %> units

                                            </span>

                                        <% } %>

                                    </td>

                                    <td>

                                        <div class="variant-actions">

                                                <% if(!variant.isDeleted) { %>

                                                <!-- EDIT -->

                                                <button
                                                    class="btn-icon edit-variant-btn"

                                                    data-id="<%= variant._id %>"
                                                    data-sku="<%= variant.SKU %>"
                                                    data-color="<%= variant.color %>"
                                                    data-storage="<%= variant.storage %>"
                                                    data-ram="<%= variant.RAM %>"
                                                    data-price="<%= variant.price %>"
                                                    data-stock="<%= variant.stock %>"
                                                    data-images='<%- JSON.stringify(variant.images) %>'>

                                                    <i
                                                        data-lucide="edit-2"
                                                        size="16"
                                                    ></i>

                                                </button>

                                                <!-- SOFT DELETE -->

                                                <button
                                                    class="btn-icon delete-variant-btn"
                                                    data-id="<%= variant._id %>">

                                                    <i
                                                        data-lucide="trash-2"
                                                        size="16"
                                                    ></i>

                                                </button>

                                                <% } else { %>

                                                <!-- RESTORE -->

                                                <button
                                                    class="btn-icon restore-variant-btn"
                                                    data-id="<%= variant._id %>">

                                                    <i
                                                        data-lucide="rotate-ccw"
                                                        size="16"
                                                    ></i>

                                                </button>

                                                <!-- PERMANENT DELETE -->

                                                <button
                                                    class="btn-icon permanent-delete-variant-btn"
                                                    data-id="<%= variant._id %>">

                                                    <i
                                                        data-lucide="x-circle"
                                                        size="16"
                                                    ></i>

                                                </button>

                                                <% } %>

                                         </div>

                                    </td>

                                </tr>

                            <% }) %>

                        <% } else { %>

                            <tr>

                                <td colspan="7">

                                   <div class="empty-variants">

    <i
        data-lucide="package-open"
        size="52"
    ></i>

    <h4>
        No Variants Found
    </h4>

    <p>
        Start by adding your first variant.
    </p>

</div>

                                </td>

                            </tr>

                        <% } %>

                    </tbody>

                </table>

            </div>

        </section>

        <!-- =========================================
             ANALYTICS + LOGS
        ========================================== -->

        <section class="analytics-logs-grid">

            <!-- LEFT -->
            <div class="chart-card">

                <div class="chart-header">

                    <h3 class="chart-title">
                        Sales Performance
                    </h3>

                    <div class="chart-tabs">

                        <span class="tab active">
                            Weekly
                        </span>

                        <span class="tab">
                            Monthly
                        </span>

                    </div>

                </div>

                <div
                    style="
                        height:320px;
                        position:relative;
                    "
                >

                    <canvas id="salesChart"></canvas>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="log-card">

                <h3 class="chart-title">
                    Product Activity Log
                </h3>

                <div class="log-timeline">

                    <div class="log-item">

                        <div
                            class="log-dot"
                            style="background:#FFD6FC;"
                        ></div>

                        <div class="log-content">

                            <span class="log-title">
                                Price updated
                            </span>

                            <span class="log-desc">
                                Admin changed base price to ₹2,39,900
                            </span>

                            <span class="log-time">
                                2 hours ago
                            </span>

                        </div>

                    </div>

                    <div class="log-item">

                        <div
                            class="log-dot"
                            style="background:#FFD8E8;"
                        ></div>

                        <div class="log-content">

                            <span class="log-title">
                                New variant added
                            </span>

                            <span class="log-desc">
                                Space Black 2 TB added to inventory
                            </span>

                            <span class="log-time">
                                Yesterday at 4:32 PM
                            </span>

                        </div>

                    </div>

                </div>

                <button
                    class="btn-detail"
                    style="
                        width:100%;
                        background:none;
                        border:1px solid rgba(96,55,99,0.12);
                        color:var(--secondary);
                    "
                >

                    View All Activity

                </button>

            </div>

        </section>



 <!-- =========================================
     VARIANT MODAL
========================================= -->

<div
    class="variant-modal-overlay"
    id="variantModal"
>

    <div class="variant-modal">

        <!-- HEADER -->

        <div class="variant-modal-header">

            <div>

                <h2 id="variantModalTitle">
                    Add Variant
                </h2>

                <p>
                    Configure variant inventory and pricing
                </p>

            </div>

            <button
                class="modal-close-btn"
                id="closeVariantModal"
            >

                <i
                    data-lucide="x"
                    size="22"
                ></i>

            </button>

        </div>

        <!-- BODY -->

        <div class="variant-modal-body">

            <!-- =========================================
                 FORM SECTION
            ========================================== -->

            <form
                class="variant-form-section"
                id="variantForm"
            >

                <!-- HIDDEN FIELDS -->

                <input
                    type="hidden"
                    id="variantProductId"
                    value="<%= product._id %>"
                >

                <input
                    type="hidden"
                    id="variantMode"
                    value="add"
                >

                <input
                    type="hidden"
                    id="editingVariantId"
                >

                <!-- CONFIG -->

                <div class="variant-form-group">

                    <h4>
                        Configuration
                    </h4>

                    <div class="variant-grid-3">

                        <div class="field">

                            <label>
                                Color
                            </label>

                            <input
                                type="text"
                                id="variantColor"
                                placeholder="Space Black"
                            >

                        </div>

                        <div class="field">

                            <label>
                                Storage
                            </label>

                            <input
                                type="text"
                                id="variantStorage"
                                placeholder="256GB"
                            >

                        </div>

                        <div class="field">

                            <label>
                                RAM
                            </label>

                            <input
                                type="text"
                                id="variantRAM"
                                placeholder="8GB"
                            >

                        </div>

                    </div>

                </div>

                <!-- SKU -->

                <div class="variant-form-group">

                    <h4>
                        SKU & Pricing
                    </h4>

                    <div class="variant-grid-2">

                        <div class="field">

                            <label>
                                SKU
                            </label>

                            <input
                                type="text"
                                id="variantSKU"
                                placeholder="IP17-BLK-256"
                            >

                        </div>

                        <div class="field">

                            <label>
                                Price
                            </label>

                            <input
                                type="number"
                                id="variantPrice"
                                placeholder="119900"
                            >

                        </div>

                    </div>

                </div>

                <!-- INVENTORY -->

                <div class="variant-form-group">

                    <h4>
                        Inventory
                    </h4>

                    <div class="variant-grid-2">

                        <div class="field">

                            <label>
                                Stock
                            </label>

                            <input
                                type="number"
                                id="variantStock"
                                placeholder="120"
                            >

                        </div>

                        <div class="field">

                            <label>
                                Threshold
                            </label>

                            <input
                                type="number"
                                id="variantThreshold"
                                placeholder="10"
                            >

                        </div>

                    </div>

                </div>

                <!-- IMAGE -->

                <div class="variant-form-group">

                    <h4>
                        Variant Media
                    </h4>

                    <label
                        class="variant-upload-box"
                    >
                    

                        <input
    type="file"
    hidden
    id="variantImageInput"
    accept="image/*"
    multiple
>

                        <i
                            data-lucide="upload"
                            size="28"
                        ></i>

                        <span>
                            Upload Variant Image
                        </span>

                    </label>
                   <div
    class="variant-images-wrapper"
>

    <div
        class="variant-preview-grid"
        id="variantPreviewGrid"
    ></div>

</div>

                </div>

            </form>

            <!-- =========================================
                 PREVIEW PANEL
            ========================================== -->

            <div class="variant-preview-panel">

               <div class="preview-card">

    <div class="preview-main-image-wrapper">

        <img
            id="previewImage"
            src="<%= product.thumbnail %>"
        >

    </div>

    

    <h3 id="previewName">
        <%= product.name %>
    </h3>

    <p id="previewSpecs">
        Space Black • 256GB • 8GB
    </p>

    <div
        class="preview-price"
        id="previewPrice"
    >

        ₹1,19,900

    </div>

</div>

                <div class="preview-analytics">

                    <div>

                        <span>
                            Sales
                        </span>

                        <strong>
                            482
                        </strong>

                    </div>

                    <div>

                        <span>
                            Returns
                        </span>

                        <strong>
                            12
                        </strong>

                    </div>

                    <div>

                        <span>
                            Health
                        </span>

                        <strong>
                            98%
                        </strong>

                    </div>

                </div>

            </div>

        </div>

        <!-- FOOTER -->

        <div class="variant-modal-footer">

            <button
                class="btn-detail"
                id="cancelVariantBtn"
                type="button"
            >

                Cancel

            </button>

            <button
                class="btn-detail btn-edit"
                id="saveVariantBtn"
                type="button"
            >

                Save Variant

            </button>

        </div>

    </div>

</div>

<!-- =========================================
     IMAGE CROPPER MODAL
========================================= -->

<div
    class="cropper-overlay"
    id="cropperOverlay"
>

    <div class="cropper-modal">

        <div class="cropper-header">

            <h3>
                Crop Image
            </h3>

            <button
                type="button"
                id="closeCropperBtn"
                class="cropper-close-btn"
            >
                ×
            </button>

        </div>

        <div class="cropper-body">

            <img id="cropperImage">

        </div>

        <div class="cropper-footer">

            <button
                type="button"
                id="cancelCropBtn"
                class="btn-detail"
            >
                Cancel
            </button>

            <button
                type="button"
                id="cropImageBtn"
                class="btn-detail btn-edit"
            >
                Crop & Add
            </button>

        </div>

    </div>

</div>
        <!-- =========================================
             FOOTER
        ========================================== -->

        <footer class="site-footer">

            © 2026 iStore Admin — Digital Atelier Environment

        </footer>

    </main>

    <div
    class="fullscreen-preview"
    id="fullscreenPreview"
>

    <img id="fullscreenImage">

</div>

    <!-- =========================================
         SCRIPTS
    ========================================== -->

    <script>

        lucide.createIcons();

        /* =========================================
           IMAGE SWITCHING
        ========================================== */

        const thumbnails =
            document.querySelectorAll(".thumbnail-item");

        const mainImage =
            document.getElementById("mainProductImage");

        thumbnails.forEach((thumb) => {

            thumb.addEventListener("click", () => {

                thumbnails.forEach((t) => {

                    t.classList.remove("active");

                });

                thumb.classList.add("active");

                const img =
                    thumb.querySelector("img").src;

                mainImage.style.opacity = "0";
mainImage.style.transform = "scale(0.98)";

setTimeout(() => {

    mainImage.src = img;

    mainImage.onload = () => {

        mainImage.style.opacity = "1";
        mainImage.style.transform = "scale(1)";

    };

}, 180);

            });

        });


        /* =========================================
   FULLSCREEN IMAGE VIEWER
========================================= */

const fullscreenPreview =
document.getElementById(
    "fullscreenPreview"
);

const fullscreenImage =
document.getElementById(
    "fullscreenImage"
);

mainImage.addEventListener(
    "click",
    () => {

        fullscreenPreview.classList.add(
            "active"
        );

        fullscreenImage.src =
        mainImage.src;

        document.body.style.overflow =
        "hidden";

    }
);

fullscreenPreview.addEventListener(
    "click",
    () => {

        fullscreenPreview.classList.remove(
            "active"
        );

        document.body.style.overflow =
        "";

    }
);
document.addEventListener(
    "keydown",
    (e) => {

        if(
            e.key === "Escape" &&
            fullscreenPreview.classList.contains(
                "active"
            )
        ) {

            fullscreenPreview.classList.remove(
                "active"
            );

            document.body.style.overflow =
            "";

        }

    }
);

        /* =========================================
           VARIANT SEARCH
        ========================================== */

        const variantSearch =
        document.getElementById("variantSearch");

        if(variantSearch) {

            variantSearch.addEventListener("keyup", () => {

                const value =
