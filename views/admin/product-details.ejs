<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Product Details - Admin | iStore
    </title>

    <!-- CSS -->
    <link
        rel="stylesheet"
        href="/css/admin-product-details.css"
    >

    <link rel="stylesheet" href="/css/components/admin-sidebar.css">

    <link
        rel="stylesheet"
        href="/css/admin-dashboard.css"
    >

    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
    >

    <!-- Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- cropper.js -->
    <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css"/>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

    <!-- Sidebar Navbar -->
   <%- include('../partials/admin/sidebar') %>

    <main class="main-canvas">

        <!-- =========================================
             HEADER
        ========================================== -->

        <header class="header-section">

            <nav class="breadcrumbs">

                <a href="/admin/dashboard">
                    DASHBOARD
                </a>

                <span class="separator">/</span>

                <a href="/admin/products">
                    PRODUCTS
                </a>

                <span class="separator">/</span>

                <span class="active">
                    PRODUCT DETAILS
                </span>

            </nav>

            <div class="title-actions-row">

                <div class="page-title-group">

                    <h1>
                        Product Details
                    </h1>

                    <p>
                        View product insights
                    </p>

                </div>

                <div class="action-buttons">

                   <button
                        class="btn-detail btn-add-variant"
                        id="openVariantModalBtn"
                    >
                        <i data-lucide="plus-circle" size="18"></i>
                        Add Variant
                    </button>

                    <button
                        class="btn-detail btn-delete"
                        id="deleteProductBtn"
                    >
                        <i data-lucide="trash-2" size="18"></i>
                        Delete
                    </button>

                </div>

            </div>

        </header>

        <!-- =========================================
             ANALYTICS GRID
        ========================================== -->

        <section class="analytics-grid">

            <div class="analytic-card">
                <div class="analytic-icon-wrapper">
                    <i data-lucide="package" size="20"></i>
                </div>
                <div class="analytic-info">
                    <span class="analytic-label">Total Stock</span>
                    <span class="analytic-value"><%= totalStock %></span>
                    <span class="analytic-subtext">Units</span>
                </div>
            </div>

            <div class="analytic-card">
                <div class="analytic-icon-wrapper">
                    <i data-lucide="shopping-bag" size="20"></i>
                </div>
                <div class="analytic-info">
                    <span class="analytic-label">Total Sales</span>
                    <span class="analytic-value"><%= typeof totalSales !== 'undefined' ? totalSales : 0 %></span>
                    <span class="analytic-subtext">Orders</span>
                </div>
            </div>

            <div class="analytic-card">
                <div class="analytic-icon-wrapper">
                    <i data-lucide="refresh-cw" size="20"></i>
                </div>
                <div class="analytic-info">
                    <span class="analytic-label">Total Returns</span>
                    <span class="analytic-value"><%= typeof totalReturns !== 'undefined' ? totalReturns : 0 %></span>
                    <span class="analytic-subtext">Returned</span>
                </div>
            </div>

            <div class="analytic-card">
                <div class="analytic-icon-wrapper">
                    <i data-lucide="banknote" size="20"></i>
                </div>
                <div class="analytic-info">
                    <span class="analytic-label">Revenue</span>
                    <span class="analytic-value">
                        ₹<%= typeof totalRevenue !== 'undefined' ? totalRevenue.toLocaleString() : '18,245,600' %>
                    </span>
                    <span class="analytic-subtext">Total Revenue</span>
                </div>
            </div>

        </section>

        <!-- =========================================
             PRODUCT SHOWCASE
        ========================================== -->

        <section class="product-showcase-grid">

            <!-- LEFT -->
            <div class="product-gallery">

                <div class="main-image-container">
                    <img
                        id="mainProductImage"
                        src="<%= variants[0]?.images?.[0] || product.thumbnail %>"
                        alt="<%= product.name %>"
                    >
                </div>

                <div class="thumbnail-list">
                    <%
                      const galleryImages = variants[0]?.images?.length
                        ? variants[0].images
                        : [product.thumbnail]
                    %>
                    <% galleryImages.forEach((image, index) => { %>
                        <div class="thumbnail-item <%= index === 0 ? 'active' : '' %>">
                            <img src="<%= image %>" alt="Thumbnail">
                        </div>
                    <% }) %>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="product-info-panel">

                <div class="info-header">

                    <div class="product-title-group">
                        <span class="badge-status">Premium Series</span>
                        <h2><%= product.name %></h2>
                    </div>

                    <div class="status-active-badge <%= product.isActive ? 'active' : 'blocked' %>">
                        <div class="status-dot-blur"></div>
                        <span class="status-active-text">
                            <%= product.isActive ? 'Active' : 'Inactive' %>
                        </span>
                    </div>

                </div>

                <div class="info-details-grid">

                    <div class="detail-item">
                        <span class="detail-label">Category</span>
                        <span class="detail-value"><%= product.categoryId?.name || "N/A" %></span>
                    </div>

                    <div class="detail-item">
                        <span class="detail-label">Variants</span>
                        <span class="detail-value"><%= totalVariants %> Configs Available</span>
                    </div>

                    <div class="detail-item">
                        <span class="detail-label">Base Price</span>
                        <div class="price-showcase">
                            <span class="detail-value price">₹<%= basePrice.toLocaleString() %></span>
                            <% if(variants[0]?.comparePrice && variants[0]?.comparePrice > variants[0]?.price) { %>
                                <span class="compare-price-large">₹<%= variants[0].comparePrice.toLocaleString() %></span>
                                <span class="discount-badge"><%= variants[0].discountPercentage %>% OFF</span>
                            <% } %>
                        </div>
                    </div>

                </div>

                <div class="detail-item">
                    <span class="detail-label">Product Offer</span>
                    <span class="detail-value">
                        <% if(productOffer) { %>
                            <%= productOffer.discountValue %>% OFF
                        <% } else { %>
                            No Active Offer
                        <% } %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="detail-label">Category Offer</span>
                    <span class="detail-value">
                        <% if(categoryOffer) { %>
                            <%= categoryOffer.discountValue %>% OFF
                        <% } else { %>
                            No Active Offer
                        <% } %>
                    </span>
                </div>

                <div class="description-section">
                    <span class="detail-label">Description</span>
                    <p class="description-text"><%= product.description %></p>
                </div>

                <div class="technical-highlights">
                    <span class="detail-label">Technical Highlights</span>
                    <div class="highlight-tags">
                        <span class="tag">Premium Build</span>
                        <span class="tag">Official Apple Product</span>
                        <span class="tag">High Performance</span>
                    </div>
                </div>

                <div class="technical-highlights">
                    <span class="detail-label">Variant Specifications</span>
                    <div id="variantSpecsContainer" class="highlight-tags">
                        <span class="tag" id="specColor">Black</span>
                        <span class="tag" id="specStorage">256GB</span>
                        <span class="tag" id="specRAM">8GB RAM</span>
                        <span class="tag" id="specSKU">IP17-BLK-256</span>
                        <span class="tag" id="specStock">5 Units</span>
                    </div>
                </div>

            </div>

        </section>

        <!-- =========================================
             VARIANTS
        ========================================== -->

        <section class="variants-section">

            <h3 class="section-title">Variant Management</h3>

            <div class="variant-toolbar">

                <div class="variant-toolbar-left">
                    <div class="search-wrapper">
                        <i data-lucide="search" size="16"></i>
                        <input
                            type="text"
                            id="variantSearch"
                            class="variant-search"
                            placeholder="Search variants..."
                        >
                    </div>
                </div>

                <div class="variant-toolbar-right">
                    <select id="stockFilter" class="variant-filter">
                        <option value="all">All Stock</option>
                        <option value="instock">In Stock</option>
                        <option value="low">Low Stock</option>
                        <option value="critical">Critical</option>
                        <option value="trash">Trash</option>
                    </select>
                    <div class="variant-count-badge"><%= totalVariants %> Variants</div>
                </div>

            </div>

            <div class="table-card">

                <table class="variants-table">

                    <thead>
                        <tr>
                            <th>Preview</th>
                            <th>Variant Name</th>
                            <th>Storage</th>
                            <th>RAM</th>
                            <th>Color</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if(variants.length > 0) { %>

                            <% variants.forEach(variant => { %>

                                <tr
                                    class="variant-row"
                                    data-deleted="<%= variant.isDeleted %>"
                                    data-sku="<%= variant.SKU %>"
                                    data-storage="<%= variant.storage %>"
                                    data-ram="<%= variant.RAM %>"
                                    data-color="<%= variant.color %>"
                                    data-price="<%= variant.price %>"
                                    data-compareprice="<%= variant.comparePrice %>"
                                    data-stock="<%= variant.stock %>"
                                    data-images='<%- JSON.stringify(variant.images) %>'
                                >
                                    <td>
                                        <div class="variant-preview">
                                            <img src="<%= variant.images?.[0] || product.thumbnail %>" alt="">
                                        </div>
                                    </td>
                                    <td class="font-bold"><%= variant.SKU %></td>
                                    <td><%= variant.storage %></td>
                                    <td><%= variant.RAM %></td>
                                    <td><%= variant.color %></td>
                                    <td class="price-cell">
                                        <div class="variant-price-wrap">
                                            <span class="sale-price">₹<%= variant.price.toLocaleString() %></span>
                                            <% if(variant.comparePrice && variant.comparePrice > variant.price) { %>
                                                <span class="compare-price">₹<%= variant.comparePrice.toLocaleString() %></span>
                                                <span class="discount-badge"><%= variant.discountPercentage %>% OFF</span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td>
                                        <% if(variant.stock <= 10) { %>
                                            <span class="stock-badge critical"><%= variant.stock %> units</span>
                                        <% } else if(variant.stock <= 50) { %>
                                            <span class="stock-badge low"><%= variant.stock %> units</span>
                                        <% } else { %>
                                            <span class="stock-badge"><%= variant.stock %> units</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="variant-actions">
                                            <% if(!variant.isDeleted) { %>
                                                <button
                                                    class="btn-icon edit-variant-btn"
                                                    data-id="<%= variant._id %>"
                                                    data-sku="<%= variant.SKU %>"
                                                    data-color="<%= variant.color %>"
                                                    data-storage="<%= variant.storage %>"
                                                    data-ram="<%= variant.RAM %>"
                                                    data-price="<%= variant.price %>"
                                                    data-compareprice="<%= variant.comparePrice %>"
                                                    data-stock="<%= variant.stock %>"
                                                    data-images='<%- JSON.stringify(variant.images) %>'
                                                >
                                                    <i data-lucide="edit-2" size="16"></i>
                                                </button>
                                                <button class="btn-icon delete-variant-btn" data-id="<%= variant._id %>">
                                                    <i data-lucide="trash-2" size="16"></i>
                                                </button>
                                            <% } else { %>
                                                <button class="btn-icon restore-variant-btn" data-id="<%= variant._id %>">
                                                    <i data-lucide="rotate-ccw" size="16"></i>
                                                </button>
                                                <button class="btn-icon permanent-delete-variant-btn" data-id="<%= variant._id %>">
                                                    <i data-lucide="x-circle" size="16"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>

                            <% }) %>

                        <% } else { %>

                            <tr>
                                <td colspan="7">
                                    <div class="empty-variants">
                                        <i data-lucide="package-open" size="52"></i>
                                        <h4>No Variants Found</h4>
                                        <p>Start by adding your first variant.</p>
                                    </div>
                                </td>
                            </tr>

                        <% } %>

                    </tbody>

                </table>

            </div>

        </section>


        <!-- =========================================
             VARIANT MODAL
        ========================================== -->

        <div class="variant-modal-overlay" id="variantModal">

            <div class="variant-modal">

                <!-- HEADER -->
                <div class="variant-modal-header">
                    <div>
                        <h2 id="variantModalTitle">Add Variant</h2>
                        <p>Configure variant inventory and pricing</p>
                    </div>
                    <button class="modal-close-btn" id="closeVariantModal">
                        <i data-lucide="x" size="22"></i>
                    </button>
                </div>

                <!-- BODY -->
                <div class="variant-modal-body">

                    <!-- FORM SECTION -->
                    <form class="variant-form-section" id="variantForm" novalidate>

                        <input type="hidden" id="variantProductId" value="<%= product._id %>">
                        <input type="hidden" id="variantMode" value="add">
                        <input type="hidden" id="editingVariantId">

                        <!-- CONFIG -->
                        <div class="variant-form-group">

                            <h4>Configuration</h4>

                            <div class="variant-grid-3">

                                <div class="vfield">
                                    <label>Color</label>
                                    <input type="text" id="variantColor" placeholder="Space Black">
                                    <span class="vfield-error" id="err-color"></span>
                                </div>

                                <div class="vfield">
                                    <label>Storage</label>
                                    <input type="text" id="variantStorage" placeholder="256GB">
                                    <span class="vfield-error" id="err-storage"></span>
                                </div>

                                <div class="vfield">
                                    <label>RAM</label>
                                    <input type="text" id="variantRAM" placeholder="8GB">
                                    <span class="vfield-error" id="err-ram"></span>
                                </div>

                            </div>

                        </div>

                        <!-- SKU & PRICING -->
                        <div class="variant-form-group">

                            <h4>SKU & Pricing</h4>

                            <div class="variant-grid-3">

                                <div class="vfield">
                                    <label>SKU</label>
                                    <input type="text" id="variantSKU" placeholder="IP17-BLK-256">
                                    <span class="vfield-error" id="err-sku"></span>
                                </div>

                                <div class="vfield">
                                    <label>Price</label>
                                    <input type="number" id="variantPrice" placeholder="119900">
                                    <span class="vfield-error" id="err-price"></span>
                                </div>

                                <div class="vfield">
                                    <label>Compare Price</label>
                                    <input type="number" id="variantComparePrice" placeholder="139900">
                                    <span class="vfield-error" id="err-compare"></span>
                                </div>

                            </div>

                        </div>

                        <!-- INVENTORY -->
                        <div class="variant-form-group">

                            <h4>Inventory</h4>

                            <div class="variant-grid-2">

                                <div class="vfield">
                                    <label>Stock</label>
                                    <input type="number" id="variantStock" placeholder="120">
                                    <span class="vfield-error" id="err-stock"></span>
                                </div>

                            </div>

                        </div>

                        <!-- IMAGE -->
                        <div class="variant-form-group">

                            <h4>Variant Media</h4>

                            <label class="variant-upload-box" id="variantUploadBox">
                                <input
                                    type="file"
                                    hidden
                                    id="variantImageInput"
                                    accept="image/*"
                                    multiple
                                >
                                <i data-lucide="upload" size="28"></i>
                                <span>Upload Variant Image</span>
                            </label>

                            <span class="vfield-error" id="err-images"></span>

                            <div class="variant-images-wrapper">
                                <div class="variant-preview-grid" id="variantPreviewGrid"></div>
                            </div>

                        </div>

                    </form>

                    <!-- PREVIEW PANEL -->
                    <div class="variant-preview-panel">

                        <div class="preview-card">
                            <div class="preview-main-image-wrapper">
                                <img id="previewImage" src="<%= product.thumbnail %>">
                            </div>
                            <h3 id="previewName"><%= product.name %></h3>
                            <p id="previewSpecs">Space Black • 256GB • 8GB</p>
                            <div class="preview-price" id="previewPrice">₹1,19,900</div>
                        </div>

                        <div class="preview-analytics">
                            <div><span>Sales</span><strong>482</strong></div>
                            <div><span>Returns</span><strong>12</strong></div>
                            <div><span>Health</span><strong>98%</strong></div>
                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="variant-modal-footer">
                    <button class="btn-detail" id="cancelVariantBtn" type="button">Cancel</button>
                    <button class="btn-detail btn-edit" id="saveVariantBtn" type="button">Save Variant</button>
                </div>

            </div>

        </div>


        <!-- =========================================
             IMAGE CROPPER MODAL
        ========================================== -->

        <div class="cropper-overlay" id="cropperOverlay">

            <div class="cropper-modal">

                <div class="cropper-header">
                    <h3>Crop Image</h3>
                    <button type="button" id="closeCropperBtn" class="cropper-close-btn">×</button>
                </div>

                <div class="cropper-body">
                    <img id="cropperImage">
                </div>

                <div class="cropper-footer">
                    <button type="button" id="cancelCropBtn" class="btn-detail">Cancel</button>
                    <button type="button" id="cropImageBtn" class="btn-detail btn-edit">Crop & Add</button>
                </div>

            </div>

        </div>


        <!-- =========================================
             FOOTER
        ========================================== -->

        <footer class="site-footer">
            © 2026 iStore Admin — Digital Atelier Environment
        </footer>

    </main>

    <div class="fullscreen-preview" id="fullscreenPreview">
        <img id="fullscreenImage">
    </div>


    <!-- =========================================
         SCRIPTS
    ========================================== -->

    <script>

        lucide.createIcons();

        /* =========================================
           IMAGE SWITCHING
        ========================================== */

        const thumbnails  = document.querySelectorAll(".thumbnail-item");
        const mainImage   = document.getElementById("mainProductImage");

        thumbnails.forEach((thumb) => {
            thumb.addEventListener("click", () => {
                thumbnails.forEach(t => t.classList.remove("active"));
                thumb.classList.add("active");
                const img = thumb.querySelector("img").src;
                mainImage.style.opacity = "0";
                mainImage.style.transform = "scale(0.98)";
                setTimeout(() => {
                    mainImage.src = img;
                    mainImage.onload = () => {
                        mainImage.style.opacity = "1";
                        mainImage.style.transform = "scale(1)";
                    };
                }, 180);
            });
        });


        /* =========================================
           FULLSCREEN IMAGE VIEWER
        ========================================== */

        const fullscreenPreview = document.getElementById("fullscreenPreview");
        const fullscreenImage   = document.getElementById("fullscreenImage");

        mainImage.addEventListener("click", () => {
            fullscreenPreview.classList.add("active");
            fullscreenImage.src = mainImage.src;
            document.body.style.overflow = "hidden";
        });

        fullscreenPreview.addEventListener("click", () => {
            fullscreenPreview.classList.remove("active");
            document.body.style.overflow = "";
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && fullscreenPreview.classList.contains("active")) {
                fullscreenPreview.classList.remove("active");
                document.body.style.overflow = "";
            }
        });


        /* =========================================
           VARIANT SEARCH
        ========================================== */

        const variantSearch = document.getElementById("variantSearch");

        if (variantSearch) {
            variantSearch.addEventListener("keyup", () => {
                const value = variantSearch.value.toLowerCase();
                document.querySelectorAll(".variants-table tbody tr").forEach(row => {
                    row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
                });
            });
        }


        /* =========================================
           STOCK FILTER
        ========================================== */

        const stockFilter = document.getElementById("stockFilter");

        if (stockFilter) {
            stockFilter.addEventListener("change", () => {
                const rows = document.querySelectorAll(".variants-table tbody tr");
                rows.forEach(row => {
                    const stockBadge = row.querySelector(".stock-badge");
                    if (!stockBadge) return;
                    const stock     = parseInt(stockBadge.innerText);
                    const isDeleted = row.dataset.deleted === "true";

                    if      (stockFilter.value === "all")      row.style.display = !isDeleted ? "" : "none";
                    else if (stockFilter.value === "trash")    row.style.display = isDeleted  ? "" : "none";
                    else if (stockFilter.value === "critical") row.style.display = !isDeleted && stock <= 10 ? "" : "none";
                    else if (stockFilter.value === "low")      row.style.display = !isDeleted && stock > 10 && stock <= 50 ? "" : "none";
                    else if (stockFilter.value === "instock")  row.style.display = !isDeleted && stock > 50 ? "" : "none";
                });
            });

            stockFilter.dispatchEvent(new Event("change"));
        }


        /* =========================================
           SALES CHART
        ========================================== */

        const ctx = document.getElementById("salesChart");

        new Chart(ctx, {
            type: "bar",
            data: {
                labels: ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"],
                datasets: [{
                    data: [12,19,14,24,18,29,22],
                    borderRadius: 10,
                    backgroundColor: ["#E9DFEA","#D8C7DA","#C4AEC8","#AF92B4","#9A78A0","#845C8B","#6D4475"]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { color: "rgba(0,0,0,0.04)" }, ticks: { color: "#6B6470" } },
                    x: { grid: { display: false }, ticks: { color: "#6B6470" } }
                }
            }
        });


        /* =========================================
           PREMIUM TOAST
        ========================================== */

        const Toast = Swal.mixin({
            toast: true,
            position: "top",
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            background: "#FFFFFF",
            color: "#2C1421",
            iconColor: "#603763",
            customClass: { popup: "premium-toast" }
        });


        /* =========================================
           DELETE PRODUCT
        ========================================== */

        document.getElementById("deleteProductBtn").addEventListener("click", async () => {
            const result = await Swal.fire({
                title: "Delete Product?",
                text: "This action cannot be undone.",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#603763",
                cancelButtonColor: "#D6CED7",
                confirmButtonText: "Delete",
                background: "#FFFFFF"
            });
            if (result.isConfirmed) {
                const response = await fetch("/admin/delete-product/<%= product._id %>", { method: "PATCH" });
                const data     = await response.json();
                if (data.success) {
                    Toast.fire({ icon: "success", title: data.message });
                    setTimeout(() => { window.location.href = "/admin/products"; }, 1000);
                } else {
                    Toast.fire({ icon: "error", title: "Failed to delete product" });
                }
            }
        });


        /* =========================================
           DELETE VARIANT
        ========================================== */

        document.querySelectorAll(".delete-variant-btn").forEach(btn => {
            btn.addEventListener("click", async () => {
                const id     = btn.dataset.id;
                const result = await Swal.fire({
                    title: "Delete Variant?",
                    text: "Variant will be removed.",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#603763",
                    cancelButtonColor: "#D6CED7",
                    confirmButtonText: "Delete",
                    background: "#FFFFFF"
                });
                if (result.isConfirmed) {
                    const response = await fetch(`/admin/variants/${id}/delete`, { method: "PATCH" });
                    const data     = await response.json();
                    if (data.success) {
                        Toast.fire({ icon: "success", title: data.message });
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        Toast.fire({ icon: "error", title: data.message });
                    }
                }
            });
        });


        /* =========================================
           RESTORE VARIANT
        ========================================== */

        document.querySelectorAll(".restore-variant-btn").forEach(btn => {
            btn.addEventListener("click", async () => {
                const id       = btn.dataset.id;
                const response = await fetch(`/admin/variants/${id}/restore`, { method: "PATCH" });
                const data     = await response.json();
                if (data.success) {
                    Toast.fire({ icon: "success", title: "Variant restored" });
                    setTimeout(() => location.reload(), 1000);
                } else {
                    Toast.fire({ icon: "error", title: data.message });
                }
            });
        });


        /* =========================================
           PERMANENT DELETE VARIANT
        ========================================== */

        document.querySelectorAll(".permanent-delete-variant-btn").forEach(btn => {
            btn.addEventListener("click", async () => {
                const id     = btn.dataset.id;
                const result = await Swal.fire({
                    title: "Delete Permanently?",
                    text: "This action cannot be undone.",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#BA1A1A",
                    cancelButtonColor: "#D6CED7",
                    confirmButtonText: "Delete Forever",
                    background: "#FFFFFF"
                });
                if (!result.isConfirmed) return;
                const response = await fetch(`/admin/variants/${id}/permanent-delete`, { method: "DELETE" });
                const data     = await response.json();
                if (data.success) {
                    Toast.fire({ icon: "success", title: "Variant permanently deleted" });
                    setTimeout(() => location.reload(), 1000);
                } else {
                    Toast.fire({ icon: "error", title: data.message });
                }
            });
        });


        /* =========================================
           MODAL OPEN / CLOSE
        ========================================== */

        const variantModal = document.getElementById("variantModal");

        function openVariantModal() {
            variantModal.classList.add("active");
        }

        function closeVariantModal() {
            variantModal.classList.remove("active");
            resetValidation();
        }

        document.getElementById("openVariantModalBtn").addEventListener("click", () => {
            document.getElementById("variantModalTitle").innerText  = "Add Variant";
            document.getElementById("variantMode").value            = "add";
            document.getElementById("editingVariantId").value       = "";
            document.getElementById("saveVariantBtn").innerText     = "Save Variant";
            document.getElementById("variantForm").reset();
            document.getElementById("previewImage").src             = "<%= product.thumbnail %>";
            document.getElementById("previewSpecs").innerText       = "Space Black • 256GB • 8GB";
            document.getElementById("previewPrice").innerText       = "₹1,19,900";
            existingImages = [];
            selectedFiles  = [];
            renderImages();
            resetValidation();
            openVariantModal();
        });

        document.getElementById("closeVariantModal").addEventListener("click", closeVariantModal);
        document.getElementById("cancelVariantBtn").addEventListener("click",  closeVariantModal);


        /* =========================================
           EDIT VARIANT MODAL
        ========================================== */

        document.querySelectorAll(".edit-variant-btn").forEach((button) => {
            button.addEventListener("click", () => {
                document.getElementById("variantModalTitle").innerText = "Edit Variant";
                document.getElementById("variantMode").value           = "edit";
                document.getElementById("editingVariantId").value      = button.dataset.id;
                document.getElementById("saveVariantBtn").innerText    = "Update Variant";

                document.getElementById("variantSKU").value           = button.dataset.sku;
                document.getElementById("variantColor").value         = button.dataset.color;
                document.getElementById("variantStorage").value       = button.dataset.storage;
                document.getElementById("variantRAM").value           = button.dataset.ram;
                document.getElementById("variantPrice").value         = button.dataset.price;
                document.getElementById("variantComparePrice").value  = button.dataset.compareprice || "";
                document.getElementById("variantStock").value         = button.dataset.stock;

                document.getElementById("previewSpecs").innerText =
                    `${button.dataset.color} • ${button.dataset.storage} • ${button.dataset.ram}`;
                document.getElementById("previewPrice").innerText =
                    `₹${Number(button.dataset.price).toLocaleString()}`;

                existingImages = JSON.parse(button.dataset.images || "[]");
                selectedFiles  = [];
                renderImages();
                resetValidation();
                openVariantModal();
            });
        });


        /* =========================================
           LIVE PREVIEW
        ========================================== */

        ["variantColor","variantStorage","variantRAM","variantPrice","variantComparePrice"].forEach((id) => {
            document.getElementById(id).addEventListener("input", () => {
                const color   = document.getElementById("variantColor").value         || "Space Black";
                const storage = document.getElementById("variantStorage").value       || "256GB";
                const ram     = document.getElementById("variantRAM").value           || "8GB";
                const price   = document.getElementById("variantPrice").value         || "119900";
                const cmp     = document.getElementById("variantComparePrice").value;
                const disc    = cmp > price ? Math.round(((cmp - price) / cmp) * 100) : 0;

                document.getElementById("previewSpecs").innerText = `${color} • ${storage} • ${ram}`;
                document.getElementById("previewPrice").innerHTML = `
                    <div class="preview-price-main">₹${Number(price).toLocaleString()}</div>
                    ${cmp > price ? `
                        <div class="preview-compare-price">₹${Number(cmp).toLocaleString()}</div>
                        <div class="discount-badge">${disc}% OFF</div>
                    ` : ""}
                `;
            });
        });


        /* =========================================
           MULTI IMAGE MANAGER
        ========================================== */

        let selectedFiles  = [];
        let existingImages = [];

        const imageInput  = document.getElementById("variantImageInput");
        const previewGrid = document.getElementById("variantPreviewGrid");
        const previewImage = document.getElementById("previewImage");

        function renderImages() {
            previewGrid.innerHTML = "";

            const allImages = [
                ...existingImages.map(img  => ({ type: "existing", url: img })),
                ...selectedFiles.map(file  => ({ type: "file", file, url: URL.createObjectURL(file) }))
            ];

            if (!allImages.length) {
                previewImage.src = "<%= product.thumbnail %>";
                /* Clear image error if images were removed AFTER a failed submit */
                if (hasAttemptedSubmit) validateImages();
                return;
            }

            previewImage.src = allImages[0].url;

            /* Clear image error once user has added images */
            if (hasAttemptedSubmit) validateImages();

            allImages.forEach((imageData) => {
                const previewItem = document.createElement("div");
                previewItem.className = "preview-image-item";
                previewItem.innerHTML = `
                    <img src="${imageData.url}">
                    <button type="button" class="remove-image-btn">×</button>
                `;

                previewItem.querySelector("img").addEventListener("click", () => {
                    previewImage.src = imageData.url;
                });

                previewItem.querySelector(".remove-image-btn").addEventListener("click", () => {
                    if (imageData.type === "file") {
                        selectedFiles = selectedFiles.filter(f => f !== imageData.file);
                    } else {
                        existingImages = existingImages.filter(img => img !== imageData.url);
                    }
                    renderImages();
                });

                previewGrid.appendChild(previewItem);
            });
        }


        /* =========================================
           CROPPER
        ========================================== */

        const cropperOverlay = document.getElementById("cropperOverlay");
        const cropperImage   = document.getElementById("cropperImage");

        let cropper;
        let pendingFiles = [];

        imageInput.addEventListener("change", async (e) => {
            pendingFiles = Array.from(e.target.files);
            if (!pendingFiles.length) return;
            openCropper(pendingFiles[0]);
        });

        function openCropper(file) {
            const reader = new FileReader();
            reader.onload = function(event) {
                cropperOverlay.classList.add("active");
                cropperImage.src = event.target.result;
                setTimeout(() => {
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(cropperImage, {
                        aspectRatio: 4/5,
                        viewMode: 1,
                        dragMode: "move",
                        autoCropArea: 0.8,
                        movable: true,
                        zoomable: true,
                        scalable: true,
                        rotatable: false,
                        cropBoxMovable: true,
                        cropBoxResizable: true,
                        background: false
                    });
                }, 100);
            };
            reader.readAsDataURL(file);
        }

        document.getElementById("cropImageBtn").addEventListener("click", () => {
            if (!cropper) return;
            const canvas = cropper.getCroppedCanvas({ width: 1200, height: 1200, imageSmoothingEnabled: true, imageSmoothingQuality: "high" });
            canvas.toBlob((blob) => {
                const croppedFile = new File([blob], `variant-${Date.now()}.jpg`, { type: "image/jpeg" });
                selectedFiles.push(croppedFile);
                renderImages();
                cropperOverlay.classList.remove("active");
                cropper.destroy();
                cropper = null;
                pendingFiles.shift();
                if (pendingFiles.length) openCropper(pendingFiles[0]);
            }, "image/jpeg", 0.9);
        });

        function closeCropper() {
            cropperOverlay.classList.remove("active");
            if (cropper) { cropper.destroy(); cropper = null; }
            imageInput.value = "";
        }

        document.getElementById("closeCropperBtn").addEventListener("click", closeCropper);
        document.getElementById("cancelCropBtn").addEventListener("click",  closeCropper);


        /* =========================================
           VARIANT ROW CLICK — SWITCH GALLERY
        ========================================== */

        const variantRows     = document.querySelectorAll(".variant-row");
        const specColor       = document.getElementById("specColor");
        const specStorage     = document.getElementById("specStorage");
        const specRAM         = document.getElementById("specRAM");
        const specSKU         = document.getElementById("specSKU");
        const specStock       = document.getElementById("specStock");
        const galleryContainer = document.querySelector(".thumbnail-list");

        variantRows.forEach((row) => {
            row.addEventListener("click", () => {
                variantRows.forEach(r => r.classList.remove("active-variant"));
                row.classList.add("active-variant");

                const sku          = row.dataset.sku;
                const storage      = row.dataset.storage;
                const ram          = row.dataset.ram;
                const color        = row.dataset.color;
                const stock        = row.dataset.stock;
                const price        = row.dataset.price;
                const comparePrice = row.dataset.compareprice;
                const images       = JSON.parse(row.dataset.images || "[]");
                const discount     = comparePrice > price ? Math.round(((comparePrice - price) / comparePrice) * 100) : 0;

                specColor.innerText   = color;
                specStorage.innerText = storage;
                specRAM.innerText     = `${ram} RAM`;
                specSKU.innerText     = sku;
                specStock.innerText   = `${stock} Units`;

                document.querySelector(".price-showcase").innerHTML = `
                    <span class="detail-value price">₹${Number(price).toLocaleString()}</span>
                    ${comparePrice > price ? `
                        <span class="compare-price-large">₹${Number(comparePrice).toLocaleString()}</span>
                        <span class="discount-badge">${discount}% OFF</span>
                    ` : ""}
                `;

                if (images.length) {
                    mainImage.style.opacity = "0";
                    setTimeout(() => { mainImage.src = images[0]; mainImage.style.opacity = "1"; }, 180);
                }

                galleryContainer.innerHTML = "";
                images.forEach((image, index) => {
                    const thumb = document.createElement("div");
                    thumb.className = `thumbnail-item ${index === 0 ? "active" : ""}`;
                    thumb.innerHTML = `<img src="${image}" alt="Thumbnail">`;
                    thumb.addEventListener("click", () => {
                        document.querySelectorAll(".thumbnail-item").forEach(t => t.classList.remove("active"));
                        thumb.classList.add("active");
                        mainImage.style.opacity = "0";
                        setTimeout(() => { mainImage.src = image; mainImage.style.opacity = "1"; }, 150);
                    });
                    galleryContainer.appendChild(thumb);
                });
            });
        });


        /* =========================================
           ─────────────────────────────────────────
           FORM VALIDATION
           ─────────────────────────────────────────
        ========================================== */

        let hasAttemptedSubmit = false;

        /* ── helpers ── */

        function vSetError(inputEl, errorId, msg) {
            inputEl.classList.add("vinput-error");
            inputEl.classList.remove("vinput-ok");
            const span = document.getElementById(errorId);
            if (span) { span.textContent = msg; span.classList.add("visible"); }
        }

        function vSetOk(inputEl, errorId) {
            inputEl.classList.remove("vinput-error");
            inputEl.classList.add("vinput-ok");
            const span = document.getElementById(errorId);
            if (span) { span.textContent = ""; span.classList.remove("visible"); }
        }

        function vClear(inputEl, errorId) {
            inputEl.classList.remove("vinput-error", "vinput-ok");
            const span = document.getElementById(errorId);
            if (span) { span.textContent = ""; span.classList.remove("visible"); }
        }

        function showImageError(msg) {
            const span = document.getElementById("err-images");
            const box  = document.getElementById("variantUploadBox");
            if (span) { span.textContent = msg; span.classList.add("visible"); }
            if (box)  box.classList.add("upload-error");
        }

        function clearImageError() {
            const span = document.getElementById("err-images");
            const box  = document.getElementById("variantUploadBox");
            if (span) { span.textContent = ""; span.classList.remove("visible"); }
            if (box)  box.classList.remove("upload-error");
        }

        /* ── field validators (return error string or null) ── */
        
function validateColor() {
    const el = document.getElementById("variantColor");
    const val = el.value.trim();

    if (!val)
        return [el, "Color is required"];

    if (val.length < 2)
        return [el, "Color must be at least 2 characters"];

    if (val.length > 40)
        return [el, "Color cannot exceed 40 characters"];

    if (!/^[A-Za-z]/.test(val))
        return [el, "Color must start with a letter"];

    if (!/^[A-Za-z\s&-]+$/.test(val))
        return [el, "Only letters, spaces, hyphens and & are allowed"];

    return [el, null];
}

        function validateStorage() {
            const el  = document.getElementById("variantStorage");
            const val = el.value.trim();
            if (!val)                              return [el, "Storage is required"];
            if (!/^[0-9]+(GB|TB|MB)$/i.test(val)) return [el, "Format must be like 256GB, 1TB or 512MB"];
            return [el, null];
        }

        function validateRAM() {
            const el  = document.getElementById("variantRAM");
            const val = el.value.trim();
            if (!val)                           return [el, "RAM is required"];
            if (!/^[0-9]+(GB|MB)$/i.test(val)) return [el, "Format must be like 8GB or 16GB"];
            return [el, null];
        }

 function validateSKU() {
    const el = document.getElementById("variantSKU");
    const val = el.value.trim();

    if (!val)
        return [el, "SKU is required"];

    if (val.length < 3)
        return [el, "SKU must be at least 3 characters"];

    if (val.length > 50)
        return [el, "SKU cannot exceed 50 characters"];

    // First 3 characters must be alphabets
    if (!/^[A-Z]{3}/.test(val))
        return [el, "First 3 characters must be letters"];

    // Entire SKU can contain only uppercase letters, numbers and hyphens
    if (!/^[A-Z0-9-]+$/.test(val))
        return [el, "Only uppercase letters, numbers and hyphens are allowed"];

    return [el, null];
}

        function validatePrice() {
            const el  = document.getElementById("variantPrice");
            const val = el.value.trim();
            if (!val)                    return [el, "Price is required"];
            if (!Number.isInteger(+val) || +val < 1) return [el, "Price must be a whole number greater than 0"];
            if (+val > 10000000)         return [el, "Price seems too high"];
            return [el, null];
        }

        function validateComparePrice() {
            const el    = document.getElementById("variantComparePrice");
            const val   = el.value.trim();
            const price = +document.getElementById("variantPrice").value;
            if (!val) return [el, null]; /* optional */
            if (!Number.isInteger(+val) || +val < 1) return [el, "Compare price must be a whole number greater than 0"];
            if (+val > 10000000)  return [el, "Compare price seems too high"];
            if (+val <= price)    return [el, "Compare price must be higher than the sale price"];
            return [el, null];
        }

        function validateStock() {
            const el  = document.getElementById("variantStock");
            const val = el.value.trim();
            if (val === "")               return [el, "Stock is required"];
            if (!Number.isInteger(+val))  return [el, "Stock must be a whole number"];
            if (+val < 0)                 return [el, "Stock cannot be negative"];
            if (+val > 999999)            return [el, "Stock value is too high"];
            return [el, null];
        }

        function validateImages() {
            const mode  = document.getElementById("variantMode").value;
            const total = (existingImages?.length || 0) + (selectedFiles?.length || 0);
            if (total === 0) {
                showImageError(
                    mode === "add"
                        ? "Please upload at least one variant image"
                        : "A variant must have at least one image"
                );
                return false;
            }
            clearImageError();
            return true;
        }

        /* ── map each validator to its error span id ── */

        const FIELD_MAP = [
            { fn: validateColor,        errId: "err-color"   },
            { fn: validateStorage,      errId: "err-storage" },
            { fn: validateRAM,          errId: "err-ram"     },
            { fn: validateSKU,          errId: "err-sku"     },
            { fn: validatePrice,        errId: "err-price"   },
            { fn: validateComparePrice, errId: "err-compare" },
            { fn: validateStock,        errId: "err-stock"   },
        ];

        /* ── run one field and show/clear its error ── */

        function runField(fn, errId) {
            const [el, msg] = fn();
            if (msg) { vSetError(el, errId, msg); return false; }
            else      { vSetOk(el, errId);         return true;  }
        }

        /* ── wire blur on each input ── */

        const fieldInputIds = {
            "variantColor":        { fn: validateColor,        errId: "err-color"   },
            "variantStorage":      { fn: validateStorage,      errId: "err-storage" },
            "variantRAM":          { fn: validateRAM,          errId: "err-ram"     },
            "variantSKU":          { fn: validateSKU,          errId: "err-sku"     },
            "variantPrice":        { fn: validatePrice,        errId: "err-price"   },
            "variantComparePrice": { fn: validateComparePrice, errId: "err-compare" },
            "variantStock":        { fn: validateStock,        errId: "err-stock"   },
        };

        Object.entries(fieldInputIds).forEach(([id, { fn, errId }]) => {
            const input = document.getElementById(id);
            if (!input) return;

            /* Validate on blur */
            input.addEventListener("blur", () => runField(fn, errId));

            /* Live-correct once the field is in error state */
            input.addEventListener("input", () => {
                if (input.classList.contains("vinput-error")) {
                    runField(fn, errId);
                }
            });
        });

        /* ── reset all validation states (called when modal opens) ── */

        function resetValidation() {
            Object.entries(fieldInputIds).forEach(([id, { errId }]) => {
                const input = document.getElementById(id);
                if (input) vClear(input, errId);
            });
            clearImageError();
            hasAttemptedSubmit = false;
        }


        /* =========================================
           SAVE VARIANT — VALIDATED
        ========================================== */

        document.getElementById("saveVariantBtn").addEventListener("click", async () => {

            hasAttemptedSubmit = true;

            /* Run all field validators */
            let allOk = true;
            FIELD_MAP.forEach(({ fn, errId }) => {
                if (!runField(fn, errId)) allOk = false;
            });

            /* Validate images */
            if (!validateImages()) allOk = false;

            /* Scroll to first error and stop */
            if (!allOk) {
                const firstError = document.querySelector(
                    "#variantForm .vinput-error, #variantUploadBox.upload-error"
                );
                firstError?.scrollIntoView({ behavior: "smooth", block: "center" });
                return;
            }

            /* ── Build FormData and send ── */

            const mode      = document.getElementById("variantMode").value;
            const variantId = document.getElementById("editingVariantId").value;
            const formData  = new FormData();

            formData.append("productId",    document.getElementById("variantProductId").value);
            formData.append("SKU",          document.getElementById("variantSKU").value.trim());
            formData.append("color",        document.getElementById("variantColor").value.trim());
            formData.append("storage",      document.getElementById("variantStorage").value.trim());
            formData.append("RAM",          document.getElementById("variantRAM").value.trim());
            formData.append("price",        document.getElementById("variantPrice").value);
            formData.append("comparePrice", document.getElementById("variantComparePrice").value);
            formData.append("stock",        document.getElementById("variantStock").value);

            selectedFiles.forEach(file => formData.append("variantImages", file));
            formData.append("existingImages", JSON.stringify(existingImages));

            try {
                const url    = mode === "add"
                    ? `/admin/products/${document.getElementById("variantProductId").value}/variants/add`
                    : `/admin/variants/${variantId}/edit`;

                const saveBtn       = document.getElementById("saveVariantBtn");
                saveBtn.disabled    = true;
                saveBtn.style.opacity = "0.7";

                const response = await fetch(url, { method: "POST", body: formData });
                const data     = await response.json();

                saveBtn.disabled      = false;
                saveBtn.style.opacity = "";

                if (data.success) {
                    Toast.fire({ icon: "success", title: data.message });
                    closeVariantModal();
                    setTimeout(() => location.reload(), 1200);
                } else {
                    Toast.fire({ icon: "error", title: data.message });
                }

            } catch (error) {
                console.error(error);
                document.getElementById("saveVariantBtn").disabled = false;
                document.getElementById("saveVariantBtn").style.opacity = "";
                Toast.fire({ icon: "error", title: "Something went wrong" });
            }

        });


        /* =========================================
           PARALLAX EFFECT
        ========================================== */

        const imageContainer = document.querySelector(".main-image-container");

        imageContainer.addEventListener("mousemove", (e) => {
            const rect    = imageContainer.getBoundingClientRect();
            const rotateY = ((e.clientX - rect.left) / rect.width  - 0.5) * 5;
            const rotateX = ((e.clientY - rect.top)  / rect.height - 0.5) * -5;
            mainImage.style.transform = `perspective(1200px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.03)`;
        });

        imageContainer.addEventListener("mouseleave", () => {
            mainImage.style.transform = `perspective(1200px) rotateX(0) rotateY(0) scale(1)`;
        });


        /* =========================================
           MOBILE SWIPE GALLERY
        ========================================== */

        let currentIndex = 0;
        const imageItems = [...thumbnails];
        let touchStartX  = 0;
        let touchEndX    = 0;

        mainImage.addEventListener("touchstart", (e) => { touchStartX = e.changedTouches[0].screenX; });
        mainImage.addEventListener("touchend",   (e) => { touchEndX   = e.changedTouches[0].screenX; handleSwipe(); });

        function handleSwipe() {
            if (touchEndX < touchStartX - 50) currentIndex = (currentIndex + 1) % imageItems.length;
            if (touchEndX > touchStartX + 50) currentIndex = (currentIndex - 1 + imageItems.length) % imageItems.length;
            imageItems[currentIndex].click();
        }

    </script>

</body>
</html>
