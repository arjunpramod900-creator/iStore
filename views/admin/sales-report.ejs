<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales Analytics - Admin | iStore</title>
  <link rel="stylesheet" href="/css/components/admin-sidebar.css">
  <link rel="stylesheet" href="/css/admin-sales-report.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<%- include('../partials/admin/sidebar') %>

<%
  const safeReport = report || {};

  const chartLabels    = safeReport.chartLabels    || [];
  const chartData      = safeReport.chartData      || [];
  const categoriesData = safeReport.topCategories  || [];
  const paymentsData   = safeReport.paymentMethods || { cod: 0, razorpay: 0, wallet: 0 };
  const paymentCounts  = safeReport.paymentCounts  || { cod: 0, razorpay: 0, wallet: 0 };
  const topProducts    = safeReport.topProducts    || [];
  const recentOrders   = safeReport.recentOrders   || [];

  // Revenue figures — all sourced directly from the service
  const grossRevenue        = safeReport.grossRevenue       || 0;
  const totalRefundAmount   = safeReport.totalRefundAmount  || 0;
  const netRevenue          = safeReport.netRevenue         || 0;
  const totalDiscount       = safeReport.totalDiscount      || 0;
  const totalOfferDiscount  = safeReport.totalOfferDiscount || 0;
  const totalCouponDiscount = safeReport.totalCouponDiscount|| 0;

  // Counts & rates
  const totalSalesCount     = safeReport.totalSalesCount    || 0;
  const totalReturnedCount  = safeReport.totalReturnedCount || 0;
  const totalCompletedOrders= safeReport.totalCompletedOrders || 0;

  // avgOrderValue now comes pre-computed from the service
  const avgOrderValue = safeReport.avgOrderValue || 0;

  /* Friendly chart title per filter */
  const chartTitles = {
    daily:   "Today — Hourly Revenue",
    weekly:  "Last 7 Days — Daily Revenue",
    monthly: "This Month — Daily Revenue",
    yearly:  "This Year — Monthly Revenue",
    custom:  "Custom Range — Revenue",
  };
  const chartTitle = chartTitles[filter] || "Revenue Trends";

  function badgeClass(s) {
    const map = {
      DELIVERED:        "badge-delivered",
      PROCESSING:       "badge-processing",
      PENDING:          "badge-pending",
      CANCELLED:        "badge-cancelled",
      RETURNED:         "badge-returned",
      SHIPPED:          "badge-processing",
      "OUT FOR DELIVERY": "badge-processing",
    };
    return map[(s || "").toUpperCase()] || "badge-pending";
  }
%>

<main class="admin-main dashboard-main">

  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="header-left">
      <nav class="breadcrumb">
        <a href="/admin/dashboard">DASHBOARD</a>
        <i data-lucide="chevron-right" size="12"></i>
        <span class="current">REPORTS</span>
      </nav>
      <h1 class="page-title">Sales Analytics</h1>
      <p class="page-subtitle">Deep dive into your revenue performance and customer growth.</p>
    </div>

    <div style="display:flex;gap:12px;">
      <a href="/admin/sales-report/pdf?filter=<%= filter %>&startDate=<%= startDate || '' %>&endDate=<%= endDate || '' %>"
        class="btn-add">PDF Report</a>
      <a href="/admin/sales-report/excel?filter=<%= filter %>&startDate=<%= startDate || '' %>&endDate=<%= endDate || '' %>"
        class="btn-add">Excel Report</a>
    </div>
  </header>

  <!-- STATS GRID -->
  <section class="stats-grid">

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">TOTAL ORDERS SOLD</span></div>
      <span class="stat-value"><%= totalSalesCount.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Delivered orders in period</div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">GROSS REVENUE</span></div>
      <span class="stat-value">₹<%= grossRevenue.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Total collected from delivered orders</div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">TOTAL REFUNDS</span></div>
      <span class="stat-value">₹<%= totalRefundAmount.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Refunded for <%= totalReturnedCount %> returned order<%= totalReturnedCount !== 1 ? 's' : '' %></div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">NET REVENUE</span></div>
      <span class="stat-value">₹<%= netRevenue.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Gross revenue minus refunds</div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">TOTAL DISCOUNT</span></div>
      <span class="stat-value">₹<%= totalDiscount.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Offer: ₹<%= totalOfferDiscount.toLocaleString("en-IN") %> · Coupon: ₹<%= totalCouponDiscount.toLocaleString("en-IN") %></div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">COUPON SAVINGS</span></div>
      <span class="stat-value">₹<%= totalCouponDiscount.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Coupon deductions applied</div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">AVG ORDER VALUE</span></div>
      <span class="stat-value">₹<%= avgOrderValue.toLocaleString("en-IN") %></span>
      <div class="stat-sub">Gross revenue ÷ delivered orders</div>
    </div>

    <div class="stat-card">
      <div class="stat-header"><span class="stat-label">RETURN RATE</span></div>
      <span class="stat-value"><%= safeReport.returnRate || "0.0" %>%</span>
      <div class="stat-sub">Returns ÷ (delivered + returned)</div>
    </div>

  </section>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <div class="filter-chip-group">
      <a href="/admin/sales-report?filter=daily"
        class="filter-chip <%= filter === 'daily'   ? 'active' : '' %>">Today</a>
      <a href="/admin/sales-report?filter=weekly"
        class="filter-chip <%= filter === 'weekly'  ? 'active' : '' %>">Last 7 Days</a>
      <a href="/admin/sales-report?filter=monthly"
        class="filter-chip <%= filter === 'monthly' ? 'active' : '' %>">This Month</a>
      <a href="/admin/sales-report?filter=yearly"
        class="filter-chip <%= filter === 'yearly'  ? 'active' : '' %>">This Year</a>
      <a href="#" id="customFilterBtn"
        class="filter-chip <%= filter === 'custom'  ? 'active' : '' %>">Custom</a>
    </div>
  </div>

  <!-- REPORT PERIOD -->
  <div class="report-period">
    <strong>Report Period:</strong>
    <%= safeReport.resolvedStartDate %> — <%= safeReport.resolvedEndDate %>
  </div>

  <!-- REVENUE CHART -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h2 class="chart-card-title"><%= chartTitle %></h2>
      <div class="chart-legend">
        <div class="legend-item">
          <div class="legend-dot current"></div>
          <span>Net Revenue (₹)</span>
        </div>
      </div>
    </div>
    <div class="chart-canvas-wrapper">
      <canvas id="revenueChart"></canvas>
    </div>
  </div>

  <!-- PERFORMANCE GRID -->
  <div class="perf-grid">

    <!-- Sales by Category -->
    <div class="perf-card">
      <h3 class="perf-card-title">Sales by Category</h3>
      <div class="progress-list">
        <% if (categoriesData.length > 0) { %>
          <% categoriesData.forEach(cat => { %>
            <div class="progress-item">
              <div class="progress-info">
                <span><%= cat._id %></span>
                <span>₹<%= (cat.revenue || 0).toLocaleString("en-IN") %> &nbsp;<em style="color:var(--text-muted);font-size:11px;font-style:normal;">(<%= cat.percentage %>%)</em></span>
              </div>
              <div class="progress-bar-bg">
                <div class="progress-bar-fill fill-purple-gradient" style="width:<%= cat.percentage %>%"></div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p style="color:var(--text-muted);font-size:13px;">No category data for this period.</p>
        <% } %>
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="perf-card">
      <h3 class="perf-card-title">Payment Methods</h3>
      <div class="payment-grid">
        <div class="pay-card">
          <i data-lucide="banknote" class="pay-icon"></i>
          <span class="pay-label">COD</span>
          <span class="pay-value"><%= paymentsData.cod %>%</span>
          <span style="font-size:11px;color:var(--text-muted);"><%= paymentCounts.cod %> order<%= paymentCounts.cod !== 1 ? 's' : '' %></span>
        </div>
        <div class="pay-card">
          <i data-lucide="credit-card" class="pay-icon"></i>
          <span class="pay-label">Razorpay</span>
          <span class="pay-value"><%= paymentsData.razorpay %>%</span>
          <span style="font-size:11px;color:var(--text-muted);"><%= paymentCounts.razorpay %> order<%= paymentCounts.razorpay !== 1 ? 's' : '' %></span>
        </div>
        <div class="pay-card wide">
          <i data-lucide="wallet" class="pay-icon"></i>
          <span class="pay-label">Wallet</span>
          <span class="pay-value"><%= paymentsData.wallet %>%</span>
          <span style="font-size:11px;color:var(--text-muted);"><%= paymentCounts.wallet %> order<%= paymentCounts.wallet !== 1 ? 's' : '' %></span>
        </div>
      </div>
    </div>

  </div>

  <!-- BOTTOM GRID: Sales by Product -->
  <div class="bottom-grid">
    <div class="table-card">
      <div class="table-header">
        <h2>Top Products by Revenue</h2>
        <a href="/admin/products" class="table-link">View All Products →</a>
      </div>
      <div class="table-responsive">
        <table class="stbl">
          <thead>
            <tr>
              <th>#</th>
              <th>Product</th>
              <th class="td-center">Units Sold</th>
              <th class="td-right">Revenue</th>
            </tr>
          </thead>
          <tbody>
            <% if (topProducts.length > 0) { %>
              <% topProducts.forEach((product, idx) => { %>
                <tr>
                  <td style="color:var(--text-muted);font-size:12px;"><%= idx + 1 %></td>
                  <td>
                    <div class="prod-cell">
                      <div class="prod-icon"><i data-lucide="package" size="18"></i></div>
                      <span class="prod-name"><%= product.name %></span>
                    </div>
                  </td>
                  <td class="td-center"><%= (product.units || 0).toLocaleString("en-IN") %></td>
                  <td class="td-right">₹<%= (product.revenue || 0).toLocaleString("en-IN") %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4" style="color:var(--text-muted);padding:24px;">No product sales for this period.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- RECENT ORDERS TABLE -->
  <div class="table-card">
    <div class="table-header">
      <h2>Recent Orders</h2>
      <div class="table-header-right">
        <div class="search-wrapper">
          <i data-lucide="search" size="15" class="search-icon"></i>
          <input type="text" class="search-input" placeholder="Search orders..." id="orderSearch">
        </div>
        <a href="/admin/sales-report/excel?filter=<%= filter %>&startDate=<%= startDate || '' %>&endDate=<%= endDate || '' %>"
          class="btn-export">
          <i data-lucide="download" size="15"></i> Export
        </a>
      </div>
    </div>

    <div class="table-responsive">
      <table class="stbl" id="ordersTable">
        <thead>
          <tr>
            <th>#</th>
            <th>Order ID</th>
            <th>Customer</th>
            <th class="td-right">Amount Paid</th>
            <th>Status</th>
            <th class="hide-mobile">Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentOrders.length > 0) { %>
            <% recentOrders.forEach((order, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td style="font-weight:700;color:#603763;"><%= order.orderId %></td>
                <td>
                  <div class="prod-cell">
                    <div class="prod-icon round"><i data-lucide="user" size="15"></i></div>
                    <span class="prod-name"><%= order.shippingAddress?.fullName || "Customer" %></span>
                  </div>
                </td>
                <td class="td-right" style="font-weight:700;">
                  ₹<%= (order.displayAmount || 0).toLocaleString("en-IN") %>
                </td>
                <td>
                  <span class="badge <%= badgeClass(order.orderStatus) %>">
                    <%= order.orderStatus %>
                  </span>
                </td>
                <td class="hide-mobile" style="color:var(--text-muted);font-size:12px;">
                  <%= new Date(order.createdAt).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="6" style="color:var(--text-muted);padding:24px;">No orders found for this period.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="pagination-footer">
      <span class="pagination-info">
        Showing <%= recentOrders.length %> most recent orders in period
      </span>
      <div class="pagination-controls">
        <button class="page-btn" type="button"><i data-lucide="chevron-left" size="14"></i></button>
        <a href="#" class="page-btn active">1</a>
        <button class="page-btn" type="button"><i data-lucide="chevron-right" size="14"></i></button>
      </div>
    </div>
  </div>

  <footer class="page-footer">
    <span class="footer-text">© 2026 iStore Admin</span>
  </footer>

</main>

<!-- Custom Date Range Modal -->
<dialog id="customDateModal" style="padding:28px;border:none;border-radius:16px;margin:auto;box-shadow:0 8px 48px rgba(46,15,47,0.16);min-width:320px;max-width:400px;width:90%;">
  <form method="GET" action="/admin/sales-report" style="display:flex;flex-direction:column;gap:16px;">
    <input type="hidden" name="filter" value="custom">
    <h3 style="margin:0;color:#2C1421;font-size:18px;font-weight:700;letter-spacing:-0.3px;">Custom Date Range</h3>
    <div style="display:flex;flex-direction:column;gap:6px;">
      <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#4d444c;">Start Date</label>
      <input type="date" name="startDate" id="modalStartDate" required
        style="padding:10px 14px;border:1px solid rgba(208,195,204,0.3);border-radius:10px;font-family:inherit;font-size:14px;color:#2c1421;outline:none;">
      <span id="startDateError" style="display:none;color:#e74c3c;font-size:12px;font-weight:500;"></span>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      <label style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:#4d444c;">End Date</label>
      <input type="date" name="endDate" id="modalEndDate" required
        style="padding:10px 14px;border:1px solid rgba(208,195,204,0.3);border-radius:10px;font-family:inherit;font-size:14px;color:#2c1421;outline:none;">
      <span id="endDateError" style="display:none;color:#e74c3c;font-size:12px;font-weight:500;"></span>
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:4px;">
      <button type="button"
        onclick="document.getElementById('customDateModal').close()"
        style="padding:10px 20px;border:none;background:#f4f4f5;border-radius:10px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;">
        Cancel
      </button>
      <button type="button" id="applyCustomDate"
        style="padding:10px 20px;border:none;background:linear-gradient(135deg,#603763,#7a4e7c);color:#fff;border-radius:10px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;">
        Apply
      </button>
    </div>
  </form>
</dialog>

<script>
  lucide.createIcons();

  /* ── Custom date modal ── */
  document.getElementById("customFilterBtn").addEventListener("click", e => {
    e.preventDefault();
    document.getElementById("customDateModal").showModal();
  });

  /* Validate custom date range before submitting */
  document.getElementById("applyCustomDate").addEventListener("click", () => {
    const startInput = document.getElementById("modalStartDate");
    const endInput   = document.getElementById("modalEndDate");
    const startErr   = document.getElementById("startDateError");
    const endErr     = document.getElementById("endDateError");

    let valid = true;
    startErr.style.display = "none";
    endErr.style.display   = "none";

    const today = new Date();
    today.setHours(23, 59, 59, 999);

    if (!startInput.value) {
      startErr.textContent   = "Start date is required";
      startErr.style.display = "block";
      valid = false;
    }

    if (!endInput.value) {
      endErr.textContent   = "End date is required";
      endErr.style.display = "block";
      valid = false;
    }

    if (startInput.value && endInput.value) {
      const start = new Date(startInput.value);
      const end   = new Date(endInput.value);

      if (start > today) {
        startErr.textContent   = "Start date cannot be in the future";
        startErr.style.display = "block";
        valid = false;
      }

      if (end > today) {
        endErr.textContent   = "End date cannot be in the future";
        endErr.style.display = "block";
        valid = false;
      }

      if (start > end) {
        endErr.textContent   = "End date must be after start date";
        endErr.style.display = "block";
        valid = false;
      }
    }

    if (valid) {
      startInput.closest("form").submit();
    }
  });

  /* ── Order search ── */
  document.getElementById("orderSearch").addEventListener("input", function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll("#ordersTable tbody tr").forEach(row => {
      row.style.display = row.innerText.toLowerCase().includes(q) ? "" : "none";
    });
  });

  /* ── Revenue Chart ── */
  const serverLabels = <%- JSON.stringify(chartLabels) %>;
  const serverData   = <%- JSON.stringify(chartData) %>;
  const filterType   = "<%= filter %>";

  document.addEventListener("DOMContentLoaded", function () {

    const ctx  = document.getElementById("revenueChart").getContext("2d");
    const grad = ctx.createLinearGradient(0, 0, 0, 280);
    grad.addColorStop(0, "rgba(96,55,99,0.22)");
    grad.addColorStop(1, "rgba(96,55,99,0)");

    /* Bar chart for hourly (daily), line for everything else */
    const useBar = (filterType === "daily");

    new Chart(ctx, {
      type: useBar ? "bar" : "line",
      data: {
        labels: serverLabels,
        datasets: [{
          label: "Net Revenue (₹)",
          data:  serverData,
          borderColor:          "#603763",
          borderWidth:          useBar ? 0 : 2.5,
          backgroundColor:      useBar ? "rgba(96,55,99,0.55)" : grad,
          fill:                 !useBar,
          tension:              0.4,
          borderRadius:         useBar ? 8 : 0,
          pointBackgroundColor: "#FFFFFF",
          pointBorderColor:     "#603763",
          pointBorderWidth:     2,
          pointRadius:          useBar ? 0 : 4,
          pointHoverRadius:     useBar ? 0 : 6,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        layout: { padding: { top: 16, bottom: 8, left: 4, right: 4 } },
        plugins: {
          legend: { display: false },
          tooltip: {
            mode: "index",
            intersect: false,
            backgroundColor: "#2C1421",
            titleColor: "#FFFFFF",
            bodyColor:  "#FFFFFF",
            padding:    12,
            cornerRadius: 10,
            callbacks: {
              label: ctx => {
                const v = ctx.parsed.y;
                return " Net Revenue: ₹" + new Intl.NumberFormat("en-IN").format(v);
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false, drawBorder: false },
            ticks: {
              color:  "#4D444C",
              font:   { family: "Inter", size: 11, weight: "600" },
              padding: 8,
              maxTicksLimit: filterType === "daily" ? 12 : undefined,
            },
          },
          y: {
            beginAtZero: true,
            grid:  { color: "rgba(208,195,204,0.2)", drawBorder: false },
            ticks: {
              color: "#4D444C",
              font:  { family: "Inter", size: 11 },
              callback: v => "₹" + new Intl.NumberFormat("en-IN").format(v),
            },
          },
        },
        interaction: { mode: "nearest", axis: "x", intersect: false },
      },
    });
  });
</script>

</body>
</html>
