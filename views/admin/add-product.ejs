<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Add New Product - Admin | iStore
    </title>

    <link rel="stylesheet" href="/css/components/admin-sidebar.css">

    <link
        rel="stylesheet"
        href="/css/admin-dashboard.css"
    >

    <link
        rel="stylesheet"
        href="/css/admin-add-product.css"
    >

    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet"
    >

    <script src="https://unpkg.com/lucide@latest"></script>

</head>

<body>
 <!-- Sidebar Navbar -->
   <%- include('../partials/admin/sidebar') %>

<main class="main-canvas">

    <!-- PAGE HEADER -->

    <header class="header-section">

        <nav class="breadcrumbs">

            <a href="/admin/dashboard">
                Dashboard
            </a>

            <span>/</span>

            <a href="/admin/products">
                Products
            </a>

            <span>/</span>

            <span class="active">
                Add Product
            </span>

        </nav>

        <h1 class="page-title">
            Add New Product
        </h1>

    </header>

    <% if(error){ %>

        <div class="error-alert">

            <%= error %>

        </div>

    <% } %>

    <form
        action="/admin/products/add"
        method="POST"
        enctype="multipart/form-data"
        class="bento-form-grid"
    >

        <!-- LEFT COLUMN -->

        <div class="column">

            <!-- BASIC DETAILS -->

            <section class="section-card">

                <div class="section-header">

                    <i
                        data-lucide="package"
                        size="20"
                    ></i>

                    <h2>
                        Product Basic Details
                    </h2>

                </div>

                <!-- PRODUCT NAME -->

                <div class="form-group">

                    <label class="form-label">
                        Product Name
                    </label>

                    <input
                        type="text"
                        name="name"
                        class="form-input"
                        placeholder="e.g., iPhone 17 Pro Max"
                        required
                    >

                </div>

                <!-- CATEGORY + STATUS -->

                <div class="form-row">

                    <div class="form-group">

                        <label class="form-label">
                            Category
                        </label>

                        <select
                            name="categoryId"
                            class="form-select"
                            required
                        >

                            <option value="">
                                Select Category
                            </option>

                            <% categories.forEach(category => { %>

                                <option value="<%= category._id %>">

                                    <%= category.name %>

                                </option>

                            <% }) %>

                        </select>

                    </div>

                    <div class="form-group">

                        <label class="form-label">
                            Product Status
                        </label>

                        <select
                            name="isActive"
                            class="form-select"
                        >

                            <option value="true">
                                Active
                            </option>

                            <option value="false">
                                Inactive
                            </option>

                        </select>

                    </div>

                </div>

                <!-- DESCRIPTION -->

                <div class="form-group">

                    <label class="form-label">
                        Description
                    </label>

                    <textarea
                        name="description"
                        class="form-textarea"
                        placeholder="Write premium product description..."
                        required
                    ></textarea>

                </div>

            </section>

            <!-- PRODUCT IMAGES -->

            <section class="section-card">

                <div class="section-header">

                    <i
                        data-lucide="image"
                        size="18"
                    ></i>

                    <h2>
                        Product Images
                    </h2>

                </div>

                <div class="image-grid">

                    <!-- UPLOAD SLOT -->

                    <label class="upload-slot">

                        <input
                            type="file"
                            name="thumbnail"
                            id="thumbnailInput"
                            accept="image/*"
                            hidden
                            required
                        >

                        <i
                            data-lucide="plus-circle"
                            size="24"
                        ></i>

                        <span>
                            Upload Image
                        </span>

                    </label>

                    <!-- PREVIEW -->

                    <div
                        class="image-preview"
                        id="thumbnailPreview"
                        style="display:none;"
                    >

                        <img
                            src=""
                            id="previewImage"
                            alt="Preview"
                        >

                        <button
                            type="button"
                            class="remove-img-btn"
                            id="removeImageBtn"
                        >

                            <i
                                data-lucide="x"
                                size="14"
                            ></i>

                        </button>

                    </div>

                </div>

                <p class="image-note">

                    Recommended size:
                    2000×2000px

                </p>
                <!-- VARIANT IMAGES -->

<div class="variant-images-wrapper">

    <label class="form-label">
        Variant Gallery Images
    </label>

    <input
        type="file"
        name="variantImages"
        id="variantImages"
        accept="image/*"
        multiple
        required
    >

    <p class="image-note">
        Upload minimum 3 images
    </p>

    <div
        class="variant-preview-grid"
        id="variantPreviewGrid"
    ></div>

</div>

            </section>

        </div>

        <!-- RIGHT COLUMN -->

        <div class="column">

            <!-- PRICING -->

            <section class="section-card">

                <div class="section-header">

                    <i
                        data-lucide="banknote"
                        size="20"
                    ></i>

                    <h2>
                        Pricing & Stock
                    </h2>

                </div>

                <!-- PRICE -->

                <div class="form-group">

                    <label class="form-label">
                        Price
                    </label>

                    <div class="price-input-wrapper">

                        <span class="price-symbol">
                            ₹
                        </span>

                        <input
                            type="number"
                            name="price"
                            class="form-input"
                            placeholder="129900"
                            required
                        >

                    </div>

                </div>

                <!-- COMPARE PRICE -->

                <div class="form-group">

                    <label class="form-label">
                        Compare Price
                    </label>

                    <div class="price-input-wrapper">

                        <span class="price-symbol">
                            ₹
                        </span>

                        <input
                            type="number"
                            name="comparePrice"
                            class="form-input"
                            placeholder="139900"
                        >

                    </div>

                </div>

                <div class="form-row">

                    <!-- STOCK -->

                    <div class="form-group">

                        <label class="form-label">
                            Stock
                        </label>

                        <input
                            type="number"
                            name="stock"
                            class="form-input"
                            placeholder="100"
                            required
                        >

                    </div>

                    <!-- SKU -->

                    <div class="form-group">

                        <label class="form-label">
                            SKU
                        </label>

                        <input
                            type="text"
                            name="SKU"
                            class="form-input sku-input"
                            placeholder="APL-IP17-512"
                            required
                        >

                    </div>

                </div>

            </section>

            <!-- TECHNICAL SPECS -->

            <section class="section-card">

                <div class="section-header">

                    <i
                        data-lucide="cpu"
                        size="18"
                    ></i>

                    <h2>
                        Technical Specs
                    </h2>

                </div>

                <div class="form-group">

                    <label class="form-label">
                        Storage
                    </label>

                    <input
                        type="text"
                        name="storage"
                        class="form-input"
                        placeholder="256GB"
                    >

                </div>

                <div class="form-group">

                    <label class="form-label">
                        RAM
                    </label>

                    <input
                        type="text"
                        name="RAM"
                        class="form-input"
                        placeholder="8GB"
                    >

                </div>

                <div class="form-group">

                    <label class="form-label">
                        Color
                    </label>

                    <input
                        type="text"
                        name="color"
                        class="form-input"
                        placeholder="Titanium"
                    >

                </div>

            </section>

            <!-- VISIBILITY -->

            <section class="section-card">

                <div class="section-header">

                    <i
                        data-lucide="eye"
                        size="18"
                    ></i>

                    <h2>
                        Visibility
                    </h2>

                </div>

                <div class="status-row">

                    <span class="form-label">
                        Featured Product
                    </span>

                    <label class="switch">

                        <input
                            type="checkbox"
                            name="isFeatured"
                            value="true"
                        >

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="status-row">

                    <span class="form-label">
                        Best Seller
                    </span>

                    <label class="switch">

                        <input
                            type="checkbox"
                            name="isBestSeller"
                            value="true"
                        >

                        <span class="slider"></span>

                    </label>

                </div>

                <div class="status-row">

                    <span class="form-label">
                        Deal Product
                    </span>

                    <label class="switch">

                        <input
                            type="checkbox"
                            name="isDeal"
                            value="true"
                        >

                        <span class="slider"></span>

                    </label>

                </div>

            </section>

        </div>

        <!-- FOOTER -->

        <div
            class="footer-actions"
            style="grid-column:1/-1;"
        >

            <span class="draft-note">
                iStore Premium Inventory System
            </span>

            <a
                href="/admin/products"
                class="btn-cancel"
            >
                Cancel
            </a>

            <button
                type="submit"
                class="btn-save"
            >
                Save Product
            </button>

        </div>

    </form>

</main>

<script>

    lucide.createIcons()

    /* IMAGE PREVIEW */

    const thumbnailInput =
    document.getElementById(
        "thumbnailInput"
    )

    const previewWrapper =
    document.getElementById(
        "thumbnailPreview"
    )

    const previewImage =
    document.getElementById(
        "previewImage"
    )

    const removeBtn =
    document.getElementById(
        "removeImageBtn"
    )

    thumbnailInput.addEventListener(

        "change",

        function () {

            const file =
            this.files[0]

            if (!file) return

            const reader =
            new FileReader()

            reader.onload = function(e){

                previewImage.src =
                e.target.result

                previewWrapper.style.display =
                "block"

            }

            reader.readAsDataURL(file)

        }

    )

    removeBtn.addEventListener(

        "click",

        () => {

            thumbnailInput.value = ""

            previewImage.src = ""

            previewWrapper.style.display =
            "none"

        }

    )

    /* =========================
   VARIANT IMAGE PREVIEW
========================= */

const variantInput =
document.getElementById(
    "variantImages"
)

const variantPreviewGrid =
document.getElementById(
    "variantPreviewGrid"
)

variantInput.addEventListener(

    "change",

    function(){

        variantPreviewGrid.innerHTML = ""

        const files =
        Array.from(this.files)

        files.forEach(file => {

            const reader =
            new FileReader()

            reader.onload = function(e){

                const preview =

                `
                    <div class="variant-preview-item">

                        <img
                            src="${e.target.result}"
                            alt="Variant"
                        >

                    </div>
                `

                variantPreviewGrid.innerHTML +=
                preview

            }

            reader.readAsDataURL(file)

        })

    }

)

</script>

</body>
</html>