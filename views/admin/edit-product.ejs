<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<title>
Edit Product - Admin | iStore
</title>

<link
rel="stylesheet"
href="/css/admin-header.css"
>

<link
rel="stylesheet"
href="/css/admin-dashboard.css"
>

<link
rel="stylesheet"
href="/css/admin-add-product.css"
>

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
rel="stylesheet"
>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"
/>

<script src="https://unpkg.com/lucide@latest"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

<%- include("../partials/admin/header") %>

<main class="main-canvas">

<!-- PAGE HEADER -->

<header class="header-section">

<nav class="breadcrumbs">

<a href="/admin/dashboard">
Dashboard
</a>

<span>/</span>

<a href="/admin/products">
Products
</a>

<span>/</span>

<span class="active">
Edit Product
</span>

</nav>

<h1 class="page-title">
Edit Product
</h1>

</header>

<% if(error){ %>

<div class="error-alert">

<%= error %>

</div>

<% } %>

<form
action="/admin/products/edit/<%= product._id %>"
method="POST"
enctype="multipart/form-data"
class="bento-form-grid"
>

<!-- LEFT COLUMN -->

<div class="column">

<!-- BASIC DETAILS -->

<section class="section-card">

<div class="section-header">

<i
data-lucide="package"
size="20"
></i>

<h2>
Product Basic Details
</h2>

</div>

<!-- PRODUCT NAME -->

<div class="form-group">

<label class="form-label">
Product Name
</label>

<input
type="text"
name="name"
class="form-input"
value="<%= product.name %>"
required
>

</div>

<!-- CATEGORY + STATUS -->

<div class="form-row">

<div class="form-group">

<label class="form-label">
Category
</label>

<select
name="categoryId"
class="form-select"
required
>

<% categories.forEach(category => { %>

<option
value="<%= category._id %>"
<%= String(category._id) === String(product.categoryId)
? "selected"
: "" %>
>

<%= category.name %>

</option>

<% }) %>

</select>

</div>

<div class="form-group">

<label class="form-label">
Product Status
</label>

<select
name="isActive"
class="form-select"
>

<option
value="true"
<%= product.isActive ? "selected" : "" %>
>

Active

</option>

<option
value="false"
<%= !product.isActive ? "selected" : "" %>
>

Inactive

</option>

</select>

</div>

</div>

<!-- DESCRIPTION -->

<div class="form-group">

<label class="form-label">
Description
</label>

<textarea
name="description"
class="form-textarea"
required
><%= product.description %></textarea>

</div>

</section>

<!-- PRODUCT IMAGES -->

<section class="section-card">

<div class="section-header">

<i
data-lucide="image"
size="18"
></i>

<h2>
Product Images
</h2>

</div>

<div class="image-grid">

<label class="upload-slot">

<input
type="file"
name="thumbnail"
id="thumbnailInput"
accept="image/*"
hidden
>

<i
data-lucide="plus-circle"
size="24"
></i>

<span>
Replace Image
</span>

</label>

<div
class="image-preview"
id="thumbnailPreview"
style="display:block;"
>

<img
src="<%= product.thumbnail %>"
id="previewImage"
alt="Preview"
>

<button
type="button"
class="remove-img-btn"
id="removeImageBtn"
>

<i
data-lucide="x"
size="14"
></i>

</button>

</div>

</div>

<p class="image-note">

Upload a new image only if needed.

</p>

</section>

</div>

<!-- RIGHT COLUMN -->

<div class="column">

<!-- PRICING -->

<section class="section-card">

<div class="section-header">

<i
data-lucide="banknote"
size="20"
></i>

<h2>
Pricing & Stock
</h2>

</div>

<!-- PRICE -->

<div class="form-group">

<label class="form-label">
Price
</label>

<div class="price-input-wrapper">

<span class="price-symbol">
₹
</span>

<input
type="number"
name="price"
class="form-input"
value="<%= variant?.price || '' %>"
required
>

</div>

</div>

<!-- COMPARE PRICE -->

<div class="form-group">

<label class="form-label">
Compare Price
</label>

<div class="price-input-wrapper">

<span class="price-symbol">
₹
</span>

<input
type="number"
name="comparePrice"
class="form-input"
value="<%= variant?.comparePrice || '' %>"
>

</div>

</div>

<div class="form-row">

<!-- STOCK -->

<div class="form-group">

<label class="form-label">
Stock
</label>

<input
type="number"
name="stock"
class="form-input"
value="<%= variant?.stock || '' %>"
required
>

</div>

<!-- SKU -->

<div class="form-group">

<label class="form-label">
SKU
</label>

<input
type="text"
name="SKU"
class="form-input sku-input"
value="<%= variant?.SKU || '' %>"
required
>

</div>

</div>

</section>

<!-- TECHNICAL SPECS -->

<section class="section-card">

<div class="section-header">

<i
data-lucide="cpu"
size="18"
></i>

<h2>
Technical Specs
</h2>

</div>

<div class="form-group">

<label class="form-label">
Storage
</label>

<input
type="text"
name="storage"
class="form-input"
value="<%= variant?.storage || '' %>"
>

</div>

<div class="form-group">

<label class="form-label">
RAM
</label>

<input
type="text"
name="RAM"
class="form-input"
value="<%= variant?.RAM || '' %>"
>

</div>

<div class="form-group">

<label class="form-label">
Color
</label>

<input
type="text"
name="color"
class="form-input"
value="<%= variant?.color || '' %>"
>

</div>

</section>

<!-- VISIBILITY -->

<section class="section-card">

<div class="section-header">

<i
data-lucide="eye"
size="18"
></i>

<h2>
Visibility
</h2>

</div>

<div class="status-row">

<span class="form-label">
Featured Product
</span>

<label class="switch">

<input
type="checkbox"
name="isFeatured"
value="true"
<%= product.isFeatured ? "checked" : "" %>
>

<span class="slider"></span>

</label>

</div>

<div class="status-row">

<span class="form-label">
Best Seller
</span>

<label class="switch">

<input
type="checkbox"
name="isBestSeller"
value="true"
<%= product.isBestSeller ? "checked" : "" %>
>

<span class="slider"></span>

</label>

</div>

<div class="status-row">

<span class="form-label">
Deal Product
</span>

<label class="switch">

<input
type="checkbox"
name="isDeal"
value="true"
<%= product.isDeal ? "checked" : "" %>
>

<span class="slider"></span>

</label>

</div>

</section>

</div>

<!-- FOOTER -->

<div
class="footer-actions"
style="grid-column:1/-1;"
>

<span class="draft-note">
iStore Premium Inventory System
</span>

<a
href="/admin/products"
class="btn-cancel"
>
Cancel
</a>

<button
type="submit"
class="btn-save"
>
Update Product
</button>

</div>

</form>

</main>

<script>

lucide.createIcons()

/* =========================
IMAGE PREVIEW
========================= */

const thumbnailInput =
document.getElementById(
"thumbnailInput"
)

const previewImage =
document.getElementById(
"previewImage"
)

thumbnailInput.addEventListener(

"change",

function () {

const file =
this.files[0]

if (!file) return

const reader =
new FileReader()

reader.onload = function(e){

previewImage.src =
e.target.result

}

reader.readAsDataURL(file)

}

)

/* =========================
SUCCESS TOAST
========================= */

const urlParams =
new URLSearchParams(
window.location.search
)

if (

urlParams.get("success")
=== "updated"

) {

Swal.fire({

toast: true,

position: "top-end",

icon: "success",

title: "Product updated successfully",

showConfirmButton: false,

timer: 2200,

timerProgressBar: true,

background: "#FFFFFF",

color: "#2C1421",

iconColor: "#701A75",

customClass: {

popup:
"animate__animated animate__fadeInDown"

}

})

}

</script>

</body>
</html>