<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management - Admin | iStore</title>
    <link rel="stylesheet" href="/css/admin-header.css">
    <link rel="stylesheet" href="/css/admin-users.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=Liberation+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin-dashboard.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <!-- Top Navbar -->
   <%- include("../partials/admin/header") %>

    <main class="dashboard-main">
        
        <!-- Header -->
        <header class="page-header">
            <h1>User Management</h1>
            <p>Manage registered customers and monitor user activity.</p>
        </header>

        <!-- Stats Section -->
        <section class="stats-grid">
            <!-- Total Users -->
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">TOTAL USERS</span>
                    <span class="stat-value"><%= totalUsers %></span>
                </div>
                <div class="stat-icon">
                    <i data-lucide="users" size="22"></i>
                </div>
            </div>

            <!-- Active Users -->
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">ACTIVE USERS</span>
                    <span class="stat-value"><%= activeUsers %></span>
                </div>
                <div class="stat-icon">
                    <i data-lucide="user-check" size="22"></i>
                </div>
            </div>

            <!-- Blocked Users -->
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">BLOCKED USERS</span>
                    <span class="stat-value"><%= blockedUsers %></span>
                </div>
                <div class="stat-icon">
                    <i data-lucide="user-minus" size="22"></i>
                </div>
            </div>
        </section>

        <!-- Filter Section -->
      <form method="GET" action="/admin/users">

<section class="filter-section">

<!-- SEARCH -->

<div class="filter-group search">

<span class="filter-label">
SEARCH DIRECTORY
</span>

<div class="search-input-wrapper">

<i data-lucide="search" size="18"></i>

<input
type="text"
name="search"
class="search-input"
placeholder="Search by Name, Email, or Phone..."
value="<%= search || '' %>">

</div>

</div>



<!-- STATUS FILTER -->

<div class="filter-group status">

<span class="filter-label">
STATUS
</span>

<div class="select-wrapper">

<select
name="status"
class="filter-select">

<option value="all"
<%= status === "all" ? "selected" : "" %>>
All Statuses
</option>

<option value="active"
<%= status === "active" ? "selected" : "" %>>
Active
</option>

<option value="blocked"
<%= status === "blocked" ? "selected" : "" %>>
Blocked
</option>

</select>

<i data-lucide="chevron-down"></i>

</div>

</div>



<!-- JOINED FILTER -->

<div class="filter-group joined">

<span class="filter-label">
JOINED
</span>

<div class="select-wrapper">

<select
name="joined"
class="filter-select">

<option value="all">
All Time
</option>

<option value="30days">
Last 30 Days
</option>

<option value="year">
This Year
</option>

</select>

<i data-lucide="chevron-down"></i>

</div>

</div>



<!-- APPLY BUTTON -->

<button
type="submit"
class="btn-apply">

Apply Filters

</button>

</section>

</form>

        <!-- User Table Section -->
        <div class="table-card">
            <div class="table-header-title">
                <h2>All Users</h2>
            </div>
            
            <div class="table-responsive">
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>USER ID</th>
                            <th>USER NAME</th>
                            <th>CONTACT DETAILS</th>
                            <th class="center">ORDERS</th>
                            <th>REGISTRATION</th>
                            <th>STATUS</th>
                            <th class="right">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>

<% users.forEach(user => { %>

<tr>

<!-- USER ID -->

<td class="td-id">

#US-<%= user._id.toString().slice(-4) %>

</td>



<!-- USER NAME -->

<td>

<div class="td-user">

<div class="user-avatar-initials">

<%= user.fullName
.charAt(0)
.toUpperCase() %>

</div>

<span class="td-user-name">

<%= user.fullName %>

</span>

</div>

</td>



<!-- CONTACT -->

<td>

<div class="td-contact">

<span class="td-email">

<%= user.email %>

</span>

<span class="td-phone">

<%= user.phoneNumber || "N/A" %>

</span>

</div>

</td>



<!-- ORDERS (future feature) -->

<td class="td-orders">

0

</td>



<!-- REGISTRATION DATE -->

<td class="td-reg">

<%= new Date(
user.createdAt
).toLocaleDateString() %>

</td>



<!-- STATUS -->

<td>

<div class="td-status">

<div class="status-dot-wrapper
<%= user.isBlocked ? "blocked" : "active" %>">

</div>

<span class="status-text
<%= user.isBlocked ? "blocked" : "" %>">

<%= user.isBlocked
? "Blocked"
: "Active" %>

</span>

</div>

</td>



<!-- ACTIONS -->

<td>

<div class="td-actions">
<a
href="/admin/users/<%= user._id %>"
class="action-btn"
title="View User">

<i data-lucide="eye"></i>

</a>



<button
type="button"
class="action-btn secondary
block-btn"
data-id="<%= user._id %>">

<i data-lucide="
<%= user.isBlocked
? 'undo'
: 'ban' %>">

</i>

</button>

</div>

</td>

</tr>

<% }) %>

</tbody>
                </table>
            </div>

            <!-- Pagination -->
           <div class="pagination-bar">

                <span class="pagination-info">

                Showing
                <%= (currentPage - 1) * limit + 1 %>
                -
                <%= Math.min(currentPage * limit, totalFilteredUsers) %>
                of
                <%= totalFilteredUsers %>
                users

                </span>



                <div class="pagination-controls">

                <!-- PREVIOUS -->

                <% if (currentPage > 1) { %>

                <a
                href="?page=<%= currentPage - 1 %>&search=<%= search %>&status=<%= status %>&joined=<%= joined %>"
                class="page-btn icon">

                <i data-lucide="chevron-left"></i>

                </a>

                <% } %>



                <!-- PAGE NUMBERS -->

                <% for (let i = 1; i <= totalPages; i++) { %>

                <a
                href="?page=<%= i %>&search=<%= search %>&status=<%= status %>&joined=<%= joined %>"
                class="page-btn
                <%= i === currentPage ? 'active' : '' %>">

                <%= i %>

                </a>

                <% } %>



                <!-- NEXT -->

                <% if (currentPage < totalPages) { %>

                <a
                href="?page=<%= currentPage + 1 %>&search=<%= search %>&status=<%= status %>&joined=<%= joined %>"
                class="page-btn icon">

                <i data-lucide="chevron-right"></i>

                </a>

                <% } %>

                </div>

                </div>
        </div>

    </main>

    <!-- Footer -->
    <footer class="page-footer">
        <span class="footer-text">© 2026 iStore Admin</span>
        <div class="footer-links">
            <a href="#" class="footer-link">PRIVACY POLICY</a>
            <a href="#" class="footer-link">TERMS OF SERVICE</a>
            <a href="#" class="footer-link">HELP CENTER</a>
        </div>
    </footer>

   <script>
  lucide.createIcons()

  document.addEventListener("click", async (e) => {

    const btn = e.target.closest(".block-btn")
    if (!btn) return

    if (btn.disabled) return
    btn.disabled = true

    const userId = btn.dataset.id

    try {

      const confirmed = await Swal.fire({
        title: "Are you sure?",
        text: "Change user status?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonText: "Yes"
      })

      if (!confirmed.isConfirmed) {
        btn.disabled = false
        return
      }

      const response = await fetch(
  `/admin/block-user/${userId}`,
  {
    method: "PATCH",
    credentials: "include",
    headers: {
      "Content-Type": "application/json"
    }
  }
)

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`)
      }

      const data = await response.json()

      if (data.success) {
        await Swal.fire({
          icon: "success",
          title: "User Updated",
          timer: 1000,
          showConfirmButton: false
        })
        window.location.href = "/admin/users"
      } else {
        throw new Error("Server returned success: false")
      }

    } catch (error) {
      console.error("Block/Unblock Error:", error)
      Swal.fire({
        icon: "error",
        title: "Failed to update user"
      })
      btn.disabled = false
    }

  })
</script>
</body>
</html>
