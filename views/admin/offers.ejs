<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Offers Management - Admin | iStore</title>
    <meta name="description" content="Create and manage promotional discounts and campaigns for iStore.">
    <link rel="stylesheet" href="/css/components/admin-sidebar.css">
    <link rel="stylesheet" href="/css/admin-offers.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        .field-error {
            display: none;
            color: #e74c3c;
            font-size: 12px;
            margin-top: 4px;
            font-weight: 500;
        }
        .field-error.visible { display: block; }
        .m-input.input-error,
        .m-select.input-error,
        .m-textarea.input-error {
            border: 1.5px solid #e74c3c !important;
            background: #fff8f8 !important;
        }
        .m-input.input-success,
        .m-select.input-success,
        .m-textarea.input-success {
            border: 1.5px solid #2ecc71 !important;
        }
    </style>
</head>
<body>

<%
  const now = new Date();

  const totalOffers     = offers.length;
  const activeOffers    = offers.filter(o =>
    o.isActive && new Date(o.startDate) <= now && new Date(o.endDate) >= now
  ).length;
  const expiredOffers   = offers.filter(o => new Date(o.endDate) < now).length;
  const scheduledOffers = offers.filter(o => new Date(o.startDate) > now).length;

  function offerStatus(o) {
    if (!o.isActive) return 'INACTIVE';
    if (new Date(o.endDate) < now) return 'EXPIRED';
    if (new Date(o.startDate) > now) return 'SCHEDULED';
    return 'ACTIVE';
  }

  function statusClass(o) {
    const s = offerStatus(o);
    return s === 'ACTIVE' ? 's-active' : s === 'EXPIRED' ? 's-expired' : s === 'SCHEDULED' ? 's-scheduled' : 's-inactive';
  }

  function durationLabel(o) {
    const end   = new Date(o.endDate);
    const start = new Date(o.startDate);
    const s     = offerStatus(o);
    if (s === 'EXPIRED') return 'ENDED';
    if (s === 'SCHEDULED') {
      const months = Math.round((start - now) / (1000 * 60 * 60 * 24 * 30));
      return months > 0 ? `STARTS IN ${months} MONTH${months > 1 ? 'S' : ''}` : 'STARTS SOON';
    }
    const daysLeft = Math.ceil((end - now) / (1000 * 60 * 60 * 24));
    return daysLeft > 0 ? `${daysLeft} DAYS LEFT` : 'ENDING TODAY';
  }

  function fmtDateShort(d) {
    return new Date(d).toLocaleDateString('en-IN', { month: 'short', day: '2-digit' });
  }

  function toInputDate(d) {
    return new Date(d).toISOString().split('T')[0];
  }

  function targetName(o) {
    if (!o.targetId) return '—';
    return o.targetId.name || o.targetId.offerName || '—';
  }
%>

    <%- include('../partials/admin/sidebar') %>

    <main class="admin-main dashboard-main">

        <!-- ── PAGE HEADER ── -->
        <header class="page-header">
            <nav class="breadcrumb">
                <a href="/admin/dashboard">DASHBOARD</a>
                <i data-lucide="chevron-right" size="10"></i>
                <span class="current">OFFERS</span>
            </nav>
            <h1 class="page-title">Offers Management</h1>
            <p class="page-subtitle">Create and manage promotional discounts and campaigns.</p>
        </header>

        <!-- ── STATS ── -->
        <section class="stats-grid">

            <div class="stat-card">
                <div class="stat-top-row">
                    <div class="stat-info">
                        <span class="stat-label">Total Offers</span>
                        <span class="stat-value"><%= totalOffers %></span>
                    </div>
                    <div class="stat-icon"><i data-lucide="tag" size="20"></i></div>
                </div>
                <div class="stat-sub">
                    <i data-lucide="tag" size="12" style="color:#7a4e7c;"></i>
                    <span class="stat-sub-text">All promotional campaigns</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-top-row">
                    <div class="stat-info">
                        <span class="stat-label">Active</span>
                        <span class="stat-value"><%= activeOffers %></span>
                    </div>
                    <div class="stat-icon"><i data-lucide="check-circle" size="20"></i></div>
                </div>
                <div class="stat-sub">
                    <span class="stat-dot dot-primary"></span>
                    <span class="stat-sub-text">Currently live on storefront</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-top-row">
                    <div class="stat-info">
                        <span class="stat-label">Expired</span>
                        <span class="stat-value"><%= expiredOffers %></span>
                    </div>
                    <div class="stat-icon"><i data-lucide="clock" size="20"></i></div>
                </div>
                <div class="stat-sub">
                    <span class="stat-dot dot-muted"></span>
                    <span class="stat-sub-text">Past promotional events</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-top-row">
                    <div class="stat-info">
                        <span class="stat-label">Scheduled</span>
                        <span class="stat-value"><%= scheduledOffers %></span>
                    </div>
                    <div class="stat-icon"><i data-lucide="calendar" size="20"></i></div>
                </div>
                <div class="stat-sub">
                    <span class="stat-dot dot-dark"></span>
                    <span class="stat-sub-text">Upcoming campaigns</span>
                </div>
            </div>

        </section>

        <!-- ── ACTION BAR ── -->
        <div class="action-bar">
            <div class="action-left">
                <div class="search-wrapper">
                    <span class="search-icon"><i data-lucide="search" size="16"></i></span>
                    <input type="text" class="search-input" id="offerSearch" placeholder="Search offers..." autocomplete="off">
                </div>
                <select class="filter-select" id="statusFilter">
                    <option value="">All Statuses</option>
                    <option value="ACTIVE">Active</option>
                    <option value="EXPIRED">Expired</option>
                    <option value="SCHEDULED">Scheduled</option>
                    <option value="INACTIVE">Inactive</option>
                </select>
            </div>
            <button class="btn-add" id="btnOpenAdd">
                <i data-lucide="plus" size="18"></i>
                Add New Offer
            </button>
        </div>

        <!-- ── TABLE ── -->
        <section class="table-card">
            <div class="table-responsive">
                <table class="offers-table" id="offersTable">
                    <thead>
                        <tr>
                            <th>Offer Name</th>
                            <th>Offer Type</th>
                            <th>Target</th>
                            <th>Discount</th>
                            <th>Duration</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="offersTableBody">

                    <% if (offers.length > 0) { %>
                        <% offers.forEach((offer, idx) => { %>
                        <%
                          const stat    = offerStatus(offer);
                          const sClass  = statusClass(offer);
                          const durLbl  = durationLabel(offer);
                          const tName   = targetName(offer);
                          const isProduct = offer.applyTo === 'PRODUCT';
                        %>
                        <tr
                          data-name="<%= offer.offerName.toLowerCase() %>"
                          data-status="<%= stat %>"
                        >
                            <!-- Offer Name -->
                            <td>
                                <div class="offer-name-cell">
                                    <span class="offer-name"><%= offer.offerName %></span>
                                    <span class="offer-id">Campaign ID: #OSS-<%= String(idx + 100) %></span>
                                </div>
                            </td>

                            <!-- Type Badge -->
                            <td>
                                <span class="type-badge <%= isProduct ? 'type-product' : 'type-category' %>">
                                    <%= isProduct ? 'Product Offer' : 'Category Offer' %>
                                </span>
                            </td>

                            <!-- Target -->
                            <td>
                                <div class="target-cell">
                                    <div class="target-thumb">
                                        <% if (isProduct && offer.targetId && offer.targetId.images && offer.targetId.images[0]) { %>
                                        <img src="<%= offer.targetId.images[0] %>" alt="<%= tName %>" loading="lazy">
                                        <% } else { %>
                                        <i data-lucide="<%= isProduct ? 'package' : 'layers' %>" size="14"></i>
                                        <% } %>
                                    </div>
                                    <span class="target-name"><%= tName %></span>
                                </div>
                            </td>

                            <!-- Discount -->
                            <td>
                                <span class="discount-value">
                                    <% if (offer.discountType === 'FIXED') { %>
                                        ₹<%= offer.discountValue %> OFF
                                    <% } else { %>
                                        <%= offer.discountValue %>% OFF
                                    <% } %>
                                </span>
                            </td>

                            <!-- Duration -->
                            <td>
                                <div class="duration-cell">
                                    <span class="duration-dates">
                                        <%= fmtDateShort(offer.startDate) %> - <%= fmtDateShort(offer.endDate) %>
                                    </span>
                                    <span class="duration-label"><%= durLbl %></span>
                                </div>
                            </td>

                            <!-- Status -->
                            <td>
                                <div class="status-cell <%= sClass %>">
                                    <span class="status-dot"></span>
                                    <span class="status-text"><%= stat.charAt(0) + stat.slice(1).toLowerCase() %></span>
                                </div>
                            </td>

                            <!-- Actions -->
                            <td>
                                <div class="action-btns">
                                    <button
                                        class="action-btn edit-offer-btn"
                                        title="Edit offer"

                                        data-id="<%= offer._id %>"
                                        data-name="<%= offer.offerName %>"
                                        data-applyto="<%= offer.applyTo %>"
                                        data-target="<%= offer.targetId ? offer.targetId._id : '' %>"
                                        data-discounttype="<%= offer.discountType || 'PERCENTAGE' %>"
                                        data-discount="<%= offer.discountValue %>"
                                        data-maxdiscount="<%= offer.maxDiscount || 0 %>"
                                        data-minpurchase="<%= offer.minPurchase || 0 %>"
                                        data-start="<%= toInputDate(offer.startDate) %>"
                                        data-end="<%= toInputDate(offer.endDate) %>"
                                        data-active="<%= offer.isActive %>"
                                    >
                                        <i data-lucide="pencil" size="15"></i>
                                    </button>
                                    <button
                                        class="action-btn delete"
                                        title="Delete offer"
                                        onclick='confirmDelete("<%= offer._id %>", <%- JSON.stringify(offer.offerName) %>)'
                                    >
                                        <i
                                            data-lucide="trash-2"
                                            size="15"
                                        ></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr id="emptyRow">
                            <td colspan="7">
                                <div class="empty-state">
                                    <div class="empty-state-icon"><i data-lucide="tag-off" size="48"></i></div>
                                    <p class="empty-state-title">No offers yet</p>
                                    <p class="empty-state-sub">Click "Add New Offer" to create your first promotional campaign.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>

                    </tbody>
                </table>
            </div>
        </section>

    </main>

    <!-- ==============================================
         ADD OFFER MODAL
    =============================================== -->
    <div class="modal-overlay" id="addModal" role="dialog" aria-modal="true">
        <div class="modal-card">
            <div class="modal-head">
                <div class="modal-head-left">
                    <h2 class="modal-title">Add New Offer</h2>
                    <p class="modal-subtitle">Create a luxury shopping incentive for your inventory.</p>
                </div>
                <button class="modal-close" onclick="closeModal('addModal')"><i data-lucide="x" size="18"></i></button>
            </div>

            <form id="addOfferForm" novalidate>
                <div class="modal-body">

                    <!-- LEFT -->
                    <div class="modal-left">

                        <!-- Offer Details -->
                        <div class="modal-section">
                            <div class="section-head">
                                <span class="section-title">
                                    <i data-lucide="megaphone" size="16"></i>
                                    Offer Details
                                </span>
                            </div>

                            <div class="m-form-group">
                                <label class="m-label" for="add-offerName">Offer Name *</label>
                                <input type="text" id="add-offerName" name="offerName" class="m-input"
                                    placeholder="e.g., Seasonal Flagship Event"
                                    oninput="updateBanner('add')">
                                <span class="field-error" id="add-offerName-error"></span>
                                <p class="m-hint"><i data-lucide="info" size="11"></i> Name will be visible to customers.</p>
                            </div>

                            <!-- Offer Type Toggle -->
                            <div class="m-form-group">
                                <label class="m-label">Offer Type *</label>
                                <div class="offer-type-toggle">
                                    <button type="button" class="type-btn active" id="add-type-product"
                                        onclick="setOfferType('add','PRODUCT')">
                                        <i data-lucide="package" size="18"></i>
                                        Product Offer
                                    </button>
                                    <button type="button" class="type-btn" id="add-type-category"
                                        onclick="setOfferType('add','CATEGORY')">
                                        <i data-lucide="layers" size="18"></i>
                                        Category Offer
                                    </button>
                                </div>
                                <input type="hidden" id="add-applyTo" name="applyTo" value="PRODUCT">
                            </div>

                            <!-- Target selection -->
                            <div class="m-form-group">
                                <label class="m-label" for="add-targetId" id="add-target-label">Target Selection *</label>
                                <select id="add-targetId" name="targetId" class="m-select" onchange="updatePricePreview('add')">
                                    <option value="">Select a product...</option>
                                    <% products.forEach(p => { %>
                                    <option value="<%= p._id %>" data-type="PRODUCT" data-price="<%= p.lowestPrice || 0 %>"><%= p.name %></option>
                                    <% }) %>
                                    <% categories.forEach(c => { %>
                                    <option value="<%= c._id %>" data-type="CATEGORY" data-price="<%= c.lowestPrice || 0 %>" style="display:none;"><%= c.name %></option>
                                    <% }) %>
                                </select>
                                <span class="field-error" id="add-targetId-error"></span>
                            </div>

                            <!-- Description (optional) -->
                            <div class="m-form-group">
                                <label class="m-label" for="add-description">Offer Description</label>
                                <textarea id="add-description" name="description" class="m-textarea"
                                    placeholder="Describe the terms and premium benefits of this offer..."></textarea>
                                <span class="field-error" id="add-description-error"></span>
                            </div>
                        </div>

                        <!-- Discount Config -->
                        <div class="modal-section">
                            <div class="section-head">
                                <span class="section-title">
                                    <i data-lucide="percent" size="16"></i>
                                    Discount Configuration
                                </span>
                                <div class="disc-type-row">
                                    <button type="button" class="disc-chip active" id="add-disc-pct" onclick="setDiscType('add','PERCENTAGE')">Percentage</button>
                                    <button type="button" class="disc-chip" id="add-disc-fixed" onclick="setDiscType('add','FIXED')">Fixed Amount</button>
                                </div>
                            </div>
                            <input type="hidden" id="add-discountType" name="discountType" value="PERCENTAGE">

                            <div class="form-row-2">
                                <div class="m-form-group">
                                    <label class="m-label" for="add-discountValue">Discount Value *</label>
                                    <div class="suffix-wrap">
                                        <input type="number" id="add-discountValue" name="discountValue"
                                            class="m-input" placeholder="10" min="1" max="100"
                                            oninput="updatePricePreview('add')">
                                        <span class="input-suffix" id="add-disc-suffix">%</span>
                                    </div>
                                    <span class="field-error" id="add-discountValue-error"></span>
                                </div>
                                <div class="m-form-group">
                                    <label class="m-label" for="add-maxDiscount">Max Discount (₹ cap)</label>
                                    <div class="suffix-wrap">
                                        <input type="number" id="add-maxDiscount" name="maxDiscount"
                                            class="m-input" placeholder="2000" min="0" value="0"
                                            oninput="updatePricePreview('add')">
                                        <span class="input-suffix" id="add-max-suffix">₹</span>
                                    </div>
                                    <span class="field-error" id="add-maxDiscount-error"></span>
                                    <p class="m-hint"><i data-lucide="info" size="11"></i> The discount will never exceed this rupee amount, regardless of discount type.</p>
                                </div>
                            </div>
                        </div>

                    </div><!-- /modal-left -->

                    <!-- RIGHT -->
                    <div class="modal-right">

                        <!-- Scheduling -->
                        <div class="modal-section">
                            <div class="scheduling-head">
                                <span class="section-title">
                                    <i data-lucide="clock" size="16"></i>
                                    Scheduling
                                </span>
                                <label class="toggle-switch-wrap">
                                    <input type="checkbox" id="add-isActive" name="isActive" value="true" checked>
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                            <div class="form-row-2">
                                <div class="m-form-group">
                                    <label class="m-label" for="add-startDate">Start Date *</label>
                                    <input type="date" id="add-startDate" name="startDate" class="m-input"
                                        oninput="updateBanner('add')">
                                    <span class="field-error" id="add-startDate-error"></span>
                                </div>
                                <div class="m-form-group">
                                    <label class="m-label" for="add-endDate">End Date *</label>
                                    <input type="date" id="add-endDate" name="endDate" class="m-input"
                                        oninput="updateBanner('add')">
                                    <span class="field-error" id="add-endDate-error"></span>
                                </div>
                            </div>
                            <div class="m-form-group">
                                <label class="m-label" for="add-minPurchase">Usage Limit Per User</label>
                                <input type="number" id="add-minPurchase" name="minPurchase" class="m-input"
                                    placeholder="1" min="0" value="1">
                                <span class="field-error" id="add-minPurchase-error"></span>
                            </div>
                        </div>

                        <!-- Banner Preview -->
                        <div class="modal-section">
                            <p class="panel-label">Banner Preview</p>
                            <div class="banner-preview">
                                <span class="banner-title" id="add-banner-name">NEW OFFER</span>
                                <div class="banner-value" id="add-banner-value">Up to —% OFF</div>
                                <div class="banner-cta">Shop Collection</div>
                                <div class="banner-days"><i data-lucide="clock" size="10"></i><span id="add-banner-days">— DAYS LEFT</span></div>
                            </div>
                            <p class="banner-sub" style="font-size:9px;color:rgba(77,68,76,0.4);letter-spacing:0.8px;text-transform:uppercase;text-align:center;">
                                Banner dynamically generated based on selection
                            </p>
                        </div>

                        <!-- Live Price Preview -->
                        <div class="modal-section">
                            <p class="panel-label">Live Price Preview</p>
                            <div class="price-preview">
                                <div class="price-row">
                                    <span class="price-row-label">Original Price</span>
                                    <span class="price-row-value" id="add-original-price">—</span>
                                </div>
                                <div class="price-row">
                                    <span class="price-row-label">Applied Discount <span id="add-pct-label">(—%)</span></span>
                                    <span class="price-row-discount" id="add-discount-amt">—</span>
                                </div>
                                <div class="price-divider"></div>
                                <div class="price-final-row">
                                    <span class="price-final-label">Final Price</span>
                                    <span class="price-final-value" id="add-final-price">₹1,29,900</span>
                                </div>
                                <div class="price-sim-tag"><i data-lucide="radio" size="10"></i> Live Simulation</div>
                            </div>
                        </div>

                    </div><!-- /modal-right -->

                </div><!-- /modal-body -->

                <div class="modal-foot">
                    <button type="button" class="btn-modal-cancel" onclick="closeModal('addModal')">Discard</button>
                    <button type="submit" class="btn-modal-save" id="addSaveBtn">
                        <span class="btn-spinner"></span>
                        <span class="btn-label">Publish Offer</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ==============================================
         EDIT OFFER MODAL
    =============================================== -->
    <div class="modal-overlay" id="editModal" role="dialog" aria-modal="true">
        <div class="modal-card">
            <div class="modal-head">
                <div class="modal-head-left">
                    <h2 class="modal-title">Edit Offer</h2>
                    <p class="modal-subtitle">Update the offer details and configuration.</p>
                </div>
                <button class="modal-close" onclick="closeModal('editModal')"><i data-lucide="x" size="18"></i></button>
            </div>

            <form id="editOfferForm" novalidate>
                <input type="hidden" id="edit-id">
                <div class="modal-body">

                    <!-- LEFT -->
                    <div class="modal-left">

                        <div class="modal-section">
                            <span class="section-title">
                                <i data-lucide="tag" size="16"></i>
                                Offer Details
                            </span>

                            <div class="form-row-2">
                                <div class="m-form-group">
                                    <label class="m-label" for="edit-offerName">Offer Name *</label>
                                    <input type="text" id="edit-offerName" name="offerName" class="m-input"
                                        oninput="updateBanner('edit')">
                                    <span class="field-error" id="edit-offerName-error"></span>
                                </div>
                                <div class="m-form-group">
                                    <label class="m-label">Offer Type *</label>
                                    <div class="offer-type-toggle">
                                        <button type="button" class="type-btn" id="edit-type-product"
                                            onclick="setOfferType('edit','PRODUCT')">
                                            <i data-lucide="package" size="16"></i>Product Offer
                                        </button>
                                        <button type="button" class="type-btn" id="edit-type-category"
                                            onclick="setOfferType('edit','CATEGORY')">
                                            <i data-lucide="layers" size="16"></i>Category Offer
                                        </button>
                                    </div>
                                    <input type="hidden" id="edit-applyTo" name="applyTo" value="PRODUCT">
                                </div>
                            </div>

                            <div class="m-form-group">
                                <label class="m-label" for="edit-targetId">Target Selection *</label>
                                <select id="edit-targetId" name="targetId" class="m-select" onchange="updatePricePreview('edit')">
                                    <option value="">Select...</option>
                                    <% products.forEach(p => { %>
                                    <option value="<%= p._id %>" data-type="PRODUCT" data-price="<%= p.lowestPrice || 0 %>"><%= p.name %></option>
                                    <% }) %>
                                    <% categories.forEach(c => { %>
                                    <option value="<%= c._id %>" data-type="CATEGORY" data-price="<%= c.lowestPrice || 0 %>"><%= c.name %></option>
                                    <% }) %>
                                </select>
                                <span class="field-error" id="edit-targetId-error"></span>
                            </div>
                        </div>

                        <!-- Discount Config -->
                        <div class="modal-section">
                            <div class="section-head">
                                <span class="section-title">
                                    <i data-lucide="percent" size="16"></i>
                                    Discount Configuration
                                </span>
                                <div class="disc-type-row">
                                    <button type="button" class="disc-chip active" id="edit-disc-pct" onclick="setDiscType('edit','PERCENTAGE')">Percentage</button>
                                    <button type="button" class="disc-chip" id="edit-disc-fixed" onclick="setDiscType('edit','FIXED')">Fixed Amount</button>
                                </div>
                            </div>
                            <input type="hidden" id="edit-discountType" name="discountType" value="PERCENTAGE">
                            <div class="form-row-2">
                                <div class="m-form-group">
                                    <label class="m-label" for="edit-discountValue">Discount Value *</label>
                                    <div class="suffix-wrap">
                                        <input type="number" id="edit-discountValue" name="discountValue"
                                            class="m-input" min="1"
                                            oninput="updatePricePreview('edit')">
                                        <span class="input-suffix" id="edit-disc-suffix">%</span>
                                    </div>
                                    <span class="field-error" id="edit-discountValue-error"></span>
                                </div>
                                <div class="m-form-group">
                                    <label class="m-label" for="edit-maxDiscount">Max Discount (₹ cap)</label>
                                    <div class="suffix-wrap">
                                        <input type="number" id="edit-maxDiscount" name="maxDiscount"
                                            class="m-input" min="0" oninput="updatePricePreview('edit')">
                                        <span class="input-suffix" id="edit-max-suffix">₹</span>
                                    </div>
                                    <span class="field-error" id="edit-maxDiscount-error"></span>
                                </div>
                            </div>
                        </div>

                    </div><!-- /modal-left -->

                    <!-- RIGHT -->
                    <div class="modal-right">

                        <!-- Status + Scheduling -->
                        <div class="modal-section">
                            <div class="status-indicator" id="edit-status-indicator">
                                <div class="si-dot" id="edit-si-dot"></div>
                                <div style="display:flex;flex-direction:column;gap:1px;">
                                    <span class="si-label">Current Status</span>
                                    <span class="si-value" id="edit-si-value">—</span>
                                </div>
                                <div style="margin-left:auto;">
                                    <label class="toggle-switch-wrap">
                                        <input type="checkbox" id="edit-isActive" name="isActive" value="true">
                                        <span class="toggle-slider"></span>
                                    </label>
                                </div>
                            </div>

                            <p class="panel-label" style="margin-top:4px;">Scheduling</p>
                            <div class="form-row-2">
                                <div class="m-form-group">
                                    <label class="m-label" for="edit-startDate">Start Date *</label>
                                    <input type="date" id="edit-startDate" name="startDate" class="m-input"
                                        oninput="updateBanner('edit')">
                                    <span class="field-error" id="edit-startDate-error"></span>
                                </div>
                                <div class="m-form-group">
                                    <label class="m-label" for="edit-endDate">End Date *</label>
                                    <input type="date" id="edit-endDate" name="endDate" class="m-input"
                                        oninput="updateBanner('edit')">
                                    <span class="field-error" id="edit-endDate-error"></span>
                                </div>
                            </div>
                            <div class="m-form-group">
                                <label class="m-label" for="edit-minPurchase">Usage Limit Per User</label>
                                <input type="number" id="edit-minPurchase" name="minPurchase" class="m-input" min="0" value="1">
                                <span class="field-error" id="edit-minPurchase-error"></span>
                            </div>
                        </div>

                        <!-- Banner Preview -->
                        <div class="modal-section">
                            <p class="panel-label">Banner Preview</p>
                            <div class="banner-preview">
                                <span class="banner-title" id="edit-banner-name">OFFER</span>
                                <div class="banner-value" id="edit-banner-value">Up to —% OFF</div>
                                <div class="banner-cta">Shop Now</div>
                                <div class="banner-days"><i data-lucide="clock" size="10"></i><span id="edit-banner-days">— DAYS LEFT</span></div>
                            </div>
                        </div>

                        <!-- Live Price Preview -->
                        <div class="modal-section">
                            <p class="panel-label">Live Price Preview</p>
                            <div class="price-preview">
                                <div class="price-row">
                                    <span class="price-row-label">Original Price</span>
                                    <span class="price-row-value" id="edit-original-price">—</span>
                                </div>
                                <div class="price-row">
                                    <span class="price-row-label">Applied Discount <span id="edit-pct-label">(—%)</span></span>
                                    <span class="price-row-discount" id="edit-discount-amt">—</span>
                                </div>
                                <div class="price-divider"></div>
                                <div class="price-final-row">
                                    <span class="price-final-label">Final Price</span>
                                    <span class="price-final-value" id="edit-final-price">₹1,29,900</span>
                                </div>
                                <div class="price-sim-tag"><i data-lucide="radio" size="10"></i> Live Simulation</div>
                            </div>
                        </div>

                    </div><!-- /modal-right -->

                </div><!-- /modal-body -->

                <div class="modal-foot">
                    <button type="button" class="btn-modal-cancel" onclick="closeModal('editModal')">Cancel</button>
                    <button type="submit" class="btn-modal-save" id="editSaveBtn">
                        <span class="btn-spinner"></span>
                        <span class="btn-label">Update Offer</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

<!-- ==============================================
     JAVASCRIPT
=============================================== -->
<script>
'use strict';

const FALLBACK_PRICE = 129900; /* used only if a target has no price data at all */

function getSelectedPrice(prefix) {
  const sel = document.getElementById(prefix + '-targetId');
  const opt = sel && sel.selectedOptions[0];
  const price = opt ? Number(opt.dataset.price) : 0;
  return (price > 0 ? price : FALLBACK_PRICE / 100) * 100;
}

/* ── MODAL HELPERS ── */
function openModal(id) {
    const modal = document.getElementById(id);
    modal.classList.add("open");
    document.body.style.overflow = "hidden";
    if (window.lucide) lucide.createIcons();
}
function closeModal(id) {
    document.getElementById(id).classList.remove("open");
    document.body.style.overflow = "";
}
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape')
    document.querySelectorAll('.modal-overlay.open').forEach(el => closeModal(el.id));
});

/* ================================================
   INLINE VALIDATION HELPERS
================================================ */

function setError(el, errorId, msg) {
  if (!el) return;
  el.classList.add("input-error");
  el.classList.remove("input-success");
  const s = document.getElementById(errorId);
  if (s) { s.textContent = msg; s.classList.add("visible"); }
}

function setSuccess(el, errorId) {
  if (!el) return;
  el.classList.remove("input-error");
  el.classList.add("input-success");
  const s = document.getElementById(errorId);
  if (s) { s.textContent = ""; s.classList.remove("visible"); }
}

function clearAllErrors(prefix) {
  const fields = ["offerName","targetId","description","discountValue","maxDiscount","startDate","endDate","minPurchase"];
  fields.forEach(f => {
    const errSpan = document.getElementById(`${prefix}-${f}-error`);
    if (errSpan) { errSpan.textContent = ""; errSpan.classList.remove("visible"); }
  });
  document.querySelectorAll(`#${prefix === "add" ? "addOfferForm" : "editOfferForm"} .input-error,
                              #${prefix === "add" ? "addOfferForm" : "editOfferForm"} .input-success`)
    .forEach(el => el.classList.remove("input-error", "input-success"));
}

/* ---- field validators ---- */

function validateOfferName(prefix) {
  const el  = document.getElementById(prefix + '-offerName');
  const val = el.value.trim();
  const err = prefix + '-offerName-error';
  if (!val)             { setError(el, err, "Offer name is required");                 return false; }
  if (!/^[A-Za-z]/.test(val)) { setError(el, err, "Must start with a letter");          return false; }
  if (val.length < 3)   { setError(el, err, "Name must be at least 3 characters");     return false; }
  if (val.length > 100) { setError(el, err, "Name cannot exceed 100 characters");      return false; }
  setSuccess(el, err); return true;
}

function validateTarget(prefix) {
  const el  = document.getElementById(prefix + '-targetId');
  const err = prefix + '-targetId-error';
  if (!el.value) { setError(el, err, "Please select a target product or category"); return false; }
  setSuccess(el, err); return true;
}

function validateDescription(prefix) {
  /* optional field — only validate length if filled.
     NOTE: the edit modal has no description field in the markup,
     so this must be null-safe or it throws and silently kills
     the rest of the submit handler (this was the root cause of
     "Update Offer" doing nothing). */
  const el = document.getElementById(prefix + '-description');
  if (!el) return true;

  const val = el.value.trim();
  const err = prefix + '-description-error';
  if (val && !/^[A-Za-z]/.test(val)) { setError(el, err, "Must start with a letter"); return false; }
  if (val && val.length < 10)  { setError(el, err, "Description must be at least 10 characters if provided"); return false; }
  if (val && val.length > 500) { setError(el, err, "Description cannot exceed 500 characters"); return false; }
  setSuccess(el, err); return true;
}

function validateDiscountValue(prefix) {
  const el   = document.getElementById(prefix + '-discountValue');
  const type = document.getElementById(prefix + '-discountType').value;
  const err  = prefix + '-discountValue-error';
  const val  = el.value;

  if (!val) { setError(el, err, "Discount value is required"); return false; }
  const n = parseFloat(val);
  if (isNaN(n) || n <= 0) { setError(el, err, "Enter a valid discount value"); return false; }

  if (type === "PERCENTAGE" && n > 100) {
    setError(el, err, "Percentage discount cannot exceed 100%");
    return false;
  }
  if (type === "FIXED" && n > 10000000) {
    setError(el, err, "Discount value seems too high");
    return false;
  }
  setSuccess(el, err); return true;
}

function validateMaxDiscount(prefix) {
  /* optional — 0 means no cap */
  const el  = document.getElementById(prefix + '-maxDiscount');
  const err = prefix + '-maxDiscount-error';
  if (el.value === "" ) { setSuccess(el, err); return true; }
  const n = parseFloat(el.value);
  if (isNaN(n) || n < 0) { setError(el, err, "Max discount cannot be negative"); return false; }
  setSuccess(el, err); return true;
}

function validateStartDate(prefix) {
  const el  = document.getElementById(prefix + '-startDate');
  const err = prefix + '-startDate-error';
  if (!el.value) { setError(el, err, "Start date is required"); return false; }
  setSuccess(el, err);

  /* re-check end date relationship */
  const endEl = document.getElementById(prefix + '-endDate');
  if (endEl.value) validateEndDate(prefix);

  return true;
}

function validateEndDate(prefix) {
  const el      = document.getElementById(prefix + '-endDate');
  const startEl = document.getElementById(prefix + '-startDate');
  const err     = prefix + '-endDate-error';

  if (!el.value) { setError(el, err, "End date is required"); return false; }

  if (startEl.value) {
    const start = new Date(startEl.value);
    const end   = new Date(el.value);
    if (end <= start) {
      setError(el, err, "End date must be after start date");
      return false;
    }
  }
  setSuccess(el, err); return true;
}

function validateMinPurchase(prefix) {
  /* "Usage Limit Per User" field — optional, default 1 */
  const el  = document.getElementById(prefix + '-minPurchase');
  const err = prefix + '-minPurchase-error';
  if (el.value === "") { setSuccess(el, err); return true; }
  const n = parseInt(el.value);
  if (isNaN(n) || n < 0) { setError(el, err, "Usage limit cannot be negative"); return false; }
  setSuccess(el, err); return true;
}

/* ---- attach blur + live-clear ---- */

function attachBlur(inputId, validator) {
  const el = document.getElementById(inputId);
  if (!el) return; /* field doesn't exist in this modal — skip safely */
  el.addEventListener("blur", validator);
  el.addEventListener("input", function () {
    if (this.classList.contains("input-error")) validator();
  });
}

["add", "edit"].forEach(prefix => {
  attachBlur(`${prefix}-offerName`,      () => validateOfferName(prefix));
  attachBlur(`${prefix}-targetId`,       () => validateTarget(prefix));
  attachBlur(`${prefix}-description`,    () => validateDescription(prefix));
  attachBlur(`${prefix}-discountValue`,  () => validateDiscountValue(prefix));
  attachBlur(`${prefix}-maxDiscount`,    () => validateMaxDiscount(prefix));
  attachBlur(`${prefix}-startDate`,      () => validateStartDate(prefix));
  attachBlur(`${prefix}-endDate`,        () => validateEndDate(prefix));
  attachBlur(`${prefix}-minPurchase`,    () => validateMinPurchase(prefix));
});

function validateOfferForm(prefix) {
  const checks = [
    validateOfferName(prefix),
    validateTarget(prefix),
    validateDescription(prefix),
    validateDiscountValue(prefix),
    validateMaxDiscount(prefix),
    validateStartDate(prefix),
    validateEndDate(prefix),
    validateMinPurchase(prefix),
  ];
  return checks.every(Boolean);
}

/* ── ADD BUTTON ── */
document.getElementById('btnOpenAdd').addEventListener('click', () => {
  document.getElementById('addOfferForm').reset();
  clearAllErrors('add');
  setOfferType('add', 'PRODUCT');
  setDiscType('add', 'PERCENTAGE');
  document.getElementById('add-isActive').checked = true;
  updateBanner('add');
  updatePricePreview('add');
  openModal('addModal');
});

/* ── OFFER TYPE TOGGLE ── */
function setOfferType(prefix, type) {
  document.getElementById(prefix + '-applyTo').value = type;

  const btnP = document.getElementById(prefix + '-type-product');
  const btnC = document.getElementById(prefix + '-type-category');
  btnP.classList.toggle('active', type === 'PRODUCT');
  btnC.classList.toggle('active', type === 'CATEGORY');

  const sel = document.getElementById(prefix + '-targetId');
  sel.value = '';
  Array.from(sel.options).forEach(opt => {
    if (!opt.value) { opt.style.display = ''; return; }
    const t = opt.dataset.type;
    opt.style.display = (t === type) ? '' : 'none';
  });

  const lbl = document.getElementById(prefix + '-target-label');
  if (lbl) lbl.textContent = (type === 'PRODUCT' ? 'Select Product *' : 'Select Category *');

  updatePricePreview(prefix);
}

function setDiscType(prefix, type) {
  document.getElementById(prefix + '-discountType').value = type;

  document.getElementById(prefix + '-disc-pct').classList.toggle('active', type === 'PERCENTAGE');
  document.getElementById(prefix + '-disc-fixed').classList.toggle('active', type === 'FIXED');

  const suffix = type === 'PERCENTAGE' ? '%' : '₹';
  document.getElementById(prefix + '-disc-suffix').textContent = suffix;

  const discInput = document.getElementById(prefix + '-discountValue');
  if (type === 'PERCENTAGE') {
    discInput.setAttribute('max', '100');
    discInput.placeholder = '10';
  } else {
    discInput.removeAttribute('max');
    discInput.placeholder = '2000';
  }

  /* re-validate value against new type's rules if already touched */
  if (discInput.classList.contains("input-error") || discInput.classList.contains("input-success")) {
    validateDiscountValue(prefix);
  }

  updatePricePreview(prefix);
}

/* ── BANNER PREVIEW ── */
function updateBanner(p) {
  const name  = document.getElementById(p + '-offerName').value.trim().toUpperCase() || 'NEW OFFER';
  const disc  = document.getElementById(p + '-discountValue').value;
  const type  = document.getElementById(p + '-discountType').value;
  const end   = document.getElementById(p + '-endDate').value;

  const display = disc
    ? (type === 'FIXED' ? `₹${disc} OFF` : `Up to ${disc}% OFF`)
    : 'Up to —% OFF';

  let daysLabel = '— DAYS LEFT';
  if (end) {
    const d = Math.ceil((new Date(end) - Date.now()) / 86400000);
    daysLabel = d > 0 ? `${d} DAYS LEFT` : 'ENDING TODAY';
  }

  document.getElementById(p + '-banner-name').textContent  = name;
  document.getElementById(p + '-banner-value').textContent = display;
  document.getElementById(p + '-banner-days').textContent  = daysLabel;
}

/* ── LIVE PRICE PREVIEW ── */
function updatePricePreview(p) {
  const disc  = Number(document.getElementById(p + '-discountValue').value) || 0;
  const type  = document.getElementById(p + '-discountType').value;
  const maxD  = Number(document.getElementById(p + '-maxDiscount').value) || 0;

  const samplePrice = getSelectedPrice(p);

  const fmt = n => '₹' + (n / 100).toLocaleString('en-IN');

  document.getElementById(p + '-original-price').textContent = fmt(samplePrice);

  let discAmt = 0;
  if (type === 'PERCENTAGE') {
    discAmt = Math.round(samplePrice * disc / 100);
  } else {
    discAmt = disc * 100;
  }

  if (maxD > 0) discAmt = Math.min(discAmt, maxD * 100);
  discAmt = Math.min(discAmt, samplePrice);

  const final = Math.max(0, samplePrice - discAmt);
  const label = type === 'PERCENTAGE' ? `(${disc}%)` : '(Fixed)';

  document.getElementById(p + '-pct-label').textContent    = label;
  document.getElementById(p + '-discount-amt').textContent = disc ? `-${fmt(discAmt)}` : '—';
  document.getElementById(p + '-final-price').textContent  = fmt(final);

  updateBanner(p);
}

/* ── POPULATE EDIT MODAL ── */
function openEditModal(data) {
  const f = id => document.getElementById('edit-' + id);

  clearAllErrors('edit');

  f('id').value             = data._id;
  f('offerName').value      = data.offerName;
  f('discountValue').value  = data.discountValue;
  f('maxDiscount').value    = data.maxDiscount;
  f('minPurchase').value    = data.minPurchase;
  f('startDate').value      = data.startDate;
  f('endDate').value        = data.endDate;
  f('isActive').checked     = data.isActive;

  setOfferType('edit', data.applyTo);
  setDiscType('edit', data.discountType || 'PERCENTAGE');

  setTimeout(() => {
    f('targetId').value = data.targetId || '';
    updatePricePreview('edit');
  }, 10);

  const now = new Date();
  const stat = !data.isActive ? 'INACTIVE'
    : new Date(data.endDate) < now ? 'EXPIRED'
    : new Date(data.startDate) > now ? 'SCHEDULED' : 'ACTIVE';

  const dotColors = { ACTIVE:'#7a4e7c', EXPIRED:'#7f747d', SCHEDULED:'#5a3e4b', INACTIVE:'#94a3b8' };
  document.getElementById('edit-si-dot').style.background = dotColors[stat] || '#94a3b8';
  document.getElementById('edit-si-value').textContent    = stat;

  openModal('editModal');
}

/* ── TOAST ── */
function showToast(icon, title) {
  Swal.fire({
    toast: true, position: 'top-end', icon, title,
    showConfirmButton: false, timer: 2400, timerProgressBar: true,
    customClass: { popup: 'swal2-toast' }
  });
}

/* ── AJAX SUBMIT ── */
async function submitOfferForm(form, url, saveBtn, modalId, successMsg) {
  saveBtn.classList.add('loading');
  saveBtn.disabled = true;

  const data     = new FormData(form);
  const isActive = form.querySelector('[name="isActive"]');
  data.set('isActive', isActive && isActive.checked ? 'true' : 'false');

  const body = new URLSearchParams(data).toString();

  try {
    const res  = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
      body
    });
    const json = await res.json();

    if (json.success) {
      closeModal(modalId);
      showToast('success', successMsg);
      setTimeout(() => location.reload(), 1600);
    } else {
      throw new Error(json.message || 'Something went wrong');
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message,
      customClass: { popup: 'swal2-popup', confirmButton: 'swal2-confirm' } });
  } finally {
    saveBtn.classList.remove('loading');
    saveBtn.disabled = false;
  }
}

document.getElementById('addOfferForm').addEventListener('submit', function(e) {
  e.preventDefault();

  if (!validateOfferForm('add')) {
    const firstError = this.querySelector('.input-error');
    if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  submitOfferForm(this, '/admin/offers/add', document.getElementById('addSaveBtn'), 'addModal', 'Offer published successfully!');
});

document.getElementById('editOfferForm').addEventListener('submit', function(e) {
  e.preventDefault();

  if (!validateOfferForm('edit')) {
    const firstError = this.querySelector('.input-error');
    if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  const id = document.getElementById('edit-id').value;
  submitOfferForm(this, `/admin/offers/edit/${id}`, document.getElementById('editSaveBtn'), 'editModal', 'Offer updated successfully!');
});

/* ── DELETE ── */
async function confirmDelete(id, name) {
  const result = await Swal.fire({
    title: 'Delete Offer?',
    html: `Are you sure you want to delete <strong>${name}</strong>?<br>This action cannot be undone.`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Yes, delete it',
    cancelButtonText: 'Cancel',
    reverseButtons: true,
    customClass: { popup: 'swal2-popup', confirmButton: 'swal2-confirm', cancelButton: 'swal2-cancel' }
  });

  if (!result.isConfirmed) return;

  try {
    const res  = await fetch(`/admin/offers/delete/${id}`, { method: 'PATCH' });
    const data = await res.json();
    if (data.success) {
      showToast('success', `"${name}" deleted`);
      setTimeout(() => location.reload(), 1600);
    } else {
      throw new Error(data.message || 'Delete failed');
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: err.message,
      customClass: { popup: 'swal2-popup', confirmButton: 'swal2-confirm' } });
  }
}

/* ── SEARCH + FILTER ── */
(function() {
  const tbody   = document.getElementById('offersTableBody');
  const allRows = Array.from(tbody.querySelectorAll('tr[data-name]'));
  const search  = document.getElementById('offerSearch');
  const status  = document.getElementById('statusFilter');

  function render() {
    const q  = search.value.trim().toLowerCase();
    const st = status.value;
    let visible = 0;

    allRows.forEach(row => {
      const nameMatch   = !q  || row.dataset.name.includes(q);
      const statusMatch = !st || row.dataset.status === st;
      row.style.display = (nameMatch && statusMatch) ? '' : 'none';
      if (nameMatch && statusMatch) visible++;
    });

    const empty = document.getElementById('emptyRow');
    if (empty) empty.style.display = visible === 0 ? '' : 'none';
  }

  search.addEventListener('input',  render);
  status.addEventListener('change', render);
}());

document
.querySelectorAll(".edit-offer-btn")
.forEach(btn => {
    btn.addEventListener("click", () => {
        openEditModal({
            _id: btn.dataset.id,
            offerName: btn.dataset.name,
            applyTo: btn.dataset.applyto,
            targetId: btn.dataset.target,
            discountType: btn.dataset.discounttype,
            discountValue: btn.dataset.discount,
            maxDiscount: btn.dataset.maxdiscount,
            minPurchase: btn.dataset.minpurchase,
            startDate: btn.dataset.start,
            endDate: btn.dataset.end,
            isActive: btn.dataset.active === "true"
        });
    });
});
</script>

<script>lucide.createIcons();</script>
</body>
</html>
