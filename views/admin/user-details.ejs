<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>User Details - Admin | iStore</title>



<link rel="stylesheet" href="/css/components/admin-sidebar.css">



<!-- PAGE CSS -->

<link rel="stylesheet"
href="/css/admin-users.css">

<link rel="stylesheet"
href="/css/admin-dashboard.css">



<!-- FONTS -->

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=Liberation+Mono&display=swap"
rel="stylesheet">



<!-- ICONS -->

<script
src="https://unpkg.com/lucide@latest"></script>

</head>


<body>
     <!-- Sidebar Navbar -->
   <%- include('../partials/admin/sidebar') %>

<main class="dashboard-main">

    <div class="breadcrumbs">

<a href="/admin/users">
Users
</a>

<span>›</span>

<span class="active">
User Details
</span>

</div>

<!-- PAGE HEADER -->

<header class="page-header">

<h1>User Details</h1>

<p>View full user information.</p>

</header>



<!-- USER PROFILE CARD -->

<div class="table-card">

<div class="table-header-title profile-header">

<h2>User Profile</h2>

<div class="profile-actions">

<a
href="/admin/users/edit/<%= user._id %>"
class="btn-edit">

Edit User

</a>

<button
class="btn-delete"
data-id="<%= user._id %>">

Delete User

</button>

</div>

</div>


<div class="user-details-container">

<!-- PROFILE LEFT -->

<div class="user-profile-left">

<% if (user.profilePhoto) { %>

<img
src="/uploads/<%= user.profilePhoto %>"
class="user-avatar-large-img"
/>

<% } else { %>

<div class="user-avatar-large">

<%= user.fullName.charAt(0).toUpperCase() %>

</div>

<% } %>

<h3 class="user-name">
<%= user.fullName %>
</h3>

<p class="user-email">
<%= user.email %>
</p>

</div>


<!-- PROFILE RIGHT -->

<div class="user-profile-right">

<div class="detail-row">
<span class="detail-label">Email</span>
<span class="detail-value">
<%= user.email %>
</span>
</div>

<div class="detail-row">
<span class="detail-label">Phone</span>
<span class="detail-value">
<%= user.phoneNumber || "N/A" %>
</span>
</div>

<div class="detail-row">
<span class="detail-label">Date of Birth</span>
<span class="detail-value">
<%= user.dateOfBirth
? new Date(user.dateOfBirth).toLocaleDateString()
: "N/A" %>
</span>
</div>

<div class="detail-row">
<span class="detail-label">Status</span>
<span class="detail-value">
<%= user.isBlocked ? "Blocked" : "Active" %>
</span>
</div>

<div class="detail-row">
<span class="detail-label">Google Account</span>
<span class="detail-value">
<%= user.googleId ? "Yes" : "No" %>
</span>
</div>

<div class="detail-row">
<span class="detail-label">Joined</span>
<span class="detail-value">
<%= new Date(user.createdAt).toLocaleDateString() %>
</span>
</div>

</div>

</div>

</div>

</main>

<script>
    lucide.createIcons();


    //delete button//
document
.querySelector(".btn-delete")
.addEventListener(
"click",
async (e) => {

const id =
e.target.dataset.id

if (
confirm("Delete this user?")
) {

const res =
await fetch(
`/admin/users/delete/${id}`,
{
method: "DELETE"
}
)

const data =
await res.json()

if (data.success) {

window.location =
"/admin/users"

}

}

})

</script>
</body>
</html>