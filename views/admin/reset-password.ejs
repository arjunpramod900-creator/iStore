<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password - Admin | iStore</title>

    <link rel="stylesheet" href="/css/admin-reset-password.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <script src="https://unpkg.com/lucide@latest"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

</head>

<body>

<div class="admin-reset-container">

<!-- LEFT SIDE -->

<aside class="branding-panel">

<div class="decor-shape shape-1"></div>
<div class="decor-shape shape-2"></div>

<div class="branding-content">

<h1 class="branding-title">
iStore Admin
</h1>

<p class="branding-subtitle">
Reset Your Password Securely
</p>

<div class="huge-icon">

<svg width="120"
      height="150"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round">

<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>

<circle cx="12"
        cy="11"
        r="3"></circle>

</svg>

</div>

</div>

<div class="branding-footer">

<div class="dot"></div>

<span>
System Secure • Encrypted Connection
</span>

</div>

</aside>



<!-- RIGHT SIDE -->

<main class="reset-panel">

<div class="reset-card">

<div class="reset-header">

<h2>
Reset Password
</h2>

<p>
Enter your new password below to complete the reset process.
</p>

</div>



<!-- 🔧 UPDATED FORM -->

<form

id="adminResetForm"

class="reset-form"

action="/admin/reset-password"

method="POST"



>

<!-- NEW PASSWORD -->

<div class="form-group">

<label class="form-label">

NEW PASSWORD

</label>

<div class="input-wrapper">

<i data-lucide="history"
   class="left-icon"></i>

<input

type="password"

class="admin-input"

placeholder="••••••••"

name="password"

id="password"

required



>

<i data-lucide="eye"
   class="right-icon"></i>

</div>

</div>



<!-- PASSWORD STRENGTH UI (UNCHANGED) -->

<div class="strength-indicator">

<div class="strength-header">

<span class="label">

Strength:

<span id="strengthText">

Medium

</span>

</span>

<span class="percent">

65%

</span>

</div>

<div class="strength-bar">

<div class="strength-progress"></div>

</div>

<p class="strength-desc">

Password must contain at least 8 characters, including uppercase, lowercase, number, and symbol.

</p>

</div>



<!-- CONFIRM PASSWORD -->

<div class="form-group">

<label class="form-label">

CONFIRM PASSWORD

</label>

<div class="input-wrapper">

<i data-lucide="shield-check"
   class="left-icon"></i>

<input

type="password"

class="admin-input"

placeholder="••••••••"

name="confirmPassword"

id="confirmPassword"

required



>

<i data-lucide="eye-off"
   class="right-icon"></i>

</div>

</div>



<button

type="submit"

class="submit-btn"

>

<span>

Reset Password

</span>

<i data-lucide="arrow-right"
   size="16"></i>

</button>



<a href="/admin/login"

class="back-to-login">

<i data-lucide="arrow-left"
   size="16"></i>

<span>

Back to Login

</span>

</a>

</form>

</div>



<footer class="page-footer">

<p>

© 2026 iStore Admin. All rights reserved.

</p>

<div class="footer-links">

<a href="#">

Privacy Policy

</a>

<div class="footer-dot"></div>

<a href="#">

Security Center

</a>

</div>

</footer>

</main>

</div>



<!-- SCRIPTS -->

<script>

lucide.createIcons()



/* PASSWORD TOGGLE */

const eyeIcons =
document.querySelectorAll(".right-icon")

eyeIcons.forEach(icon => {

icon.addEventListener(

"click",

(e) => {

const input =
e.target
.parentElement
.querySelector("input")

if (input.type === "password") {

input.type = "text"

}

else {

input.type = "password"

}

}

)

})



/* PASSWORD MATCH VALIDATION */

const form =
document.getElementById(
"adminResetForm"
)

form.addEventListener(

"submit",

(e) => {

const password =
document.getElementById(
"password"
).value

const confirmPassword =
document.getElementById(
"confirmPassword"
).value



if (password !== confirmPassword) {

e.preventDefault()

alert(
"Passwords do not match"
)

}

}

)

</script>

</body>

</html>