<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Login - iStore</title>

<link rel="stylesheet" href="/css/admin-login.css">

<link rel="stylesheet"
href="/css/sweetalert-theme.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<script src="https://unpkg.com/lucide@latest"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</head>

<body>

<div class="admin-login-container">

<!-- LEFT SIDE -->

<aside class="branding-panel">

<div class="decor-shape shape-1"></div>
<div class="decor-shape shape-2"></div>

<div class="branding-content">

<div class="admin-logo-box">
<i data-lucide="layout-dashboard" size="32"></i>
</div>

<h1 class="branding-title">
iStore Admin
</h1>

<p class="branding-subtitle">
Secure Access to Dashboard
</p>

<div class="feature-grid">

<div class="feature-card">
<i data-lucide="shield-check" class="feature-icon"></i>
<h4>End-to-End Encryption</h4>
</div>

<div class="feature-card">
<i data-lucide="bar-chart-3" class="feature-icon"></i>
<h4>Real-time Analytics</h4>
</div>

</div>

</div>

</aside>

<!-- RIGHT SIDE -->

<main class="login-panel">

<div class="bg-blur-circles">
<div class="blur-circle-1"></div>
<div class="blur-circle-2"></div>
</div>

<div class="login-wrapper">

<div class="login-card">

<div class="login-header">

<h2>Admin Login</h2>

<p>Sign in to manage your store</p>

</div>

<!-- ADMIN LOGIN FORM -->

<form id="adminLoginForm" action="/admin/login" method="POST">
<div class="form-group">

<label class="form-label">

Email Address

</label>

<div class="input-wrapper">

<i data-lucide="mail"></i>

<input
type="email"
name="email"
id="email"
class="admin-input"
placeholder="Enter admin email"
required>

</div>

</div>

<div class="form-group">

<label class="form-label">

Password

</label>

<div class="input-wrapper">

<i data-lucide="lock"></i>

<input
type="password"
name="password"
id="passwordInput"
class="admin-input"
placeholder="Enter password"
required>

<button
type="button"
class="password-toggle"
id="togglePassword">

<i data-lucide="eye" size="18"></i>

</button>

</div>

</div>

<div class="form-options">

<!-- <label class="remember-me">

<input type="checkbox">

<span>Remember Me</span>

</label> -->

<a
href="/admin/forgot-password"
class="forgot-password">

Forgot Password?

</a>

</div>

<button
type="submit"
class="login-btn">

<span>Login to Admin</span>

<i data-lucide="arrow-right" size="18"></i>

</button>

</form>



<footer class="admin-footer">

<p class="copyright">

© 2026 iStore Admin. All rights reserved.

</p>

<div class="footer-links">

<a href="#" class="footer-link">

Privacy Policy

</a>

<a href="#" class="footer-link">

Terms of Service

</a>

</div>

</footer>

</div>

</main>

</div>

<!-- ======================
SCRIPTS
====================== -->

<script>

/* ICONS */

lucide.createIcons()

/* PASSWORD TOGGLE */

const togglePassword =
document.querySelector('#togglePassword')

const passwordInput =
document.querySelector('#passwordInput')

togglePassword.addEventListener(
'click',

function () {

const type =
passwordInput.getAttribute('type') === 'password'
? 'text'
: 'password'

passwordInput.setAttribute('type', type)

lucide.createIcons()

}
)

/* ADMIN LOGIN REQUEST */

const adminLoginForm =
document.getElementById("adminLoginForm")

adminLoginForm.addEventListener(

"submit",

async (e) => {

e.preventDefault()

const email =
document.getElementById("email").value.trim()

const password =
document.getElementById("passwordInput").value.trim()

try {

/* Loading */

Swal.fire({

title: "Logging in...",

allowOutsideClick: false,

didOpen: () => {

Swal.showLoading()

}

})

const response =
await axios.post(

"/admin/login",

{
email,
password
}

)

if (response.data.success) {

Swal.fire({

icon: "success",

title: "Login Successful",

timer: 1200,

showConfirmButton: false

})

setTimeout(() => {

window.location.href =
"/admin/dashboard"

}, 1200)

}

}

catch (error) {

Swal.fire({

icon: "error",

title: "Login Failed",

text:

error.response?.data?.message
|| "Invalid admin credentials"

})

}

}

)

/* GSAP ANIMATIONS */

gsap.from(".branding-content > *", {

y: 30,
opacity: 0,
duration: 0.8,
stagger: 0.2,
ease: "power2.out"

})

gsap.from(".login-card", {

x: 50,
opacity: 0,
duration: 1,
ease: "power3.out",
delay: 0.3

})




//for safari


/* Prevent Cached Login Page */

window.addEventListener(
"pageshow",
function (event) {

if (event.persisted) {

window.location.reload()

}

}
)



</script>

</body>
</html>