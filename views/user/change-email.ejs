<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Email - iStore</title>
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/change-email.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <nav class="nav">
            <a href="/" class="logo">iStore</a>
            <div class="nav-links">
                <a href="/" class="nav-link active">Home</a>
                <a href="/categories" class="nav-link">Categories</a>
                <a href="/products" class="nav-link">Products</a>
                <a href="/deals" class="nav-link">Deals</a>
            </div>
            <div class="nav-icons">
                <div class="nav-icon"><i data-lucide="search"></i></div>
                <div class="nav-icon"><i data-lucide="heart"></i></div>
                <div class="nav-icon"><i data-lucide="shopping-cart"></i></div>
              <a href="/profile" class="nav-icon" title="Profile"><i data-lucide="user"></i></a>
            </div>
        </nav>
    </header>

    <main class="change-email-main">
        <div class="change-email-container">
            <!-- Breadcrumbs -->
            <nav class="breadcrumb">
                <a href="/">Home</a>
                <div class="breadcrumb-separator">
                    <svg width="5" height="8" viewBox="0 0 5 8" fill="none"><path d="M1 1L4 4L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <a href="/profile">My Account</a>
                <div class="breadcrumb-separator">
                    <svg width="5" height="8" viewBox="0 0 5 8" fill="none"><path d="M1 1L4 4L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span class="breadcrumb-current">Change Email</span>
            </nav>

            <!-- Header Section -->
            <header class="change-email-header">
                <h1>Change Email</h1>
                <p>Update your email address securely.</p>
            </header>

            <!-- Form Card -->
            <div class="change-email-card">
               <form
class="change-email-form"
action="/send-email-change-otp"
method="POST">

<!-- Current Email -->
<div class="form-group">
<label>Current Email</label>

<div class="input-wrapper read-only">

<input
type="email"
value="<%= user.email %>"
readonly>

</div>

</div>

<!-- New Email -->
<div class="form-group">

<label>New Email Address</label>

<div class="input-wrapper">

<input
type="email"
name="newEmail"
placeholder="Enter new email address"
required>

</div>

</div>

<!-- Confirm Email -->
<div class="form-group">

<label>Confirm New Email</label>

<div class="input-wrapper">

<input
type="email"
name="confirmEmail"
placeholder="Re-enter new email address"
required>

</div>

</div>

<div class="action-buttons">

<button
type="submit"
class="update-btn">

Send OTP

</button>

<a
href="/profile"
class="cancel-btn-outlined">

Cancel

</a>

</div>

</form>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-main">
                <div class="footer-col-1">
                    <h3 class="footer-logo">iStore</h3>
                    <p class="footer-desc">The ultimate destination for premium Apple technology and bespoke customer experiences.</p>
                </div>
                <div class="footer-col">
                    <h4 class="footer-heading">Products</h4>
                    <ul class="footer-list">
                        <li><a href="#">iPhone</a></li>
                        <li><a href="#">MacBook</a></li>
                        <li><a href="#">iPad Pro</a></li>
                        <li><a href="#">Apple Watch</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-heading">Support</h4>
                    <ul class="footer-list">
                        <li><a href="#">Order Status</a></li>
                        <li><a href="#">Returns</a></li>
                        <li><a href="#">Product Help</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-heading">Company</h4>
                    <ul class="footer-list">
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Store Finder</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Sustainability</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="footer-socials">
                    <a href="#" class="social-icon facebook">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1V12h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/></svg>
                    </a>
                    <a href="#" class="social-icon instagram">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="#" class="social-icon twitter">
                        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                    </a>
                    <a href="#" class="social-icon youtube">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                </div>
                <p class="footer-copyright">© 2026 iStore. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        lucide.createIcons();

        // Entrance animation
        gsap.from(".change-email-container", {
            y: 30,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out"
        });
        
        gsap.from(".change-email-card", {
            scale: 0.98,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out",
            delay: 0.2
        });


/* =========================
   SAFARI BACK BUTTON FIX
========================= */

window.addEventListener("pageshow", function (event) {

if (event.persisted) {

window.location.reload()

}

})


    </script>
</body>
</html>
