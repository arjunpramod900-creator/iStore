<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Addresses - iStore</title>
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/addresses.css?v=5.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <!-- Header -->
    <%- include("../partials/user/header", { page: 'addresses' }) %>


    <main class="addresses-main">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/">Home</a>
            <div class="breadcrumb-separator">
                <svg width="5" height="8" viewBox="0 0 5 8" fill="none"><path d="M1 1L4 4L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <a href="/profile">My Account</a>
            <div class="breadcrumb-separator">
                <svg width="5" height="8" viewBox="0 0 5 8" fill="none"><path d="M1 1L4 4L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="breadcrumb-current">My Addresses</span>
        </nav>

        <!-- Page Header -->
        <header class="addresses-header">
            <div class="addresses-title-group">
                <h1>My Addresses</h1>
                <p>Manage your saved delivery addresses.</p>
            </div>
            <button class="add-address-btn" id="add-btn-main">
                <i data-lucide="plus"></i>
                Add New Address
            </button>
        </header>

        <!-- Address Grid -->
        <div class="addresses-grid" id="address-grid">

<% if(!addresses || addresses.length === 0) { %>
<p>No addresses added yet.</p>

<% } %>



<% addresses.forEach(address => { %>

    <%- include(
    "../partials/user/address-card",
    { address }
) %>

<% }) %>



<!-- Add Placeholder -->

<div class="add-placeholder-card"

id="add-card-placeholder">

Add Address

</div>

</div>

        <!-- Add Address Modal -->
        <div class="modal-overlay" id="address-modal">
            <div class="modal-card">
                <div class="modal-header">
                    <h2>Add New Address</h2>
                    <p>Enter your delivery details for a seamless shipping experience.</p>
                </div>
              <form
                id="new-address-form"
                class="address-form-v2"
                method="POST"
                action="/add-address"
                >
                    <div class="form-row">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" id="form-name" name="fullName" placeholder="e.g. fullName" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input type="tel" id="form-phone" name="phoneNumber" placeholder="(+91)00 00 00 00" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>Street Address</label>
                        <input type="text" id="form-address" name="addressLine1" placeholder="In Hariharnagar In" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                    </div>

                    <div class="form-group">
                        <label>Apartment / Building (Optional)</label>
                        <input type="text" id="form-building" placeholder="Suite, floor, gate code" style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                    </div>

                    <div class="form-row-3">
                        <div class="form-group">
                            <label>City</label>
                            <input type="text" id="form-city" name="city" placeholder="Kannur" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        <div class="form-group">
                            <label>State</label>
                            <input type="text" id="form-state" name="state" placeholder="Kerala" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        <div class="form-group">
                            <label>Pin Code</label>
                            <input type="text" id="form-pin" name="pincode" placeholder="670571" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Country</label>
                        <div class="custom-select-wrapper">
                            <select id="form-country" name="country">
                                <option value="United States">United States</option>
                                <option value="India">India</option>
                                <option value="United Kingdom">United Kingdom</option>
                                <option value="Canada">Canada</option>
                            </select>
                            <div class="select-arrow"><i data-lucide="chevron-down"></i></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Address Type</label>
                        <div class="type-selector-premium">
                            <div class="type-option-premium">
                                <input type="radio" name="type" id="type-home" value="Home" checked>
                                <label for="type-home">
                                    <i data-lucide="home"></i>
                                    <span>Home</span>
                                </label>
                            </div>
                            <div class="type-option-premium">
                                <input type="radio" name="type" id="type-work" value="Work">
                                <label for="type-work">
                                    <i data-lucide="briefcase"></i>
                                    <span>Work</span>
                                </label>
                            </div>
                            <div class="type-option-premium">
                                <input type="radio" name="type" id="type-other" value="Other">
                                <label for="type-other">
                                    <i data-lucide="more-horizontal"></i>
                                    <span>Other</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="default-toggle-wrapper">
                        <label class="switch">
                            <input type="checkbox" id="form-default" name="isDefault" value="true">
                            <span class="slider"></span>
                        </label>
                        <span class="toggle-label">Set as Default Address</span>
                    </div>

                    <div class="modal-actions-premium">
                        <button type="button" class="cancel-btn-premium" id="close-modal">Cancel</button>
                        <button type="submit" class="save-address-btn-premium">Save Address</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Edit Address Modal -->
        <div class="modal-overlay" id="edit-address-modal">
            <div class="edit-modal-card">
                <div class="edit-modal-left">
                    <div class="modal-header" style="margin-bottom: 32px;">
                        <h2>Edit Address</h2>
                        <p>Update your delivery details.</p>
                    </div>
                    <form class="address-form-v2" id="edit-address-form" method="POST">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" id="edit-form-name" name="fullName" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Phone Number</label>
                                <input type="tel" id="edit-form-phone" name="phoneNumber" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                            <div class="form-group">
                                <label>Address Type</label>
                                <div class="type-selector-pill">
                                    <div class="type-option-pill">
                                        <input type="radio" name="type" id="edit-type-home" value="Home">
                                        <label for="edit-type-home">Home</label>
                                    </div>
                                    <div class="type-option-pill">
                                        <input type="radio" name="type" id="edit-type-work" value="Work">
                                        <label for="edit-type-work">Work</label>
                                    </div>
                                    <div class="type-option-pill">
                                        <input type="radio" name="type" id="edit-type-other" value="Other">
                                        <label for="edit-type-other">Other</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Street Address</label>
                            <input type="text" id="edit-form-address" name="addressLine1" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>

                        <div class="form-group">
                            <label>Apartment / Area</label>
                            <input type="text" id="edit-form-building" name="building" style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>

                        <div class="form-row-3">
                            <div class="form-group">
                                <label>City</label>
                                <input type="text" id="edit-form-city" name="city" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                            <div class="form-group">
                                <label>State</label>
                                <input type="text" id="edit-form-state" name="state" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                           <div class="form-group">
                                <label>Country</label>

                                <select
                                id="edit-form-country"
                                name="country"
                                required
                                style="
                                width: 100%;
                                padding: 14px 16px;
                                background: #EEEEF0;
                                border: none;
                                border-radius: 12px;
                                ">

                                <option value="India">India</option>
                                <option value="United States">United States</option>
                                <option value="United Kingdom">United Kingdom</option>
                                <option value="Canada">Canada</option>
                                <option value="Australia">Australia</option>
                                <option value="Germany">Germany</option>
                                <option value="France">France</option>
                                <option value="Singapore">Singapore</option>
                                <option value="UAE">UAE</option>

                                </select>

                                </div>
                            <div class="form-group">
                                <label>Postal Code</label>
                                <input type="text" id="edit-form-pin" name="pincode" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                        </div>

                        <label class="custom-checkbox-container">
                            <input type="checkbox" id="edit-form-default" name="isDefault" value="true">
                            <span class="checkmark"></i></span>
                            <span class="toggle-label" style="font-size: 14px;">Set as Default Address</span>
                        </label>

                        <div class="edit-modal-actions">
                            <button type="submit" class="update-address-btn">Update Address</button>
                            <button type="button" class="edit-cancel-btn" id="close-edit-modal">Cancel</button>
                        </div>
                    </form>
                </div>
                <div class="edit-modal-right">
                    <div class="edit-info-card">
                        <i data-lucide="truck"></i>
                        <h3>Delivery Precision</h3>
                        <p>Accurate addresses ensure your iStore orders reach you on time. Make sure your postal code matches your city to avoid shipping delays.</p>
                    </div>
                    <div class="edit-image-container">
                        <img src="/images/premium_apartment.png" alt="Premium Apartment">
                    </div>
                </div>
            </div>
        </div>

        <!-- Delete Address Modal -->
        <div class="modal-overlay" id="delete-address-modal">
            <div class="delete-modal-card">
                <div class="trash-circle">
                    <i data-lucide="trash-2"></i>
                </div>
                <h2>Delete Address?</h2>
                <p>Are you sure you want to delete this address?<br>This action cannot be undone.</p>
                
                <div class="delete-address-preview">
                    <div class="preview-tags" id="delete-preview-tags">
                        <!-- Tags will be injected here -->
                    </div>
                    <h4 id="delete-preview-name">John Doe</h4>
                    <p class="preview-phone" id="delete-preview-phone">+91 9876543210</p>
                    <p class="preview-text" id="delete-preview-address">Flat No. 203, Green Residency, MG Road, Kochi, Kerala, 682001</p>
                </div>

                <div class="delete-warning-alert" id="delete-default-warning" style="display: none;">
                    <i data-lucide="alert-circle"></i>
                    <p>This is your default address. Another address will automatically become default.</p>
                </div>

                <div class="delete-modal-actions">
                    <button type="button" class="confirm-delete-btn" id="confirm-delete-btn">Delete Address</button>
                    <button type="button" class="keep-address-btn" id="close-delete-modal">Keep Address</button>
                </div>
            </div>
        </div>

        <!-- Privacy Section -->
        <section class="privacy-section">
            <div class="privacy-map">
                <img src="/images/minimal_map.png" alt="Privacy Map Illustration">
            </div>
            <div class="privacy-content">
                <h2>Your Privacy & Security</h2>
                <p>We only use your address for logistics and delivery purposes. Your data is encrypted and managed according to our high-standard privacy policy. You can remove or edit your addresses at any time.</p>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <%- include("../partials/user/footer") %>

    <script>
        lucide.createIcons();

        const modal = document.getElementById('address-modal');
        const openBtnMain = document.getElementById('add-btn-main');
        const openBtnPlaceholder = document.getElementById('add-card-placeholder');
        const closeBtn = document.getElementById('close-modal');
        const addressForm = document.getElementById('new-address-form');
        const addressGrid = document.getElementById('address-grid');
        const placeholderCard = document.getElementById('add-card-placeholder');

        // Modal Controls
        const openModal = () => {
            modal.style.display = 'flex';
            gsap.from(".modal-card", {
                scale: 0.9,
                opacity: 0,
                duration: 0.4,
                ease: "back.out(1.7)"
            });
        };

       const closeModal = () => {

gsap.to(".modal-card", {

scale: 0.9,
opacity: 0,
duration: 0.3,
ease: "power2.in",

onComplete: () => {

modal.style.display = "none"

/* RESET STATE */
gsap.set(".modal-card", {
clearProps: "all"
})

addressForm.reset()

}

})

};
        openBtnMain.addEventListener('click', openModal);
        openBtnPlaceholder.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);

       
        // Edit Modal Controls
        const editModal = document.getElementById('edit-address-modal');
        const editForm = document.getElementById('edit-address-form');
        const closeEditBtn = document.getElementById('close-edit-modal');
        let currentEditingCard = null;

        const openEditModal = (card) => {
            currentEditingCard = card;
            const name = card.querySelector('.address-content h3').textContent;
            const phone = card.querySelector('.address-phone').textContent;
            const addressText = card.querySelector('.address-text');
            const type = card.querySelector('.tag-secondary').textContent.trim();
            const isDefault = card.querySelector('.tag-primary') !== null;

            document.getElementById('edit-form-name').value = name;
            document.getElementById('edit-form-phone').value = phone;
            document.getElementById('edit-form-address').value = addressText.dataset.street || "";
            document.getElementById('edit-form-building').value = addressText.dataset.building || "";
            document.getElementById('edit-form-city').value = addressText.dataset.city || "";
            document.getElementById('edit-form-state').value = addressText.dataset.state || "";
            document.getElementById('edit-form-country').value =addressText.dataset.country || "India";
            document.getElementById('edit-form-pin').value = addressText.dataset.pin || "";
            document.getElementById('edit-form-default').checked = isDefault;

            const typeRadio = editModal.querySelector(`input[name="type"][value="${type}"]`);
            if (typeRadio) typeRadio.checked = true;
            const addressId =card.querySelector(".edit-trigger").dataset.id 
            editForm.action =`/edit-address/${addressId}`

            editModal.style.display = 'flex';
            gsap.from(".edit-modal-card", {
                scale: 0.95,
                opacity: 0,
                duration: 0.4,
                ease: "power2.out"
            });
        };

        const closeEditModal = () => {
            gsap.to(".edit-modal-card", {
                scale: 0.95,
                opacity: 0,
                duration: 0.3,
                ease: "power2.in",
                onComplete: () => {
                    editModal.style.display = 'none';
                    /* RESET STATE */

gsap.set(".edit-modal-card", {

clearProps: "all"

})
                }
            });
        };

        closeEditBtn.addEventListener('click', closeEditModal);

        
/* =========================
   EDIT ADDRESS SWEET ALERT
========================= */

editForm.addEventListener("submit", function(e) {

e.preventDefault();



Swal.fire({

title: "Update Address?",

text: "Save changes to this address?",

icon: "question",

iconColor: "#4C0080",

showCancelButton: true,

confirmButtonText: "Update",

cancelButtonText: "Cancel",

background: "#FFFFFF",

color: "#2D004F",

customClass: {

popup: "swal-popup-istore",

confirmButton: "swal-confirm-istore",

cancelButton: "swal-cancel-istore"

},

buttonsStyling: false

})

.then((result) => {

if (result.isConfirmed) {

/* Animate modal close */

gsap.to(".edit-modal-card", {

scale: 0.95,

opacity: 0,

duration: 0.25,

ease: "power2.in",

onComplete: () => {

editForm.submit();

}

});

}

});

});

        // Delete Modal Controls
        const deleteModal = document.getElementById('delete-address-modal');
        const closeDeleteBtn = document.getElementById('close-delete-modal');
        const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
        let cardToDelete = null;

        const openDeleteModal = (card) => {
            cardToDelete = card;
            const name = card.querySelector('.address-content h3').textContent;
            const phone = card.querySelector('.address-phone').textContent;
            const address = card.querySelector('.address-text').textContent;
            const type = card.querySelector('.tag-secondary').textContent;
            const isDefault = card.querySelector('.tag-primary') !== null;

            document.getElementById('delete-preview-name').textContent = name;
            document.getElementById('delete-preview-phone').textContent = phone;
            document.getElementById('delete-preview-address').textContent = address;
            
            const tagsContainer = document.getElementById('delete-preview-tags');
            tagsContainer.innerHTML = `
                <span class="preview-tag">${type}</span>
                ${isDefault ? '<span class="preview-tag">DEFAULT ADDRESS</span>' : ''}
            `;

            document.getElementById('delete-default-warning').style.display = isDefault ? 'flex' : 'none';

            deleteModal.style.display = 'flex';
            gsap.from(".delete-modal-card", {
                scale: 0.9,
                opacity: 0,
                duration: 0.4,
                ease: "back.out(1.7)"
            });
        };

        const closeDeleteModal = () => {
            gsap.to(".delete-modal-card", {
                scale: 0.9,
                opacity: 0,
                duration: 0.3,
                ease: "power2.in",
                onComplete: () => {
                    deleteModal.style.display = 'none';
                    /* RESET STATE */

gsap.set(".delete-modal-card", {

clearProps: "all"

})
                }
            });
        };

        closeDeleteBtn.addEventListener('click', closeDeleteModal);

       confirmDeleteBtn.addEventListener('click', () => {

if (!cardToDelete) return;

const addressId =
cardToDelete
.querySelector(".delete-trigger")
.dataset.id;



/* SWEET ALERT CONFIRM */

Swal.fire({

title: "Delete Address?",

text: "This action cannot be undone.",

icon: "warning",

showCancelButton: true,

confirmButtonText: "Delete",

cancelButtonText: "Cancel",

background: "#FFFFFF",

color: "#2D004F",

customClass: {

popup: "swal-popup-istore",

confirmButton: "swal-confirm-istore",

cancelButton: "swal-cancel-istore"

},

buttonsStyling: false

})

.then((result) => {

if (result.isConfirmed) {

/* RUN GSAP ANIMATION */

gsap.to(cardToDelete, {

scale: 0.8,

opacity: 0,

duration: 0.4,

ease: "power2.in",

onComplete: () => {

window.location.href =
`/delete-address/${addressId}`;

closeDeleteModal();

}

});

}

});

});

        // Global Trigger Handler
       document.addEventListener('click', (e) => {

const editBtn =
e.target.closest('.edit-trigger')

const deleteBtn =
e.target.closest('.delete-trigger')

if (editBtn) {

e.preventDefault()

openEditModal(
editBtn.closest('.address-card-v2')
)

}

if (deleteBtn) {

e.preventDefault()

openDeleteModal(
deleteBtn.closest('.address-card-v2')
)

}

})

        
        // Entrance animation
        gsap.from(".address-card-v2, .add-placeholder-card", {
            y: 30,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1,
            ease: "power2.out",
            onComplete: () => {
                gsap.set(".address-card-v2, .add-placeholder-card", { clearProps: "all" });
            }
        });

        gsap.from(".privacy-section", {
            y: 40,
            opacity: 0,
            duration: 1,
            ease: "power2.out",
            delay: 0.4
        });








/* =========================
   ADD ADDRESS VALIDATION
========================= */

const newForm = document.getElementById("new-address-form")

newForm.addEventListener("submit", function (e) {

let errors = []

const fullName = document.getElementById("form-name").value.trim()
const phone = document.getElementById("form-phone").value.trim()
const address = document.getElementById("form-address").value.trim()
const city = document.getElementById("form-city").value.trim()
const state = document.getElementById("form-state").value.trim()
const pin = document.getElementById("form-pin").value.trim()

/* VALIDATIONS */

// Full Name
if (fullName.length < 3) {
errors.push("Name must be at least 3 characters")
}

// Phone
if (!/^[0-9]{10}$/.test(phone)) {
errors.push("Phone must be 10 digits")
}

// Address
if (address.length < 5) {
errors.push("Address is too short")
}

// City
if (city.length < 2) {
errors.push("Enter valid city")
}

// State
if (state.length < 2) {
errors.push("Enter valid state")
}

// PIN
if (!/^[0-9]{6}$/.test(pin)) {
errors.push("PIN must be 6 digits")
}

/* ERROR HANDLING */

if (errors.length > 0) {

e.preventDefault()

Swal.fire({
icon: "error",
title: "Invalid Input",
html: errors.join("<br>")
})

}

})






/* =========================
   EDIT ADDRESS VALIDATION
========================= */

editForm.addEventListener("submit", function (e) {

let errors = []

const fullName = document.getElementById("edit-form-name").value.trim()
const phone = document.getElementById("edit-form-phone").value.trim()
const address = document.getElementById("edit-form-address").value.trim()
const city = document.getElementById("edit-form-city").value.trim()
const state = document.getElementById("edit-form-state").value.trim()
const pin = document.getElementById("edit-form-pin").value.trim()

/* VALIDATIONS */

if (fullName.length < 3) {
errors.push("Name must be at least 3 characters")
}

if (!/^[0-9]{10}$/.test(phone)) {
errors.push("Phone must be 10 digits")
}

if (address.length < 5) {
errors.push("Address is too short")
}

if (city.length < 2) {
errors.push("Enter valid city")
}

if (state.length < 2) {
errors.push("Enter valid state")
}

if (!/^[0-9]{6}$/.test(pin)) {
errors.push("PIN must be 6 digits")
}

/* ERROR */

if (errors.length > 0) {

e.preventDefault()

Swal.fire({
icon: "error",
title: "Invalid Input",
html: errors.join("<br>")
})

return
}

/* KEEP YOUR EXISTING SWEET ALERT CONFIRM */

})




/* =========================
   CLOSE MODAL ON OUTSIDE CLICK
========================= */

window.addEventListener("click", (e) => {

if (e.target.classList.contains("modal-overlay")) {

closeModal()
closeEditModal()
closeDeleteModal()

}

})

/* =========================
   ESC KEY CLOSE
========================= */

document.addEventListener("keydown", (e) => {

if (e.key === "Escape") {

if (modal.style.display === "flex")
closeModal()

if (editModal.style.display === "flex")
closeEditModal()

if (deleteModal.style.display === "flex")
closeDeleteModal()

}

})


/* =========================
   SAFARI BACK BUTTON FIX
========================= */

window.addEventListener("pageshow", function (event) {

if (event.persisted) {

window.location.reload()

}

})


    </script>
