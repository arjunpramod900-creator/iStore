<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - iStore</title>
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/edit-profile.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <nav class="nav">
            <a href="/" class="logo">iStore</a>
            <div class="nav-links">
                <a href="/" class="nav-link">Home</a>
                <a href="#" class="nav-link">Categories</a>
                <a href="#" class="nav-link">Products</a>
                <a href="#" class="nav-link">Deals</a>
            </div>
            <div class="nav-icons">
                <div class="nav-icon"><i data-lucide="search"></i></div>
                <div class="nav-icon"><i data-lucide="heart"></i></div>
                <div class="nav-icon"><i data-lucide="shopping-cart"></i></div>
                <a href="/profile" class="nav-icon active" style="text-decoration: none; color: inherit;"><i data-lucide="user"></i></a>
            </div>
        </nav>
    </header>

    <main class="edit-profile-main">
        <div class="edit-profile-container">
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/">Home</a>
                <div class="breadcrumb-separator"></div>
                <a href="/profile">My Account</a>
                <div class="breadcrumb-separator"></div>
                <span class="breadcrumb-current">Edit Profile</span>
            </nav>

            <!-- Page Header -->
            <header class="page-header">
                <h1>Edit Profile</h1>
                <p>Update your personal information.</p>
            </header>

            <!-- Form Container -->
           <div class="form-container">

<form
class="edit-form"
action="/update-profile"
method="POST"
enctype="multipart/form-data">

<!-- FILE INPUT MUST BE INSIDE FORM -->


<!-- Profile Image Section -->
<div class="profile-img-section">

<div class="profile-img-wrapper">

<div
class="profile-img-main"
style="background-image: url(<%= user.profilePhoto ? user.profilePhoto : '/images/default-user.png' %>);">

<div class="edit-icon-badge">

<svg width="10.5" height="10.5" viewBox="0 0 24 24">

<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
<path d="m15 5 4 4"/>

</svg>

</div>

</div>

</div>

<button
type="button"
class="change-photo-btn"
onclick="document.getElementById('profileUpload').click()">

Change Photo

</button>
<input
type="file"
name="profilePhoto"
accept="image/*"
hidden
id="profileUpload">


</div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Full Name</label>
                            <div class="input-wrapper">
                               <input type="text" name="fullName" value="<%= user.fullName %>" placeholder="Enter Full Name" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <div class="input-wrapper">
                               <input type="email" value="<%= user.email %>" readonly>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <div class="input-wrapper">
                               <input type="tel" name="phoneNumber" value="<%= user.phoneNumber %>" placeholder="Enter Phone Number" required>
                                <span class="form-hint">Enter a valid 10-digit mobile number.</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Date of Birth</label>
                            <div class="input-wrapper">
                               <input type="date" name="dateOfBirth" value="<%= user.dateOfBirth ? user.dateOfBirth.toISOString().split('T')[0] : '' %>">
                                <div class="input-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons">
                        <button type="submit" class="save-btn">Save Changes</button>
                        <a href="/profile" class="cancel-btn">Cancel</a>
                    </div>

                   
                </form>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-main">
                <div class="footer-col-1">
                    <h3 class="footer-logo">iStore</h3>
                    <p class="footer-desc">The ultimate destination for premium Apple technology and bespoke customer experiences.</p>
                </div>
                <div class="footer-col">
                    <h4 class="footer-heading">Products</h4>
                    <ul class="footer-list">
                        <li><a href="#">iPhone</a></li>
                        <li><a href="#">MacBook</a></li>
                        <li><a href="#">iPad Pro</a></li>
                        <li><a href="#">Apple Watch</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-heading">Support</h4>
                    <ul class="footer-list">
                        <li><a href="#">Order Status</a></li>
                        <li><a href="#">Returns</a></li>
                        <li><a href="#">Product Help</a></li>
                        <li><a href="#">Contact Us</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-heading">Company</h4>
                    <ul class="footer-list">
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Store Finder</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Sustainability</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="footer-socials">
                    <a href="#" class="social-icon facebook">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1V12h3v3h-3v6.8c4.56-.93 8-4.96 8-9.8z"/></svg>
                    </a>
                    <a href="#" class="social-icon instagram">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="#" class="social-icon twitter">
                        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                    </a>
                    <a href="#" class="social-icon youtube">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                </div>
                <p class="footer-copyright">© 2026 iStore. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        lucide.createIcons();

        // Entrance animation
        gsap.from(".edit-profile-container", {
            y: 30,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out"
        });
        
        gsap.from(".form-container", {
            scale: 0.98,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out",
            delay: 0.2
        });
    </script>
    <script>

document
.getElementById("profileUpload")
.addEventListener("change", function (event) {

const file = event.target.files[0]

if (file) {

const reader = new FileReader()

reader.onload = function (e) {

document
.querySelector(".profile-img-main")
.style.backgroundImage =
`url(${e.target.result})`

}

reader.readAsDataURL(file)

}

})


/* =========================
   SAFARI BACK BUTTON FIX
========================= */

window.addEventListener("pageshow", function (event) {

if (event.persisted) {

window.location.reload()

}

})



</script>
</body>
</html>
