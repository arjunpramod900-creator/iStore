<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - iStore</title>
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/edit-profile.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
</head>
<body>
    <!-- Header -->
    <%- include("../partials/user/header") %>


    <main class="edit-profile-main">
        <div class="edit-profile-container">
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/">Home</a>
                <div class="breadcrumb-separator"></div>
                <a href="/profile">My Account</a>
                <div class="breadcrumb-separator"></div>
                <span class="breadcrumb-current">Edit Profile</span>
            </nav>

            <!-- Page Header -->
            <header class="page-header">
                <h1>Edit Profile</h1>
                <p>Update your personal information.</p>
            </header>

            <!-- Form Container -->
           <div class="form-container">

<form
id="editProfileForm" 
class="edit-form"
action="/update-profile"
method="POST"
enctype="multipart/form-data">

<!-- FILE INPUT MUST BE INSIDE FORM -->


<!-- Profile Image Section -->
<div class="profile-img-section">

<div class="profile-img-wrapper">

            <%let initials = "";

            if (user.fullName) {

            const name = user.fullName.trim();

            if (name.length >= 2) {

                initials =
                name.charAt(0).toUpperCase() +
                name.charAt(1).toLowerCase();

            }

            else {

                initials =
                name.charAt(0).toUpperCase();

            }

            }
            %>

           <div
class="profile-img-main <%= !user.profilePhoto ? 'profile-initials' : '' %>"

<% if (user.profilePhoto) { %>
style="background-image: url('<%= user.profilePhoto %>');"
<% } %>
>

            <% if (!user.profilePhoto) { %>

            <span class="initials-text">

            <%= initials %>

            </span>

            <% } %>

<div class="edit-icon-badge">

<svg width="10.5" height="10.5" viewBox="0 0 24 24">

<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
<path d="m15 5 4 4"/>

</svg>

</div>

</div>

</div>

<button
type="button"
class="change-photo-btn"
onclick="document.getElementById('profileUpload').click()">

Change Photo

</button>
<input
type="file"
name="profilePhoto"
accept="image/*"
hidden
id="profileUpload">


</div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Full Name</label>
                            <div class="input-wrapper">
                              <input 
type="text"
name="fullName"
id="fullName"
value="<%= user.fullName %>"
placeholder="Enter Full Name"
maxlength="50"
required>

<span class="error-text" id="nameError"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <div class="input-wrapper">
                               <input type="email" value="<%= user.email %>" readonly>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <div class="input-wrapper">
                             <input 
                                type="tel"
                                name="phoneNumber"
                                value="<%= user.phoneNumber || '' %>"
                                placeholder="Enter Phone Number"
                                maxlength="10"
                                pattern="[0-9]{10}"
                                inputmode="numeric"
                                title="Enter a valid 10-digit phone number">
                                <span class="form-hint">Enter a valid 10-digit mobile number.</span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Date of Birth</label>
                            <div class="input-wrapper">
                               <input type="date" name="dateOfBirth" value="<%= user.dateOfBirth ? user.dateOfBirth.toISOString().split('T')[0] : '' %>">
                                <div class="input-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons">
                        <button type="submit" class="save-btn">Save Changes</button>
                        <a href="/profile" class="cancel-btn">Cancel</a>
                    </div>

                   
                </form>
            </div>
        </div>
    </main>

    <!-- Crop Modal -->
    <div class="crop-modal-overlay" id="cropModal">
        <div class="crop-modal">
            <div class="crop-modal-header">
                <h3>Crop Profile Photo</h3>
                <button type="button" class="crop-modal-close" id="cropCancel">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="crop-modal-body">
                <div class="crop-container">
                    <img id="cropImage" src="" alt="Crop preview">
                </div>
            </div>
            <div class="crop-modal-footer">
                <button type="button" class="crop-btn crop-btn-cancel" id="cropCancelBtn">Cancel</button>
                <button type="button" class="crop-btn crop-btn-confirm" id="cropConfirm">Apply Crop</button>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <%- include("../partials/user/footer") %>

    <script>
        lucide.createIcons();

        // Entrance animation
        gsap.from(".edit-profile-container", {
            y: 30,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out"
        });
        
        gsap.from(".form-container", {
            scale: 0.98,
            opacity: 0,
            duration: 0.8,
            ease: "power2.out",
            delay: 0.2
        });
    </script>
    <script>

/* =========================
   IMAGE UPLOAD + CROP
========================= */

const ALLOWED_TYPES = [
    "image/jpeg",
    "image/png",
    "image/webp",
    "image/gif"
]

const MAX_SIZE = 5 * 1024 * 1024 /* 5 MB */

let cropper = null
let croppedBlob = null

const profileUpload = document.getElementById("profileUpload")
const cropModal = document.getElementById("cropModal")
const cropImage = document.getElementById("cropImage")
const cropConfirm = document.getElementById("cropConfirm")
const cropCancel = document.getElementById("cropCancel")
const cropCancelBtn = document.getElementById("cropCancelBtn")

/* --- File select handler --- */

profileUpload.addEventListener("change", function (event) {

    const file = event.target.files[0]

    if (!file) return

    /* TYPE VALIDATION */

    if (!ALLOWED_TYPES.includes(file.type)) {

        showUploadError(
            "Invalid file type. Please upload a JPG, PNG, WebP or GIF image."
        )

        profileUpload.value = ""
        return
    }

    /* SIZE VALIDATION */

    if (file.size > MAX_SIZE) {

        showUploadError(
            "File is too large. Maximum size is 5 MB."
        )

        profileUpload.value = ""
        return
    }

    /* CLEAR PREVIOUS ERROR */
    clearUploadError()

    /* OPEN CROP MODAL */
    const reader = new FileReader()

    reader.onload = function (e) {

        cropImage.src = e.target.result

        cropModal.classList.add("active")

        document.body.style.overflow = "hidden"

        /* Init cropper after image loads */
        cropImage.onload = function () {

            if (cropper) cropper.destroy()

            cropper = new Cropper(cropImage, {
                aspectRatio: 1,
                viewMode: 1,
                dragMode: "move",
                autoCropArea: 0.85,
                cropBoxResizable: true,
                cropBoxMovable: true,
                background: false,
                responsive: true,
                guides: false,
                center: true,
                highlight: false,
            })

        }

    }

    reader.readAsDataURL(file)

})

/* --- Confirm crop --- */

cropConfirm.addEventListener("click", function () {

    if (!cropper) return

    const canvas = cropper.getCroppedCanvas({
        width: 512,
        height: 512,
        imageSmoothingEnabled: true,
        imageSmoothingQuality: "high",
    })

    /* Update preview */
    const imgEl = document.querySelector(".profile-img-main")
    imgEl.style.backgroundImage = `url(${canvas.toDataURL()})`
    imgEl.classList.remove("profile-initials")

    /* Hide initials */
    const initSpan = imgEl.querySelector(".initials-text")
    if (initSpan) initSpan.style.display = "none"

    /* Store blob for form submission */
    canvas.toBlob(function (blob) {
        croppedBlob = blob
    }, "image/jpeg", 0.92)

    closeCropModal()

})

/* --- Cancel crop --- */

cropCancel.addEventListener("click", closeCropModal)
cropCancelBtn.addEventListener("click", closeCropModal)

cropModal.addEventListener("click", function (e) {
    if (e.target === cropModal) closeCropModal()
})

function closeCropModal() {
    cropModal.classList.remove("active")
    document.body.style.overflow = ""
    if (cropper) {
        cropper.destroy()
        cropper = null
    }
    profileUpload.value = ""
}

/* --- Error helpers --- */

function showUploadError(msg) {
    clearUploadError()
    const el = document.createElement("span")
    el.className = "upload-error-text"
    el.textContent = msg
    document.querySelector(".profile-img-section").appendChild(el)
}

function clearUploadError() {
    const existing = document.querySelector(".upload-error-text")
    if (existing) existing.remove()
}


/* =========================
   SAFARI BACK BUTTON FIX
========================= */

window.addEventListener("pageshow", function (event) {

if (event.persisted) {

window.location.reload()

}

})



/* =========================
   OPTIONAL PHONE VALIDATION
========================= */

const phoneInput =
document.querySelector(
'input[name="phoneNumber"]'
)

if (phoneInput) {

phoneInput.addEventListener(
"input",

function () {

const value =
phoneInput.value.trim()

/* Allow empty */

if (value === "") {

phoneInput.setCustomValidity("")
return

}

/* Validate exactly 10 digits */

if (!/^[0-9]{10}$/.test(value)) {

phoneInput.setCustomValidity(
"Enter a valid 10-digit phone number"
)

}

else {

phoneInput.setCustomValidity("")

}

}

)

}

/* =========================
   FULL NAME VALIDATION
========================= */

const nameInput =
document.getElementById("fullName")

const nameError =
document.getElementById("nameError")

nameInput.addEventListener("input", () => {

let value = nameInput.value

/* Remove leading spaces */
value = value.replace(/^\s+/, "")

nameInput.value = value

/* Validation */

if (value.trim().length === 0) {

nameError.textContent = "Name cannot be empty"

}

else if (value.trim().length < 3) {

nameError.textContent = "Minimum 3 characters required"

}

else if (value.length > 50) {

nameError.textContent = "Maximum 50 characters allowed"

}

else if (!/^[A-Za-z ]+$/.test(value)) {

nameError.textContent =
"Only letters and spaces allowed"

}

else {

nameError.textContent = ""

}

})


/* =========================
   FORM SUBMIT VALIDATION
========================= */

const form =
document.getElementById("editProfileForm")

form.addEventListener("submit", (e) => {

const value =
nameInput.value.trim()

if (
value.length < 3 ||
value.length > 50 ||
!/^[A-Za-z ]+$/.test(value)
) {

e.preventDefault()

nameError.textContent =
"Please enter a valid name"

nameInput.focus()
return

}

/* =========================
   INJECT CROPPED BLOB
========================= */

if (croppedBlob) {

    e.preventDefault()

    const formData = new FormData(form)

    /* Remove original file input */
    formData.delete("profilePhoto")

    /* Append cropped blob */
    formData.append(
        "profilePhoto",
        croppedBlob,
        "profile-cropped.jpg"
    )

    fetch(form.action, {
        method: "POST",
        body: formData,
    })
    .then(res => {
        if (res.redirected) {
            window.location.href = res.url
        } else {
            window.location.href = "/profile"
        }
    })
    .catch(() => {
        window.location.href = "/edit-profile"
    })

}

})


</script>
</body>
</html>
