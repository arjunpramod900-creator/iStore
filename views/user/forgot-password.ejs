<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>iStore - Forgot Password</title>

<link rel="stylesheet" href="/css/index.css">
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/css/sweetalert-theme.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<!-- GSAP -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<!-- Axios -->
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<!-- SweetAlert -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Alert Config -->
<script src="/js/alertConfig.js"></script>

</head>



<body>

<div class="main-container">

<!-- LEFT PANEL -->

<section class="branding-panel">

<div class="blur-circle blur-circle-1"></div>
<div class="blur-circle blur-circle-2"></div>

<div class="branding-content">

<div class="logo-container">

<h1 class="logo-text">
iStore
</h1>

<p class="sub-greeting">
Recover access to your iStore account.
</p>

</div>



<!-- PRODUCT SHOWCASE -->

<div class="product-showcase">

<div class="glass-card card-1">

<div class="product-img"
style="background-image: url('/images/iphone.png');">
</div>

<span class="card-label">
iPhone 17
</span>

</div>



<div class="glass-card card-2">

<div class="product-img"
style="background-image: url('/images/macbook.png');">
</div>

<span class="card-label">
MacBook Pro M5
</span>

</div>



<div class="glass-card card-3">

<div class="product-img"
style="background-image: url('/images/watch.png');">
</div>

<span class="card-label">
Watch Ultra
</span>

</div>



<div class="glass-card card-4">

<div class="product-img"
style="background-image: url('/images/airpods.png');">
</div>

<span class="card-label">
AirPods Pro
</span>

</div>

</div>

</div>

</section>



<!-- RIGHT PANEL -->

<section class="login-section auth-section">

<div class="form-container">

<header class="form-header">

<h2>
Forgot Password?
</h2>

<p>
Enter your email to receive an OTP code.
</p>

</header>



<form id="forgotForm"
class="login-form">

<!-- Email -->

<div class="form-group">

<label>
Email Address
</label>

<div class="input-wrapper">

<input
type="email"
id="email"
class="input-field"
placeholder="name@example.com"
required>

</div>

</div>



<button
type="submit"
class="login-btn">

Send OTP →

</button>



<footer class="form-footer">

<p>

Remember your password?

<a href="/login">
Back to Login
</a>

</p>

</footer>

</form>

</div>

</section>

</div>



<script>

/* ============================
   FORGOT PASSWORD SUBMIT
============================ */

const forgotForm =
document.getElementById("forgotForm")

forgotForm.addEventListener(

"submit",

async (e) => {

e.preventDefault()

const email =
document.getElementById("email").value.trim()



try {

/* Loading */

showLoadingAlert(
"Sending Reset OTP..."
)



const response =
await axios.post(

"/forgot-password",

{ email }

)



if (response.data.success) {

/* Success */

showSuccessAlert(

"OTP Sent",
"Check your email"

)



setTimeout(() => {

window.location.href =
"/verify-otp?type=reset"

}, 1500)

}

}



catch (error) {

/* Error */

showErrorAlert(

"Failed",

error.response?.data?.message
|| "Something went wrong"

)

}

}

)

</script>



<!-- Animations -->

<script src="/js/animations.js"></script>
<script src="/js/tilt.js"></script>

</body>

</html>