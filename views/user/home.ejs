<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iStore - Discover the Latest Apple Products</title>
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
        <link rel="stylesheet" href="/css/components/toast.css">
    <link rel="stylesheet" href="/css/components/alert.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/components/product-card.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
    <!-- Header -->
  <%- include("../partials/user/header", { page: 'home' }) %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">Discover the <span>Latest</span> Apple Products</h1>
            <p class="hero-description">Experience innovation like never before. From iPhone to MacBook, find everything you need to light up your life.</p>
        </div>
        <div class="hero-image-container">
            <img src="/images/hero_new.png" alt="Apple Products" class="hero-image">
        </div>
    </section>

    <!-- Shop by Category -->
    <section class="section categories">
        <div class="category-header">
            <span class="section-label">Collections</span>
            <h2 class="section-title">Shop by Category</h2>
        </div>
<div class="category-grid-container">

<% categories.forEach(category => { %>

<div class="category-card">

<a
href="/products?category=<%= category._id %>"
style="
text-decoration:none;
display:block;
height:100%;
"
>

<div
class="category-img"
style="
background-image:url('<%= category.image || "/images/default-category.jpg" %>');
"
></div>

<div class="category-gradient"></div>

<div class="category-content">

<p class="category-name">

<%= category.name %>

</p>

<p class="category-description">

Explore Collection

</p>

</div>

</a>

</div>

<% }) %>

</div>
    </section>

    <!-- Featured Products -->
    <section class="section featured">
        <div class="featured-container">
            <h2 class="featured-title">Featured Products</h2>
           <div class="product-grid">

<% if(featuredProducts.length > 0){ %>

    <% featuredProducts.forEach(product => { %>

        <%- include(
            "../partials/user/product-card",
            {
                product,
                wishlistVariantIds,
                cartVariantIds
            }
        ) %>

    <% }) %>

<% } else { %>

    <p class="empty-state">

        No featured products available

    </p>

<% } %>

</div>
        </div>
    </section>

    <!-- Best Sellers -->
    <section class="section best-sellers">
        <h2 class="best-sellers-title">Best Sellers</h2>
       <div class="best-grid">

<% if(bestSellerProducts.length > 0){ %>

    <% bestSellerProducts.forEach(product => { %>

        <%- include(
            "../partials/user/product-card",
            {
                product,
                wishlistVariantIds,
                cartVariantIds
            }
        ) %>

    <% }) %>

<% } else { %>

    <p class="empty-state">

        No best sellers available

    </p>

<% } %>

</div>
    </section>

    <!-- Today's Deals -->
    <section class="section deals">
        <div class="deals-container">
            <h2 class="section-title" style="margin:0">Today's Deals</h2>
<div class="deals-grid">

<% if(dealProducts.length > 0){ %>

    <% dealProducts.forEach(product => { %>

        <div class="deal-card">

            <div class="deal-badge">

                <%= product.offerData?.appliedOffer?.discountValue || 0 %>% OFF

            </div>

            <h3 class="deal-title">

                <%= product.name %>

            </h3>

            <p class="deal-text">

                Save ₹<%= product.offerData?.offerDiscount?.toLocaleString("en-IN") || 0 %>

            </p>

            <a
                href="/products/<%= product._id %>?variant=<%= product.variant._id %>"
                class="deal-btn"
            >
                View Product
            </a>

        </div>

    <% }) %>

<% } %>

</div>
        </div>
    </section>

    <!-- Apple Lifestyle -->
    <section class="section lifestyle">
        <div class="lifestyle-container">
            <h2 class="lifestyle-title">Apple Lifestyle</h2>
            <div class="lifestyle-grid">
                <div class="lifestyle-left lifestyle-card">
                    <img src="/images/lifestyle_imac.png" alt="iMac Workspace" class="lifestyle-img">
                </div>
                <div class="lifestyle-right">
                    <div class="lifestyle-right-top">
                        <div class="lifestyle-card">
                            <img src="/images/lifestyle_iphone.png" alt="iPhone Sunset" class="lifestyle-img">
                        </div>
                        <div class="lifestyle-card">
                            <img src="/images/lifestyle_watch.png" alt="Apple Watch Cycling" class="lifestyle-img">
                        </div>
                    </div>
                    <div class="lifestyle-right-bottom lifestyle-card">
                        <img src="/images/lifestyle_ipad.png" alt="iPad Creativity" class="lifestyle-img">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
   <%- include("../partials/user/footer") %>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        gsap.registerPlugin(ScrollTrigger);

        // Entrance animations
        gsap.from(".hero-title, .hero-description", {
            y: 50,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: "power3.out"
        });

        gsap.from(".hero-image", {
            x: 100,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
            delay: 0.5
        });

        // Scroll animations for sections
        gsap.utils.toArray(".category-card, .product-card, .best-card, .deal-card, .bento-item").forEach(item => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: "top 90%",
                },
                y: 40,
                opacity: 0,
                duration: 1,
                ease: "power3.out"
            });
        });

    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="/js/wishlist.js"></script>
</body>
</html>
