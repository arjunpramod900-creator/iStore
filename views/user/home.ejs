<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iStore - Discover the Latest Apple Products</title>
    <link rel="stylesheet" href="/css/home.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
    <!-- Header -->
   <%- include("../partials/user/header") %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">Discover the <span>Latest</span> Apple Products</h1>
            <p class="hero-description">Experience innovation like never before. From iPhone to MacBook, find everything you need to light up your life.</p>
        </div>
        <div class="hero-image-container">
            <img src="/images/hero_new.png" alt="Apple Products" class="hero-image">
        </div>
    </section>

    <!-- Shop by Category -->
    <section class="section categories">
        <div class="category-header">
            <span class="section-label">Collections</span>
            <h2 class="section-title">Shop by Category</h2>
        </div>
        <div class="category-grid-container">
            <!-- Card 1: iPhone -->
            <div class="category-card iphone">
                <div class="category-img" style="background-image: url('/images/cat_iphone.png');"></div>
                <div class="category-gradient"></div>
                <div class="category-content">
                    <p class="category-name">iPhone</p>
                    <p class="category-description">Everything you need</p>
                </div>
            </div>
            <!-- Card 2: MacBook -->
            <div class="category-card macbook">
                <div class="category-img" style="background-image: url('/images/cat_macbook.png');"></div>
                <div class="category-gradient"></div>
                <div class="category-content">
                    <p class="category-name">MacBook</p>
                    <p class="category-description">Pure power</p>
                </div>
            </div>
            <!-- Card 3: iPad -->
            <div class="category-card ipad">
                <div class="category-img" style="background-image: url('/images/cat_ipad.png');"></div>
                <div class="category-gradient"></div>
                <div class="category-content">
                    <p class="category-name">iPad</p>
                    <p class="category-description">Your new studio</p>
                </div>
            </div>
            <!-- Card 4: Watch -->
            <div class="category-card watch">
                <div class="category-img" style="background-image: url('/images/cat_watch.png');"></div>
                <div class="category-gradient"></div>
                <div class="category-content">
                    <p class="category-name">Apple Watch</p>
                    <p class="category-description">Health on your wrist</p>
                </div>
            </div>
            <!-- Card 5: AirPods -->
            <div class="category-card airpods">
                <div class="category-img" style="background-image: url('/images/cat_airpods.png');"></div>
                <div class="category-gradient"></div>
                <div class="category-content">
                    <p class="category-name">AirPods</p>
                    <p class="category-description">Magic in your ears</p>
                </div>
            </div>
            <!-- Card 6: Accessories -->
            <div class="category-card accessories">
                <div class="category-img" style="background-image: url('/images/cat_accessories.png');"></div>
                <div class="category-gradient"></div>
                <div class="category-content">
                    <p class="category-name">Accessories</p>
                    <p class="category-description">Complete the kit</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="section featured">
        <div class="featured-container">
            <h2 class="featured-title">Featured Products</h2>
            <div class="product-grid">
                <!-- Product 1 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/prod_iphone17pro.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">iPhone 17 Pro</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹1,19,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 2 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/prod_macbookm5.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">MacBook Pro M5</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹1,99,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 3 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/prod_ipadpro.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">iPad Pro</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹79,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 4 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/prod_airpodsmax.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">AirPods Max</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹59,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 5 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/prod_iphone17.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">iPhone 17</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹79,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 6 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/macbook.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">MacBook Air M5</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹1,14,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 7 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/hero.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">iMac M5</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹1,34,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
                <!-- Product 8 -->
                <div class="product-card">
                    <div class="product-img-container">
                        <div class="product-img" style="background-image: url('/images/airpods.png');"></div>
                        <button class="wishlist-btn"><i data-lucide="heart"></i></button>
                    </div>
                    <div class="product-info">
                        <p class="product-name">AirPods Pro</p>
                    </div>
                    <div class="product-price-container">
                        <p class="product-price">₹24,900</p>
                    </div>
                    <button class="add-cart-btn"><i data-lucide="shopping-cart"></i> Add to Cart</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Best Sellers -->
    <section class="section best-sellers">
        <h2 class="best-sellers-title">Best Sellers</h2>
        <div class="best-grid">
            <!-- Item 1: iPhone 16 Pro -->
            <div class="best-card">
                <div class="best-tag"><span>HOT</span></div>
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/iphone.png');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">iPhone 16 Pro</p>
                    <p class="best-price">₹1,19,900</p>
                </div>
            </div>
            <!-- Item 2: MacBook Air M4 -->
            <div class="best-card">
                <div class="best-tag"><span>HOT</span></div>
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/macbook.png');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">MacBook Air M4</p>
                    <p class="best-price">₹1,14,900</p>
                </div>
            </div>
            <!-- Item 3: Apple Watch Ultra 2 -->
            <div class="best-card">
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/watch.png');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">Apple Watch Ultra 2</p>
                    <p class="best-price">₹89,900</p>
                </div>
            </div>
            <!-- Item 4: AirPods Max -->
            <div class="best-card">
                <div class="best-tag"><span>HOT</span></div>
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/best_airpods_max.jpg');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">AirPods Max</p>
                    <p class="best-price">₹59,900</p>
                </div>
            </div>
            <!-- Item 5: Magic Keyboard -->
            <div class="best-card">
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/best_keyboard.jpg');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">Magic Keyboard</p>
                    <p class="best-price">₹29,900</p>
                </div>
            </div>
            <!-- Item 6: Apple Pencil Pro -->
            <div class="best-card">
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/best_pencil.jpg');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">Apple Pencil Pro</p>
                    <p class="best-price">₹12,900</p>
                </div>
            </div>
            <!-- Item 7: AirTag -->
            <div class="best-card">
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/best_airtag.jpg');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">AirTag</p>
                    <p class="best-price">₹3,490</p>
                </div>
            </div>
            <!-- Item 8: HomePod Mini -->
            <div class="best-card">
                <div class="best-tag"><span>HOT</span></div>
                <div class="best-img-container">
                    <div class="best-img" style="background-image: url('/images/best_homepod_mini.jpg');"></div>
                </div>
                <div class="best-info">
                    <p class="best-name">HomePod Mini</p>
                    <p class="best-price">₹9,900</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Today's Deals -->
    <section class="section deals">
        <div class="deals-container">
            <h2 class="section-title" style="margin:0">Today's Deals</h2>
            <div class="deals-grid">
                <!-- Deal 1 -->
                <div class="deal-card">
                    <div class="deal-badge">Limited Time</div>
                    <h3 class="deal-title">Save 10% on MacBooks</h3>
                    <p class="deal-text">Upgrade your workspace with the latest M5 chips.</p>
                    <a href="#" class="deal-btn">Claim Offer</a>
                    <i data-lucide="laptop" class="deal-icon-bg"></i>
                </div>
                <!-- Deal 2 -->
                <div class="deal-card">
                    <div class="deal-badge">Audio Deal</div>
                    <h3 class="deal-title">AirPods Pro Discount</h3>
                    <p class="deal-text">Experience superior sound at an unbeatable price.</p>
                    <a href="#" class="deal-btn">Claim Offer</a>
                    <i data-lucide="headphones" class="deal-icon-bg"></i>
                </div>
                <!-- Deal 3 -->
                <div class="deal-card">
                    <div class="deal-badge">Shipping</div>
                    <h3 class="deal-title">Free Delivery on iPhones</h3>
                    <p class="deal-text">Get your new iPhone delivered to your door today.</p>
                    <a href="#" class="deal-btn">Claim Offer</a>
                    <i data-lucide="truck" class="deal-icon-bg"></i>
                </div>
            </div>
        </div>
    </section>

    <!-- Apple Lifestyle -->
    <section class="section lifestyle">
        <div class="lifestyle-container">
            <h2 class="lifestyle-title">Apple Lifestyle</h2>
            <div class="lifestyle-grid">
                <div class="lifestyle-left lifestyle-card">
                    <img src="/images/lifestyle_imac.png" alt="iMac Workspace" class="lifestyle-img">
                </div>
                <div class="lifestyle-right">
                    <div class="lifestyle-right-top">
                        <div class="lifestyle-card">
                            <img src="/images/lifestyle_iphone.png" alt="iPhone Sunset" class="lifestyle-img">
                        </div>
                        <div class="lifestyle-card">
                            <img src="/images/lifestyle_watch.png" alt="Apple Watch Cycling" class="lifestyle-img">
                        </div>
                    </div>
                    <div class="lifestyle-right-bottom lifestyle-card">
                        <img src="/images/lifestyle_ipad.png" alt="iPad Creativity" class="lifestyle-img">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
   <%- include("../partials/user/footer") %>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        gsap.registerPlugin(ScrollTrigger);

        // Entrance animations
        gsap.from(".hero-title, .hero-description", {
            y: 50,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: "power3.out"
        });

        gsap.from(".hero-image", {
            x: 100,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
            delay: 0.5
        });

        // Scroll animations for sections
        gsap.utils.toArray(".category-card, .product-card, .best-card, .deal-card, .bento-item").forEach(item => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: "top 90%",
                },
                y: 40,
                opacity: 0,
                duration: 1,
                ease: "power3.out"
            });
        });
    </script>
</body>
</html>
