<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Your Email - iStore</title>
    <link rel="stylesheet" href="/css/verify-emailpass-otp.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body class="verify-otp-body">

    <div class="blur-overlay blur-1"></div>
    <div class="blur-overlay blur-2"></div>

    <!-- Brand Header -->
    <header class="brand-anchor">
        <h1>iStore</h1>
        <span>Verify Your <%= flow === 'email' ? 'Email Change' : 'Password Change' %></span>
    </header>

    <!-- OTP Card -->
    <main class="otp-card">
        <div class="otp-header">
            <h2>Enter Verification Code</h2>
            <p>
                We sent a 6-digit code to
                <span id="masked-email">
                    <%= typeof newEmail !== "undefined" && newEmail
                        ? newEmail
                        : "your registered email" %>
                </span>
            </p>
        </div>

        <!-- OTP Form — submitted via axios, NOT native POST -->
        <div class="otp-form">

            <div class="otp-input-group">
                <input type="text" maxlength="1" pattern="\d*" inputmode="numeric" autofocus>
                <input type="text" maxlength="1" pattern="\d*" inputmode="numeric">
                <input type="text" maxlength="1" pattern="\d*" inputmode="numeric">
                <input type="text" maxlength="1" pattern="\d*" inputmode="numeric">
                <input type="text" maxlength="1" pattern="\d*" inputmode="numeric">
                <input type="text" maxlength="1" pattern="\d*" inputmode="numeric">
            </div>

            <!-- Inline OTP error -->
            <p id="otp-error" style="display:none;color:#e74c3c;font-size:13px;font-weight:500;text-align:center;margin-top:8px;"></p>

            <div class="otp-timer-section">
                <div class="timer-display">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span id="countdown">Resend available in 00:30</span>
                </div>
                <div class="resend-text">
                    Didn't receive the code?
                    <a href="#" class="resend-link" id="resendLink">Resend Code</a>
                </div>
            </div>

            <button type="button" class="verify-btn" id="verifyBtn">Verify Code</button>
        </div>

        <div class="card-footer">
            <a href="/profile" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m15 18-6-6 6-6"/>
                </svg>
                Back to Account
            </a>
            <div class="security-note-small">
                <svg width="16" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:#4C0080;">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span>For your security, this code will expire shortly.</span>
            </div>
        </div>
    </main>

    <footer class="otp-page-footer">
        © 2026 iStore Editorial. All rights reserved.
    </footer>

    <script>
        lucide.createIcons();

        const flow = "<%= flow %>";

        /* ================================================
           OTP INPUT — auto-advance & backspace
        ================================================ */

        const otpInputs = document.querySelectorAll(".otp-input-group input");

        otpInputs.forEach((input, index) => {
            input.addEventListener("input", (e) => {
                e.target.value = e.target.value.replace(/[^0-9]/g, "");
                if (e.target.value.length === 1 && index < otpInputs.length - 1) {
                    otpInputs[index + 1].focus();
                }
                /* Clear inline error when user starts typing */
                showOtpError("");
            });

            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace" && e.target.value === "" && index > 0) {
                    otpInputs[index - 1].focus();
                }
            });
        });

        /* Paste support */
        otpInputs[0].addEventListener("paste", (e) => {
            const paste = e.clipboardData.getData("text").replace(/[^0-9]/g, "");
            if (paste.length === 6) {
                otpInputs.forEach((input, i) => { input.value = paste[i] || ""; });
                otpInputs[5].focus();
            }
            e.preventDefault();
        });

        /* ================================================
           INLINE OTP ERROR HELPER
        ================================================ */

        function showOtpError(msg) {
            const el = document.getElementById("otp-error");
            if (msg) {
                el.textContent = msg;
                el.style.display = "block";
            } else {
                el.textContent = "";
                el.style.display = "none";
            }
        }

        function getOtpValue() {
            return Array.from(otpInputs).map(i => i.value.trim()).join("");
        }

        /* ================================================
           VERIFY OTP — axios POST, show SweetAlert
        ================================================ */

        const verifyBtn = document.getElementById("verifyBtn");

        verifyBtn.addEventListener("click", async () => {
            const otp = getOtpValue();

            if (otp.length !== 6) {
                showOtpError("Please enter all 6 digits");
                return;
            }

            verifyBtn.disabled = true;
            verifyBtn.textContent = "Verifying...";

            const endpoint = flow === "password"
                ? "/verify-change-password-otp"
                : "/verify-email-change-otp";

            try {
                const response = await axios.post(endpoint, { otp });

                if (response.data.success) {
                    if (flow === "email") {
                        await Swal.fire({
                            icon: "success",
                            title: "Email Updated!",
                            text: "Your email address has been changed successfully.",
                            confirmButtonText: "Go to Profile",
                        });
                        window.location.href = "/profile";
                    } else {
                        await Swal.fire({
                            icon: "success",
                            title: "Password Updated!",
                            text: "Your password has been changed successfully. Please log in again.",
                            confirmButtonText: "OK",
                        });
                        window.location.href = "/profile";
                    }
                }

            } catch (error) {
                const msg = error.response?.data?.message || "Invalid or expired OTP. Please try again.";

                /* Show inline error under the inputs */
                showOtpError(msg);

                /* Also highlight inputs red */
                otpInputs.forEach(input => {
                    input.style.borderColor = "#e74c3c";
                    input.style.background  = "#fff8f8";
                });

                /* Clear inputs so user can re-enter */
                otpInputs.forEach(input => { input.value = ""; });
                otpInputs[0].focus();

            } finally {
                verifyBtn.disabled = false;
                verifyBtn.textContent = "Verify Code";
            }
        });

        /* Clear red border when user starts typing again */
        otpInputs.forEach(input => {
            input.addEventListener("input", () => {
                input.style.borderColor = "";
                input.style.background  = "";
            });
        });

        /* ================================================
           IN-MEMORY COUNTDOWN TIMER
           (no localStorage — avoids stale state)
        ================================================ */

        const timerElement = document.getElementById("countdown");
        const resendLink   = document.getElementById("resendLink");

        const TIMER_DURATION = 30;
        let remaining = TIMER_DURATION;
        let timerInterval;

        function startTimer() {
            resendLink.style.pointerEvents = "none";
            resendLink.style.opacity       = "0.4";
            remaining = TIMER_DURATION;

            timerInterval = setInterval(() => {
                remaining--;
                timerElement.textContent = `Resend available in 00:${String(remaining).padStart(2, "0")}`;

                if (remaining <= 0) {
                    clearInterval(timerInterval);
                    timerElement.innerHTML = `<span style="color:#16A34A;">You can resend OTP now</span>`;
                    resendLink.style.pointerEvents = "auto";
                    resendLink.style.opacity       = "1";
                }
            }, 1000);
        }

        startTimer();

        /* ================================================
           RESEND OTP
        ================================================ */

        resendLink.addEventListener("click", async (e) => {
            e.preventDefault();

            const endpoint = flow === "password"
                ? "/send-change-password-otp"
                : "/send-email-change-otp";

            try {
                await axios.post(endpoint);

                /* Reset inputs */
                otpInputs.forEach(input => { input.value = ""; });
                otpInputs[0].focus();
                showOtpError("");

                /* Restart timer */
                clearInterval(timerInterval);
                startTimer();

                Swal.fire({
                    icon: "success",
                    title: "OTP Resent",
                    text: "A new code has been sent to your email.",
                    timer: 2000,
                    showConfirmButton: false,
                });

            } catch (error) {
                Swal.fire({
                    icon: "error",
                    title: "Failed to Resend",
                    text: error.response?.data?.message || "Could not resend OTP. Please try again.",
                });
            }
        });

        /* ================================================
           GSAP ANIMATIONS
        ================================================ */

        gsap.from(".brand-anchor", { y: -20, opacity: 0, duration: 0.8, ease: "power2.out" });
        gsap.from(".otp-card",     { y: 30,  opacity: 0, duration: 1,   ease: "power3.out", delay: 0.2 });
        gsap.from(".blur-overlay", { opacity: 0, scale: 0.8, duration: 1.5, ease: "power2.out" });

    </script>
</body>
</html>
