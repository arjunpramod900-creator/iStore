<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>iStore - Reset Password</title>

<link rel="stylesheet" href="/css/index.css">
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/css/sweetalert-theme.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<!-- GSAP -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<!-- Axios -->
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<!-- SweetAlert -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script src="/js/alertConfig.js"></script>

</head>

<body>

<div class="main-container">

<!-- LEFT PANEL -->

<section class="branding-panel">

<div class="blur-circle blur-circle-1"></div>
<div class="blur-circle blur-circle-2"></div>

<div class="branding-content">

<div class="logo-container">

<h1 class="logo-text">
iStore
</h1>

<p class="sub-greeting">
Create a new secure password.
</p>

</div>

<div class="product-showcase">

<div class="glass-card card-1">
<div class="product-img"
style="background-image: url('/images/iphone.png');"></div>
<span class="card-label">iPhone 17</span>
</div>

<div class="glass-card card-2">
<div class="product-img"
style="background-image: url('/images/macbook.png');"></div>
<span class="card-label">MacBook Pro M5</span>
</div>

<div class="glass-card card-3">
<div class="product-img"
style="background-image: url('/images/watch.png');"></div>
<span class="card-label">Watch Ultra</span>
</div>

<div class="glass-card card-4">
<div class="product-img"
style="background-image: url('/images/airpods.png');"></div>
<span class="card-label">AirPods Pro</span>
</div>

</div>

</div>

</section>



<!-- RIGHT PANEL -->

<section class="login-section auth-section">

<div class="form-container">

<header class="form-header">

<h2>
Reset Password
</h2>

<p>
Create a new password for your account.
</p>

</header>



<form id="resetForm"
class="login-form">

<!-- NEW PASSWORD -->

<div class="form-group">

<label>New Password</label>

<div class="input-wrapper password-wrapper">

<input
type="password"
id="newPassword"
class="input-field"
placeholder="Enter new password"
required>

<button
type="button"
class="eye-btn"
onclick="togglePassword('newPassword', this)">

<svg
class="eye-icon"
xmlns="http://www.w3.org/2000/svg"
viewBox="0 0 24 24">

<path stroke="currentColor"
stroke-width="2"
fill="none"
d="M1 12s4-8 11-8
11 8 11 8
-4 8-11 8
-11-8-11-8z"/>

<circle cx="12"
cy="12"
r="3"
stroke="currentColor"
stroke-width="2"
fill="none"/>

</svg>

</button>

</div>

</div>



<!-- PASSWORD STRENGTH -->

<div class="password-strength-container">

<p class="strength-label">

Password Strength:

<span id="strengthText">
Weak
</span>

</p>

<div class="strength-bar">

<div
id="strengthFill"
class="strength-fill">
</div>

</div>

<ul class="password-rules">

<li id="rule-length">
At least 8 characters
</li>

<li id="rule-uppercase">
One uppercase letter
</li>

<li id="rule-number">
One number
</li>

<li id="rule-special">
One special character
</li>

</ul>

</div>



<!-- CONFIRM PASSWORD -->

<div class="form-group">

<label>Confirm Password</label>

<div class="input-wrapper password-wrapper">

<input
type="password"
id="confirmPassword"
class="input-field"
placeholder="Confirm new password"
required>

<button
type="button"
class="eye-btn"
onclick="togglePassword('confirmPassword', this)">

<svg
class="eye-icon"
xmlns="http://www.w3.org/2000/svg"
viewBox="0 0 24 24">

<path stroke="currentColor"
stroke-width="2"
fill="none"
d="M1 12s4-8 11-8
11 8 11 8
-4 8-11 8
-11-8-11-8z"/>

<circle cx="12"
cy="12"
r="3"
stroke="currentColor"
stroke-width="2"
fill="none"/>

</svg>

</button>

</div>

</div>



<button
type="submit"
class="login-btn">

Reset Password

</button>



<footer class="form-footer">

<p>

<a href="/login">
← Back to Login
</a>

</p>

</footer>

</form>

</div>

</section>

</div>



<script>

/* PASSWORD TOGGLE */
function togglePassword(inputId, btn) {

const input =
document.getElementById(inputId)

const svg =
btn.querySelector("svg")

if (input.type === "password") {

input.type = "text"

/* Eye-Off Icon (with slash) */

svg.innerHTML = `
<path
stroke="currentColor"
stroke-width="2"
fill="none"
d="M17.94 17.94
A10.94 10.94 0 0 1 12 20
C5 20 1 12 1 12
A21.76 21.76 0 0 1
5.06 5.06M9.88 9.88
A3 3 0 0 1 14.12
14.12M1 1l22 22"/>
`

}

else {

input.type = "password"

/* Eye Icon */

svg.innerHTML = `
<path
stroke="currentColor"
stroke-width="2"
fill="none"
d="M1 12s4-8 11-8
11 8 11 8
-4 8-11 8
-11-8-11-8z"/>

<circle
cx="12"
cy="12"
r="3"
stroke="currentColor"
stroke-width="2"
fill="none"/>
`

}

}



/* PASSWORD STRENGTH */

const passwordInput =
document.getElementById("newPassword")

const strengthFill =
document.getElementById("strengthFill")

const strengthText =
document.getElementById("strengthText")

const ruleLength =
document.getElementById("rule-length")

const ruleUppercase =
document.getElementById("rule-uppercase")

const ruleNumber =
document.getElementById("rule-number")

const ruleSpecial =
document.getElementById("rule-special")

passwordInput.addEventListener("input", () => {

const password = passwordInput.value

let strength = 0



if (password.length >= 8) {

ruleLength.classList.add("valid")

strength++

} else {

ruleLength.classList.remove("valid")

}



if (/[A-Z]/.test(password)) {

ruleUppercase.classList.add("valid")

strength++

} else {

ruleUppercase.classList.remove("valid")

}



if (/[0-9]/.test(password)) {

ruleNumber.classList.add("valid")

strength++

} else {

ruleNumber.classList.remove("valid")

}



if (/[!@#$%^&*]/.test(password)) {

ruleSpecial.classList.add("valid")

strength++

} else {

ruleSpecial.classList.remove("valid")

}



/* Strength Display */

strengthFill.className =
"strength-fill"



if (strength <= 1) {

strengthFill.style.width = "25%"

strengthFill.classList.add("strength-weak")

strengthText.textContent = "Weak"

}

else if (strength <= 3) {

strengthFill.style.width = "60%"

strengthFill.classList.add("strength-medium")

strengthText.textContent = "Medium"

}

else {

strengthFill.style.width = "100%"

strengthFill.classList.add("strength-strong")

strengthText.textContent = "Strong"

}

})



/* RESET PASSWORD */

const resetForm =
document.getElementById("resetForm")

resetForm.addEventListener(
"submit",
async (e) => {

e.preventDefault()

const newPassword =
document.getElementById("newPassword").value.trim()

const confirmPassword =
document.getElementById("confirmPassword").value.trim()



if (newPassword !== confirmPassword) {

showErrorAlert(
"Mismatch",
"Passwords do not match"
)

return

}



try {

showLoadingAlert(
"Resetting password..."
)

const response =
await axios.post(
"/reset-password",
{
newPassword,
confirmPassword
}
)



if (response.data.success) {

showSuccessAlert(
"Password Reset Successful",
"Redirecting to login..."
)

setTimeout(() => {

window.location.href =
"/login"

}, 1500)

}

}

catch (error) {

showErrorAlert(
"Failed",
error.response?.data?.message
|| "Something went wrong"
)

}

}

)

</script>



<script src="/js/animations.js"></script>
<script src="/js/tilt.js"></script>

</body>

</html>