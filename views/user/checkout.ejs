<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout — iStore</title>
    <meta name="description" content="Complete your iStore purchase. Secure checkout with multiple payment options.">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/components/toast.css">
    <link rel="stylesheet" href="/css/checkout.css">
    <link rel="stylesheet" href="/css/addresses.css?v=5.0">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>

<body>

    <%- include('../partials/user/header', { page: 'checkout' }) %>

<%
const grandTotal = finalAmount;
const currentCouponDiscount = couponDiscount || 0;
%>

    <main class="checkout-page" id="checkoutPage">

        <div class="checkout-container">

            <!-- ── BREADCRUMBS ── -->
            <nav class="co-breadcrumbs" aria-label="Breadcrumb">
                <a href="/" class="bc-crumb">Home</a>
                <span class="bc-sep">
                    <i data-lucide="chevron-right" size="12"></i>
                </span>
                <a href="/cart" class="bc-crumb">Cart</a>
                <span class="bc-sep">
                    <i data-lucide="chevron-right" size="12"></i>
                </span>
                <span class="bc-crumb active">Checkout</span>
            </nav>

            <!-- ── PAGE HEADING ── -->
            <h1 class="co-heading">Checkout</h1>

            <!-- ── TWO-COLUMN LAYOUT ── -->
            <div class="co-layout">

                <!-- ══════════════════════════════
                     LEFT COLUMN — Forms
                ══════════════════════════════ -->
                <section class="co-left" id="coLeft">

                    <!-- ── SECTION 1: SHIPPING DETAILS ── -->
                    <div class="co-section" id="sectionShipping">

                        <div class="co-section-header">
                            <span class="co-section-icon">
                                <i data-lucide="map-pin" size="16"></i>
                            </span>
                            <h2 class="co-section-title">Shipping Details</h2>
                        </div>

                        <div class="checkout-addresses-grid">
                            <input
    type="hidden"

    id="selectedAddressId"

    name="selectedAddressId"

    value="<%= addresses?.find(a => a.isDefault)?._id || '' %>"
>

    <% if(addresses && addresses.length > 0){ %>

        <% addresses.forEach(address => { %>

            <div

                class="
                checkout-address-wrapper
                <%= address.isDefault ? 'active' : '' %>
                "

                data-address-id="<%= address._id %>"

            >

                <%- include(

                    "../partials/user/address-card",

                    { address }

                ) %>

            </div>

        <% }) %>

    <% } else { %>

        <div class="co-empty-address">

            <p>
                No saved addresses found
            </p>

        </div>

    <% } %>

</div>

<button
type="button"
id="checkoutAddAddressBtn"
class="co-add-address-btn">

+ Add New Address

</button>
                    </div>

                    <!-- ── SECTION 2: DELIVERY OPTIONS ── -->
                    <div class="co-section" id="sectionDelivery">

                        <div class="co-section-header">
                            <span class="co-section-icon">
                                <i data-lucide="truck" size="16"></i>
                            </span>
                            <h2 class="co-section-title">Delivery Options</h2>
                        </div>

                        <div class="co-delivery-grid">

                            <!-- Standard Delivery (selected) -->
                            <label class="co-delivery-card selected" id="deliveryStandard">
                                <input
                                    type="radio"
                                    name="delivery"
                                    value="standard"
                                    class="co-radio-hidden"
                                    checked
                                >
                                <span class="co-radio-dot">
                                    <span class="co-radio-dot-inner"></span>
                                </span>
                                <span class="co-delivery-info">
                                    <span class="co-delivery-name">Standard Delivery</span>
                                    <span class="co-delivery-desc">3–5 Business Days</span>
                                </span>
                                <span class="co-delivery-price free">Free</span>
                            </label>

                            <!-- Express Delivery -->
                            <label class="co-delivery-card" id="deliveryExpress">
                                <input
                                    type="radio"
                                    name="delivery"
                                    value="express"
                                    class="co-radio-hidden"
                                >
                                <span class="co-radio-dot unselected">
                                    <span class="co-radio-dot-inner"></span>
                                </span>
                                <span class="co-delivery-info">
                                    <span class="co-delivery-name">Express Delivery</span>
                                    <span class="co-delivery-desc">Next Day Delivery</span>
                                </span>
                                <span class="co-delivery-price">₹500</span>
                            </label>

                        </div>
                    </div>

                    <!-- ── SECTION 3: PAYMENT METHOD ── -->
                    <div class="co-section" id="sectionPayment">

                        <div class="co-section-header">
                            <span class="co-section-icon">
                                <i data-lucide="credit-card" size="16"></i>
                            </span>
                            <h2 class="co-section-title">Payment Method</h2>
                        </div>

                        <div class="co-payment-card">

                            <!-- Payment method tabs -->
                            <div class="co-payment-tabs">

                                <button class="co-pay-tab active" data-method="card" id="tabCard">
                                    <i data-lucide="credit-card" size="18"></i>
                                    <span>Card</span>
                                </button>

                                <button class="co-pay-tab" data-method="upi" id="tabUpi">
                                    <i data-lucide="smartphone" size="18"></i>
                                    <span>UPI / Net</span>
                                </button>

                                <button class="co-pay-tab" data-method="wallet" data-lucide-icon="wallet" id="tabWallet">
                                    <i data-lucide="wallet" size="18"></i>
                                    <span>Wallet</span>
                                </button>

                                <button class="co-pay-tab" data-method="cod" id="tabCod">
                                    <i data-lucide="banknote" size="18"></i>
                                    <span>COD</span>
                                </button>

                            </div>

                            <!-- ── CARD DETAILS ── -->
                            <div class="co-card-details" id="panelCard">

                                <div class="co-field co-field--full">
                                    <label class="co-label" for="cardNumber">Card Number</label>
                                    <div class="co-card-input-wrap">
                                        <input
                                            type="text"
                                            id="cardNumber"
                                            name="cardNumber"
                                            class="co-input"
                                            placeholder="0000 0000 0000 0000"
                                            maxlength="19"
                                            autocomplete="cc-number"
                                        >
                                        <span class="co-card-brand-badges">
                                            <span class="co-card-badge visa"></span>
                                            <span class="co-card-badge mc"></span>
                                        </span>
                                    </div>
                                </div>

                                <div class="co-form-grid">
                                    <div class="co-field">
                                        <label class="co-label" for="expiry">Expiry Date</label>
                                        <input
                                            type="text"
                                            id="expiry"
                                            name="expiry"
                                            class="co-input"
                                            placeholder="MM/YY"
                                            maxlength="5"
                                            autocomplete="cc-exp"
                                        >
                                    </div>
                                    <div class="co-field">
                                        <label class="co-label" for="cvv">CVV</label>
                                        <input
                                            type="password"
                                            id="cvv"
                                            name="cvv"
                                            class="co-input"
                                            placeholder="•••"
                                            maxlength="4"
                                            autocomplete="cc-csc"
                                        >
                                    </div>
                                </div>

                            </div>

                            <!-- ── UPI PANEL ── -->
                            <div class="co-card-details hidden" id="panelUpi">
                                <div class="co-field co-field--full">
                                    <label class="co-label" for="upiId">UPI ID</label>
                                    <input
                                        type="text"
                                        id="upiId"
                                        name="upiId"
                                        class="co-input"
                                        placeholder="yourname@upi"
                                    >
                                </div>
                                <p class="co-panel-note">
                                    <i data-lucide="info" size="14"></i>
                                    You'll receive a payment request on your UPI app.
                                </p>
                            </div>

                            <!-- ── WALLET PANEL ── -->
                            <div class="co-card-details hidden" id="panelWallet">
                                <div class="co-wallet-options">
                                    <label class="co-wallet-opt">
                                        <input type="radio" name="wallet" value="paytm" checked>
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/4/42/Paytm_logo.png" alt="Paytm" class="co-wallet-logo">
                                    </label>
                                    <label class="co-wallet-opt">
                                        <input type="radio" name="wallet" value="phonepe">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/PhonePe_Logo.png/180px-PhonePe_Logo.png" alt="PhonePe" class="co-wallet-logo">
                                    </label>
                                    <label class="co-wallet-opt">
                                        <input type="radio" name="wallet" value="amazonpay">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/a9/Amazon_logo.svg/200px-Amazon_logo.svg.png" alt="Amazon Pay" class="co-wallet-logo">
                                    </label>
                                </div>
                            </div>

                            <!-- ── COD PANEL ── -->
                            <div class="co-card-details hidden" id="panelCod">
                                <div class="co-cod-notice">
                                    <i data-lucide="package-check" size="24"></i>
                                    <div>
                                        <p class="co-cod-title">Cash on Delivery</p>
                                        <p class="co-cod-desc">Pay in cash when your order arrives. A convenience fee of ₹29 may apply.</p>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </section>

                <!-- ══════════════════════════════
                     RIGHT COLUMN — Order Summary
                ══════════════════════════════ -->
                <aside class="co-right" id="coRight">

                    <!-- ORDER SUMMARY CARD -->
                    <div class="co-summary-card">

                        <h2 class="co-summary-title">Order Summary</h2>

                        <!-- Items list -->
                        <div class="co-summary-items">

                            <% if (cart && cart.items && cart.items.length > 0) { %>

                                <% cart.items.forEach(item => { %>

                                    <div class="co-summary-item">
                                        <div class="co-item-thumb">
                                            <img
                                                src="<%= item.variantId.images?.[0] || item.productId.thumbnail || '/img/placeholder.png' %>"
                                                alt="<%= item.productId.name %>"
                                                loading="lazy"
                                            >
                                        </div>
                                        <div class="co-item-meta">
                                            <p class="co-item-name"><%= item.productId.name %></p>
                                            <p class="co-item-variant">
                                                <%= [item.variantId.color, item.variantId.storage].filter(Boolean).join(' • ') %>
                                                <% if (item.quantity > 1) { %> &nbsp;·&nbsp; Qty: <%= item.quantity %><% } %>
                                            </p>
                                        </div>
                                        <span class="co-item-price">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></span>
                                    </div>

                                <% }) %>

                            <% } else { %>

                                <!-- Demo items when no real cart data -->
                                <div class="co-summary-item">
                                    <div class="co-item-thumb co-item-thumb--placeholder">
                                        <i data-lucide="smartphone" size="24"></i>
                                    </div>
                                    <div class="co-item-meta">
                                        <p class="co-item-name">iPhone 17 Pro</p>
                                        <p class="co-item-variant">Natural Titanium • 256GB</p>
                                    </div>
                                    <span class="co-item-price">₹1,19,900</span>
                                </div>

                                <div class="co-summary-item">
                                    <div class="co-item-thumb co-item-thumb--placeholder">
                                        <i data-lucide="headphones" size="24"></i>
                                    </div>
                                    <div class="co-item-meta">
                                        <p class="co-item-name">AirPods Pro (2nd Gen)</p>
                                        <p class="co-item-variant">Qty: 1</p>
                                    </div>
                                    <span class="co-item-price">₹24,800</span>
                                </div>

                            <% } %>

                        </div>

                        <!-- Summary totals -->
                        <div class="co-summary-breakdown">

                            <div class="co-breakdown-row">
                                <span>Subtotal</span>
                                <span id="coSubtotal">
                                    ₹<%= subtotal.toLocaleString('en-IN') %>
                                </span>
                            </div>

                            <div class="co-breakdown-row">
    <span>Shipping</span>

    <span
        class="<%= deliveryCharge === 0 ? 'co-free' : '' %>"
        id="coShipping"
    >
        <%= deliveryCharge === 0
            ? 'Free'
            : `₹${deliveryCharge.toLocaleString('en-IN')}` %>
    </span>
</div>

                           <div
                            class="co-breakdown-row co-discount"
                            id="coDiscountRow"
                            style="<%= currentCouponDiscount > 0 ? '' : 'display:none;' %>"
                            >
                                <span>Discount (<span id="coCouponCode">
<%= appliedCoupon?.code || "-" %>
</span>)</span>
                                <span class="co-discount-val" id="coDiscount">

    −₹<%= currentCouponDiscount.toLocaleString('en-IN') %>

</span>
                            </div>

                            <div class="co-breakdown-row">
                                <span>Estimated Tax</span>
                                <span id="coTax">

                                    ₹<%= taxAmount.toLocaleString('en-IN') %>

                                </span>
                            </div>

                        </div>

                        <!-- Grand Total -->
                        <div class="co-total-row">
                            <div class="co-total-label">
                                Total Amount
                                <span class="co-total-incl">Incl. all taxes</span>
                            </div>
                            <span class="co-total-value" id="coGrandTotal">
                                ₹<%= grandTotal.toLocaleString('en-IN') %>
                            </span>
                        </div>

                        <!-- Place Order CTA -->
                        <button class="co-place-order-btn" id="placeOrderBtn" type="button">
                            Place Order
                        </button>

                        <!-- Secure checkout badge -->
                        <div class="co-secure-badge">
                            <i data-lucide="lock" size="14"></i>
                            <span>Secure Checkout — Your payment information is protected</span>
                        </div>

                    </div>

                    <!-- AVAILABLE COUPONS -->
                    <div class="co-coupons-card">

                        <h3 class="co-coupons-title">Available Coupons</h3>

                        <div class="co-coupon-list">

                            <% if(availableCoupons && availableCoupons.length > 0){ %>

                                <% availableCoupons.forEach(coupon => { %>

                                    <div class="co-coupon">

                                        <div class="co-coupon-info">

                                            <span class="co-coupon-code">
                                                <%= coupon.code %>
                                            </span>

                                            <span class="co-coupon-desc">

                                                <% if(coupon.discountType === "PERCENTAGE"){ %>

                                                    <%= coupon.discountValue %>% OFF

                                                <% } else { %>

                                                    ₹<%= coupon.discountValue.toLocaleString("en-IN") %> OFF

                                                <% } %>

                                                <% if(coupon.minPurchase > 0){ %>

                                                    • Min ₹<%= coupon.minPurchase.toLocaleString("en-IN") %>

                                                <% } %>

                                            </span>

                                        </div>

                                        <button
                                            class="co-coupon-apply-btn"
                                            data-code="<%= coupon.code %>">

                                            Apply

                                        </button>

                                    </div>

                                <% }) %>

                            <% } else { %>

                                <div class="co-coupon">

                                    <div class="co-coupon-info">

                                        <span class="co-coupon-desc">
                                            No coupons available right now
                                        </span>

                                    </div>

                                </div>

                            <% } %>

                        </div>

                        <!-- Manual coupon entry -->
                        <div class="co-coupon-manual">

                            <input
                                type="text"
                                id="couponInput"
                                class="co-coupon-input"
                                placeholder="Enter promo code"
                                value="<%= appliedCoupon?.code || '' %>"
                            >

                            <button
                                class="co-coupon-manual-btn"
                                id="applyCouponBtn"
                            >
                                Apply
                            </button>

                            <button
                                type="button"
                                id="removeCouponBtn"
                                class="co-coupon-manual-btn"
                                style="<%= currentCouponDiscount > 0 ? 'display:inline-flex;' : 'display:none;' %>"
                            >
                                Remove
                            </button>

                        </div>

                    </div>

                </aside>

            </div>
        </div>

    </main>
     <!-- Add Address Modal -->
        <div class="modal-overlay" id="address-modal">
            <div class="modal-card">
                <div class="modal-header">
                    <h2>Add New Address</h2>
                    <p>Enter your delivery details for a seamless shipping experience.</p>
                </div>
             <form
                id="new-address-form"
                class="address-form-v2"
                method="POST"
                action="/add-address"
                >

                <input
                type="hidden"
                name="redirectTo"
                value="/checkout"
                >
                    <div class="form-row">
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" id="form-name" name="fullName" placeholder="e.g. fullName" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input type="tel" id="form-phone" name="phoneNumber" placeholder="(+91)00 00 00 00" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>Street Address</label>
                        <input type="text" id="form-address" name="addressLine1" placeholder="In Hariharnagar In" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                    </div>

                    <div class="form-group">
                        <label>Apartment / Building (Optional)</label>
                        <input type="text" id="form-building" placeholder="Suite, floor, gate code" style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                    </div>

                    <div class="form-row-3">
                        <div class="form-group">
                            <label>City</label>
                            <input type="text" id="form-city" name="city" placeholder="Kannur" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        <div class="form-group">
                            <label>State</label>
                            <input type="text" id="form-state" name="state" placeholder="Kerala" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        <div class="form-group">
                            <label>Pin Code</label>
                            <input type="text" id="form-pin" name="pincode" placeholder="670571" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Country</label>
                        <div class="custom-select-wrapper">
                            <select id="form-country" name="country">
                                <option value="United States">United States</option>
                                <option value="India">India</option>
                                <option value="United Kingdom">United Kingdom</option>
                                <option value="Canada">Canada</option>
                            </select>
                            <div class="select-arrow"><i data-lucide="chevron-down"></i></div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Address Type</label>
                        <div class="type-selector-premium">
                            <div class="type-option-premium">
                                <input type="radio" name="type" id="type-home" value="Home" checked>
                                <label for="type-home">
                                    <i data-lucide="home"></i>
                                    <span>Home</span>
                                </label>
                            </div>
                            <div class="type-option-premium">
                                <input type="radio" name="type" id="type-work" value="Work">
                                <label for="type-work">
                                    <i data-lucide="briefcase"></i>
                                    <span>Work</span>
                                </label>
                            </div>
                            <div class="type-option-premium">
                                <input type="radio" name="type" id="type-other" value="Other">
                                <label for="type-other">
                                    <i data-lucide="more-horizontal"></i>
                                    <span>Other</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="default-toggle-wrapper">
                        <label class="switch">
                            <input type="checkbox" id="form-default" name="isDefault" value="true">
                            <span class="slider"></span>
                        </label>
                        <span class="toggle-label">Set as Default Address</span>
                    </div>

                    <div class="modal-actions-premium">
                        <button type="button" class="cancel-btn-premium" id="close-modal">Cancel</button>
                        <button type="submit" class="save-address-btn-premium">Save Address</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Edit Address Modal -->
        <div class="modal-overlay" id="edit-address-modal">
            <div class="edit-modal-card">
                <div class="edit-modal-left">
                    <div class="modal-header" style="margin-bottom: 32px;">
                        <h2>Edit Address</h2>
                        <p>Update your delivery details.</p>
                    </div>
                    <form
                    class="address-form-v2"
                    id="edit-address-form"
                    method="POST"
                    >

                    <input
                    type="hidden"
                    name="redirectTo"
                    value="/checkout"
                    >
                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" id="edit-form-name" name="fullName" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label>Phone Number</label>
                                <input type="tel" id="edit-form-phone" name="phoneNumber" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                            <div class="form-group">
                                <label>Address Type</label>
                                <div class="type-selector-pill">
                                    <div class="type-option-pill">
                                        <input type="radio" name="type" id="edit-type-home" value="Home">
                                        <label for="edit-type-home">Home</label>
                                    </div>
                                    <div class="type-option-pill">
                                        <input type="radio" name="type" id="edit-type-work" value="Work">
                                        <label for="edit-type-work">Work</label>
                                    </div>
                                    <div class="type-option-pill">
                                        <input type="radio" name="type" id="edit-type-other" value="Other">
                                        <label for="edit-type-other">Other</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Street Address</label>
                            <input type="text" id="edit-form-address" name="addressLine1" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>

                        <div class="form-group">
                            <label>Apartment / Area</label>
                            <input type="text" id="edit-form-building" name="building" style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                        </div>

                        <div class="form-row-3">
                            <div class="form-group">
                                <label>City</label>
                                <input type="text" id="edit-form-city" name="city" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                            <div class="form-group">
                                <label>State</label>
                                <input type="text" id="edit-form-state" name="state" required style="width: 100%; padding: 14px 16px; background: #EEEEF0; border: none; border-radius: 12px;">
                            </div>
                           <div class="form-group">
                                <label>Country</label>

                                <select
                                id="edit-form-country"
