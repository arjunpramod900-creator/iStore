    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        lucide.createIcons();

        /* ── Entrance animations ── */
        gsap.from('#coLeft', { x: -30, opacity: 0, duration: 0.7, ease: 'power2.out' });
        gsap.from('#coRight', { x: 30, opacity: 0, duration: 0.7, ease: 'power2.out' });
        gsap.from('.co-section', { y: 20, opacity: 0, duration: 0.5, stagger: 0.12, delay: 0.2, ease: 'power2.out' });

        /* ── Payment method tab switching ── */
        let selectedPaymentMethod = "COD";
        const tabs   = document.querySelectorAll('.co-pay-tab');
        const panels = {
            card:   document.getElementById('panelCard'),
            upi:    document.getElementById('panelUpi'),
            wallet: document.getElementById('panelWallet'),
            cod:    document.getElementById('panelCod'),
        };

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const method = tab.dataset.method;
                switch (method) {

                    case "cod":
                        selectedPaymentMethod = "COD";
                        break;

                    case "wallet":
                        selectedPaymentMethod = "WALLET";
                        break;

                    case "card":
                    case "upi":
                        selectedPaymentMethod = "RAZORPAY";
                        break;

                    default:
                        selectedPaymentMethod = "COD";

                }
                Object.values(panels).forEach(p => p.classList.add('hidden'));
                panels[method].classList.remove('hidden');
                lucide.createIcons();
            });
        });

        /* ── Delivery option selection ── */
                    const deliveryCards =
                document.querySelectorAll('.co-delivery-card');

                deliveryCards.forEach(card => {

                    card.addEventListener('click', () => {

                        deliveryCards.forEach(c =>
                            c.classList.remove('selected')
                        );

                        card.classList.add('selected');

                        const shippingEl =
                        document.getElementById('coShipping');

                        const taxEl =
                        document.getElementById('coTax');

                        const totalEl =
                        document.getElementById('coGrandTotal');

                        const tax =
                        Number(
                            taxEl.textContent
                            .replace(/[₹,]/g,'')
                        );

                        let shipping = 0;

                        if (
                            card.querySelector(
                                'input[value="express"]'
                            )
                        ) {

                            shipping = 500;

                            shippingEl.textContent =
                            '₹500';

                            shippingEl.classList.remove(
                                'co-free'
                            );

                        } else {

                            shipping = 0;

                            shippingEl.textContent =
                            'Free';

                            shippingEl.classList.add(
                                'co-free'
                            );
                        }

                        const subtotal =
                        <%= subtotal %>;

                        const discount =
                            Number(
                            document
                            .getElementById("coDiscount")
                            .textContent
                            .replace(/[−₹,]/g,"")
                            ) || 0;

                        const newTotal =
                        subtotal +
                        tax +
                        shipping -
                        discount;

                        totalEl.textContent =
                        `₹${newTotal.toLocaleString('en-IN')}`;

                    });

                });

        /* ── Card number formatting ── */
        const cardInput = document.getElementById('cardNumber');
        if (cardInput) {
            cardInput.addEventListener('input', e => {
                let v = e.target.value.replace(/\D/g, '').slice(0, 16);
                e.target.value = v.replace(/(.{4})/g, '$1 ').trim();
            });
        }

        /* ── Expiry formatting ── */
        const expiryInput = document.getElementById('expiry');
        if (expiryInput) {
            expiryInput.addEventListener('input', e => {
                let v = e.target.value.replace(/\D/g, '').slice(0, 4);
                if (v.length >= 2) v = v.slice(0,2) + '/' + v.slice(2);
                e.target.value = v;
            });
        }

        /* ── Coupon apply ── */
        document.querySelectorAll('.co-coupon-apply-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const code = btn.dataset.code;
                document.getElementById('couponInput').value = code;
                applyCouponCode(code);
            });
        });

        document.getElementById('applyCouponBtn').addEventListener('click', () => {
            const code = document.getElementById('couponInput').value.trim().toUpperCase();
            if (code) applyCouponCode(code);
        });

        document.getElementById("removeCouponBtn")?.addEventListener("click", async () => {

        try {

            const response =
            await fetch(
                "/checkout/remove-coupon",
                {
                    method: "POST"
                }
            );

            const data =
            await response.json();

            if (!data.success) {

                return Swal.fire({

                    icon: "error",

                    title: "Coupon Error",

                    text: data.message
                });

            }

            document.getElementById(
                    "couponInput"
                ).value = "";

                document.getElementById(
                    "coCouponCode"
                ).textContent = "-";

                document.getElementById(
                    "coDiscount"
                ).textContent = "−₹0";

                document.getElementById(
                    "coDiscountRow"
                ).style.display = "none";

                /* RESTORE TAX */

                document.getElementById(
                    "coTax"
                ).textContent =
                `₹${data.taxAmount.toLocaleString("en-IN")}`;

                /* RESTORE SHIPPING */

                const shippingEl =
                document.getElementById(
                    "coShipping"
                );

                shippingEl.textContent =
                data.deliveryCharge === 0
                ? "Free"
                : `₹${data.deliveryCharge.toLocaleString("en-IN")}`;

                shippingEl.classList.toggle(
                    "co-free",
                    data.deliveryCharge === 0
                );

                /* RESTORE GRAND TOTAL */

                document.getElementById(
                    "coGrandTotal"
                ).textContent =
                `₹${data.finalAmount.toLocaleString("en-IN")}`;

                /* HIDE REMOVE BUTTON */

                document.getElementById(
                    "removeCouponBtn"
                ).style.display =
                "none";

        }

        catch (error) {

            Swal.fire({

                icon: "error",

                title: "Something went wrong"
            });

        }

    }
);

       async function applyCouponCode(code) {

    try {

        const response =
        await fetch(
            "/checkout/apply-coupon",
            {
                method: "POST",

                headers: {
                    "Content-Type":
                    "application/json"
                },

                body: JSON.stringify({
                    couponCode: code
                })
            }
        );

        const data =
        await response.json();

        if (!data.success) {

            return Swal.fire({

                icon: "error",

                title: "Coupon Error",

                text: data.message,

                confirmButtonColor:
                "#603763"
            });
        }

        document.getElementById(
            "coCouponCode"
        ).textContent =
        data.couponCode;

        document.getElementById(
            "coDiscountRow"
        ).style.display = "flex";

        document.getElementById(
            "coDiscount"
        ).textContent =
        `−₹${data.couponDiscount.toLocaleString("en-IN")}`;

        document.getElementById(
            "coTax"
        ).textContent =
        `₹${data.taxAmount.toLocaleString("en-IN")}`;

        document.getElementById(
            "coGrandTotal"
        ).textContent =
        `₹${data.finalAmount.toLocaleString("en-IN")}`;

        document.getElementById(
            "removeCouponBtn"
        ).style.display =
        "inline-flex";

        Swal.fire({

            toast: true,

            position: "top-end",

            icon: "success",

            title:
            "Coupon Applied",

            showConfirmButton: false,

            timer: 2000,
        });

    }

    catch (error) {

        Swal.fire({

            icon: "error",

            title:
            "Something went wrong",

            text:
            "Please try again later.",
        });

    }

}
