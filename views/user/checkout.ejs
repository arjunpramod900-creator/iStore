/* =========================================
   ADD ADDRESS AJAX
========================================= */

const addAddressForm =
document.getElementById(
"new-address-form"
);

addAddressForm?.addEventListener(

"submit",

async (e) => {

e.preventDefault();

try {

const formData = Object.fromEntries(
  new FormData(addAddressForm)
);

const response = await fetch(
  "/add-address",
  {
    method: "POST",

    headers: {
      "Content-Type": "application/json"
    },

    body: JSON.stringify(formData)
  }
);

const data =
await response.json();

if(!data.success){

return Swal.fire({

    toast: true,

    position: "top",

    icon: "warning",

    title: data.message,

    showConfirmButton: false,

    timer: 3000,

    timerProgressBar: true,

    background: "#FFFFFF",

    color: "#1A1C1D"

});

}

await Swal.fire({

icon:"success",

title:"Address Added",

text:data.message,

confirmButtonColor:"#603763"

});

window.location.reload();

}

catch(error){

Swal.fire({

icon:"error",

title:"Something went wrong",

text:"Please try again."

});

}

}

);

