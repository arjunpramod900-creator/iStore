<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders — iStore</title>

    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/components/toast.css">
    <link rel="stylesheet" href="/css/components/alert.css">
    <link rel="stylesheet" href="/css/orders.css">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <style>
        /* Retry button — sits alongside other action buttons */
        .or-btn--retry {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            height: 48px;
            padding: 12px 0;
            font-family: var(--font);
            font-size: 15px;
            font-weight: 700;
            border-radius: var(--or-radius-lg);
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: var(--or-transition);
            border: none;
            background: linear-gradient(135deg, #BA1A1A 0%, #D32F2F 100%);
            color: #fff;
            gap: 8px;
            box-shadow: 0 6px 16px rgba(186, 26, 26, 0.24);
        }
        .or-btn--retry:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 24px rgba(186, 26, 26, 0.32);
        }
        .or-btn--retry:disabled {
            opacity: 0.65;
            cursor: not-allowed;
            transform: none;
        }

        /* REFACTOR: Payment Alert banner inside the card (Handles both Pending and Failed) */
        .or-payment-alert-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 9999px;
            margin-top: 4px;
        }
        .or-payment-alert-tag.failed {
            background: rgba(186, 26, 26, 0.10);
            color: #BA1A1A;
        }
        .or-payment-alert-tag.pending {
            background: rgba(230, 154, 0, 0.10);
            color: #E69A00;
        }
    </style>

</head>

<body>

    <%- include("../partials/user/header", { page: "orders" }) %>

    <main class="or-page">

        <div class="or-container">

            <nav class="or-breadcrumbs" aria-label="Breadcrumb">
                <a href="/" class="or-bc-crumb">Home</a>
                <span class="or-bc-sep">
                    <i data-lucide="chevron-right" size="12"></i>
                </span>
                <span class="or-bc-crumb active">Orders</span>
            </nav>

            <header class="or-header">
                <h1 class="or-title">My Orders</h1>
                <p class="or-subtitle">View and manage your recent and past orders.</p>
            </header>

            <form class="or-filter-bar" method="GET" action="/orders">

                <div class="or-filter-group">
                    <label class="or-filter-label">Search Orders</label>
                    <div class="or-search-wrap">
                        <span class="or-search-icon">
                            <i data-lucide="search" size="18"></i>
                        </span>
                        <input
                            type="text"
                            name="search"
                            class="or-search-input"
                            placeholder="Search order ID or product"
                            value="<%= filters?.search || '' %>"
                        >
                    </div>
                </div>

                <div class="or-filter-select-wrap">
                    <label class="or-filter-label">Status</label>
                    <select name="status" class="or-select">
                        <option value="">All Statuses</option>
                        <option value="Pending"    <%= filters?.status === "Pending"    ? "selected" : "" %>>Pending</option>
                        <option value="Processing" <%= filters?.status === "Processing" ? "selected" : "" %>>Processing</option>
                        <option value="Shipped"    <%= filters?.status === "Shipped"    ? "selected" : "" %>>Shipped</option>
                        <option value="Delivered"  <%= filters?.status === "Delivered"  ? "selected" : "" %>>Delivered</option>
                        <option value="Cancelled"  <%= filters?.status === "Cancelled"  ? "selected" : "" %>>Cancelled</option>
                    </select>
                </div>

                <div class="or-filter-select-wrap">
                    <label class="or-filter-label">Sort By</label>
                    <select name="sort" class="or-select">
                        <option value="newest"      <%= filters?.sort === "newest"      ? "selected" : "" %>>Newest First</option>
                        <option value="oldest"      <%= filters?.sort === "oldest"      ? "selected" : "" %>>Oldest First</option>
                        <option value="amount_high" <%= filters?.sort === "amount_high" ? "selected" : "" %>>Amount High–Low</option>
                        <option value="amount_low"  <%= filters?.sort === "amount_low"  ? "selected" : "" %>>Amount Low–High</option>
                    </select>
                </div>

                <button class="or-filter-btn" type="submit">Apply</button>

            </form>

            <% if (!orders || orders.length === 0) { %>

                <div class="or-empty">
                    <div class="or-empty-icon">
                        <i data-lucide="package-open" size="64"></i>
                    </div>
                    <h2 class="or-empty-title">No orders found</h2>
                    <p class="or-empty-sub">You haven't placed any orders yet.</p>
                    <a href="/products" class="or-empty-cta">
                        <i data-lucide="shopping-bag" size="18"></i>
                        Browse Products
                    </a>
                </div>

            <% } else { %>

                <div class="or-order-list" id="orOrderList">

                    <% orders.forEach((order) => {

                        const status = (order.orderStatus || "Pending").toLowerCase().replace(/\s+/g, "-");
                        const orderId = order.orderId;

                        const orderDate = new Date(order.createdAt).toLocaleDateString("en-IN", {
                            day: "numeric", month: "short", year: "numeric",
                        });

                        const activeItemsCount = order.items.filter(i => i.itemStatus !== ORDER_STATUS.CANCELLED && i.itemStatus !== ORDER_STATUS.RETURNED && i.itemReturnStatus !== "Approved").length;
                        const displayAmount = (activeItemsCount === 0 && order.pricingSnapshot?.originalFinalAmount) 
                            ? order.pricingSnapshot.originalFinalAmount 
                            : (order.finalAmount || 0);
                        const total = "₹" + Number(displayAmount).toLocaleString("en-IN");

                        const items     = order.items || [];
                        const itemNames = items.map(i => i.productName || "Product").join(", ");

                        /* REFACTOR: Determine if order is eligible for Retry */

                        const isRetryable = 
                            order.paymentMethod === "RAZORPAY" && 
                            order.paymentStatus !== "Paid" && 
                            order.paymentStatus !== "Refunded" &&
                            order.orderStatus !== ORDER_STATUS.CANCELLED &&
                            order.orderStatus !== ORDER_STATUS.RETURNED &&
                            !order.isStockRestored;
                    %>

                    <article
                        class="or-card or-card--<%= isRetryable ? 'retryable' : status %>"
                        data-order-id="<%= orderId.toLowerCase() %>"
                        data-status="<%= status %>"
                    >
                        <div class="or-card-inner">

                            <div class="or-card-left">

                                <div class="or-card-meta">
                                    <span class="or-badge or-badge--<%= status %>">
                                        <%= order.orderStatus %>
                                    </span>
                                    <span class="or-order-id">Order #<%= orderId %></span>
                                    <span class="or-order-date">• <%= orderDate %></span>

                                    <% if (isRetryable) { %>
                                    <span class="or-payment-alert-tag <%= order.paymentStatus === 'Failed' ? 'failed' : 'pending' %>">
                                        <i data-lucide="<%= order.paymentStatus === 'Failed' ? 'alert-circle' : 'clock' %>" size="11"></i>
                                        <%= order.paymentStatus === PAYMENT_STATUS.FAILED ? "Payment Failed" : "Payment Pending" %>
                                    </span>
                                    <% } %>
                                </div>

                                <div class="or-card-items">
                                    <div class="or-thumbs">
                                        <% items.slice(0, 2).forEach(item => { %>
                                        <div class="or-thumb">
                                            <img
                                                src="<%= item.productImage || '/images/product-placeholder.png' %>"
                                                alt="<%= item.productName %>"
                                                loading="lazy"
                                            >
                                        </div>
                                        <% }) %>
                                    </div>
                                    <span class="or-item-names"><%= itemNames %></span>
                                </div>

                                <div class="or-card-total">
                                    <span class="or-total-label">Total Amount:</span>
                                    <span class="or-total-amount"><%= total %></span>
                                </div>

                            </div>

                            <div class="or-card-actions">

                                <% if (isRetryable) { %>

                                    <button
                                        class="or-btn or-btn--retry retry-payment-btn"
                                        data-order-id="<%= orderId %>"
                                        data-amount="<%= order.finalAmount %>"
                                    >
                                        <i data-lucide="refresh-cw" size="16"></i>
                                        Retry Payment
                                    </button>

                                    <a href="/orders/<%= orderId %>" class="or-btn or-btn--subtle">
                                        View Details
                                    </a>

                                <% } else { %>

                                    <% if (["pending","processing","shipped","out-for-delivery"].includes(status)) { %>
                                    <a href="/orders/<%= orderId %>" class="or-btn or-btn--primary">
                                        Track Order
                                    </a>
                                    <% } %>

                                    <a href="/orders/<%= orderId %>" class="or-btn or-btn--subtle">
                                        View Details
                                    </a>

                                    <% if (["pending","processing","shipped","out-for-delivery"].includes(status)) { %>
                                    <button
                                        class="or-btn or-btn--danger cancel-order-btn"
                                        data-id="<%= orderId %>"
                                    >
                                        Cancel Order
                                    </button>
                                    <% } %>

<% if (
    status === "delivered" &&
    !["Requested","Approved"].includes(order.returnStatus)
) { %>

<button
    class="or-btn or-btn--outline return-order-btn"
    data-order-id="<%= orderId %>"
>
    Return Order
</button>

<% } %>

                                <% } %>

                            </div>

                        </div>
                    </article>

                    <% }) %>

                </div>

                <% if (pagination && pagination.totalPages > 1) { %>
                <div class="or-pagination">

                    <% if (pagination.hasPrevPage) { %>
                    <a href="/orders?page=<%= pagination.currentPage - 1 %><%= filters.search ? `&search=${filters.search}` : '' %><%= filters.status ? `&status=${filters.status}` : '' %><%= filters.sort ? `&sort=${filters.sort}` : '' %>" class="or-page-btn">←</a>
                    <% } %>

                    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                    <a href="/orders?page=<%= i %><%= filters.search ? `&search=${filters.search}` : '' %><%= filters.status ? `&status=${filters.status}` : '' %><%= filters.sort ? `&sort=${filters.sort}` : '' %>" class="or-page-btn <%= i === pagination.currentPage ? 'active' : '' %>"><%= i %></a>
                    <% } %>

                    <% if (pagination.hasNextPage) { %>
                    <a href="/orders?page=<%= pagination.currentPage + 1 %><%= filters.search ? `&search=${filters.search}` : '' %><%= filters.status ? `&status=${filters.status}` : '' %><%= filters.sort ? `&sort=${filters.sort}` : '' %>" class="or-page-btn">→</a>
                    <% } %>

                </div>
                <% } %>

            <% } %>

        </div>

    </main>

    <%- include("../partials/user/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/toast.js"></script>
    <script src="/js/alertConfig.js"></script>

    <script>
        lucide.createIcons();

        gsap.fromTo(".or-card",
            { y: 24, opacity: 0 },
            { y: 0, opacity: 1, duration: 0.5, stagger: 0.08, ease: "power2.out", clearProps: "all" }
        );


document.querySelectorAll(".retry-payment-btn").forEach(btn => {

    btn.addEventListener("click", function () {

        const orderId = this.dataset.orderId;

        window.location.href = `/orders/${orderId}/retry`;

    });

});
        /* ================================================
           CANCEL ORDER
        ================================================ */
        document.querySelectorAll(".cancel-order-btn").forEach(button => {
            button.addEventListener("click", async () => {
                const orderId = button.dataset.id;

                const result = await showConfirmAlert({
                    title:       "Cancel this order?",
                    text:        "This action cannot be undone.",
                    confirmText: "Yes, Cancel",
                    cancelText:  "Keep Order",
                    icon:        "warning",
                });

                if (!result.isConfirmed) return;

                try {
                    button.disabled   = true;
                    button.innerText  = "Cancelling...";

                    const response = await fetch(`/orders/${orderId}/cancel`, {
                        method:  "POST",
                        headers: { "Content-Type": "application/json" },
                        body:    JSON.stringify({ reason: "Cancelled by user" }),
                    });

                    const data = await response.json();

                    if (data.success) {
                        showToast("success", data.message);
                        setTimeout(() => window.location.reload(), 1200);
                    } else {
                        showToast("error", data.message);
                        button.disabled  = false;
                        button.innerText = "Cancel Order";
                    }
                } catch {
                    showToast("error", "Something went wrong");
                    button.disabled  = false;
                    button.innerText = "Cancel Order";
                }
            });
        });



        /* ================================================
   RETURN ORDER
================================================ */
document.querySelectorAll(".return-order-btn").forEach(button => {

    button.addEventListener("click", async () => {

        const orderId = button.dataset.orderId;

        const { value: formValues } = await showReturnReasonAlert();

        if (!formValues) return;

        try {

            showLoadingAlert();

            const response = await fetch(`/orders/${orderId}/return`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    reason: formValues.reason
                })
            });

            const data = await response.json();

            Swal.close();

            if (data.success) {

                showToast("success", data.message);

                setTimeout(() => {
                    window.location.reload();
                }, 900);

            } else {

                showToast("error", data.message);

            }

        } catch {

            Swal.close();

            showToast("error", "Something went wrong");

        }

    });

});

    </script>

</body>
</html>