<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - iStore</title>
    <!-- CSS Includes -->
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/components/product-card.css">
    <link rel="stylesheet" href="/css/components/product-gallery.css">
    <link rel="stylesheet" href="/css/components/toast.css">
    <link rel="stylesheet" href="/css/product-details.css">
    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
    <%- include('../partials/user/header', { page: 'products' }) %>

    <main class="product-detail-page">
        <div class="product-container">
            <!-- Nav - Breadcrumbs -->
            <nav class="breadcrumbs">
                <a href="/" class="breadcrumb-link">Home</a>
                <span class="breadcrumb-sep">/</span>
                <a href="/products" class="breadcrumb-link">Products</a>
                <span class="breadcrumb-sep">/</span>
                <a href="/products?category=<%= product.categoryId._id %>" class="breadcrumb-link"><%= product.categoryId.name %></a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current"><%= product.name %></span>
            </nav>

            <!-- Hero Section -->
            <section class="product-hero">
                <!-- Gallery Column -->
                <div class="gallery-column">
                    <div class="main-image-container" id="mainView">
                        <img

    src="<%= product.variant.images?.[0] || product.thumbnail %>"

    alt="<%= product.name %>"

    id="mainImage" >
                    </div>
                    <div class="thumbnail-grid">
                        <% if(product.variant && product.variant.images) { %>
                            <% product.variant.images.forEach((img, index) => { %>
                                <button class="thumb-btn <%= index === 0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                                    <img src="<%= img %>" alt="View <%= index + 1 %>">
                                </button>
                            <% }) %>
                        <% } %>
                    </div>
                </div>

                <!-- Info Column -->
                <div class="info-column">
                    <p class="product-label"><%= product.categoryId.name %></p>
                    <h1 class="product-title"><%= product.name %></h1>
                    
                    <div class="rating-row">
                        <div class="stars">
                            <% for(let i=0; i<5; i++) { %>
                                <i data-lucide="star" fill="<%= i < Math.floor(product.rating || 4.5) ? '#EAB308' : 'none' %>" size="20"></i>
                            <% } %>
                        </div>
                        <span class="rating-text"><%= product.rating || 4.5 %> stars (<%= product.reviewCount || '1,240' %> reviews)</span>
                    </div>

                 <div class="price-wrapper">

    <p

        class="stock-status

        <%= product.variant.stock > 0
        ? 'in-stock'
        : 'out-stock'
        %>"

        id="stockStatus"

    >

        <%= product.variant.stock > 0
        ? 'In Stock'
        : 'Out of Stock'
        %>

    </p>

    <p

        class="variant-message"

        id="variantMessage"

    ></p>

    <p

        class="product-price"

        id="productPrice"

    >

        ₹<%= product.variant.price.toLocaleString() %>

    </p>

</div>
                    
                    <p class="product-summary">
                        <%= product.description %>
                    </p>

                    <!-- Configuration Section -->
                  
<div class="config-container">

    <!-- COLOR -->

    <div class="config-group">

        <span class="config-label">

            Select Color

        </span>

        <div class="color-options">

            <%

            const uniqueColors =

            [...new Set(

                product.variants.map(

                    variant =>

        variant.color

        ?.trim()

                )

            )]

            %>

            <% uniqueColors.forEach(color => { %>

                <button

                    class="color-btn

                    <%= product.variant.color === color
                    ? 'active'
                    : ''
                    %>"

                    data-color="<%= color %>"

                    title="<%= color %>"

                    style="background-color:

                    <%= color === 'Black'
                    ? '#111111'
                    : color === 'Silver'
                    ? '#D1D5DB'
                    : color === 'Purple'
                    ? '#6D28D9'
                    : '#CBD5E1'
                    %>"

                ></button>

            <% }) %>

        </div>

    </div>

    <!-- RAM -->

    <div class="config-group">

        <span class="config-label">

            RAM

        </span>

        <div class="ram-options">

            <%

            const uniqueRAMs =

            [...new Set(

                product.variants.map(

                    variant =>

        variant.RAM

        ?.trim()

        .toUpperCase()
                )

            )]

            %>

            <% uniqueRAMs.forEach(ram => { %>

                <button

                    class="ram-btn

                    <%= product.variant.RAM === ram
                    ? 'active'
                    : ''
                    %>"

                    data-ram="<%= ram %>"

                >

                    <%= ram %>

                </button>

            <% }) %>

        </div>

    </div>

    <!-- STORAGE -->

    <div class="config-group">

        <span class="config-label">

            Storage

        </span>

        <div class="storage-options">

            <%

            const uniqueStorages =

            [...new Set(

                product.variants.map(

                   variant => variant.storage.trim().toUpperCase()

                )

            )]

            %>

            <% uniqueStorages.forEach(storage => { %>

                <button

                    class="storage-btn

                    <%= product.variant.storage === storage
                    ? 'active'
                    : ''
                    %>"

                    data-storage="<%= storage %>"

                >

                    <%= storage %>

                </button>

            <% }) %>

        </div>

    </div>

</div>

                    <!-- Actions -->
                    <div class="action-row">
                       <button

class="btn-primary add-to-cart-btn

<%= cartVariantIds?.includes(
    product.variant?._id?.toString()
)
? 'added'
: ''
%>"

id="addToCartBtn"

data-product-id="<%= product._id %>"

data-variant-id="<%= product.variant?._id %>"

>

<% if(

    cartVariantIds?.includes(
        product.variant?._id?.toString()
    )

){ %>

    Go to Cart

<% } else { %>

    Add to Cart

<% } %>

</button>
                        <button class="btn-secondary">Buy Now</button>
                     <button

class="btn-wishlist wishlist-toggle

<%= wishlistVariantIds?.includes(
    product.variant?._id?.toString()
)
? 'active'
: ''
%>"

data-product-id="<%= product._id %>"

data-variant-id="<%= product.variant?._id %>"

>

    <i
        data-lucide="heart"
        size="24"
    ></i>

</button>
                    </div>

                    <!-- Trust Badges -->
                    <div class="trust-badges">
                        <div class="badge-item">
                            <i data-lucide="truck" size="22"></i>
                            <span>Free Express Delivery</span>
                        </div>
                        <div class="badge-item">
                            <i data-lucide="shield-check" size="22"></i>
                            <span>1 Year Apple Warranty</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Bento Section: Description & Specs -->
            <section class="bento-section">
                <!-- Features Card -->
                <div class="features-card">
                    <h2 class="bento-title">Product Description</h2>
                    <div class="features-grid">
                        <% (product.features || [
                            { title: 'Titanium Strength', desc: 'Crafted with aerospace-grade titanium that’s strong yet remarkably light. The refined brushed texture feels incredibly premium in hand.' },
                            { title: 'A19 Bionic Chip', desc: 'Our fastest chip ever. Incredible efficiency for all-day battery life and desktop-class gaming performance on the go.' },
                            { title: 'Pro Camera System', desc: '48MP main camera with advanced computational photography. Capture stunning low-light photos and cinematic 4K video.' },
                            { title: 'OLED ProMotion', desc: 'Super Retina XDR display with adaptive 120Hz refresh rate. Colors are more vivid and motion is smoother than ever before.' }
                        ]).forEach(feature => { %>
                            <div class="feature-item">
                                <h3><%= feature.title %></h3>
                                <p><%= feature.desc %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Specifications Card -->
                <div class="specs-card">
                    <h2 class="bento-title" style="font-size: 20px; margin-bottom: 0;">Specifications</h2>
                    <div class="specs-table">
                        <% Object.entries(product.specs || {
                            'Display': '6.7-inch OLED',
                            'Processor': 'Apple A19',
                            'Camera': '48MP Triple',
                            'Battery': '4500mAh',
                            'Storage': 'Up to 512GB'
                        }).forEach(([label, value]) => { %>
                            <div class="spec-row">
                                <span class="spec-label"><%= label %></span>
                                <span class="spec-value"><%= value %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </section>

            <!-- Related Products -->
            <section class="related-section">
                <div class="related-header">
                    <h3 class="bento-title">You May Also Like</h3>
                    <a href="/products" class="view-all-link">View all recommendations</a>
                </div>
                <div class="related-grid">
                    <% (relatedProducts || []).forEach(relProduct => { %>
                        <%- include('../partials/user/product-card',{product: relProduct,wishlistVariantIds}) %>
                    <% }) %>
                </div>
            </section>

            <!-- Customer Reviews -->
            <section class="reviews-section">
                <h3 class="bento-title">Customer Reviews</h3>
                <div class="reviews-grid">
                    <% (product.reviews || [
                        { user: 'Arjun Reddy', initial: 'AR', color: '#F1DAFF', text: 'The transition to the 17 Pro has been seamless. The camera capabilities for night photography are genuinely mind-blowing. Truly a piece of art.', stars: 5 },
                        { user: 'Meera Sharma', initial: 'MS', color: '#ECDCFF', text: 'Absolutely stunning design. The new violet finish is deep and premium. The processing power handles all my editing apps with ease.', stars: 5 }
                    ]).forEach(review => { %>
                        <div class="review-card">
                            <div class="review-header">
                                <div class="avatar" style="background-color: <%= review.color %>;">
                                    <%= review.initial %>
                                </div>
                                <div class="review-info">
                                    <h4><%= review.user %></h4>
                                    <div class="stars">
                                        <% for(let i=0; i<5; i++) { %>
                                            <i data-lucide="star" fill="<%= i < review.stars ? '#EAB308' : 'none' %>" size="15"></i>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <p class="review-body">"<%= review.text %>"</p>
                        </div>
                    <% }) %>
                </div>
            </section>
        </div>
    </main>

    <%- include('../partials/user/footer') %>

    <script>
        lucide.createIcons();
        
        gsap.registerPlugin(ScrollTrigger);

        function changeImage(src, btn) {
            const mainImg = document.getElementById('mainImage');
            
            gsap.to(mainImg, {
                opacity: 0,
                scale: 0.95,
                duration: 0.2,
                onComplete: () => {
                    mainImg.src = src;
                    gsap.to(mainImg, {
                        opacity: 1,
                        scale: 1,
                        duration: 0.4,
                        ease: "power2.out"
                    });
                }
            });

            document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        function selectConfig(btn, type) {
            const selector = type === 'color' ? '.color-btn' : '.storage-btn';
            document.querySelectorAll(selector).forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            gsap.from(btn, {
                scale: 0.9,
                duration: 0.3,
                ease: "back.out(1.7)"
            });
        }

        // Entrance Animations
        gsap.from(".gallery-column", { x: -50, opacity: 0, duration: 1, ease: "power3.out" });
        gsap.from(".info-column > *", { 
            y: 30, 
            opacity: 0, 
            duration: 0.8, 
            stagger: 0.1, 
            ease: "power3.out" 
        });

        // Scroll Reveal Animations
        gsap.from(".bento-section", {
            scrollTrigger: {
                trigger: ".bento-section",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power2.out"
        });

        gsap.from(".related-section", {
            scrollTrigger: {
                trigger: ".related-section",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power2.out"
        });



    </script>
    <script src="/js/toast.js"></script>

    <script src="/js/addToCart.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="/js/wishlist.js"></script>

<script>

/* =========================================
   VARIANTS
========================================= */

const variants =
<%- JSON.stringify(product.variants) %>

const cartVariantIds =
<%- JSON.stringify(cartVariantIds) %>

const wishlistVariantIds =
<%- JSON.stringify(wishlistVariantIds) %>

/* =========================================
   CURRENT STATE
========================================= */

let selectedColor =
"<%= product.variant.color %>"

let selectedRAM =
"<%= product.variant.RAM %>"

let selectedStorage =
"<%= product.variant.storage %>"

/* =========================================
   ELEMENTS
========================================= */

const mainImage =
document.getElementById("mainImage")

const priceElement =
document.getElementById("productPrice")

const stockElement =
document.getElementById("stockStatus")

const variantMessage =
document.getElementById("variantMessage")

const cartButton =
document.querySelector(".add-to-cart-btn")

const wishlistButton =
document.querySelector(".wishlist-toggle")

const thumbnailGrid =
document.querySelector(".thumbnail-grid")

/* =========================================
   FIND BEST VARIANT
========================================= */

function findBestVariant(

    type,

    value

){

    let variant = null

    /* =====================================
       COLOR PRIORITY
    ===================================== */

    if(type === "color"){

        variant = variants.find(v => {

            return (

                v.color === value &&
                v.RAM === selectedRAM &&
                v.storage === selectedStorage

            )

        })

        ||

        variants.find(v => {

            return (

                v.color === value &&
                v.RAM === selectedRAM

            )

        })

        ||

        variants.find(v => {

            return (

                v.color === value &&
                v.storage === selectedStorage

            )

        })

        ||

        variants.find(v => {

            return v.color === value

        })

    }

    /* =====================================
       RAM PRIORITY
    ===================================== */

    if(type === "ram"){

        variant = variants.find(v => {

            return (

                v.RAM === value &&
                v.color === selectedColor &&
                v.storage === selectedStorage

            )

        })

        ||

        variants.find(v => {

            return (

                v.RAM === value &&
                v.color === selectedColor

            )

        })

        ||

        variants.find(v => {

            return (

                v.RAM === value &&
                v.storage === selectedStorage

            )

        })

        ||

        variants.find(v => {

            return v.RAM === value

        })

    }

    /* =====================================
       STORAGE PRIORITY
    ===================================== */

    if(type === "storage"){

        variant = variants.find(v => {

            return (

                v.storage === value &&
                v.color === selectedColor &&
                v.RAM === selectedRAM

            )

        })

        ||

        variants.find(v => {

            return (

                v.storage === value &&
                v.color === selectedColor

            )

        })

        ||

        variants.find(v => {

            return (

                v.storage === value &&
                v.RAM === selectedRAM

            )

        })

        ||

        variants.find(v => {

            return v.storage === value

        })

    }

    return variant || variants[0]

}

/* =========================================
   RENDER THUMBNAILS
========================================= */

function renderThumbnails(images){

    thumbnailGrid.innerHTML = ""

    images.forEach((image,index) => {

        thumbnailGrid.innerHTML +=

        `
            <button

                class="thumb-btn ${index === 0 ? "active" : ""}"

                onclick="changeImage('${image}', this)"

            >

                <img
                    src="${image}"
                    alt="Thumbnail"
                >

            </button>
        `

    })

}

/* =========================================
   REFRESH OPTIONS
========================================= */
function refreshOptions(){

    /* RAM */

    document.querySelectorAll(".ram-btn")
    .forEach(button => {

        const exists = variants.some(v => {

            return v.RAM === button.dataset.ram

        })

        button.classList.toggle(
            "unavailable",
            !exists
        )

        button.classList.toggle(
            "active",
            selectedRAM === button.dataset.ram
        )

    })

    /* STORAGE */

    document.querySelectorAll(".storage-btn")
    .forEach(button => {

        const exists = variants.some(v => {

            return v.storage === button.dataset.storage

        })

        button.classList.toggle(
            "unavailable",
            !exists
        )

        button.classList.toggle(
            "active",
            selectedStorage === button.dataset.storage
        )

    })

    /* COLOR */

    document.querySelectorAll(".color-btn")
    .forEach(button => {

        const exists = variants.some(v => {

            return v.color === button.dataset.color

        })

        button.classList.toggle(
            "unavailable",
            !exists
        )

        button.classList.toggle(
            "active",
            selectedColor === button.dataset.color
        )

    })

}
/* =========================================
   UPDATE UI
========================================= */

function updateVariantUI(variant){

    /* UPDATE STATE FIRST */

    selectedColor =
    variant.color

    selectedRAM =
    variant.RAM

    selectedStorage =
    variant.storage

    /* REFRESH OPTIONS */

    refreshOptions()

    /* MESSAGE */

    variantMessage.innerText = ""

    /* PRICE */

    priceElement.innerText =
    `₹${variant.price.toLocaleString()}`

    /* IMAGE */

    if(variant.images?.length){

        gsap.to(mainImage, {

            opacity: 0,

            duration: 0.15,

            onComplete: () => {

                mainImage.src =
                variant.images[0]

                gsap.to(mainImage, {

                    opacity: 1,

                    duration: 0.3

                })

            }

        })

       renderThumbnails(
    variant.images
)

setTimeout(() => {

    const firstThumb =
    document.querySelector(".thumb-btn")

    if(firstThumb){

        firstThumb.classList.add("active")

    }

},0)

    }

    /* STOCK */

    if(variant.stock > 0){

        stockElement.innerText =
        "In Stock"

        stockElement.className =
        "stock-status in-stock"

        cartButton.disabled = false

    }

    else{

        stockElement.innerText =
        "Out of Stock"

        stockElement.className =
        "stock-status out-stock"

        cartButton.disabled = true

    }

    /* UPDATE DATASETS */

    cartButton.dataset.variantId =
    variant._id

    wishlistButton.dataset.variantId =
    variant._id

    /* CART */

    if(

        cartVariantIds.includes(
            variant._id.toString()
        )

    ){

        cartButton.classList.add(
            "added"
        )

        cartButton.innerHTML =

        `
            <i
                data-lucide="shopping-bag"
                size="18"
            ></i>

            Go to Cart
        `

    }

    else{

        cartButton.classList.remove(
            "added"
        )

        cartButton.innerHTML =

        `
            <i
                data-lucide="shopping-cart"
                size="18"
            ></i>

            Add to Cart
        `

    }

    /* WISHLIST */

    if(

        wishlistVariantIds.includes(
            variant._id.toString()
        )

    ){

        wishlistButton.classList.add(
            "active"
        )

    }

    else{

        wishlistButton.classList.remove(
            "active"
        )

    }

    lucide.createIcons()

}

/* =========================================
   COLOR EVENTS
========================================= */

document.querySelectorAll(".color-btn")
.forEach(button => {

    button.addEventListener("click", () => {


        const variant =
        findBestVariant(

            "color",

            button.dataset.color

        )

        updateVariantUI(variant)

    })

})

/* =========================================
   RAM EVENTS
========================================= */

document.querySelectorAll(".ram-btn")
.forEach(button => {

    button.addEventListener("click", () => {

        const variant =
        findBestVariant(

            "ram",

            button.dataset.ram

        )

        updateVariantUI(variant)

    })

})

/* =========================================
   STORAGE EVENTS
========================================= */

document.querySelectorAll(".storage-btn")
.forEach(button => {

    button.addEventListener("click", () => {


        const variant =
        findBestVariant(

            "storage",

            button.dataset.storage

        )

        updateVariantUI(variant)

    })

})

/* =========================================
   INIT
========================================= */

updateVariantUI(

    variants.find(v => {

        return v._id ===
        "<%= product.variant._id %>"

    })

    ||

    variants[0]

)

</script>
<script>
/* =========================================
   PREMIUM PRECISE IMAGE ZOOM
========================================= */

const imageContainer =
document.getElementById("mainView")

const zoomImage =
document.getElementById("mainImage")

if(

    imageContainer &&
    zoomImage &&
    window.innerWidth > 768

){

    imageContainer.addEventListener(

        "mousemove",

        (e) => {

            const rect =

            imageContainer.getBoundingClientRect()

            const x =
            ((e.clientX - rect.left)
            / rect.width) * 100

            const y =
            ((e.clientY - rect.top)
            / rect.height) * 100

            zoomImage.style.transformOrigin =
            `${x}% ${y}%`

            zoomImage.style.transform =
            "scale(2)"

        }

    )

    imageContainer.addEventListener(

        "mouseleave",

        () => {

            zoomImage.style.transformOrigin =
            "center center"

            zoomImage.style.transform =
            "scale(1)"

        }

    )

}
</script>

<!-- =========================================
     FULLSCREEN IMAGE VIEWER
========================================= -->

<div class="fullscreen-viewer" id="fullscreenViewer">

    <button
        class="fullscreen-close"
        id="fullscreenClose"
    >

        ✕

    </button>

    <img
        src=""
        alt="Fullscreen Product"
        id="fullscreenImage"
    >

</div>
<script>
/* =========================================
   FULLSCREEN IMAGE VIEWER
========================================= */

const fullscreenViewer =
document.getElementById(
    "fullscreenViewer"
)

const fullscreenImage =
document.getElementById(
    "fullscreenImage"
)

const fullscreenClose =
document.getElementById(
    "fullscreenClose"
)

/* OPEN */
imageContainer.addEventListener(

    "click",

    () => {

        /* RESET ZOOM */

        zoomImage.style.transform =
        "scale(1)"

        zoomImage.style.transformOrigin =
        "center center"

        /* LOAD FULL IMAGE */

        fullscreenImage.src =
        zoomImage.src

        /* OPEN VIEWER */

        fullscreenViewer.classList.add(
            "active"
        )

        document.body.style.overflow =
        "hidden"

    }

)

/* CLOSE BUTTON */

fullscreenClose.addEventListener(

    "click",

    closeFullscreen

)

/* CLICK OUTSIDE */

fullscreenViewer.addEventListener(

    "click",

    (e) => {

        if(

            e.target === fullscreenViewer

        ){

            closeFullscreen()

        }

    }

)

/* ESC KEY */

document.addEventListener(

    "keydown",

    (e) => {

        if(e.key === "Escape"){

            closeFullscreen()

        }

    }

)

/* CLOSE FUNCTION */

function closeFullscreen(){

    fullscreenViewer.classList.remove(
        "active"
    )

    document.body.style.overflow =
    ""

}
</script>
</body>
</html>
