<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - iStore</title>
    <!-- CSS Includes -->
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/components/product-card.css">
    <link rel="stylesheet" href="/css/components/product-gallery.css">
    <link rel="stylesheet" href="/css/components/toast.css">
    <link rel="stylesheet" href="/css/components/alert.css">
    <link rel="stylesheet" href="/css/product-details.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>
    <%- include('../partials/user/header', { page: 'products' }) %>

    <main class="product-detail-page">
        <div class="product-container">
            <!-- Nav - Breadcrumbs -->
            <nav class="breadcrumbs">
                <a href="/" class="breadcrumb-link">Home</a>
                <span class="breadcrumb-sep">/</span>
                <a href="/products" class="breadcrumb-link">Products</a>
                <span class="breadcrumb-sep">/</span>
                <a href="/products?category=<%= product.categoryId._id %>" class="breadcrumb-link"><%= product.categoryId.name %></a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current"><%= product.name %></span>
            </nav>

            <!-- Hero Section -->
            <section class="product-hero">
                <!-- Gallery Column -->
                <div class="gallery-column">
                    <div class="main-image-container" id="mainView">
                        <img

    src="<%= product.variant.images?.[0] || product.thumbnail %>"

    alt="<%= product.name %>"

    id="mainImage" >
                    </div>
                    <div class="thumbnail-grid">
                        <% if(product.variant && product.variant.images) { %>
                            <% product.variant.images.forEach((img, index) => { %>
                                <button class="thumb-btn <%= index === 0 ? 'active' : '' %>" onclick="changeImage('<%= img %>', this)">
                                    <img src="<%= img %>" alt="View <%= index + 1 %>">
                                </button>
                            <% }) %>
                        <% } %>
                    </div>
                </div>

                <!-- Info Column -->
                <div class="info-column">
                    <p class="product-label"><%= product.categoryId.name %></p>
                    <h1 class="product-title"><%= product.name %></h1>
                    
                    <div class="rating-row">
                        <div class="stars">
                            <% for(let i=0; i<5; i++) { %>
                                <i data-lucide="star" fill="<%= i < Math.floor(product.rating || 4.5) ? '#EAB308' : 'none' %>" size="20"></i>
                            <% } %>
                        </div>
                        <span class="rating-text"><%= product.rating || 4.5 %> stars (<%= product.reviewCount || '1,240' %> reviews)</span>
                    </div>

<!-- =========================================
     PRICE SECTION
========================================= -->

<div class="price-wrapper">

    <p

        class="stock-status

        <%= product.variant.stock > 0
        ? 'in-stock'
        : 'out-stock'
        %>"

        id="stockStatus"

    >

        <%= product.variant.stock > 0
        ? 'In Stock'
        : 'Out of Stock'
        %>

    </p>

    <p

        class="variant-message"

        id="variantMessage"

    ></p>

    <div class="price-stack">

<div class="price-row">

    <h2
        class="product-price"
        id="productPrice"
    >

        ₹<%= product.offerData?.finalPrice?.toLocaleString() || product.variant.price.toLocaleString() %>

    </h2>

    <% if(product.offerData?.offerDiscount > 0){ %>

        <span
            class="compare-price"
            id="comparePrice"
        >

            ₹<%= product.offerData.originalPrice.toLocaleString() %>

        </span>

        <span
            class="discount-badge"
            id="discountBadge"
        >

            <%= product.offerData.appliedOffer.discountValue %>% OFF

        </span>

    <% } else { %>

        <span
            class="compare-price"
            id="comparePrice"
            style="display:none"
        ></span>

        <span
            class="discount-badge"
            id="discountBadge"
            style="display:none"
        ></span>

    <% } %>

</div>

<div
    id="offerInfo"
    class="offer-info"
>

<% if(product.offerData?.offerDiscount > 0){ %>

    <span class="offer-saving">

        Save ₹<%= product.offerData.offerDiscount.toLocaleString() %>

    </span>

    <span class="offer-name">

        <%= product.offerData.appliedOffer.offerName %>

    </span>

<% } %>

</div>

        <p class="tax-text">
            Inclusive of all taxes
        </p>

        <!-- UPDATED -->

        <p
            class="emi-text"
            id="emiText"
        >
            EMI starting from ₹
            <%= Math.round(product.variant.price / 12).toLocaleString() %>/month
        </p>

    </div>

</div>
                    
                    <p class="product-summary">
                        <%= product.description %>
                    </p>

                    <!-- Configuration Section -->
                  
<div class="config-container">

    <!-- COLOR -->

    <div class="config-group">

        <span class="config-label">

            Select Color

        </span>

        <div class="color-options">

            <%

            const uniqueColors =

            [...new Set(

                product.variants.map(

                    variant =>

        variant.color

        ?.trim()

                )

            )]

            %>

            <% uniqueColors.forEach(color => { %>

                <button

                    class="color-btn

                    <%= product.variant.color === color
                    ? 'active'
                    : ''
                    %>"

                    data-color="<%= color %>"

                    title="<%= color %>"

                    style="background-color:

                    <%= color === 'Black'
                    ? '#111111'
                    : color === 'Silver'
                    ? '#D1D5DB'
                    : color === 'Purple'
                    ? '#6D28D9'
                    : '#CBD5E1'
                    %>"

                ></button>

            <% }) %>

        </div>

    </div>

    <!-- RAM -->

    <div class="config-group">

        <span class="config-label">

            RAM

        </span>

        <div class="ram-options">

            <%

            const uniqueRAMs =

            [...new Set(

                product.variants.map(

                    variant =>

        variant.RAM

        ?.trim()

        .toUpperCase()
                )

            )]

            %>

          <% uniqueRAMs.forEach(ram => { %>

    <button
        class="ram-btn <%= product.variant.RAM.trim().toUpperCase() === ram ? 'active' : '' %>"
        data-ram="<%= ram %>"
    >
        <%= ram %>
    </button>

<% }) %>

        </div>

    </div>

    <!-- STORAGE -->

    <div class="config-group">

        <span class="config-label">

            Storage

        </span>

        <div class="storage-options">

            <%

            const uniqueStorages =

            [...new Set(

                product.variants.map(

                   variant => variant.storage.trim().toUpperCase()

                )

            )]

            %>

           <% uniqueStorages.forEach(storage => { %>

    <button
        class="storage-btn <%= product.variant.storage.trim().toUpperCase() === storage ? 'active' : '' %>"
        data-storage="<%= storage %>"
    >
        <%= storage %>
    </button>

<% }) %>

        </div>

    </div>

</div>

                    <!-- Actions -->
                    <div class="action-row">
                       <button

class="btn-primary add-to-cart-btn

<%= cartVariantIds?.includes(
    product.variant?._id?.toString()
)
? 'added'
: ''
%>"

id="addToCartBtn"

data-product-id="<%= product._id %>"

data-variant-id="<%= product.variant?._id %>"

>

<% if(

    cartVariantIds?.includes(
        product.variant?._id?.toString()
    )

){ %>

    Go to Cart

<% } else { %>

    Add to Cart

<% } %>

                    </button>
                        <button
                            class="btn-secondary"
                            id="buyNowBtn"
                        >
                            Buy Now
                        </button>
                     <button

class="btn-wishlist wishlist-toggle

<%= wishlistVariantIds?.includes(
    product.variant?._id?.toString()
)
? 'active'
: ''
%>"

data-product-id="<%= product._id %>"

data-variant-id="<%= product.variant?._id %>"

>

    <i
        data-lucide="heart"
        size="24"
    ></i>

</button>
                    </div>

                    <!-- Trust Badges -->
                    <div class="trust-badges">
                        <div class="badge-item">
                            <i data-lucide="truck" size="22"></i>
                            <span>Free Express Delivery</span>
                        </div>
                        <div class="badge-item">
                            <i data-lucide="shield-check" size="22"></i>
                            <span>1 Year Apple Warranty</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Bento Section: Description & Specs -->
            <section class="bento-section">
                <!-- Features Card -->
                <div class="features-card">
                    <h2 class="bento-title">Product Description</h2>
                    <div class="features-grid">
                        <% (product.features || [
                            { title: 'Titanium Strength', desc: 'Crafted with aerospace-grade titanium that’s strong yet remarkably light. The refined brushed texture feels incredibly premium in hand.' },
                            { title: 'A19 Bionic Chip', desc: 'Our fastest chip ever. Incredible efficiency for all-day battery life and desktop-class gaming performance on the go.' },
                            { title: 'Pro Camera System', desc: '48MP main camera with advanced computational photography. Capture stunning low-light photos and cinematic 4K video.' },
                            { title: 'OLED ProMotion', desc: 'Super Retina XDR display with adaptive 120Hz refresh rate. Colors are more vivid and motion is smoother than ever before.' }
                        ]).forEach(feature => { %>
                            <div class="feature-item">
                                <h3><%= feature.title %></h3>
                                <p><%= feature.desc %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <!-- Specifications Card -->
                <div class="specs-card">
                    <h2 class="bento-title" style="font-size: 20px; margin-bottom: 0;">Specifications</h2>
                    <div class="specs-table">
                        <% Object.entries(product.specs || {
                            'Display': '6.7-inch OLED',
                            'Processor': 'Apple A19',
                            'Camera': '48MP Triple',
                            'Battery': '4500mAh',
                            'Storage': 'Up to 512GB'
                        }).forEach(([label, value]) => { %>
                            <div class="spec-row">
                                <span class="spec-label"><%= label %></span>
                                <span class="spec-value"><%= value %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </section>

            <!-- Related Products -->
            <section class="related-section">
                <div class="related-header">
                    <h3 class="bento-title">You May Also Like</h3>
                    <a href="/products" class="view-all-link">View all recommendations</a>
                </div>
                <div class="related-grid">
                    <% (relatedProducts || []).forEach(relProduct => { %>
                        <%- include('../partials/user/product-card',{product: relProduct,wishlistVariantIds}) %>
                    <% }) %>
                </div>
            </section>

            <!-- Customer Reviews -->
            <section class="reviews-section">
                <h3 class="bento-title">Customer Reviews</h3>
                <div class="review-form">

    <h4>Write a Review</h4>

    <form id="reviewForm">

        <input
            type="hidden"
            id="reviewProductId"
            value="<%= product._id %>"
        >

       

        <div class="review-input-group">

            <select id="reviewRating">

            <option value="5">5 Stars</option>
            <option value="4">4 Stars</option>
            <option value="3">3 Stars</option>
            <option value="2">2 Stars</option>
            <option value="1">1 Star</option>

            </select>

            <textarea

                id="reviewComment"

                placeholder="Write your review"

            ></textarea>
        </div>

        <button type="submit">

            Submit Review

        </button>

    </form>

</div>
               <div class="reviews-grid">

    <% if(product.reviews?.length){ %>

        <% product.reviews.forEach(review => { %>

            <div class="review-card">

                <div class="review-header">

                    <div class="avatar">

                        <%= review.userId?.name
?.split(' ')
?.map(word => word[0])
?.join('')
?.slice(0,2)
?.toUpperCase() || 'U' %>

                    </div>

                    <div class="review-info">

                        <h4>

                            <%= review.userId?.name || 'User' %>

                        </h4>
                        <p class="review-date">
    <%= new Date(review.createdAt)
    .toLocaleDateString("en-IN",{
        day:"numeric",
        month:"short",
        year:"numeric"
    }) %>
</p>

                        <div class="stars">

                            <% for(let i = 0; i < 5; i++){ %>

                                <i

                                    data-lucide="star"

                                    fill="<%= i < review.rating ? '#EAB308' : 'none' %>"

                                    size="15"

                                ></i>

                            <% } %>

                        </div>

                    </div>

                </div>

                <p class="review-body">

                    "<%= review.comment %>"

                </p>

            </div>

        <% }) %>

    <% } else { %>

        <p class="no-reviews">

            No reviews yet

        </p>

    <% } %>

</div>
            </section>
        </div>
    </main>

    <%- include('../partials/user/footer') %>

    <script>
        lucide.createIcons();
        
        gsap.registerPlugin(ScrollTrigger);

        function changeImage(src, btn) {
            const mainImg = document.getElementById('mainImage');
            
            gsap.to(mainImg, {
                opacity: 0,
                scale: 0.95,
                duration: 0.2,
                onComplete: () => {
                    mainImg.src = src;
                    gsap.to(mainImg, {
                        opacity: 1,
                        scale: 1,
                        duration: 0.4,
                        ease: "power2.out"
                    });
                }
            });

            document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        function selectConfig(btn, type) {
            const selector = type === 'color' ? '.color-btn' : '.storage-btn';
            document.querySelectorAll(selector).forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            gsap.from(btn, {
                scale: 0.9,
                duration: 0.3,
                ease: "back.out(1.7)"
            });
        }

        // Entrance Animations
        gsap.from(".gallery-column", { x: -50, opacity: 0, duration: 1, ease: "power3.out" });
        gsap.from(".info-column > *", { 
            y: 30, 
            opacity: 0, 
            duration: 0.8, 
            stagger: 0.1, 
            ease: "power3.out" 
        });

        // Scroll Reveal Animations
        gsap.from(".bento-section", {
            scrollTrigger: {
                trigger: ".bento-section",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power2.out"
        });

        gsap.from(".related-section", {
            scrollTrigger: {
                trigger: ".related-section",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power2.out"
        });



    </script>
    <script src="/js/toast.js"></script>

    <script src="/js/alertConfig.js"></script>

    <script src="/js/addToCart.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="/js/wishlist.js"></script>


<script>

/* =========================================
   VARIANTS
========================================= */

const variants =

<%- JSON.stringify(
product.variants.filter(v => !v.isDeleted)
) %>

console.log(variants)

const cartVariantIds =
<%- JSON.stringify(cartVariantIds) %>

const wishlistVariantIds =
<%- JSON.stringify(wishlistVariantIds) %>

/* =========================================
   NORMALIZE
========================================= */

function normalize(value){

    return value
    ?.toString()
    ?.trim()
    ?.toUpperCase()

}

/* =========================================
   CURRENT STATE
========================================= */

let selectedColor =
normalize("<%= product.variant.color %>")

let selectedRAM =
normalize("<%= product.variant.RAM %>")

let selectedStorage =
normalize("<%= product.variant.storage %>")

/* =========================================
   ELEMENTS
========================================= */

const mainImage =
document.getElementById("mainImage")

const priceElement =
document.getElementById("productPrice")

const comparePriceElement =
document.getElementById("comparePrice")

const discountBadge =
document.getElementById("discountBadge")

const offerInfo =
document.getElementById("offerInfo")

const stockElement =
document.getElementById("stockStatus")

const variantMessage =
document.getElementById("variantMessage")

const cartButton =
document.querySelector(".add-to-cart-btn")

const wishlistButton =
document.querySelector(".wishlist-toggle")

const thumbnailGrid =
document.querySelector(".thumbnail-grid")

const emiText =
document.getElementById("emiText")

const buyNowBtn =
document.getElementById("buyNowBtn")

/* =========================================
   FIND BEST VARIANT
========================================= */



function findBestVariant(type, value){

    /* =====================================
       COLOR CLICK
    ===================================== */

    if(type === "color"){

        return variants.find(v => {

            return (
                normalize(v.color) === normalize(value)
            )

        })

    }

    /* =====================================
       RAM CLICK
    ===================================== */

    if(type === "ram"){

        return variants.find(v => {

            return (
                normalize(v.RAM) === normalize(value)
            )

        })

    }

    /* =====================================
       STORAGE CLICK
    ===================================== */

    if(type === "storage"){

        return variants.find(v => {

            return (
                normalize(v.storage) === normalize(value)
            )

        })

    }

    return variants[0]

}

/* =========================================
   RENDER THUMBNAILS
========================================= */

function renderThumbnails(images){

    thumbnailGrid.innerHTML = ""

    images.forEach((image,index) => {

        thumbnailGrid.innerHTML +=

        `
            <button
                class="thumb-btn ${index === 0 ? "active" : ""}"
                onclick="changeImage('${image}', this)"
            >

                <img
                    src="${image}"
                    alt="Thumbnail"
                >

            </button>
        `

    })

}



function refreshOptions(){

    /* RAM */

    document.querySelectorAll(".ram-btn")
    .forEach(button => {

        const exists = variants.some(v => {

            return (

                normalize(v.RAM) ===
                normalize(button.dataset.ram) &&

                normalize(v.color) ===
                normalize(selectedColor) &&

                v.stock > 0 &&
                !v.isDeleted

            )

        })

        // button.classList.toggle(
        //     "unavailable",
        //     !exists
        // )

        button.classList.toggle(
            "active",
            normalize(selectedRAM) ===
            normalize(button.dataset.ram)
        )

    })

    /* STORAGE */

    document.querySelectorAll(".storage-btn")
    .forEach(button => {

        const exists = variants.some(v => {

            return (

                normalize(v.storage) ===
                normalize(button.dataset.storage) &&

                normalize(v.color) ===
                normalize(selectedColor) &&

                normalize(v.RAM) ===
                normalize(selectedRAM) &&

                v.stock > 0 &&
                !v.isDeleted

            )

        })

        // button.classList.toggle(
        //     "unavailable",
        //     !exists
        // )

        button.classList.toggle(
            "active",
            normalize(selectedStorage) ===
            normalize(button.dataset.storage)
        )

    })

    /* COLOR */

    document.querySelectorAll(".color-btn")
    .forEach(button => {

        const exists = variants.some(v => {

            return (

                normalize(v.color) ===
                normalize(button.dataset.color) &&

                v.stock > 0 &&
                !v.isDeleted

            )

        })

        // button.classList.toggle(
        //     "unavailable",
        //     !exists
        // )

        button.classList.toggle(
            "active",
            normalize(selectedColor) ===
            normalize(button.dataset.color)
        )

    })

}

/* =========================================
   UPDATE UI
========================================= */

function updateVariantUI(variant){

    selectedColor =
    normalize(variant.color)

    selectedRAM =
    normalize(variant.RAM)

    selectedStorage =
    normalize(variant.storage)

    refreshOptions()

    variantMessage.innerText = ""

   /* PRICE */

if(

    variant.offerData &&
    variant.offerData.offerDiscount > 0

){

    priceElement.innerText =
    `₹${variant.offerData.finalPrice.toLocaleString()}`

    comparePriceElement.innerText =
    `₹${variant.offerData.originalPrice.toLocaleString()}`

    comparePriceElement.style.display =
    "inline-flex"

    discountBadge.innerText =
    `${variant.offerData.appliedOffer.discountValue}% OFF`

    discountBadge.style.display =
    "inline-flex"

    offerInfo.innerHTML = `

        <span class="offer-saving">

            Save ₹${variant.offerData.offerDiscount.toLocaleString()}

        </span>

        <span class="offer-name">

            ${variant.offerData.appliedOffer.offerName}

        </span>

    `

}

else{

    priceElement.innerText =
    `₹${variant.price.toLocaleString()}`

    comparePriceElement.style.display =
    "none"

    discountBadge.style.display =
    "none"

    offerInfo.innerHTML = ""

}

    /* IMAGE */

    if(variant.images?.length){

        mainImage.src =
        variant.images[0]

        renderThumbnails(
            variant.images
        )

    }

    /* STOCK */

    if(variant.stock > 0){

        stockElement.innerText =
        "In Stock"

        stockElement.className =
        "stock-status in-stock"

        cartButton.disabled = false

    }

    else{

        stockElement.innerText =
        "Out of Stock"

        stockElement.className =
        "stock-status out-stock"

        cartButton.disabled = true

    }

    /* LOW STOCK */

    if(

        variant.stock > 0 &&
        variant.stock <= 5

    ){

        variantMessage.innerText =
        `Only ${variant.stock} left in stock`

    }

    /* EMI */

    emiText.innerText =

    `EMI starting from ₹${Math.round(
        variant.price / 12
    ).toLocaleString()}/month`

    /* DATASETS */

    cartButton.dataset.variantId =
    variant._id

    wishlistButton.dataset.variantId =
    variant._id

    buyNowBtn.dataset.variantId =
    variant._id

}

/* =========================================
   COLOR EVENTS
========================================= */

document.querySelectorAll(".color-btn")
.forEach(button => {

    button.addEventListener("click", () => {

        const variant =
        findBestVariant(
            "color",
            button.dataset.color
        )

        updateVariantUI(variant)

    })

})

/* =========================================
   RAM EVENTS
========================================= */

document.querySelectorAll(".ram-btn")
.forEach(button => {

    button.addEventListener("click", () => {

        const variant =
        findBestVariant(
            "ram",
            button.dataset.ram
        )

        updateVariantUI(variant)

    })

})

/* =========================================
   STORAGE EVENTS
========================================= */

document.querySelectorAll(".storage-btn")
.forEach(button => {

    button.addEventListener("click", () => {

        const variant =
        findBestVariant(
            "storage",
            button.dataset.storage
        )

        updateVariantUI(variant)

    })

})

/* =========================================
   INIT
========================================= */

updateVariantUI(

    variants.find(v => {

        return v._id ===
        "<%= product.variant._id %>"

    })

    ||

    variants[0]

)

</script>
<script>
/* =========================================
   PREMIUM PRECISE IMAGE ZOOM
========================================= */

const imageContainer =
document.getElementById("mainView")

const zoomImage =
document.getElementById("mainImage")

if(

    imageContainer &&
    zoomImage &&
    window.innerWidth > 768

){

    imageContainer.addEventListener(

        "mousemove",

        (e) => {

            const rect =

            imageContainer.getBoundingClientRect()

            const x =
            ((e.clientX - rect.left)
            / rect.width) * 100

            const y =
            ((e.clientY - rect.top)
            / rect.height) * 100

            zoomImage.style.transformOrigin =
            `${x}% ${y}%`

            zoomImage.style.transform =
            "scale(2)"

        }

    )

    imageContainer.addEventListener(

        "mouseleave",

        () => {

            zoomImage.style.transformOrigin =
            "center center"

            zoomImage.style.transform =
            "scale(1)"

        }

    )

}
</script>

<!-- =========================================
     FULLSCREEN IMAGE VIEWER
========================================= -->

<div class="fullscreen-viewer" id="fullscreenViewer">

    <button
        class="fullscreen-close"
        id="fullscreenClose"
    >

        ✕

    </button>

    <img
        src=""
        alt="Fullscreen Product"
        id="fullscreenImage"
    >

</div>
<script>
/* =========================================
   FULLSCREEN IMAGE VIEWER
========================================= */

const fullscreenViewer =
document.getElementById(
    "fullscreenViewer"
)

const fullscreenImage =
document.getElementById(
    "fullscreenImage"
)

const fullscreenClose =
document.getElementById(
    "fullscreenClose"
)

/* OPEN */
imageContainer.addEventListener(

    "click",

    () => {

        /* RESET ZOOM */

        zoomImage.style.transform =
        "scale(1)"

        zoomImage.style.transformOrigin =
        "center center"

        /* LOAD FULL IMAGE */

        fullscreenImage.src =
        zoomImage.src

        /* OPEN VIEWER */

        fullscreenViewer.classList.add(
            "active"
        )

        document.body.style.overflow =
        "hidden"

    }

)

/* CLOSE BUTTON */

fullscreenClose.addEventListener(

    "click",

    closeFullscreen

)

/* CLICK OUTSIDE */

fullscreenViewer.addEventListener(

    "click",

    (e) => {

        if(

            e.target === fullscreenViewer

        ){

            closeFullscreen()

        }

    }

)

/* ESC KEY */

document.addEventListener(

    "keydown",

    (e) => {

        if(e.key === "Escape"){

            closeFullscreen()

        }

    }

)

/* CLOSE FUNCTION */

function closeFullscreen(){

    fullscreenViewer.classList.remove(
        "active"
    )

    document.body.style.overflow =
    ""

}
</script>
<script>

document.getElementById(

    "reviewForm"

)?.addEventListener(

    "submit",

    async (e) => {

        e.preventDefault()

        try{

            const productId =

            document.getElementById(
                "reviewProductId"
            ).value

            const rating =

            document.getElementById(
                "reviewRating"
            ).value

            const comment =

            document.getElementById(
                "reviewComment"
            ).value

            const response =

            await fetch(

                "/review/add",

                {

                    method: "POST",

                    headers: {

                        "Content-Type":
                        "application/json"

                    },

                    body: JSON.stringify({

                        productId,

                        rating,

                        comment

                    })

                }

            )

            const data =
            await response.json()

            if(data.success){

                Swal.fire({

                    icon: "success",

                    title: data.message,

                    confirmButtonColor:
                    "#603763"

                })

                setTimeout(() => {

                    location.reload()

                },1000)

            }

            else{

                Swal.fire({

                    icon: "error",

                    title: data.message,

                    confirmButtonColor:
                    "#603763"

                })

            }

        }

        catch(error){

            console.log(error)

            Swal.fire({

                icon: "error",

                title: "Something went wrong",

                confirmButtonColor:
                "#603763"

            })

        }

    }

)

</script>
</body>
</html>
