<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - iStore</title>
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/change-password.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body>

    <!-- Header -->
    <%- include("../partials/user/header") %>

    <main class="change-password-main">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" style="margin-bottom: 32px;">
            <a href="/">Home</a>
            <div class="breadcrumb-separator">
                <svg width="5" height="8" viewBox="0 0 5 8" fill="none">
                    <path d="M1 1L4 4L1 7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"/>
                </svg>
            </div>

            <a href="/profile">My Account</a>

            <div class="breadcrumb-separator">
                <svg width="5" height="8" viewBox="0 0 5 8" fill="none">
                    <path d="M1 1L4 4L1 7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"/>
                </svg>
            </div>

            <span class="breadcrumb-current">
                Change Password
            </span>

        </nav>



        <div class="change-password-grid">

            <!-- Left Column -->

            <div class="change-password-info">

                <h1>Change Password</h1>

                <p>
                Update your password to keep your account secure.
                We recommend using a unique password that you don't use on any other site.
                </p>

                <div class="vault-image-container">
                    <img
                    src="/images/change_password_vault.png"
                    alt="Digital Vault">
                </div>

            </div>



            <!-- Right Column -->

            <div class="password-form-card">

<form class="password-form"
action="/send-change-password-otp"
method="POST">



<!-- =========================
     CURRENT PASSWORD
     ONLY FOR NORMAL USERS
========================= -->

<% if (user && !user.googleId) { %>

<div class="form-group">

<label>Current Password</label>

<div class="password-input-wrapper">

<input
type="password"
name="oldPassword"
placeholder="Enter current password"
required>

<div class="password-toggle">
<i data-lucide="eye"></i>
</div>

</div>

</div>

<% } %>



<!-- =========================
     NEW PASSWORD
========================= -->

<div class="form-group">

<label>New Password</label>

<div class="password-input-wrapper">

<input
type="password"
name="newPassword"
placeholder="Enter new password"
required>

<div class="password-toggle">
<i data-lucide="eye"></i>
</div>

</div>

</div>



<!-- Strength Meter -->

<div class="strength-meter-section">

<div class="strength-header">

<span class="strength-label">
Strength
</span>

<span class="strength-indicator">
Strong
</span>

</div>

<div class="meter-bar">

<div class="meter-segment active-red"></div>

<div class="meter-segment active-orange"></div>

<div class="meter-segment active-green"></div>

<div class="meter-segment active-green"></div>

</div>

</div>



<!-- =========================
     CONFIRM PASSWORD
========================= -->

<div class="form-group">

<label>Confirm New Password</label>

<div class="password-input-wrapper">

<input
type="password"
name="confirmPassword"
placeholder="Re-enter new password"
required>

<div class="password-toggle">
<i data-lucide="eye"></i>
</div>

</div>

</div>



<!-- Requirements Box -->

<div class="requirements-box">

<h4>Password Requirements</h4>

<div class="requirements-grid">

<div class="requirement-item valid">

<svg
class="valid-icon"
width="16"
height="16"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="3"
stroke-linecap="round"
stroke-linejoin="round">

<polyline points="20 6 9 17 4 12"/>

</svg>

8 characters minimum

</div>



<div class="requirement-item valid">

<svg
class="valid-icon"
width="16"
height="16"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="3"
stroke-linecap="round"
stroke-linejoin="round">

<polyline points="20 6 9 17 4 12"/>

</svg>

At least one uppercase letter

</div>



<div class="requirement-item">

<svg
class="pending-icon"
width="16"
height="16"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="3"
stroke-linecap="round"
stroke-linejoin="round">

<circle cx="12" cy="12" r="10"/>

</svg>

At least one number

</div>



<div class="requirement-item">

<svg
class="pending-icon"
width="16"
height="16"
viewBox="0 0 24 24"
fill="none"
stroke="currentColor"
stroke-width="3"
stroke-linecap="round"
stroke-linejoin="round">

<circle cx="12" cy="12" r="10"/>

</svg>

At least one special character

</div>

</div>

</div>



<p class="password-disclaimer">

For security reasons, you may need to log in again after changing your password.

</p>



<div class="form-actions">

<button
type="submit"
class="update-pw-btn">

Update Password

</button>



<a
href="/profile"
class="cancel-pw-btn">

Cancel

</a>

</div>



</form>

            </div>

        </div>

    </main>



    <!-- Footer -->

    <%- include("../partials/user/footer") %>



<script>

lucide.createIcons()



/* PASSWORD TOGGLE */

const toggles =
document.querySelectorAll(
'.password-toggle'
)

toggles.forEach(toggle => {

toggle.addEventListener(
'click',

() => {

const input =
toggle.parentElement
.querySelector('input')

const type =
input.getAttribute('type')
=== 'password'
? 'text'
: 'password'

input.setAttribute(
'type',
type
)

const icon =
toggle.querySelector('i')

const iconName =
type === 'password'
? 'eye'
: 'eye-off'

icon.setAttribute(
'data-lucide',
iconName
)

lucide.createIcons()

}

)

})



/* GSAP ANIMATIONS */

gsap.from(
".change-password-info",
{
x: -30,
opacity: 0,
duration: 0.8,
ease: "power2.out"
}
)

gsap.from(
".password-form-card",
{
x: 30,
opacity: 0,
duration: 0.8,
ease: "power2.out",
delay: 0.2
}
)



/* SAFARI FIX */

window.addEventListener(
"pageshow",

function (event) {

if (event.persisted) {

window.location.reload()

}

}

)

</script>



</body>
</html>