<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - iStore</title>
    <link rel="stylesheet" href="/css/components/header.css">
    <link rel="stylesheet" href="/css/components/footer.css">
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/change-password.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <style>
        .field-error {
            display: none;
            color: #e74c3c;
            font-size: 12px;
            margin-top: 5px;
            padding-left: 2px;
            font-weight: 500;
        }
        .field-error.visible {
            display: block;
        }
        .password-input-wrapper input.input-error {
            border: 1.5px solid #e74c3c !important;
            background: #fff8f8 !important;
        }
        .password-input-wrapper input.input-success {
            border: 1.5px solid #2ecc71 !important;
        }
    </style>
</head>
<body>

    <%- include("../partials/user/header") %>

    <main class="change-password-main">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" style="margin-bottom: 32px;">
            <a href="/">Home</a>
            <div class="breadcrumb-separator">
                <svg width="5" height="8" viewBox="0 0 5 8" fill="none">
                    <path d="M1 1L4 4L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <a href="/profile">My Account</a>
            <div class="breadcrumb-separator">
                <svg width="5" height="8" viewBox="0 0 5 8" fill="none">
                    <path d="M1 1L4 4L1 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <span class="breadcrumb-current">Change Password</span>
        </nav>

        <div class="change-password-grid">

            <!-- Left Column -->
            <div class="change-password-info">
                <h1>Change Password</h1>
                <p>Update your password to keep your account secure. We recommend using a unique password that you don't use on any other site.</p>
                <div class="vault-image-container">
                    <img src="/images/change_password_vault.png" alt="Digital Vault">
                </div>
            </div>

            <!-- Right Column -->
            <div class="password-form-card">

                <form class="password-form" id="changePasswordForm"
                    action="/send-change-password-otp" method="POST" novalidate>

                    <!-- Current Password (normal users only) -->
                    <% if (user && !user.googleId) { %>
                    <div class="form-group">
                        <label>Current Password</label>
                        <div class="password-input-wrapper">
                            <input
                                type="password"
                                name="oldPassword"
                                id="oldPassword"
                                placeholder="Enter current password">
                            <div class="password-toggle">
                                <i data-lucide="eye"></i>
                            </div>
                        </div>
                        <span class="field-error" id="oldPassword-error"></span>
                    </div>
                    <% } %>

                    <!-- New Password -->
                    <div class="form-group">
                        <label>New Password</label>
                        <div class="password-input-wrapper">
                            <input
                                type="password"
                                name="newPassword"
                                id="newPassword"
                                placeholder="Enter new password">
                            <div class="password-toggle">
                                <i data-lucide="eye"></i>
                            </div>
                        </div>
                        <span class="field-error" id="newPassword-error"></span>
                    </div>

                    <!-- Strength Meter -->
                    <div class="strength-meter-section">
                        <div class="strength-header">
                            <span class="strength-label">Strength</span>
                            <span class="strength-indicator" id="strengthIndicator">—</span>
                        </div>
                        <div class="meter-bar">
                            <div class="meter-segment" id="seg0"></div>
                            <div class="meter-segment" id="seg1"></div>
                            <div class="meter-segment" id="seg2"></div>
                            <div class="meter-segment" id="seg3"></div>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <div class="password-input-wrapper">
                            <input
                                type="password"
                                name="confirmPassword"
                                id="confirmPassword"
                                placeholder="Re-enter new password">
                            <div class="password-toggle">
                                <i data-lucide="eye"></i>
                            </div>
                        </div>
                        <span class="field-error" id="confirmPassword-error"></span>
                    </div>

                    <!-- Requirements Box -->
                    <div class="requirements-box">
                        <h4>Password Requirements</h4>
                        <div class="requirements-grid">
                            <div class="requirement-item" id="req-length">
                                <svg class="pending-icon" id="req-length-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                </svg>
                                6 characters minimum
                            </div>
                            <div class="requirement-item" id="req-upper">
                                <svg class="pending-icon" id="req-upper-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                </svg>
                                At least one uppercase letter
                            </div>
                            <div class="requirement-item" id="req-number">
                                <svg class="pending-icon" id="req-number-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                </svg>
                                At least one number
                            </div>
                            <div class="requirement-item" id="req-special">
                                <svg class="pending-icon" id="req-special-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                </svg>
                                At least one special character
                            </div>
                        </div>
                    </div>

                    <p class="password-disclaimer">
                        For security reasons, you may need to log in again after changing your password.
                    </p>

                    <div class="form-actions">
                        <button type="submit" class="update-pw-btn" id="submitBtn">
                            Update Password
                        </button>
                        <a href="/profile" class="cancel-pw-btn">Cancel</a>
                    </div>

                </form>
            </div>
        </div>

    </main>

    <%- include("../partials/user/footer") %>

    <script>
        lucide.createIcons();

        const isGoogleUser = <%= (user && user.googleId) ? 'true' : 'false' %>;

        /* ================================================
           HELPERS
        ================================================ */

        function setError(inputEl, errorId, msg) {
            if (!inputEl) return;
            inputEl.classList.add("input-error");
            inputEl.classList.remove("input-success");
            const s = document.getElementById(errorId);
            if (s) { s.textContent = msg; s.classList.add("visible"); }
        }

        function setSuccess(inputEl, errorId) {
            if (!inputEl) return;
            inputEl.classList.remove("input-error");
            inputEl.classList.add("input-success");
            const s = document.getElementById(errorId);
            if (s) { s.textContent = ""; s.classList.remove("visible"); }
        }

        function clearState(inputEl, errorId) {
            if (!inputEl) return;
            inputEl.classList.remove("input-error", "input-success");
            const s = document.getElementById(errorId);
            if (s) { s.textContent = ""; s.classList.remove("visible"); }
        }

        /* ================================================
           INDIVIDUAL VALIDATORS
        ================================================ */

        function validateOldPassword() {
            if (isGoogleUser) return true;
            const el  = document.getElementById("oldPassword");
            const val = el.value;
            if (!val) {
                setError(el, "oldPassword-error", "Current password is required");
                return false;
            }
            if (val.length < 6) {
                setError(el, "oldPassword-error", "Password must be at least 6 characters");
                return false;
            }
            setSuccess(el, "oldPassword-error");
            return true;
        }

        function validateNewPassword() {
            const el  = document.getElementById("newPassword");
            const val = el.value;
            if (!val) {
                setError(el, "newPassword-error", "New password is required");
                return false;
            }
            if (val.length < 6) {
                setError(el, "newPassword-error", "Password must be at least 6 characters");
                return false;
            }
            if (val.length > 50) {
                setError(el, "newPassword-error", "Password cannot exceed 50 characters");
                return false;
            }

            /* Must not be same as old password (client-side hint) */
            const oldEl = document.getElementById("oldPassword");
            if (oldEl && oldEl.value && val === oldEl.value) {
                setError(el, "newPassword-error", "New password must be different from current password");
                return false;
            }

            setSuccess(el, "newPassword-error");

            /* Re-check confirm if already filled */
            const confirmEl = document.getElementById("confirmPassword");
            if (confirmEl && confirmEl.value) validateConfirmPassword();

            return true;
        }

        function validateConfirmPassword() {
            const el      = document.getElementById("confirmPassword");
            const newPass = document.getElementById("newPassword").value;
            const val     = el.value;
            if (!val) {
                setError(el, "confirmPassword-error", "Please confirm your new password");
                return false;
            }
            if (val !== newPass) {
                setError(el, "confirmPassword-error", "Passwords do not match");
                return false;
            }
            setSuccess(el, "confirmPassword-error");
            return true;
        }

        /* ================================================
           REAL-TIME — blur + live fix
        ================================================ */

        const oldPasswordEl = document.getElementById("oldPassword");
        const newPasswordEl = document.getElementById("newPassword");
        const confirmEl     = document.getElementById("confirmPassword");

        if (oldPasswordEl) {
            oldPasswordEl.addEventListener("blur", validateOldPassword);
            oldPasswordEl.addEventListener("input", function () {
                if (this.classList.contains("input-error")) validateOldPassword();
            });
        }

        newPasswordEl.addEventListener("blur", validateNewPassword);
        newPasswordEl.addEventListener("input", function () {
            updateStrengthMeter(this.value);
            updateRequirements(this.value);
            if (this.classList.contains("input-error")) validateNewPassword();
        });

        confirmEl.addEventListener("blur", validateConfirmPassword);
        confirmEl.addEventListener("input", function () {
            if (this.classList.contains("input-error")) validateConfirmPassword();
        });

        /* ================================================
           FORM SUBMIT
        ================================================ */

        document.getElementById("changePasswordForm").addEventListener("submit", function (e) {
            e.preventDefault();

            const oldOk     = validateOldPassword();
            const newOk     = validateNewPassword();
            const confirmOk = validateConfirmPassword();

            if (!oldOk || !newOk || !confirmOk) {
                /* Scroll to first error */
                const firstError = this.querySelector(".input-error");
                if (firstError) firstError.scrollIntoView({ behavior: "smooth", block: "center" });
                return;
            }

            /* All valid — submit */
            this.submit();
        });

        /* ================================================
           PASSWORD STRENGTH METER
        ================================================ */

        const strengthIndicator = document.getElementById("strengthIndicator");
        const segments = [
            document.getElementById("seg0"),
            document.getElementById("seg1"),
            document.getElementById("seg2"),
            document.getElementById("seg3"),
        ];

        const strengthColors = ["#ef4444", "#f59e0b", "#10b981", "#10b981"];
        const strengthLabels = ["Weak", "Fair", "Good", "Strong"];
        const strengthLabelColors = ["#ef4444", "#f59e0b", "#10b981", "#059669"];

        function updateStrengthMeter(value) {
            const checks = [
                value.length >= 6,
                /[A-Z]/.test(value),
                /[0-9]/.test(value),
                /[^A-Za-z0-9]/.test(value),
            ];
            const score = checks.filter(Boolean).length;

            segments.forEach((seg, i) => {
                if (i < score) {
                    seg.style.background = strengthColors[score - 1];
                    seg.style.opacity    = "1";
                } else {
                    seg.style.background = "#e5e7eb";
                    seg.style.opacity    = "1";
                }
            });

            if (!value) {
                strengthIndicator.textContent = "—";
                strengthIndicator.style.color = "#a1a1aa";
            } else {
                strengthIndicator.textContent = strengthLabels[score - 1] || "Weak";
                strengthIndicator.style.color = strengthLabelColors[score - 1] || "#ef4444";
            }
        }

        /* ================================================
           REQUIREMENTS CHECKER
        ================================================ */

        const checkTick = `<svg class="valid-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        const checkCircle = `<svg class="pending-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>`;

        const reqMap = [
            { id: "req-length",  test: v => v.length >= 6,              label: "6 characters minimum" },
            { id: "req-upper",   test: v => /[A-Z]/.test(v),            label: "At least one uppercase letter" },
            { id: "req-number",  test: v => /[0-9]/.test(v),            label: "At least one number" },
            { id: "req-special", test: v => /[^A-Za-z0-9]/.test(v),     label: "At least one special character" },
        ];

        function updateRequirements(value) {
            reqMap.forEach(req => {
                const el = document.getElementById(req.id);
                if (!el) return;
                const passed = req.test(value);
                el.classList.toggle("valid", passed);
                el.innerHTML = (passed ? checkTick : checkCircle) + " " + req.label;
            });
        }

        /* ================================================
           PASSWORD TOGGLE
        ================================================ */

        document.querySelectorAll(".password-toggle").forEach(toggle => {
            toggle.addEventListener("click", () => {
                const input    = toggle.parentElement.querySelector("input");
                const icon     = toggle.querySelector("i");
                const isHidden = input.getAttribute("type") === "password";
                input.setAttribute("type", isHidden ? "text" : "password");
                icon.setAttribute("data-lucide", isHidden ? "eye-off" : "eye");
                lucide.createIcons();
            });
        });

        /* ================================================
           GSAP ANIMATIONS
        ================================================ */

        gsap.from(".change-password-info", {
            x: -30, opacity: 0, duration: 0.8, ease: "power2.out"
        });
        gsap.from(".password-form-card", {
            x: 30, opacity: 0, duration: 0.8, ease: "power2.out", delay: 0.2
        });

        /* ================================================
           SAFARI BACK BUTTON FIX
        ================================================ */

        window.addEventListener("pageshow", function (event) {
            if (event.persisted) window.location.reload();
        });

    </script>

</body>
</html>
