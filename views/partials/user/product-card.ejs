<div class="product-card">

    <!-- Wishlist -->

<button

class="wishlist-toggle
<%= wishlistVariantIds?.includes(product.variant?._id?.toString())
? 'active'
: ''
%>

<%= product.variant.stock <= 0
? 'disabled'
: ''
%>"

data-product-id="<%= product._id %>"

data-variant-id="<%= product.variant?._id %>"

<%= product.variant.stock <= 0
? "disabled"
: ""
%>

>

<i
    data-lucide="heart"
    size="18"
></i>

</button>


    <!-- Clickable Product Area -->

    <a
        href="/products/<%= product._id %>?variant=<%= product.variant._id %>"
        class="product-card-link"
    >

        <!-- Product Image -->

        <div class="card-img-container">

            <img
                src="<%= product.variant?.images?.[0] || product.thumbnail %>"
                alt="<%= product.name %>"
                loading="lazy"
            >

        </div>


        <!-- Product Content -->

        <div class="card-content">

            <p class="card-category">

                <%= product.categoryId?.name %>

            </p>


            <h3 class="card-title">

                <%= product.name %>

            </h3>

<% if(product.offerData?.offerDiscount > 0){ %>

<div class="offer-price-block">

    <div class="offer-badge">

        <%= product.offerData.appliedOffer.discountValue %>% OFF

    </div>

    <p class="original-price">

        ₹<%= product.offerData.originalPrice.toLocaleString() %>

    </p>

    <p class="discounted-price">

        ₹<%= product.offerData.finalPrice.toLocaleString() %>

    </p>

    <p class="saving-price">

        Save ₹<%= product.offerData.offerDiscount.toLocaleString() %>

    </p>

</div>

<% } else { %>

<p class="card-price">

    ₹<%= product.variant?.price?.toLocaleString() %>

</p>

<% } %>
            <!-- Variant Details -->

<div class="variant-details">

    <% if(product.variant?.RAM){ %>

        <span class="variant-pill">

            <%= product.variant.RAM %>

        </span>

    <% } %>

    <% if(product.variant?.storage){ %>

        <span class="variant-pill">

            <%= product.variant.storage %>

        </span>

    <% } %>

    <% if(product.variant?.color){ %>

        <span class="variant-pill color-pill">

            <span

                class="color-dot"

                style="background:
                <%= product.variant.color === 'Black'
                ? '#111111'
                : product.variant.color === 'Silver'
                ? '#D1D5DB'
                : product.variant.color === 'Purple'
                ? '#6D28D9'
                : '#CBD5E1'
                %>"

            ></span>

            <%= product.variant.color %>

        </span>

    <% } %>

</div>

        </div>

    </a>



   <!-- Add To Cart -->

<button

class="add-to-cart-btn

<%= product.variant.stock <= 0
    ? "unavailable"
    : cartVariantIds?.includes(product.variant?._id?.toString())
    ? "added"
    : ""
%>"

data-product-id="<%= product._id %>"

data-variant-id="<%= product.variant?._id %>"

<%= product.variant.stock <= 0 ? "disabled" : "" %>

>

<% if(product.variant.stock <= 0){ %>

    <i
        data-lucide="slash"
        size="18"
    ></i>

    Out of Stock

<% } else if(

    cartVariantIds?.includes(
        product.variant?._id?.toString()
    )

){ %>

    <i
        data-lucide="shopping-bag"
        size="18"
    ></i>

    Go to Cart

<% } else { %>

    <i
        data-lucide="shopping-cart"
        size="18"
    ></i>

    Add to Cart

<% } %>

</button>

</div>