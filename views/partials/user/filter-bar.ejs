<section class="filter-bar-section">

    <form
        action="/products"
        method="GET"
        class="filter-form"
    >

        <!-- SEARCH -->

        <div class="filter-search-group">

            <i
                data-lucide="search"
                class="filter-icon"
            ></i>

            <input
                type="text"
                name="search"
                placeholder="Search products..."
                value="<%= search || '' %>"
                class="filter-search-input"
            >

            <% if(search){ %>

                <a
                    href="/products"
                    class="clear-search-btn"
                >

                    Clear

                </a>

            <% } %>

        </div>



        <!-- CATEGORY -->

        <div class="filter-select-wrapper">

            <i
                data-lucide="layout-grid"
                class="filter-icon"
            ></i>

            <select
                name="category"
                class="premium-filter-select"
            >

                <option value="">
                    All Categories
                </option>

                <% categories.forEach(categoryItem => { %>

                    <option

                        value="<%= categoryItem._id %>"

                        <%= category === categoryItem._id.toString()
                        ? "selected"
                        : ""
                        %>

                    >

                        <%= categoryItem.name %>

                    </option>

                <% }) %>

            </select>

        </div>

        <!-- PRICE RANGE -->

        <div class="filter-select-wrapper">

            <i
                data-lucide="indian-rupee"
                class="filter-icon"
            ></i>

            <select
                name="price"
                class="premium-filter-select"
            >

                <option value="">
                    All Prices
                </option>

                <option
                    value="0-50000"
                    <%= price === "0-50000"
                    ? "selected"
                    : ""
                    %>
                >
                    Under ₹50,000
                </option>

                <option
                    value="50000-100000"
                    <%= price === "50000-100000"
                    ? "selected"
                    : ""
                    %>
                >
                    ₹50,000 - ₹1,00,000
                </option>

                <option
                    value="100000-150000"
                    <%= price === "100000-150000"
                    ? "selected"
                    : ""
                    %>
                >
                    ₹1,00,000 - ₹1,50,000
                </option>

                <option
                    value="150000+"
                    <%= price === "150000+"
                    ? "selected"
                    : ""
                    %>
                >
                    Above ₹1,50,000
                </option>

            </select>

        </div>

        <!-- SORT -->

        <div class="filter-select-wrapper">

            <i
                data-lucide="arrow-up-down"
                class="filter-icon"
            ></i>

            <select
                name="sort"
                class="premium-filter-select"
            >

                <option
                    value="latest"
                    <%= sort === "latest"
                    ? "selected"
                    : ""
                    %>
                >
                    Latest
                </option>

                <option
                    value="priceLow"
                    <%= sort === "priceLow"
                    ? "selected"
                    : ""
                    %>
                >
                    Price: Low to High
                </option>

                <option
                    value="priceHigh"
                    <%= sort === "priceHigh"
                    ? "selected"
                    : ""
                    %>
                >
                    Price: High to Low
                </option>

                <option
                    value="a-z"
                    <%= sort === "a-z"
                    ? "selected"
                    : ""
                    %>
                >
                    A - Z
                </option>

                <option
                    value="z-a"
                    <%= sort === "z-a"
                    ? "selected"
                    : ""
                    %>
                >
                    Z - A
                </option>

            </select>

        </div>



        <!-- BUTTON -->

        <button
            type="submit"
            class="filter-apply-btn"
        >

            <i
                data-lucide="sliders-horizontal"
                size="18"
            ></i>

            Apply

        </button>

    </form>

</section>