<%
    const currentPage =
    typeof page !== "undefined"
        ? page
        : "";
%>

<!-- Header -->
<header class="header">

    <nav class="nav">

        <a href="/" class="logo">
            iStore
        </a>

        <div class="nav-links">

            <a
                href="/"
                class="nav-link <%= currentPage === 'home' ? 'active' : '' %>"
            >
                Home
            </a>

            <!-- <a
                href="/categories"
                class="nav-link <%= currentPage === 'categories' ? 'active' : '' %>"
            >
                Categories
            </a> -->

            <a
                href="/products"
                class="nav-link <%= currentPage === 'products' ? 'active' : '' %>"
            >
                Products
            </a>

            <a
                href="/deals"
                class="nav-link <%= currentPage === 'deals' ? 'active' : '' %>"
            >
                Deals
            </a>

        </div>

        <div class="nav-icons">

            <div class="nav-icon">
                <i data-lucide="search"></i>
            </div>

 <a href="/wishlist" class="nav-icon <%= currentPage === 'wishlist' ? 'active' : '' %>">

    <i data-lucide="heart"></i>

    <% if(typeof wishlistCount !== "undefined" && wishlistCount > 0){ %>

        <span class="wishlist-count">

            <%= wishlistCount %>

        </span>

    <% } %>

</a>

<a href="/cart" class="nav-icon <%= currentPage === 'cart' ? 'active' : '' %>">

    <i data-lucide="shopping-cart"></i>

    <% if(typeof cartCount !== "undefined" && cartCount > 0){ %>

        <span class="cart-count">

            <%= cartCount %>

        </span>

    <% } %>

</a>

            <% if (userId) { %>

                <a
                    href="/profile"
                    class="nav-icon"
                    title="Profile"
                >

                    <i data-lucide="user"></i>

                    <div></div>

                </a>

            <% } else { %>

                <a
                    href="/login"
                    class="login-btn"
                >

                    Login

                </a>

            <% } %>

        </div>

    </nav>

</header>

<!-- Mobile Bottom Navigation -->

<div class="mobile-bottom-nav">

    <a
        href="/"
        class="mobile-nav-item <%= currentPage === 'home' ? 'active' : '' %>"
    >

        <i data-lucide="house"></i>

        <span>Home</span>

    </a>

    <!-- <a
        href="/categories"
        class="mobile-nav-item <%= currentPage === 'categories' ? 'active' : '' %>"
    >

        <i data-lucide="layout-grid"></i>

        <span>Categories</span>

    </a> -->

    <a
        href="/products"
        class="mobile-nav-item <%= currentPage === 'products' ? 'active' : '' %>"
    >

        <i data-lucide="shopping-bag"></i>

        <span>Products</span>

    </a>

    <a
        href="/deals"
        class="mobile-nav-item <%= currentPage === 'deals' ? 'active' : '' %>"
    >

        <i data-lucide="badge-percent"></i>

        <span>Deals</span>

    </a>

</div>