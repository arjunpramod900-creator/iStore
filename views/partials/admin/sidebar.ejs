<!-- ── SIDEBAR TOGGLE BUTTON ──
     Desktop: chevron tab anchored to sidebar right edge.
     Mobile:  hamburger pill at top-left corner.
     Both icons live here; CSS shows/hides the right one.
-->
<button class="sidebar-toggle-btn" id="sidebarToggleBtn"
        title="Toggle Sidebar" aria-label="Toggle Sidebar">
    <!-- Chevron icon (desktop only) -->
    <svg class="toggle-icon icon-chevron"
         viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.2"
         stroke-linecap="round" stroke-linejoin="round"
         aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
    <!-- Hamburger icon (mobile/tablet only) -->
    <svg class="toggle-icon icon-hamburger"
         viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.2"
         stroke-linecap="round" stroke-linejoin="round"
         aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
</button>

<!-- ============================================================
     SIDEBAR JAVASCRIPT
     All sidebar toggle logic lives here so sidebar.ejs is
     the single source of truth for sidebar behaviour.
============================================================ -->
<script>
(function () {
    'use strict';

    /* ── Config ── */
    var STORAGE_KEY = 'istore_sidebar_state';
    var MOBILE_BP   = 1024;   /* px — below this = overlay/drawer mode */

    /* ── Elements ── */
    var btn     = document.getElementById('sidebarToggleBtn');
    var overlay = document.getElementById('sidebarOverlay');
    var body    = document.body;

    /* ─────────────────────────────────────────────────
       isMobile()
       Returns true when viewport width ≤ MOBILE_BP.
    ───────────────────────────────────────────────── */
    function isMobile() {
        return window.innerWidth <= MOBILE_BP;
    }

    /* ─────────────────────────────────────────────────
       applyInitialState()
       Called on load and on every resize.
       Desktop : honours localStorage collapsed pref.
       Mobile  : always starts closed (drawer hidden).
    ───────────────────────────────────────────────── */
    function applyInitialState() {
        if (isMobile()) {
            /* Mobile/tablet — always start closed */
            body.classList.remove('sidebar-collapsed');
            body.classList.remove('sidebar-open');
        } else {
            /* Desktop — restore saved preference */
            body.classList.remove('sidebar-open');
            if (localStorage.getItem(STORAGE_KEY) === 'collapsed') {
                body.classList.add('sidebar-collapsed');
            } else {
                body.classList.remove('sidebar-collapsed');
            }
        }
    }

    /* ─────────────────────────────────────────────────
       toggle()
       Desktop : toggles sidebar-collapsed on <body>.
       Mobile  : toggles sidebar-open on <body>.
    ───────────────────────────────────────────────── */
    function toggle() {
        if (isMobile()) {
            body.classList.toggle('sidebar-open');
            body.classList.remove('sidebar-collapsed');
        } else {
            var collapsed = body.classList.toggle('sidebar-collapsed');
            body.classList.remove('sidebar-open');
            try {
                localStorage.setItem(STORAGE_KEY, collapsed ? 'collapsed' : 'open');
            } catch (e) { /* storage blocked — ignore */ }
        }
    }

    /* ─────────────────────────────────────────────────
       closeDrawer()
       Closes mobile drawer (overlay tap or Escape key).
    ───────────────────────────────────────────────── */
    function closeDrawer() {
        body.classList.remove('sidebar-open');
    }

    /* ── Wire up events ── */
    btn.addEventListener('click', toggle);
    overlay.addEventListener('click', closeDrawer);

    /* Escape key closes mobile drawer */
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isMobile()) closeDrawer();
    });

    /* Re-evaluate mode on resize (handles orientation change) */
    var resizeTimer;
    window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(applyInitialState, 120);
    });

    /* ── Apply immediately on page load ── */
    applyInitialState();

}());
</script>
